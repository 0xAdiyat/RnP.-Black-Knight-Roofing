---
export const prerender = true;
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/Navbar.astro';
import Hero from '@/components/hero/Hero.astro';
import Brands from '@/components/Brands.astro';
import CTASection from '@/components/cta/CTASection.astro';
import { serviceAreaCTA } from '@/data/cta';
import Footer from '@/components/Footer.astro';
import QuoteForm from '@/components/cta/QuoteForm.astro';

import { Icon } from 'astro-icon/components';
import Button from '@/components/ui/Button.astro';
import RatingStars from '@/components/ui/RatingStars.astro';
import Testimonials from '@/components/Testimonials.astro';
import Process from '@/components/process/Process.astro';
import Faqs from '@/components/faqs/Faqs.astro';
import { homeFaqs } from '@/data/faqs/home';

import step1 from '@/assets/steps/step-1.png';
import step2 from '@/assets/steps/step-2.png';
import step3 from '@/assets/steps/step-3.png';
import step4 from '@/assets/steps/step-4.png';
import NoiseBg from '@/components/NoiseBg.astro';
import BadgeTitle from '@/components/BadgeTitle.astro';
import ServiceCard from '@/components/services/ServiceCard.astro';
import { cn } from '@/lib/utils';

import { services } from '@/data/services';
import { serviceAreas } from '@/data/service-areas';
import heroBg from '@/assets/bg/specific-service-area-section__hero.avif';
import sunFlow from '@/assets/sunflow.avif';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  return serviceAreas.map(area => ({
    params: { slug: area.slug },
    props: { area },
  }));
}

const { area } = Astro.props;

// Row pattern: defines how many cards per row (repeats if more services exist)
const rowPattern = [3, 2, 3, 4];

// Map of cards-per-row to Tailwind col-span class (must be literal for Tailwind to detect)
const colSpanMap: Record<number, string> = {
  2: 'md:col-span-6',
  3: 'md:col-span-4',
  4: 'md:col-span-3',
};

// Compute col-span class for each service based on its position in the pattern
function getColSpanClass(index: number): string {
  let remaining = index;
  let patternIndex = 0;
  while (remaining >= rowPattern[patternIndex % rowPattern.length]) {
    remaining -= rowPattern[patternIndex % rowPattern.length];
    patternIndex++;
  }
  const cardsInRow = rowPattern[patternIndex % rowPattern.length];
  return colSpanMap[cardsInRow] || 'col-span-4';
}

const processSteps = [
  {
    image: step1,
    step: 'Step 1',
    title: 'Contact Our Team',
    description: 'Get in touch with us by phone or fill out a form! Our customer service team is on standby.',
  },
  {
    image: step2,
    step: 'Step 2',
    title: 'Schedule Inspection',
    description: 'We will schedule a convenient time to inspect your roof and assess the project scope.',
  },
  {
    image: step3,
    step: 'Step 3',
    title: 'Review Your Proposal',
    description: 'Receive a detailed proposal outlining the work, timeline, and transparent pricing.',
  },
  {
    image: step4,
    step: 'Step 4',
    title: 'Project Completion',
    description: 'Our expert team completes the project to the highest standards with a final walkthrough.',
  },
];
---

<Layout title={`Roofing Services in ${area.city}, ${area.state} | Black Knight Roofing`}>
  <Navbar />
  <Hero
    backgroundImage={heroBg}
    title={`Expert Roofing Services in <br /> ${area.city}, ${area.state}`}
    subtitle={`${area.city}'s Preferred Veteran-Owned Roofers`}
  >
    <p>
      Black Knight Roofing provides premium roofing solutions, storm restoration, and exterior upgrades for homeowners
      in {area.city} and the surrounding areas. From minor repairs to full replacements, we bring quality craftsmanship and
      veteran-owned integrity to every project.
    </p>
  </Hero>

  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>

  <Testimonials />

  <NoiseBg class="relative bg-[#131313] px-0 py-0">
    <Image
      src={sunFlow}
      width={1440}
      height={810}
      alt="Sunflow"
      class="pointer-events-none absolute top-0 right-0 h-full w-full object-cover opacity-20"
    />

    <div class="relative container grid grid-cols-1 items-center gap-12 py-20 lg:grid-cols-2">
      <div class="space-y-8">
        <BadgeTitle badge="Service Area" title={`${area.city}’s Favorite Roofers`} class="flex flex-col items-start" />
        <p class="text-lg text-[#AAAAAA]">
          We&apos;re proud to call {area.city} our home. Our dependable service and quality roofing reflect the care we have
          for our community. Through Black Knight Cares, we support local initiatives and help residents stay safe when storms
          approach. Serving {area.city} means helping the community shine brighter every day.
        </p>
        <Button variant="primary" data-estimate-trigger>FREE Roof Estimate</Button>
      </div>
      <div class="relative aspect-2/1 h-[360px] w-full overflow-hidden rounded-[12px] lg:aspect-square">
        <img src="/bg/case-studies-section__hero.avif" alt={`${area.city} roofing projects`} class="h-full w-full object-cover" />
      </div>
    </div>
  </NoiseBg>

  <!-- Services -->
  <NoiseBg class="bg-[#111] px-0 py-0">
    <div class="container py-20">
      <BadgeTitle
        badge="Our Services"
        title={`Roofing Services Offered in ${area.city}`}
        class="flex flex-col items-center text-center"
      />
      <div class="grid grid-cols-12 gap-x-4 gap-y-8 pt-16">
        {
          services.map((service, index) => (
            <ServiceCard
              image={service.image}
              title={service.title}
              description={service.description}
              icon={service.icon}
              tags={service.tags}
              href={`/services/${service.slug}`}
              class={cn('col-span-12', getColSpanClass(index))}
            />
          ))
        }
      </div>
    </div>

    <!-- Statistics -->
    <div class="container grid grid-cols-1 gap-x-2 py-16 md:grid-cols-2 lg:grid-cols-4">
      <!-- Total Projects Completed -->
      <div class="from-primary rounded-[5px] bg-radial-[at_30%_30%] via-[#594216] to-[#594216] p-px">
        <NoiseBg class="flex h-full items-center justify-center gap-x-2 rounded-[5px] px-6 py-4">
          <div class="font-heading text-primary text-[2rem]">100+</div>
          <div>
            <div class="text-lg font-bold">Roofing Projects</div>
            <div class="text-[#AAAAAA]">in Colorado</div>
          </div>
        </NoiseBg>
      </div>

      <!-- Google Retings -->
      <div class="from-primary rounded-[5px] bg-radial-[at_30%_30%] via-[#594216] to-[#594216] p-px">
        <NoiseBg class="flex h-full items-center justify-center gap-x-2 rounded-[5px] px-6 py-4">
          <div class="text-primary text-[2rem] font-bold">5.0</div>
          <div class="space-y-1">
            <div class="text-lg font-bold">
              <RatingStars rating={5} size={16} fillColor="#F7B715" strokeColor="none" />
            </div>
            <div class="text-[#AAAAAA]">40+ Google Reviews</div>
          </div>
        </NoiseBg>
      </div>

      <!-- Workmanship Warranty -->
      <div class="from-primary rounded-[5px] bg-radial-[at_30%_30%] via-[#594216] to-[#594216] p-px">
        <NoiseBg class="flex h-full items-center justify-center gap-x-2 rounded-[5px] px-6 py-4">
          <div class="text-primary size-12 font-bold">
            <Icon name="shield-check" size={48} />
          </div>
          <div>
            <div class="font-heading text-[2rem] leading-11 font-normal">Licensed</div>
            <div class="text-[#AAAAAA]">Bonded & Insured</div>
          </div>
        </NoiseBg>
      </div>

      <div class="from-primary rounded-[5px] bg-radial-[at_30%_30%] via-[#594216] to-[#594216] p-px">
        <NoiseBg class="flex h-full items-center justify-center gap-x-2 rounded-[5px] px-6 py-4">
          <div class="text-primary size-12 font-bold">
            <Icon name="badge" size={48} />
          </div>
          <div>
            <div class="font-heading text-[2rem] leading-11 font-normal">Lifetime</div>
            <div class="text-[#AAAAAA]">Workmanship Warranty</div>
          </div>
        </NoiseBg>
      </div>
    </div>
  </NoiseBg>

  <Process steps={processSteps} />
  <Faqs faqs={homeFaqs} />

  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>
  <CTASection cta={serviceAreaCTA} />
  <Footer />
</Layout>
