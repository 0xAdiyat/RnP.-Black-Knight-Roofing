---
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/Navbar.astro';
import Brands from '@/components/Brands.astro';
import CTASection from '@/components/cta/CTASection.astro';
import { defaultCTA } from '@/data/cta';
import Footer from '@/components/Footer.astro';
import Testimonials from '@/components/Testimonials.astro';
import Faqs from '@/components/faqs/Faqs.astro';
import { homeFaqs } from '@/data/faqs/home';
import NoiseBg from '@/components/NoiseBg.astro';
import Button from '@/components/ui/Button.astro';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import Hero from '@/components/hero/Hero.astro';
import RatingStars from '@/components/ui/RatingStars.astro';
import QuoteForm from '@/components/cta/QuoteForm.astro';
import RecentArticales from '@/components/articales/RecentArticales.astro';
import ServiceAreas from '@/components/service-area/ServiceAreas.astro';
import BeforeAfter from '@/components/comparison/BeforeAfter.astro';
import Pagination from '@/components/ui/pagination/Pagination.astro';
import Statistics from '@/components/ui/Statistics.astro';
import PastWorkFilter from '@/components/past-work/PastWorkFilter.astro';
import heroImage from '@/assets/bg/before-after-section__hero.avif';
import stormHero from '@/assets/bg/storm-damage-repair-section__hero.avif';
import asphaltShingleHero from '@/assets/bg/roof-replacement-section__hero.avif';
import hailHero from '@/assets/bg/hail-damage-repair-section__hero.avif';
import metalRoofingHero from '@/assets/bg/metal-roofing-section__hero.avif';
import windHero from '@/assets/bg/wind-damage-repair-section__hero.avif';
import commercialRoofingHero from '@/assets/bg/commercial-roofing-section__hero.avif';
import caseStudiesHero from '@/assets/bg/case-studies-section__hero.avif';
import sidingHero from '@/assets/bg/siding-section__hero.avif';
import residentialHero from '@/assets/bg/residential-roofing-section__hero.avif';
import concreteTileHero from '@/assets/bg/concrete-tile-roof-section__hero.avif';
import windowHero from '@/assets/bg/window-replacement-section__hero.avif';
import guttersHero from '@/assets/bg/gutters-section__hero.avif';

const beforeAfterProjects = [
  {
    before: stormHero,
    after: asphaltShingleHero,
    aspect: 'aspect-square',
  },
  {
    before: hailHero,
    after: metalRoofingHero,
    aspect: 'aspect-video',
  },
  {
    before: windHero,
    after: commercialRoofingHero,
    aspect: 'aspect-[3/4]',
  },
  {
    before: caseStudiesHero,
    after: sidingHero,
    aspect: 'aspect-video',
  },
  {
    before: residentialHero,
    after: concreteTileHero,
    aspect: 'aspect-[9/16]',
  },
  {
    before: windowHero,
    after: guttersHero,
    aspect: 'aspect-video',
  },
  {
    before: stormHero,
    after: asphaltShingleHero,
    aspect: 'aspect-square',
  },
  {
    before: windHero,
    after: commercialRoofingHero,
    aspect: 'aspect-video',
  },
  {
    before: hailHero,
    after: metalRoofingHero,
    aspect: 'aspect-[4/3]',
  },
];

const url = new URL(Astro.request.url);
const currentPage = Number(url.searchParams.get('page')) || 1;
const totalPages = 96; // Matching the image's '96' at the end
---

<Layout noindex={true}>
  <Navbar />

  <Hero backgroundImage={heroImage} title="Before &amp; After Gallery" subtitle="Colorado's #1 Veteran-Owned Roofing Company">
    <p>
      Use your cursor to move the image sliders left and right to see the difference we made for these Wisconsin and
      Illinois homes. We work with quality in mind so your roof, windows, doors, & siding stay durable and under
      warranty for years to come.
    </p>
  </Hero>

  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>

  <!-- Filters -->
  <PastWorkFilter currentPage="before-after" />

  <!-- Before and After Gallery -->
  <NoiseBg class="px-0 py-0">
    <div class="container py-10 lg:py-20">
      <div class="columns-1 gap-6 space-y-6 md:columns-2 lg:columns-3">
        {
          beforeAfterProjects.map(project => (
            <div class="mb-6 break-inside-avoid">
              <BeforeAfter beforeImage={project.before} afterImage={project.after} class={project.aspect} />
            </div>
          ))
        }
      </div>

      <!-- Pagination -->
      <div class="mt-16 flex justify-center">
        <Pagination currentPage={currentPage} totalPages={totalPages} baseUrl="/before-and-after" />
      </div>
    </div>
  </NoiseBg>

  <!-- Statistics -->
  <div class="container py-16">
    <Statistics />
  </div>
  <Testimonials />
  <ServiceAreas />
  <Faqs faqs={homeFaqs} />
  <RecentArticales />
  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>
  <CTASection cta={defaultCTA} />
  <Footer />
</Layout>
