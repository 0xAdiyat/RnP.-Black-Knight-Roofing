---
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/Navbar.astro';
import Hero from '@/components/hero/Hero.astro';
import Brands from '@/components/Brands.astro';
import CTASection from '@/components/cta/CTASection.astro';
import Footer from '@/components/Footer.astro';
import QuoteForm from '@/components/cta/QuoteForm.astro';
import Testimonials from '@/components/Testimonials.astro';
import ServiceAreas from '@/components/service-area/ServiceAreas.astro';
import NoiseBg from '@/components/NoiseBg.astro';
import { Icon } from 'astro-icon/components';
import Button from '@/components/ui/Button.astro';
import RatingStars from '@/components/ui/RatingStars.astro';
import Pagination from '@/components/ui/pagination/Pagination.astro';
import ArticalCard from '@/components/articales/ArticalCard.astro';
import { blogListItems } from '@/data/blogs';

const currentPage = Number(Astro.url.searchParams.get('page') || 1);
const itemsPerPage = 6;
const totalPages = Math.ceil(blogListItems.length / itemsPerPage);
const displayedBlogs = blogListItems.slice((currentPage - 1) * itemsPerPage, currentPage * itemsPerPage);
---

<Layout>
  <Navbar />
  <Hero title="See Past Work In Your <br/> Neighborhood" subtitle="Colorado's #1 Veteran-Owned Roofing Company">
    <p>
      Lorem ipsum dolor sit amet consectetur. Dictum morbi ac nibh nibh leo vitae at id faucibus. Ultrices duis tempor
      eget proin euismod sed dolor eu suspendisse. Amet ridiculus erat sit vulputate. Dui est feugiat risus ultrices.
    </p>

    <div class="flex items-center gap-x-4">
      <Button variant="primary" size="lg">
        <span class="text-xs">
          $99/month roofs <br />
          No repayment penalty</span
        >
        <span class="h-6 w-0.5 bg-[rgba(133,89,1,0.4)]"></span>
        <span class="font-[var(--Font-Family-Text,Manrope)] text-center text-[14px] leading-[20px] font-bold text-[#111]">FREE Estimate</span>
      </Button>

      <Button variant="link">
        <Icon name="map" />
        See Our Past Work
      </Button>
    </div>

    <Fragment slot="social-proof">
      <div class="flex items-center gap-x-4 pr-4">
        <Icon name="google-logo" size={32} />
        <div>
          40+ Five-Star <br />
          Google Reviews
        </div>
      </div>

      <div class="flex items-center gap-x-4 px-4">
        <Icon name="facebook-logo" size={32} />
        <div>
          <RatingStars rating={5} size={10} fillColor="white" strokeColor="none" />
          <span class="text-sm font-bold"> 5.0 Rating </span>
        </div>
      </div>

      <div class="flex items-center gap-x-4 pl-4">
        <Icon name="google-logo" size={32} />
        <div>
          <RatingStars rating={5} size={10} fillColor="white" strokeColor="none" />
          <span class="text-sm font-bold"> 5.0 Rating </span>
        </div>
      </div>
    </Fragment>

    <QuoteForm slot="sidebar" />
  </Hero>

  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>

  <!-- Gallery/Blogs -->
  <NoiseBg class="bg-[#222]">
    <div class="container py-20">
      <div class="mb-12 space-y-8">
        <div class="flex flex-col items-center justify-between gap-8 md:flex-row">
           <div class="space-y-4 text-left">
              <div class="flex items-center gap-x-2">
                <div class="relative size-5">
                   <div class="absolute inset-0 size-full animate-pulse rounded-full bg-primary/20"></div>
                   <div class="absolute inset-1.5 size-2 rounded-full bg-primary shadow-[0_0_8px_rgba(242,199,68,0.8)]"></div>
                </div>
                <span class="text-sm font-bold tracking-wider text-white uppercase">Blogs</span>
              </div>
              <h2 class="font-heading text-4xl text-white md:text-5xl">Blog Posts by The Roof Pros</h2>
           </div>
           
           <div class="w-full max-w-md">
              <div class="relative group">
                <Icon name="search" class="absolute left-4 top-1/2 size-5 -translate-y-1/2 text-white/40 transition-colors group-focus-within:text-primary" />
                <input 
                   type="text" 
                   placeholder="Search articles about roofing, gutters, etc..." 
                   class="w-full rounded-2xl border border-primary/20 bg-[#111] py-4 pl-12 pr-4 text-white placeholder-white/40 outline-none transition-all focus:border-primary focus:ring-1 focus:ring-primary/50"
                />
              </div>
           </div>
        </div>

        <div class="flex flex-wrap items-center gap-2 border-t border-white/5 pt-6">
           <span class="pr-2 text-xs font-bold tracking-widest text-white/40 uppercase">Trending:</span>
           {['Storm Damage', 'Cost Estimates', 'Spring Maintenance'].map(tag => (
             <button class="rounded-full bg-white/5 px-4 py-1.5 text-sm text-white transition-all hover:bg-primary hover:text-black">
               {tag}
             </button>
           ))}
        </div>
      </div>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        {displayedBlogs.map(blog => (
          <ArticalCard {...blog} />
        ))}
      </div>

      <!-- Pagination -->
      <div class="mt-20 flex justify-center">
        <Pagination currentPage={currentPage} totalPages={totalPages} baseUrl="/blogs" />
      </div>
    </div>
  </NoiseBg>

  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>
  <CTASection />
  <Footer />
</Layout>
