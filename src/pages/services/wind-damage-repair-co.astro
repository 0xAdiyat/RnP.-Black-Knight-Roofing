---
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/Navbar.astro';
import Brands from '@/components/Brands.astro';
import CTASection from '@/components/cta/CTASection.astro';
import Footer from '@/components/Footer.astro';
import Testimonials from '@/components/Testimonials.astro';
import Faqs from '@/components/faqs/Faqs.astro';
import NoiseBg from '@/components/NoiseBg.astro';
import WhyChooseUs from '@/components/WhyChooseUs.astro';
import Button from '@/components/ui/Button.astro';
import EstimateButton from '@/components/EstimateButton.astro';
import { Icon } from 'astro-icon/components';
import { type Service } from '@/data/services';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import Hero from '@/components/hero/Hero.astro';
import RatingStars from '@/components/ui/RatingStars.astro';
import QuoteForm from '@/components/cta/QuoteForm.astro';
import { Image } from 'astro:assets';
import Process from '@/components/process/Process.astro';
import step1 from '@/assets/steps/step-1.png';
import step2 from '@/assets/steps/step-2.png';
import step3 from '@/assets/steps/step-3.png';
import step4 from '@/assets/steps/step-4.png';
import RecentProjects from '@/components/recent-projects/RecentProjects.astro';
import RecentArticales from '@/components/articales/RecentArticales.astro';
import ServiceAreas from '@/components/service-area/ServiceAreas.astro';
import StylesProfiles from '@/components/services/StylesProfiles.astro';
import OtherServicesCarousel from '@/components/services/OtherServicesCarousel.astro';
import PopularRoofingMaterials from '@/components/services/PopularRoofingMaterials.astro';
import ComparisonTable from '@/components/services/ComparisonTable.astro';
import SocialProof from '@/components/ui/SocialProof.astro';
import Statistics from '@/components/ui/Statistics.astro';
import heroImage from '@/assets/bg/wind-damage-repair-section__hero.avif';
import sunflow from '@/assets/sunflow.avif';

const roofingMaterials = [
  {
    id: 'shingles',
    label: 'Architectural Shingles',
    description:
      'A reliable, budget-friendly choice with layered dimension, broad color options, and dependable everyday performance for Colorado homes.',
    image: '/placeholders/popular-materials/1.png',
  },
  {
    id: 'steel',
    label: 'Stone Coated Steel',
    description:
      'The ultimate protection against Colorado hail. Lightweight, non-combustible, and designed to last a lifetime with the look of traditional tile or wood shake.',
    image: '/placeholders/popular-materials/2.png',
  },
  {
    id: 'tile',
    label: 'Concrete Tile',
    description:
      'Superior thermal performance and exceptional durability. Concrete tile offers high fire resistance and a distinct aesthetic for premium Colorado residences.',
    image: '/placeholders/popular-materials/3.png',
  },
];

const processSteps = [
  {
    image: step1,
    step: 'Step 1',
    title: 'Contact Our Team',
    description: 'Get in touch with us by phone or fill out a form! Our customer service team is on standby.',
  },
  {
    image: step2,
    step: 'Step 2',
    title: 'Schedule Inspection',
    description: 'We will schedule a convenient time to inspect your roof and assess the project scope.',
  },
  {
    image: step3,
    step: 'Step 3',
    title: 'Review Your Proposal',
    description: 'Receive a detailed proposal outlining the work, timeline, and transparent pricing.',
  },
  {
    image: step4,
    step: 'Step 4',
    title: 'Project Completion',
    description: 'Our expert team completes the project to the highest standards with a final walkthrough.',
  },
];
---

<Layout>
  <Navbar />

  <Hero
    backgroundImage={heroImage}
    title="Wind Damage Roof Repair in Colorado"
    subtitle="Wind Damage Repair Services in Colorado"
  >
    <p class="text-sm">
      The Front Range lies in "hail alley," a top U.S. hail zone. Colorado ranks second for hail insurance claims, with
      storms April to September dropping hail from pea to golf ball size. Damage like bruised shingles and bent flashing
      often goes unseen until leaks form. Black Knight Roofing inspects and repairs storm damage properly, working with
      your insurance adjuster to ensure you get the coverage you deserve.
    </p>
  </Hero>

  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>

  <!-- Service Details -->
  <NoiseBg class="relative px-0 py-0">
    <Image
      {...sunflow}
      alt="Sunflow Image"
      class="pointer-events-none absolute inset-0 top-0 left-0 w-full opacity-10"
    />
    <div class="container py-8 lg:py-20">
      <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:items-stretch">
        <!-- Left contents -->
        <div class="space-y-8 py-8">
          <div class="flex-1 space-y-4">
            <Breadcrumb items={[{ label: 'Services', href: '/services' }, { label: 'Wind Damage Repair' }]} />

            <h2 class="text-medium max-w-[530px] text-[clamp(28px,4vw,48px)] leading-[clamp(40px,4vw,52px)]">
              Wind Breaks Seals Before It Breaks Shingles
            </h2>

            <p class="text-sm lg:text-base">
              The most dangerous wind damage on a Colorado roof isn’t the missing shingle, but the one lifted enough for
              rain to seep in, breaking its seal. This hidden damage often goes unnoticed and causes leaks later. Front
              Range winds often exceed 60 mph, with gusts up to 100 mph during storms. Every high-wind event deserves
              inspection. We check the entire roof system—shingles, flashing, valleys, fascia, and soffits—and document
              with photos. We inspect with a builder’s eye, focusing on the structure, not just the surface.
            </p>
          </div>

          <Button class="px-8 py-4 text-base" data-estimate-trigger> FREE Wind Damage Inspection </Button>
        </div>

        <!-- Right Contents -->

        <div class="h-[380px] w-full items-center overflow-hidden rounded-lg lg:self-center">
          <Image
            src="/placeholders/thumbnails/roof-replacement-1.avif"
            alt="Roof Replacement"
            width={442}
            height={785}
            class="h-full w-full rounded-lg object-cover"
          />
        </div>
      </div>
    </div>
  </NoiseBg>

  <Statistics />
  <Testimonials />

  <WhyChooseUs
    badgeText="Why Choose Us"
    title="We Fix What the Wind Actually Damaged — Not Just What's Easy to See"
    description=" <p> Many wind damage repairs miss hidden issues. A roofer might replace a couple of missing shingles and call it done, but nearby shingles with broken seals, lifting ridge caps, and misaligned flashing often get overlooked. We inspect every section of your roof thoroughly, checking for lifted edges, creased tabs, loose nails, and flashing problems. We document all damage with photos to ensure your insurance claim covers everything, not just what's visible from the driveway. </p> <p> Insurance companies sometimes deny wind damage claims, especially on older roofs, blaming wear and tear instead. We link our findings to weather data and damage patterns to support your claim. With our A+ BBB rating, 41+ five-star Google reviews, and lifetime warranty, we stand behind every repair we do.</p>"
    image="/placeholders/thumbnails/residential-2.png"
    buttonText="FREE Wind Damage Inspection"
    imagePosition="left"
  />

  <div class="via-primary container h-px bg-linear-to-r from-transparent to-transparent lg:hidden"></div>

  <Process steps={processSteps} />
  <ServiceAreas />
  <Faqs />
  <RecentArticales />

  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>
  <CTASection />
  <Footer />
</Layout>
