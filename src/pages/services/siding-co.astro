---
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/Navbar.astro';
import Brands from '@/components/Brands.astro';
import CTASection from '@/components/cta/CTASection.astro';
import Footer from '@/components/Footer.astro';
import Testimonials from '@/components/Testimonials.astro';
import Faqs from '@/components/faqs/Faqs.astro';
import NoiseBg from '@/components/NoiseBg.astro';
import WhyChooseUs from '@/components/WhyChooseUs.astro';
import Button from '@/components/ui/Button.astro';
import EstimateButton from '@/components/EstimateButton.astro';
import { Icon } from 'astro-icon/components';
import { type Service } from '@/data/services';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import Hero from '@/components/hero/Hero.astro';
import RatingStars from '@/components/ui/RatingStars.astro';
import QuoteForm from '@/components/cta/QuoteForm.astro';
import { Image } from 'astro:assets';
import Process from '@/components/process/Process.astro';
import step1 from '@/assets/steps/step-1.png';
import step2 from '@/assets/steps/step-2.png';
import step3 from '@/assets/steps/step-3.png';
import step4 from '@/assets/steps/step-4.png';
import RecentProjects from '@/components/recent-projects/RecentProjects.astro';
import RecentArticales from '@/components/articales/RecentArticales.astro';
import ServiceAreas from '@/components/service-area/ServiceAreas.astro';
import StylesProfiles from '@/components/services/StylesProfiles.astro';
import OtherServicesCarousel from '@/components/services/OtherServicesCarousel.astro';
import PopularRoofingMaterials from '@/components/services/PopularRoofingMaterials.astro';
import ComparisonTable from '@/components/services/ComparisonTable.astro';
import SocialProof from '@/components/ui/SocialProof.astro';
import Statistics from '@/components/ui/Statistics.astro';
import heroImage from '@/assets/bg/siding-section__hero.avif';
import sidingMainImg from '@/assets/generated/siding-main.png';

import vinylHorizontalLap from '@/assets/generated/vinyl-horizontal-lap.png';
import vinylBoardBatten from '@/assets/generated/vinyl-board-batten.png';
import steelSeamlessPanels from '@/assets/generated/steel-seamless-panels.png';
import metalRibbedSiding from '@/assets/generated/metal-ribbed-siding.png';
import fibreCementPanels from '@/assets/generated/fibre-cement-panels.png';
import stoneVeneerAccent from '@/assets/generated/stone-veneer-accent.png';
import { callSafely } from 'astro:actions';
import { string } from 'astro:schema';

const categories = [
  {
    id: 'vinyl',
    label: 'Vinyl Siding',
    items: [
      {
        id: 'horizontal-lap',
        title: 'Premium Horizontal Lap',
        description:
          'Traditional look with modern performance. Durable, low-maintenance, and available in a wide range of colors to match any Colorado home.',
        image: vinylHorizontalLap,
      },
      {
        id: 'board-batten',
        title: 'Authentic Board & Batten',
        description:
          'Vertical lines that add height and character. Perfect for farmhouse or modern-rustic styles with the durability of high-grade vinyl.',
        image: vinylBoardBatten,
      },
    ],
  },
  {
    id: 'metal',
    label: 'Steel & Metal Siding',
    items: [
      {
        id: 'seamless-steel',
        title: 'Seamless Steel Panels',
        description:
          'The ultimate in structural strength. No seams means no gaps for moisture or insects, providing a clean, unbreakable shield for your home.',
        image: steelSeamlessPanels,
      },
      {
        id: 'ribbed-metal',
        title: 'Ribbed Metal Siding',
        description:
          'Contemporary architectural appeal with exceptional resilience. Engineered to withstand high winds and severe weather with an industrial-luxury finish.',
        image: metalRibbedSiding,
      },
    ],
  },
  {
    id: 'composite',
    label: 'Specialty & Composite',
    items: [
      {
        id: 'fibre-cement',
        title: 'Fibre Cement Panels',
        description:
          'Unmatched fire resistance and a premium masonry-like feel. Fiber cement offers the look of natural wood with none of the rotting or pest issues.',
        image: fibreCementPanels,
      },
      {
        id: 'stone-veneer',
        title: 'Stone Veneer Accents',
        description:
          'Add texture and value with realistic stone accents. Perfectly complements our siding options for a fully finished, high-end exterior look.',
        image: stoneVeneerAccent,
      },
    ],
  },
];

const processSteps = [
  {
    image: step1,
    step: 'Step 1',
    title: 'Contact Our Team',
    description: 'Get in touch with us by phone or fill out a form! Our customer service team is on standby.',
  },
  {
    image: step2,
    step: 'Step 2',
    title: 'Schedule Inspection',
    description: 'We will schedule a convenient time to inspect your roof and assess the project scope.',
  },
  {
    image: step3,
    step: 'Step 3',
    title: 'Review Your Proposal',
    description: 'Receive a detailed proposal outlining the work, timeline, and transparent pricing.',
  },
  {
    image: step4,
    step: 'Step 4',
    title: 'Project Completion',
    description: 'Our expert team completes the project to the highest standards with a final walkthrough.',
  },
];
---

<Layout>
  <Navbar />

  <Hero
    backgroundImage={heroImage}
    title="Reliable Siding Services in Denver, CO"
    subtitle="Siding Installation In Colorado"
  >
    <p class="text-sm">
      New siding should do two things well: protect your home from Colorado weather and make the whole exterior look
      more finished. Black Knight Roofing helps homeowners choose siding that fits the style of the home, the level of
      maintenance they want, and the long-term result they are after with vinyl and steel siding options from Colorado
      Springs to Fort Collins.
    </p>
  </Hero>

  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>

  <!-- Service Details -->
  <NoiseBg class="px-0 py-0">
    <div class="container py-8 lg:py-20">
      <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2">
        <!-- Left contents -->
        <div class="space-y-8 py-8">
          <div class="flex-1 space-y-4">
            <Breadcrumb items={[{ label: 'Services', href: '/services' }, { label: 'Siding' }]} />

            <h2 class="text-medium max-w-[530px] text-[clamp(28px,4vw,48px)] leading-[clamp(40px,4vw,52px)]">
              Siding That Fits the Home and Holds Up Over Time
            </h2>

            <p class="text-sm lg:text-base">
              Siding changes more than curb appeal. It affects how your home handles weather, how much upkeep the
              exterior needs, and how clean and finished the property looks from the street. Black Knight Roofing helps
              homeowners compare siding options clearly, so you can choose the right look and level of durability
              without second-guessing the decision later.
            </p>
          </div>

          <EstimateButton offerText="" actionText="Talk to a Siding Professional" class="px-8 py-4 text-base" />
        </div>

        <!-- Right Contents -->

        <div class="h-[400px] overflow-hidden rounded-2xl">
          <Image
            src={sidingMainImg}
            alt="Siding Installation"
            width={600}
            height={400}
            class="rounded-2xl object-cover"
          />
        </div>
      </div>
    </div>
  </NoiseBg>

  <Statistics />
  <Testimonials />

  <WhyChooseUs
    badgeText="Why Choose Us"
    title="Exterior Work That Looks Better Up Close"
    description="At Black Knight Roofing Roofing, we proudly support Colorado businesses with reliable commercial roofing solutions. We understand the region’s weather challenges, from intense heat to severe storms and hurricanes, and we tailor every project to meet the specific needs of commercial properties. Using high-quality, weather-resistant materials and expert craftsmanship, we ensure your roof is built to last and protect your business from the elements. Serving Colorado is more than just our job—it’s about safeguarding the businesses that drive this vibrant community forward."
    image="/placeholders/thumbnails/residential-2.png"
    buttonText="FREE Roof Estimate"
    imagePosition="left"
  />

  <div class="via-primary container h-px bg-linear-to-r from-transparent to-transparent lg:hidden"></div>

  <Process steps={processSteps} />
  <OtherServicesCarousel />
  <PopularRoofingMaterials
    quote="“Good siding should protect the home, clean up the look, and still make sense for how you want to maintain the exterior.”"
    categories={categories}
  />
  <RecentProjects />
  <ServiceAreas />
  <Faqs />
  <RecentArticales />

  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>
  <CTASection />
  <Footer />
</Layout>
