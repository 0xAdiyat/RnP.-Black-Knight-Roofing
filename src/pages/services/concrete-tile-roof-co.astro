---
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/Navbar.astro';
import Brands from '@/components/Brands.astro';
import CTASection from '@/components/cta/CTASection.astro';
import { residentialCTA } from '@/data/cta';
import Footer from '@/components/Footer.astro';
import Faqs from '@/components/faqs/Faqs.astro';
import { concreteFaqs } from '@/data/faqs/concrete-tile';
import NoiseBg from '@/components/NoiseBg.astro';
import Button from '@/components/ui/Button.astro';
import { Icon } from 'astro-icon/components';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import Hero from '@/components/hero/Hero.astro';
import { Image } from 'astro:assets';
import RecentProjects from '@/components/recent-projects/RecentProjects.astro';
import ServiceAreas from '@/components/service-area/ServiceAreas.astro';
import StylesProfiles from '@/components/services/StylesProfiles.astro';
import PopularRoofingMaterials from '@/components/services/PopularRoofingMaterials.astro';
import ComparisonTable from '@/components/services/ComparisonTable.astro';
import Statistics from '@/components/ui/Statistics.astro';
import sunflow from '@/assets/sunflow.avif';
import heroImage from '@/assets/bg/concrete-tile-roof-section__hero.avif';
import profileImg from '@/assets/hero-person.avif';

import heroBg from '@/assets/tiles/hero-bg.png';
import heroGradient from '@/assets/tiles/hero-gradient.png';
import concreteTileRoof from '@/assets/services/concrete-tile-roof.png';
import comparisonHero from '@/assets/tiles/comparison-hero.png';
import missionSPreview from '@/assets/tiles/mission-s-preview.png';
import terraCottaThumb from '@/assets/tiles/terra-cotta-thumb.png';
import barroRojoThumb from '@/assets/tiles/barro-rojo-thumb.png';
import sierraCoveBrownThumb from '@/assets/tiles/sierra-cove-brown-thumb.png';
import salernoClayThumb from '@/assets/tiles/salerno-clay-thumb.png';
import marbledTerraCottaThumb from '@/assets/tiles/marbled-terra-cotta-thumb.png';
import appleBarkThumb from '@/assets/tiles/apple-bark-thumb.png';
import laTerraBlendThumb from '@/assets/tiles/la-terra-blend-thumb.png';
import californiaMissionBlendThumb from '@/assets/tiles/california-mission-blend-thumb.png';
import cascaraBrownThumb from '@/assets/tiles/cascara-brown-thumb.png';
import BadgeTitle from '@/components/BadgeTitle.astro';
import EstimateButton from '@/components/EstimateButton.astro';

// Assets
import roiIllustration from '@/assets/tiles/roi-illustration.png';
import component1 from '@/assets/tiles/component-1.png';
import component2 from '@/assets/tiles/component-2.png';
import component3 from '@/assets/tiles/component-3.png';
import component4 from '@/assets/tiles/component-4.png';
import component5 from '@/assets/tiles/component-5.png';
import hailProtection from '@/assets/materials/hail-protection.png';
import windPerformance from '@/assets/materials/wind-performance.png';
import wildfireSafety from '@/assets/materials/wildfire-safety.png';
import energyEfficiency from '@/assets/materials/energy-efficiency.png';

// Generated Assets
import windInterlocking from '@/assets/generated/wind-interlocking.png';
import windMass from '@/assets/generated/wind-mass.png';
import hailImpact from '@/assets/generated/hail-impact.png';
import hailDurability from '@/assets/generated/hail-durability.png';
import fireNonCombustible from '@/assets/generated/fire-non-combustible.png';
import fireEmbers from '@/assets/generated/fire-embers.png';
import energyThermal from '@/assets/generated/energy-thermal.png';
import energyVentilation from '@/assets/generated/energy-ventilation.png';

// Concrete Style Previews
import villaPreview from '@/assets/generated/concrete-villa.png';
import belAirPreview from '@/assets/generated/concrete-bel-air.png';
import ponderosaPreview from '@/assets/generated/concrete-ponderosa.png';

const concreteProfiles = [
  {
    id: 'mission-s',
    label: 'Mission "S"',
    title: 'Newpoint™ Mission "S"',
    description: 'A high-profile S-tile that captures the classic look of Mediterranean and Spanish architecture.',
    previewImage: missionSPreview,
    colors: [
      { name: 'Terra Cotta', code: '1MSCS6100', color: '#B35A3E', thumbnail: terraCottaThumb },
      { name: 'Barro Rojo', code: '1MSCS7024', color: '#8C3F2F', thumbnail: barroRojoThumb },
      { name: 'Sierra Cove Brown', code: '1MSCS3570', color: '#6D5A4A', thumbnail: sierraCoveBrownThumb },
      { name: 'Salerno Clay', code: '1MSCS6330', color: '#8C7355', thumbnail: salernoClayThumb },
      { name: 'Marbled Terra Cotta', code: '1MSCS6129', color: '#B35A3E', thumbnail: marbledTerraCottaThumb },
      { name: 'Apple Bark', code: '1MSCS0431', color: '#6B5A4A', thumbnail: appleBarkThumb },
      { name: 'La Terra Blend', code: '1MSCS6031', color: '#8C7355', thumbnail: laTerraBlendThumb },
      { name: 'California Mission Blend', code: '1MSCS6464', color: '#8C5A4A', thumbnail: californiaMissionBlendThumb },
      { name: 'Cascara Brown', code: '1MSCS3238', color: '#6D5A4A', thumbnail: cascaraBrownThumb },
    ]
  },
  {
    id: 'boosted-barcelona',
    label: 'Boosted Barcelona Caps',
    title: 'Newpoint™ Boosted Barcelona',
    description: 'Authentic high-profile design creates the look of a traditional mortar-boosted roof.',
    previewImage: missionSPreview,
    colors: [
      { name: 'TERRA COTTA', code: '4VAP9104001', color: '#B35A3E', thumbnail: terraCottaThumb },
      { name: 'MARBLED TERRA COTTA', code: '1MSCS6129', color: '#B35A3E', thumbnail: marbledTerraCottaThumb },
    ]
  },
  {
    id: 'villa',
    label: 'Villa',
    title: 'Newpoint™ Villa',
    description: 'A medium-profile S-tile providing a classic Mediterranean aesthetic with modern durability.',
    previewImage: villaPreview,
    colors: [
      { name: 'BARCELONA', code: '4VAP93185SF', color: '#7B4A4A', thumbnail: barroRojoThumb },
      { name: 'SALERNO CLAY', code: '1MSCS6330', color: '#8C7355', thumbnail: salernoClayThumb },
    ]
  },
  {
    id: 'saxony-slate',
    label: 'Saxony® 900 Slate',
    title: 'Saxony® 900 Slate',
    description: 'A low-profile tile that replicates the natural beauty and clean lines of slate.',
    previewImage: belAirPreview,
    colors: [
      { name: 'CHARCOAL', code: '4BAP9104000', color: '#333333', thumbnail: cascaraBrownThumb },
      { name: 'SIERRA COVE', code: '1MSCS3570', color: '#6D5A4A', thumbnail: sierraCoveBrownThumb },
    ]
  },
  {
    id: 'saxony-shake',
    label: 'Saxony® 900 Shake',
    title: 'Saxony® 900 Shake',
    description: 'A medium-profile tile that replicates the rugged texture and beauty of natural wood shake.',
    previewImage: ponderosaPreview,
    colors: [
      { name: 'APPLE BARK', code: '1MSCS0431', color: '#6B5A4A', thumbnail: appleBarkThumb },
      { name: 'LA TERRA BLEND', code: '1MSCS6031', color: '#8C7355', thumbnail: laTerraBlendThumb },
    ]
  },
  {
    id: 'madera-900',
    label: 'Madera 900',
    title: 'Madera 900',
    description: 'A premium medium-profile shake tile with high-definition textures for maximum curb appeal.',
    previewImage: ponderosaPreview,
    colors: [
      { name: 'CASCARA BROWN', code: '1MSCS3238', color: '#6D5A4A', thumbnail: cascaraBrownThumb },
      { name: 'CALIFORNIA MISSION', code: '1MSCS6464', color: '#8C5A4A', thumbnail: californiaMissionBlendThumb },
    ]
  }
];


const tileComparison = [
  { label: 'Lifespan', icon: 'battery', standard: '20-30 years', premium: '50-100 years' },
  { label: 'Fire Rating', icon: 'shield-fire', standard: 'Lower', premium: 'Class A' },
  { label: 'Hail Options', icon: 'hail', standard: 'Varies', premium: 'Class 3 & 4' },
  { label: 'Attic Temp (Tested)', icon: 'heat-meter', standard: '139°', premium: '94°' },
  { label: 'Energy Savings', icon: 'bolt', standard: '-', premium: 'Up to 22% potential' },
  { label: 'Aesthetic Value', icon: 'star', standard: 'Standard', premium: 'Architectural premium' },
];

const components = [
  { img: component1, label: 'Newpoint™ Concrete Roof Tile' },
  { img: component2, label: 'Westlake Royal TileSeal™ Underlayment' },
  { img: component3, label: 'Vented Eave Riser' },
  { img: component4, label: 'Elevated Batten System®' },
  { img: component5, label: 'Vented Ridge' },
];

const categories = [
  {
    id: 'wind',
    label: 'Wind',
    items: [
      {
        id: 'wind-mass',
        title: 'Wind',
        description:
          "Concrete tile's weight works in its favor against wind. Each Newpoint™ tile is installed over a batten system with proper mechanical fastening — meaning Colorado's Front Range gusts don't lift or peel tiles the way they can with lightweight shingle systems. High-profile tile models are specifically tested to FM 4473 wind standards",
        image: windMass,
      },
    ],
  },
  {
    id: 'hail',
    label: 'Hail',
    items: [
      {
        id: 'hail-resistance',
        title: 'Hail',
        description:
          'Newpoint™ concrete tile profiles carry Class 3 or Class 4 hail ratings — the two highest classifications available. Their dense composition absorbs impact energy differently than granule-coated materials, which means hail damage to concrete tile is often cosmetic rather than structural. Colorado homeowners often qualify for insurance discounts with Class 4-rated tile.',
        image: hailImpact,
      },
    ],
  },
  {
    id: 'fire',
    label: 'Fire',
    items: [
      {
        id: 'fire-rating',
        title: 'Fire',
        description:
          'All Newpoint™ concrete tiles carry a Class A fire rating — the highest classification for roofing products. Concrete is naturally non-combustible, which means there\'s no underlying material that can ignite or accelerate a fire. In Colorado, where wildfire risk is real and growing, a Class A-rated roof is one of the most meaningful protections you can add to your home.',
        image: fireNonCombustible,
      },
    ],
  },
];
---

<Layout>
  <Navbar />

  <Hero
    backgroundImage={heroImage}
    title="Concrete Tile Roofing in Colorado"
    subtitle="Concrete Tile Roof Services in Colorado"
  >
    <!-- Hero section list -->
    <ul class="space-y-4 text-[14px] sm:text-[15px] lg:space-y-3">
      <li class="flex items-start gap-x-4 lg:items-center">
        <Icon name="shield" size={24} class="shrink-0" />
        <span class="text-normal flex-1">
          <strong class="font-semibold text-white"> 50-100 Year Performance Potential: </strong> Concrete tile is one of the
          longest-lasting roofing systems available. Properly installed, it can outlast two or three asphalt shingle replacements
          on the same house.
        </span>
      </li>

      <li class="flex items-start gap-x-4 lg:items-center">
        <Icon name="helmet" size={24} class="shrink-0" />
        <span class="text-normal flex-1">
          <strong class="font-semibold text-white"> Class 3 & Class 4 Hail-Rated Profiles: </strong> Newpoint™ concrete tile
          profiles carry Class 3 or Class 4 hail ratings depending on the profile — engineered to handle Colorado's hail corridor
          on the Front Range.
        </span>
      </li>

      <li class="flex items-start gap-x-4 lg:items-center">
        <Icon name="star-leaf" size={24} class="shrink-0" />
        <span class="text-normal flex-1">
          <strong class="font-semibold text-white">Fully Transferable Limited Lifetime Warranty: </strong> Westlake Royal
          Roofing Solutions™ backs every Newpoint™ tile with a fully transferable, non-prorated limited lifetime warranty
          — plus our own lifetime workmanship guarantee.
        </span>
      </li>
    </ul>
  </Hero>

  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>

  <!-- Service Details -->
  <NoiseBg class="relative px-0 py-0">
    <Image
      src={sunflow}
      alt=""
      width={sunflow.width}
      height={sunflow.height}
      class="pointer-events-none absolute inset-x-0 top-0 left-0 opacity-10"
    />

    <div class="z-10 container py-8 lg:py-20">
      <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:items-stretch">
        <!-- Left contents -->
        <div class="space-y-8 py-8">
          <div class="flex-1 space-y-4">
            <Breadcrumb items={[{ label: 'Services', href: '/services' }, { label: 'Concrete Tile Roofing' }]} />

            <h2 class="text-medium max-w-[530px] text-[clamp(28px,4vw,48px)] leading-[clamp(40px,4vw,52px)] text-white">
              What is Concrete Tile Roofing?
            </h2>

            <p class="text-neutral-lighter text-sm lg:text-base">
              Concrete tile roofing combines architectural elegance with long-term structural performance — making it
              one of the most durable and energy-efficient roofing systems for Colorado homes. Unlike traditional
              shingles, concrete tile is solid through its entire thickness, giving it natural resistance to impact,
              heat, and fire that lightweight roofing materials simply can't match. Newpoint™ concrete tile by Westlake
              Royal is engineered for both new construction and reroofing, with multidimensional textures and natural
              colorways that harmonize with any architectural style.
            </p>
            <p class="text-neutral-lighter">Unlike traditional shingles, concrete tile is engineered to provide:</p>

            <ul class="text-neutral-lighter columns-1 gap-x-8 gap-y-4 text-sm sm:columns-2">
              <li class="mb-4 flex gap-x-2">
                <Icon name="calender-clock" size={24} class="text-primary shrink-0" />
                50-100 Year Performance Potential
              </li>

              <li class="mb-4 flex gap-x-2">
                <Icon name="shield-fire" size={24} class="text-primary shrink-0" />
                Class A Fire Rating
              </li>

              <li class="mb-4 flex gap-x-2">
                <Icon name="cloude" size={24} class="text-primary shrink-0" />
                Class 3 & Class 4 Hail-Rated Profiles
              </li>

              <li class="mb-4 flex gap-x-2">
                <Icon name="color-test" size={24} class="text-primary shrink-0" />
                Cool Roof Rated Color Options
              </li>

              <li class="mb-4 flex gap-x-2">
                <Icon name="badge-tick" size={24} class="text-primary shrink-0" />
                Fully Transferable Limited Lifetime Warranty
              </li>
            </ul>
          </div>

          <div class="flex gap-4">
            <EstimateButton offerText="" actionText="**FREE** Estimate" class="px-8 py-4 text-base" />

            <Button variant="link" class="flex h-12 items-center gap-2 py-4 text-base">
              <svg width="13" height="16" viewBox="0 0 13 16" fill="none">
                <path
                  d="M12.361 8.2787L0.503906 14.868C0.367002 14.9454 0.249442 14.9543 0.151228 14.8948C0.0530134 14.8353 0.00390625 14.7281 0.00390625 14.5733V1.43049C0.00390625 1.27573 0.0530134 1.16858 0.151228 1.10906C0.249442 1.04954 0.367002 1.05846 0.503906 1.13585L12.361 7.72513C12.498 7.80251 12.5664 7.89477 12.5664 8.00192C12.5664 8.10906 12.498 8.20132 12.361 8.2787Z"
                  fill="white"></path>
              </svg>

              <span> Explore Styles & Colors </span>
            </Button>
          </div>
        </div>

        <!-- Right Contents -->

        <div class="h-[500px] w-full items-center overflow-hidden rounded-lg lg:self-center">
          <Image
            src={concreteTileRoof}
            alt="Newpoint™ Concrete Tile Roofing"
            width={600}
            height={400}
            class="h-full w-full object-cover"
          />
        </div>
      </div>
    </div>
  </NoiseBg>

  <Statistics />
  <PopularRoofingMaterials
    badge="Why Concrete Tile"
    title="Extreme Weather Protection for Colorado Homes"
    description="Colorado's climate tests every roofing material — high-altitude UV that fades and degrades lighter systems, hail seasons that peak April through September, temperature swings of 30+ degrees in a single day, and freeze-thaw cycles all winter long. Concrete tile handles all of it through material density, not coatings. It's solid through its entire thickness, which means there's nothing to peel, chip, or lose to UV exposure over time."
    categories={categories}
    quote="“For every weather we got you covered.”"
    quoteAuthor="Adam Knight"
    quoteRole="Owner & Stone Coated Steel Expert"
    quoteImage={profileImg}
    source={{
      label: 'Source: Westlake Royal Building Products — Newpoint™ Concrete Roof Tile',
      href: 'https://www.westlakeroyalroofing.com/newpoint/',
    }}
  />

  <!-- Comparison Section -->

  <section class="relative overflow-hidden py-16 lg:py-24">
    <!-- Dynamic Background Layers -->
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-[#0A0A0A]"></div>
      <Image src={heroBg} alt="" class="absolute inset-0 h-full w-full object-cover opacity-5" loading="lazy" />
      <Image
        src={heroGradient}
        alt=""
        class="absolute inset-0 h-full w-full object-cover opacity-20 lg:opacity-30"
        loading="lazy"
      />
    </div>

    <div class="container space-y-12">
      <!-- Temperature Differences Hero -->
      <div class="relative flex flex-col items-center justify-center pt-10 lg:min-h-[600px] lg:pt-20">
        <div class="w-full max-w-[1440px]">
          <Image
            src={comparisonHero}
            width={comparisonHero.width}
            height={comparisonHero.height}
            alt="Temperature comparison between concrete tile and asphalt shingle roof"
            class="w-full rounded-3xl object-cover"
          />
        </div>

        <div class="relative z-10 flex flex-col items-center justify-center px-4 pt-10 text-center uppercase">
          <div
            class="bg-linear-to-b from-white via-[#d9d9d9] to-white/10 bg-clip-text text-[clamp(1.5rem,6vw,5rem)] leading-none font-extrabold tracking-tighter text-transparent"
          >
            <span class="block lg:inline">Concrete Tile</span>
            <span class="text-primary italic opacity-80">vs</span>
            <span class="block lg:inline">Asphalt Shingle</span>
          </div>
          <div
            class="mt-2 bg-linear-to-b from-white via-[#d9d9d9] to-[#1a1a1a] bg-clip-text text-[clamp(1.8rem,8vw,64px)] font-bold tracking-tight text-transparent lg:mt-4"
            style="text-shadow: 0px 4px 24px rgba(0,0,0,0.8), 0px -8px 100px black;"
          >
            Temperature Differences
          </div>
        </div>
      </div>

      <!-- Core Messaging Section -->
      <div class="flex flex-col items-center gap-6">
        <div class="lg:col-span-5">
          <h2 class="font-heading text-3xl leading-[1.1] tracking-tight lg:text-5xl">
            Designed for Colorado Architecture. Built from the Right Material.
          </h2>
        </div>
        <div class="border-primary/30 border-l-2 py-2 pl-6 lg:col-span-7 lg:pl-10">
          <div class="text-neutral-lighter space-y-3 text-base leading-relaxed font-normal lg:text-xl">
            <p>
              Colorado homes face extremes — high-altitude UV radiation, rapid temperature swings, freeze-thaw cycles,
              heavy hailstorms, and growing wildfire risk. The roofing material must do more than look good. It must
              endure. Concrete tile delivers structural integrity and architectural permanence that lightweight roofing
              systems can't match. Its density and composition provide natural resistance to impact, heat, and fire —
              making it a practical and resilient choice for Colorado's demanding climate.
            </p>
            <p>
              *Attic temperatures measured using identical heat sources simulating the sun's radiation comparing the
              Newpoint™ Cool Roof System to a common asphalt shingle installation.
            </p>
          </div>
        </div>

        <div class="flex w-full items-center gap-2 text-xs">
          <Icon name="circle-info" class="text-primary" />
          <span class="text-neutral-lighter">
            Source:
            <a
              href="https://www.westlakeroyalroofing.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-primary text-white underline"
            >
              Westlake Royal Building Products.
            </a>
          </span>
        </div>
      </div>

      <!-- ROI Analysis Section -->
      <div class="grid items-center gap-10 py-10 lg:grid-cols-2 lg:gap-20">
        <div class="order-2 space-y-6 lg:order-1 lg:space-y-8">
          <BadgeTitle badge="The ROI" title="Keeping Temperatures Cool and ROI High" />
          <p class="text-neutral-lighter text-lg leading-relaxed">
            The Newpoint™ Cool Roof System and CRRC-rated Cool Roof color options create a more comfortable indoor
            climate, reduce heating and cooling costs, and help your roof last longer than traditional construction. Oak
            Ridge National Laboratory research found the system can reduce heating and cooling costs by up to 22%
            annually.
          </p>

          <div class="flex w-full items-center gap-2 text-xs">
            <Icon name="circle-info" class="text-primary" />
            <span class="text-neutral-lighter">
              Source:
              <a
                href="https://www.westlakeroyalroofing.com/"
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-primary text-white underline"
              >
                Westlake Royal Building Products.
              </a>
            </span>
          </div>

          <div class="pt-4">
            <Button variant="primary" size="lg" class="text-sm font-bold tracking-wide uppercase">Learn More</Button>
          </div>
        </div>
        <div class="relative order-1 overflow-hidden rounded-3xl border border-white/10 shadow-2xl lg:order-2">
          <Image
            src={roiIllustration}
            alt="Visual ROI Illustration"
            class="w-full transition-transform duration-1000 hover:scale-105"
          />
        </div>
      </div>

      <!-- Components Showcase -->
      <div class="space-y-10">
        <BadgeTitle
          badge="How it Work"
          title="We Use 5 Components to Provide Energy Efficiency and Give Substantial Return on Your Investment"
          class="mx-auto flex max-w-4xl flex-col items-center text-center"
        />

        <div
          class="grid grid-cols-[repeat(auto-fit,minmax(200px,1fr))] justify-center gap-6 lg:flex lg:flex-wrap lg:items-center lg:justify-center"
        >
          {
            components.map(comp => (
              <div class="group relative w-full max-w-[400px] space-y-3 text-center">
                <div class="relative aspect-5/3 overflow-hidden rounded-2xl border border-white/5 bg-neutral-900 shadow-xl">
                  <Image
                    src={comp.img}
                    alt={comp.label}
                    class="h-full w-full object-cover transition-all duration-700 group-hover:scale-110 group-hover:brightness-110"
                  />
                </div>
                <p class="text-neutral-lighter group-hover:text-primary px-2 text-sm font-semibold tracking-wide transition-colors duration-300">
                  {comp.label}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <ComparisonTable
    title="Concrete Tile vs <br class='hidden lg:block' /> Asphalt Shingles"
    standardColumn="Asphalt Shingles"
    premiumColumn="Concrete Tile"
    standardLabel="Asphalt"
    premiumLabel="Concrete"
    data={tileComparison}
  />

  <StylesProfiles 
    badge="Styles"
    title="Concrete Tile Profiles"
    description="Select a Newpoint™ concrete tile profile to see how different textures and CRRC-rated colors transform your home's curb appeal."
    profiles={concreteProfiles}
  />

  <RecentProjects />
  <Faqs faqs={concreteFaqs} />
  <ServiceAreas />

  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>
  <CTASection cta={residentialCTA} />
  <Footer />
</Layout>
