---
import Button from '@/components/ui/Button.astro';
import { Image } from 'astro:assets';

interface Props {
  title: string;
  description: string;
  image: string;
}

const { title, description, image } = Astro.props;
---

<div class="relative h-[490px] w-full max-w-[872px] pr-20">
  <div class="bg-inverted h-full">
    {image && (
      <Image
        src={image}
        alt={title || ""}
        width={600}
        height={490}
        class="h-full w-full rounded-lg object-cover"
      />
    )}
  </div>
  <div class="bg-primary text-inverted absolute top-1/2 right-0 w-[448px] -translate-y-1/2 rounded-xl px-12 py-8">
    <div class="space-y-6 py-4">
      <div class="space-y-4">
        <h4 class="font-body font-medium">{title}</h4>
        <p class="font-normal text-[#444444]">
          {description}
        </p>
      </div>

      <Button variant="outline" class="border-inverted"> Learn More </Button>
    </div>
  </div>
</div>
