---
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/Navbar.astro';
import Brands from '@/components/Brands.astro';
import CTASection from '@/components/cta/CTASection.astro';
import Footer from '@/components/Footer.astro';
import Faqs from '@/components/faqs/Faqs.astro';
import NoiseBg from '@/components/NoiseBg.astro';
import Button from '@/components/ui/Button.astro';
import { Icon } from 'astro-icon/components';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import Hero from '@/components/hero/Hero.astro';
import { Image } from 'astro:assets';
import RecentProjects from '@/components/recent-projects/RecentProjects.astro';
import ServiceAreas from '@/components/service-area/ServiceAreas.astro';
import StylesProfiles from '@/components/services/StylesProfiles.astro';
import PopularRoofingMaterials from '@/components/services/PopularRoofingMaterials.astro';
import ComparisonTable from '@/components/services/ComparisonTable.astro';
import Statistics from '@/components/ui/Statistics.astro';
import sunflow from '@/assets/sunflow.avif';
import WhyStoneCoated from '@/components/services/WhyStoneCoated.astro';
import heroImage from '@/assets/bg/stone-coated-steel-roofing-section__hero.avif';

import heroBg from '@/assets/tiles/hero-bg.png';
import heroGradient from '@/assets/tiles/hero-gradient.png';
import comparisonHero from '@/assets/tiles/comparison-hero.png';
import BadgeTitle from '@/components/BadgeTitle.astro';
import EstimateButton from '@/components/EstimateButton.astro';

const materials = [
  {
    id: 'shingles',
    label: 'Architectural Shingles',
    description:
      'A reliable, budget-friendly choice with layered dimension, broad color options, and dependable everyday performance for Colorado homes.',
    image: '/placeholders/popular-materials/1.png',
  },
  {
    id: 'steel',
    label: 'Stone Coated Steel',
    description:
      'The ultimate protection against Colorado hail. Lightweight, non-combustible, and designed to last a lifetime with the look of traditional tile or wood shake.',
    image: '/placeholders/popular-materials/1.png',
  },
  {
    id: 'tile',
    label: 'Concrete Tile',
    description:
      'Superior thermal performance and exceptional durability. Concrete tile offers high fire resistance and a distinct aesthetic for premium Colorado residences.',
    image: '/placeholders/popular-materials/1.png',
  },
];

const components = [
  {
    img: '/placeholders/thumbnails/stone-coated-2.png',
    label: 'Elevated Batten System® (EBS) creates airflow beneath panels ',
  },
  { img: '/placeholders/thumbnails/stone-coated-3.png', label: 'Continuous ridge vent exhausts hot air' },
  { img: '/placeholders/thumbnails/stone-coated-4.png', label: 'Sol-R-Skin™ underlayment enhances performance ' },
];
---

<Layout>
  <Navbar />

  <Hero
    backgroundImage={heroImage}
    title="Stone-Coated Steel Roofing Built for Colorado Storms"
    subtitle="Stone-Coated Steel Services in Colorado"
  >
    <!-- Hero section list -->
    <ul class="space-y-4 text-[14px] sm:text-[15px] lg:space-y-3">
      <li class="flex items-start gap-x-4 lg:items-center">
        <Icon name="shield" size={24} class="shrink-0" />
        <span class="text-normal flex-1">
          <strong class="font-semibold text-white">Proud Veteran Owned:</strong>
          Most roofers just replace shingles. As a licensed general contractor and Army veteran, Adam inspects your whole
          home — and builds to last.
        </span>
      </li>

      <li class="flex items-start gap-x-4 lg:items-center">
        <Icon name="helmet" size={24} class="shrink-0" />
        <span class="text-normal flex-1">
          <strong class="font-semibold text-white">Stone-Coated Steel Experts:</strong> We specialize in the materials most
          roofers won't touch — stone-coated steel and concrete tile — because we know they're the best thing on your roof.
        </span>
      </li>

      <li class="flex items-start gap-x-4 lg:items-center">
        <Icon name="star-leaf" size={24} class="shrink-0" />
        <span class="text-normal flex-1">
          <strong class="font-semibold text-white">Insurance Claim Specialists + Lifetime Guarantee:</strong>
          We handle insurance claim and provide lifetime workmanship warranty plus manufacturer guarantees.
        </span>
      </li>
    </ul>
  </Hero>

  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>

  <!-- Service Details -->
  <NoiseBg class="relative px-0 py-0">
    <Image
      src={sunflow}
      alt="Sun Flow"
      width={sunflow.width}
      height={sunflow.height}
      class="pointer-events-none absolute inset-x-0 top-0 left-0 opacity-10"
    />

    <div class="z-10 container py-8 lg:py-20">
      <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:items-stretch">
        <!-- Left contents -->
        <div class="space-y-8 py-8">
          <div class="flex-1 space-y-4">
            <Breadcrumb items={[{ label: 'Services', href: '/services' }, { label: 'Stone-Coated Steel' }]} />

            <h2 class="text-medium max-w-[530px] text-[clamp(28px,4vw,48px)] leading-[clamp(40px,4vw,52px)]">
              What is Stone-Coated Steel Roofing?
            </h2>

            <p class="text-sm lg:text-base">
              Stone-coated steel roofing gives you the look of shake, clay tile, or traditional shingles — with the
              strength of a steel core underneath. Each panel is built from a galvanized steel base, coated with a layer
              of natural stone granules bonded with an acrylic film. The result is a roof that handles Colorado's hail,
              UV intensity, and freeze-thaw cycles without granule loss, cracking, or warping. Installed over battens
              using Above-Sheathing Ventilation (ASV), hot air rises naturally and vents away from the roof deck —
              keeping your attic cooler in summer and reducing heat loss in winter. It looks nothing like industrial
              metal roofing. It looks like the best roof on the block.
            </p>
          </div>

          <div class="flex gap-4">
            <EstimateButton offerText="" actionText="**FREE** Estimate" class="px-8 py-4 text-base" />

            <Button variant="link" class="flex items-center gap-2">
              <svg width="13" height="16" viewBox="0 0 13 16" fill="none">
                <path
                  d="M12.361 8.2787L0.503906 14.868C0.367002 14.9454 0.249442 14.9543 0.151228 14.8948C0.0530134 14.8353 0.00390625 14.7281 0.00390625 14.5733V1.43049C0.00390625 1.27573 0.0530134 1.16858 0.151228 1.10906C0.249442 1.04954 0.367002 1.05846 0.503906 1.13585L12.361 7.72513C12.498 7.80251 12.5664 7.89477 12.5664 8.00192C12.5664 8.10906 12.498 8.20132 12.361 8.2787Z"
                  fill="white"></path>
              </svg>

              <span> Explore Styles & Colors </span>
            </Button>
          </div>
        </div>

        <!-- Right Contents -->

        <div class="h-[400px] w-full items-center overflow-hidden rounded-lg lg:self-center">
          <Image
            src="/placeholders/thumbnails/residential-1.png"
            alt="Residential Roofing"
            width={600}
            height={400}
            class="h-full w-full object-cover"
          />
        </div>
      </div>
    </div>
  </NoiseBg>

  <WhyStoneCoated
    badgeText="Why Stone-Coated Steel"
    title="Why Upgrade to Stone-Coated Steel?"
    description="<p>Most roofers can install asphalt shingles, but metal roofing needs special skills and precise work. It requires correct fastener placement, thermal expansion handling, proper underlayment, and careful panel checks. Poor installation can cause leaks and damage, but done right, a metal roof lasts a lifetime. As a Metal Roofing Alliance member and authorized Westlake Royal installer, we meet high standards and offer a lifetime workmanship warranty.</p> <p> We act as licensed general contractors, inspecting your roof’s structure, pitch, decking, ventilation, and drainage before recommending a system. A metal roof over damaged decking or poor ventilation won’t perform well. We handle everything: tear-off, deck repair, installation, and final inspection. Plus, financing options start at $99/month through Service Finance Company and Wisetack. </p>"
    image="/placeholders/thumbnails/residential-2.png"
    buttonText="Get FREE Metal Roofing Estimate"
    imagePosition="left"
  />

  <Statistics />
  <PopularRoofingMaterials
    badge="Why Stone-Coated Steel"
    title="Extreme Weather Protection for Colorado Homes"
    description="Colorado doesn't have one type of severe weather — it has all of them. Hail season runs April through September. Wind events regularly push past 60 mph on the Front Range. Wildfires are a growing concern across the state, and UV exposure at altitude degrades ordinary roofing materials faster than anywhere at sea level. Unified Steel™ stone-coated panels are engineered to handle all of it — tested and warranted, not just rated."
    materials={materials}
    source={{ label: 'Source: Westlake Royal Building Products — Unified Steel™', href: '#' }}
  />

  <!-- Comparison Section -->

  <section class="relative overflow-hidden py-16 lg:py-24">
    <!-- Dynamic Background Layers -->
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-[#0A0A0A]"></div>
      <Image src={heroBg} alt="" class="absolute inset-0 h-full w-full object-cover opacity-5" loading="lazy" />
      <Image
        src={heroGradient}
        alt=""
        class="absolute inset-0 h-full w-full object-cover opacity-20 lg:opacity-30"
        loading="lazy"
      />
    </div>

    <div class="container space-y-6">
      <!-- Temperature Differences Hero -->
      <div class="relative flex flex-col items-center justify-center pt-10 lg:min-h-[600px] lg:pt-20">
        <div class="w-full max-w-[1440px]">
          <Image
            src={comparisonHero}
            width={comparisonHero.width}
            height={comparisonHero.height}
            alt="Temperature comparison between concrete tile and asphalt shingle roof"
            class="w-full rounded-3xl object-cover"
          />
        </div>

        <div class="relative z-10 flex flex-col items-center justify-center px-4 pt-10 text-center uppercase">
          <div
            class="bg-linear-to-b from-white via-[#d9d9d9] to-white/10 bg-clip-text text-[clamp(1.5rem,6vw,3rem)] leading-none font-extrabold tracking-tighter text-transparent"
          >
            <span class="block uppercase lg:inline">Stone Coated</span>
            <span class="text-[clamp(3rem,6vw,5rem)]">vs</span>
            <span class="block uppercase lg:inline">Asphalt Shingle</span>
          </div>
          <div
            class="mt-2 bg-linear-to-b from-white via-[#d9d9d9] to-[#1a1a1a] bg-clip-text text-[clamp(1.8rem,8vw,68px)] font-bold tracking-tight text-transparent lg:mt-4"
            style="text-shadow: 0px 4px 24px rgba(0,0,0,0.8), 0px -8px 100px black;"
          >
            Temperature Differences
          </div>
        </div>
      </div>

      <!-- Core Messaging Section -->
      <div class="flex flex-col items-center gap-6">
        <div class="lg:col-span-5">
          <h2 class="font-heading text-3xl leading-[1.1] tracking-tight lg:text-5xl">Engineered for Colorado Hail</h2>
        </div>
        <div class="border-primary/30 border-l-2 py-2 pl-6 lg:col-span-7 lg:pl-10">
          <div class="text-neutral-lighter space-y-3 text-base leading-relaxed font-normal lg:text-xl">
            <p>
              Colorado leads the nation in hail claims. Normal shingles can crack or puncture under heavy hail — but
              stone-coated steel performs like armor. All Unified Steel™ panels carry Class 4 impact resistance (the
              highest rating for hail resistance) and are tested against 2½" hailstones and 120 mph winds.
            </p>
            <p>*Attic Heat Transfer test data from Westlake Royal Building Products.</p>
          </div>
        </div>

        <div class="flex w-full items-center gap-2 text-xs">
          <Icon name="circle-info" class="text-primary" />
          <span class="text-neutral-lighter">
            Source:
            <a href="#" class="hover:text-primary text-white underline"> Westlake Royal Building Products. </a>
          </span>
        </div>
      </div>

      <!-- ROI Analysis Section -->
      <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-20">
        <div class="text-neutral-lighter order-2 space-y-6 lg:order-1">
          <div class="space-y-1">
            <p>Why It Matters:</p>
            <ul class="list-disc pl-5">
              <li>A Class 4 roof greatly reduces the risk of premature storm damage replacement</li>
              <li>Many Colorado homeowners qualify for insurance premium discounts with Class 4 materials</li>
              <li>You replace the roof once — not every few years after storm season</li>
            </ul>
          </div>

          <div class="space-y-1">
            <p>That means:</p>
            <ul class="list-disc pl-5">
              <li>Reduced risk of premature replacement</li>
              <li>Potential insurance premium benefits (varies by carrier)</li>
              <li>Peace of mind during severe weather season</li>
            </ul>
          </div>

          <p class="leading-relaxed">
            If you've replaced shingles multiple times due to hail, upgrading once may significantly reduce long-term
            storm-related costs.
          </p>

          <div class="flex w-full items-center gap-2 text-xs">
            <Icon name="circle-info" class="text-primary" />
            <span class="text-neutral-lighter">
              Source:
              <a href="#" class="hover:text-primary text-white underline">
                Westlake Royal — Unified Steel™, Class 4 impact-rated panels.</a
              >
            </span>
          </div>
        </div>

        <div
          class="relative order-1 h-[360px] overflow-hidden rounded-3xl border border-white/10 shadow-2xl lg:order-2"
        >
          <Image
            src="/placeholders/thumbnails/stone-coated-1.png"
            width={1207}
            height={843}
            alt="Visual ROI Illustration"
            class="absolute inset-0 top-0 left-0 h-full w-full object-cover"
          />
        </div>
      </div>

      <!-- Components Showcase -->
      <div class="space-y-8 pt-10 lg:pt-20">
        <BadgeTitle
          badge="How it Work"
          title="We Use 5 Components to Provide Energy Efficiency and Give Substantial Return on Your Investment"
          class="mx-auto flex max-w-4xl flex-col items-center text-center"
        />

        <div
          class="grid grid-cols-[repeat(auto-fit,minmax(200px,1fr))] justify-center gap-6 lg:flex lg:flex-wrap lg:items-center lg:justify-center"
        >
          {
            components.map(comp => (
              <div class="group relative w-full max-w-[400px] space-y-3 text-center">
                <div class="relative aspect-5/3 overflow-hidden rounded-2xl border border-white/5 bg-neutral-900 shadow-xl">
                  <Image
                    src={comp.img}
                    alt={comp.label}
                    width={800}
                    height={400}
                    class="h-full w-full object-cover transition-all duration-700 group-hover:scale-110 group-hover:brightness-110"
                  />
                </div>
                <p class="text-neutral-lighter group-hover:text-primary px-2 text-sm font-semibold tracking-wide transition-colors duration-300">
                  {comp.label}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <ComparisonTable />
  <StylesProfiles />

  <RecentProjects />
  <Faqs />
  <ServiceAreas />

  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>
  <CTASection />
  <Footer />
</Layout>
