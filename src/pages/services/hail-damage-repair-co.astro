---
import Layout from '@/layouts/Layout.astro';
import Brands from '@/components/Brands.astro';
import CTASection from '@/components/cta/CTASection.astro';
import { stormCTA } from '@/data/cta';
import Testimonials from '@/components/Testimonials.astro';
import Faqs from '@/components/faqs/Faqs.astro';
import { hailDamageFaqs } from '@/data/faqs/hail-damage';
import NoiseBg from '@/components/NoiseBg.astro';
import WhyChooseUs from '@/components/WhyChooseUs.astro';
import Button from '@/components/ui/Button.astro';
import EstimateButton from '@/components/EstimateButton.astro';
import { Icon } from 'astro-icon/components';
import { type Service } from '@/data/services';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import Hero from '@/components/hero/Hero.astro';
import RatingStars from '@/components/ui/RatingStars.astro';
import QuoteForm from '@/components/cta/QuoteForm.astro';
import { Image } from 'astro:assets';
import heroImage from '@/assets/bg/hail-damage-repair-section__hero.avif';
import Process from '@/components/process/Process.astro';
import step1 from '@/assets/steps/step-1.png';
import step2 from '@/assets/steps/step-2.png';
import step3 from '@/assets/steps/step-3.png';
import step4 from '@/assets/steps/step-4.png';
import RecentProjects from '@/components/recent-projects/RecentProjects.astro';
import RecentArticales from '@/components/articales/RecentArticales.astro';
import ServiceAreas from '@/components/service-area/ServiceAreas.astro';
import StylesProfiles from '@/components/services/StylesProfiles.astro';
import OtherServicesCarousel from '@/components/services/OtherServicesCarousel.astro';
import PopularRoofingMaterials from '@/components/services/PopularRoofingMaterials.astro';
import ComparisonTable from '@/components/services/ComparisonTable.astro';
import SocialProof from '@/components/ui/SocialProof.astro';
import Statistics from '@/components/ui/Statistics.astro';
import sunflow from '@/assets/sunflow.avif';

const processSteps = [
  {
    image: step1,
    step: 'Step 1',
    title: 'Contact Our Team',
    description: 'Get in touch with us by phone or fill out a form! Our customer service team is on standby.',
  },
  {
    image: step2,
    step: 'Step 2',
    title: 'Schedule Inspection',
    description: 'We will schedule a convenient time to inspect your roof and assess the project scope.',
  },
  {
    image: step3,
    step: 'Step 3',
    title: 'Review Your Proposal',
    description: 'Receive a detailed proposal outlining the work, timeline, and transparent pricing.',
  },
  {
    image: step4,
    step: 'Step 4',
    title: 'Project Completion',
    description: 'Our expert team completes the project to the highest standards with a final walkthrough.',
  },
];
---

<Layout
  title="Hail Damage Roof Repair in Colorado | Black Knight Roofing"
  description="Hail damage roof repair in Colorado with detailed inspections, claim-ready documentation, and repair or replacement recommendations built around long-term storm protection."
>

  <Hero
    backgroundImage={heroImage}
    title="Your Roof Took a Hit. Here's What To Do Next."
    subtitle="Hail Damage Repair Services in Colorado"
  >
    <p class="text-sm">
      Colorado gets more hail days per year than almost any state in the country — and the Front Range sits squarely in
      what's known as "hail alley." The problem isn't just what you can see from the ground. A storm that leaves no
      missing shingles can still bruise the granule layer, crack seal strips, compromise flashing, and quietly shorten
      your roof's lifespan by years. By the time a leak shows up, the damage has been spreading for months. At Black
      Knight Roofing, we specialize in hail damage inspection, documentation, and repair for Colorado homes. We know
      exactly what adjusters look for — and exactly what they miss. Call us before you call your insurance company.
    </p>
  </Hero>

  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>

  <!-- Service Details -->
  <NoiseBg class="relative px-0 py-0">
    <Image
      {...sunflow}
      alt=""
      class="pointer-events-none absolute inset-0 top-0 left-0 w-full opacity-10"
    />

    <div class="container py-8 lg:py-20">
      <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:items-stretch">
        <!-- Left contents -->
        <div class="space-y-8 py-8">
          <div class="flex-1 space-y-4">
            <Breadcrumb items={[{ label: 'Services', href: '/services' }, { label: 'Hail Damage Repair' }]} />

            <h2 class="text-medium max-w-[530px] text-[clamp(28px,4vw,48px)] leading-[clamp(40px,4vw,52px)]">
              You Don't Have To Navigate the Insurance Process On Your Own! Hail Damage Is Often Invisible — Until It
              Isn't
            </h2>

            <p class="text-neutral-lighter text-sm font-normal lg:text-base">
              After a hailstorm, most Colorado homeowners walk outside, look up, see the shingles are still there, and
              assume everything is fine. It's not always that simple. Hail damage to asphalt shingles shows up as soft
              spots and circular bruising — areas where the impact has fractured the granule layer beneath the surface.
              That granule loss exposes the underlying mat to UV radiation and moisture. It doesn't fail immediately. It
              fails over the next two to five years, quietly, until a heavy snow or hard rain turns a weakened spot into
              an active leak. We inspect your roof the way it needs to be inspected — up close, methodically, section by
              section. As a licensed general contractor, we look at the full picture: shingles, ridge caps, flashing,
              gutters, siding, and windows. We document every impact point with photos and written reports, and we give
              you a straight answer about what needs to be done.
            </p>
          </div>

          <Button class="px-8 py-4 text-base" data-estimate-trigger> FREE Storm Damage Inspection </Button>
        </div>

        <!-- Right Contents -->

        <div class="w-full items-center overflow-hidden rounded-lg lg:h-[580px] lg:self-center">
          <Image
            src="/placeholders/thumbnails/roof-replacement-1.avif"
            alt="Hail-damaged roof being evaluated for repair in Colorado"
            width={442}
            height={785}
            class="h-full w-full rounded-lg object-cover"
          />
        </div>
      </div>
    </div>
  </NoiseBg>

  <Statistics />
  <Testimonials />

  <WhyChooseUs
    badgeText="Why Choose Us"
    title="We Inspect Hail Damage the Way Your Insurance Adjuster Will — and Then Some"
    description="<p>Insurance adjusters often miss subtle roof damage like tiny shingle cracks, loose seals, or scattered granule loss. In Colorado's harsh climate, these small issues can quickly lead to big problems. A roof that looks fine now might fail after a couple of winters. We inspect carefully, spotting damage adjusters might overlook, and provide detailed reports to support your claim.</p> <p>As a licensed general contractor, Adam inspects your home the way a builder would — not just the shingles, but the full system. Gutters bent and clogged from impact. Flashing lifted at the ridge. Siding dented and cracked. Window seals compromised. We document all of it, back it with our lifetime workmanship warranty, and install using Tamko Pro Certified materials and processes so your replacement stands up to the next storm too.</p>"
    image="/placeholders/thumbnails/residential-2.png"
    buttonText="FREE Hail Damage Inspection"
    imagePosition="left"
  />

  <div class="via-primary container h-px bg-linear-to-r from-transparent to-transparent lg:hidden"></div>

  <Process steps={processSteps} />
  <ServiceAreas />
  <Faqs faqs={hailDamageFaqs} />
  <RecentArticales />

  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>
  <CTASection cta={stormCTA} />
</Layout>
