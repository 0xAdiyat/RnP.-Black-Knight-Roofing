---
import Layout from '@/layouts/Layout.astro';
import Brands from '@/components/Brands.astro';
import CTASection from '@/components/cta/CTASection.astro';
import { residentialCTA } from '@/data/cta';
import Testimonials from '@/components/Testimonials.astro';
import Faqs from '@/components/faqs/Faqs.astro';
import { residentialFaqs } from '@/data/faqs/residential-roofing';
import NoiseBg from '@/components/NoiseBg.astro';
import WhyChooseUs from '@/components/WhyChooseUs.astro';
import EstimateButton from '@/components/EstimateButton.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import Hero from '@/components/hero/Hero.astro';
import { Image } from 'astro:assets';
import heroImage from '@/assets/bg/residential-roofing-section__hero.avif';
import edcoImg from '@/assets/generated/steel-seamless-panels.png';
import metalImg from '@/assets/generated/standing-seam-metal.png';
import tileImg from '@/assets/generated/concrete-villa.png';
import stoneCoatedImg from '@/assets/generated/stone-coated-steel-main.png';
import flatRoofImg from '@/assets/bg/commercial-roofing-section__hero.avif';
import profileImg from '@/assets/hero-person.avif';
import Process from '@/components/process/Process.astro';
import step1 from '@/assets/steps/step-1.png';
import step2 from '@/assets/steps/step-2.png';
import step3 from '@/assets/steps/step-3.png';
import step4 from '@/assets/steps/step-4.png';
import RecentProjects from '@/components/recent-projects/RecentProjects.astro';
import RecentArticales from '@/components/articales/RecentArticales.astro';
import ServiceAreas from '@/components/service-area/ServiceAreas.astro';
import OtherServicesCarousel from '@/components/services/OtherServicesCarousel.astro';
import PopularRoofingMaterials from '@/components/services/PopularRoofingMaterials.astro';
import Statistics from '@/components/ui/Statistics.astro';

const roofingMaterialsCategories = [
  {
    id: 'shingles',
    label: 'Architectural Shingles',
    items: [
      {
        title: 'Architectural Shingles',
        description:
          'A reliable, budget-friendly choice with layered dimension, broad color options, and dependable everyday performance for Colorado homes.',
        image: heroImage,
      },
    ],
  },
  {
    id: 'edco-steel',
    label: 'EDCO Steel',
    items: [
      {
        title: 'EDCO Steel',
        description:
          'Built for long-term durability with a clean architectural finish, strong weather resistance, and lower maintenance over time.',
        image: edcoImg,
      },
    ],
  },
  {
    id: 'metal',
    label: 'Metal Roofing',
    items: [
      {
        title: 'Metal Roofing',
        description:
          'Lightweight, durable, and energy-efficient—ideal for homeowners who want modern performance with a long service life.',
        image: metalImg,
      },
    ],
  },
  {
    id: 'concrete-tile',
    label: 'Concrete Roof Tile',
    items: [
      {
        title: 'Concrete Roof Tile',
        description:
          'We install Newpoint™ concrete tile by Westlake Royal Building Products, featuring a transferable lifetime warranty, Class A fire rating, and a Cool Roof System that cuts attic heat by up to 45°F. Comes in 6 profiles and various colors, lasting 50–100 years with proper care.',
        image: tileImg,
      },
    ],
  },
  {
    id: 'stone-coated-steel',
    label: 'Stone-Coated Steel',
    items: [
      {
        title: 'Stone-Coated Steel',
        description:
          'We install Unified Steel™ by Westlake Royal Building Products, a stone-coated steel roofing with Class 4 impact protection, 120 MPH wind resistance, and a 50-Year transferable warranty. Available in five profiles mimicking shake, shingle, and tile without the weight or upkeep of natural materials.',
        image: stoneCoatedImg,
      },
    ],
  },
  {
    id: 'flat-roofing',
    label: 'EPDM & Flat Roofing',
    items: [
      {
        title: 'EPDM & Flat Roofing',
        description:
          'A practical flat-roof solution with strong waterproofing, low upkeep, and dependable protection for residential and commercial structures.',
        image: flatRoofImg,
      },
    ],
  },
];

const processSteps = [
  {
    image: step1,
    step: 'Step 1',
    title: 'Contact Our Team',
    description: 'Get in touch with us by phone or fill out a form! Our customer service team is on standby.',
  },
  {
    image: step2,
    step: 'Step 2',
    title: 'Schedule Inspection',
    description: 'We will schedule a convenient time to inspect your roof and assess the project scope.',
  },
  {
    image: step3,
    step: 'Step 3',
    title: 'Review Your Proposal',
    description: 'Receive a detailed proposal outlining the work, timeline, and transparent pricing.',
  },
  {
    image: step4,
    step: 'Step 4',
    title: 'Project Completion',
    description: 'Our expert team completes the project to the highest standards with a final walkthrough.',
  },
];
---

<Layout>

  <Hero backgroundImage={heroImage} title="Residential Roofing in Denver, CO" subtitle="Residential Roofing Services">
    <p class="text-sm">
      From roof repairs and full replacements to premium upgrades, Black Knight Roofing helps Colorado homeowners choose
      the right residential roofing system for protection, curb appeal, and long-term value. We install asphalt
      shingles, metal roofing, flat roofing, tile, stone-coated steel, and concrete tile systems from Colorado Springs
      to Fort Collins.
    </p>
  </Hero>

  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>

  <!-- Service Details -->
  <NoiseBg class="px-0 py-0">
    <div class="container py-8 lg:py-20">
      <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:items-stretch">
        <!-- Left contents -->
        <div class="space-y-8 py-8">
          <div class="flex-1 space-y-4">
            <Breadcrumb items={[{ label: 'Services', href: '/services' }, { label: 'Residential Roofing' }]} />

            <h2 class="text-medium max-w-[530px] text-[clamp(28px,4vw,48px)] leading-[clamp(40px,4vw,52px)]">
              Repairs vs. Replacement: Which Is Right For You?
            </h2>

            <p class="text-neutral-lighter text-sm font-normal lg:text-base">
              When you're dealing with a roofing issue, it can feel overwhelming, especially when you do not know what
              to expect. We help you understand the difference between repairs and replacements, and when each one makes
              the most sense. In many cases, you might be surprised by what can be repaired, which can save you time and
              money. And when it is time for a new roofing system, we are here to guide you toward the right product and
              install it with care.
            </p>
          </div>

          <EstimateButton class="px-8 py-4 text-base" offerText="" actionText="**FREE** Roof Estimate" />
        </div>

        <!-- Right Contents -->

        <div class="h-[400px] w-full items-center overflow-hidden rounded-lg lg:self-center">
          <Image
            src="/placeholders/thumbnails/residential-1.png"
            alt="Residential Roofing"
            width={600}
            height={400}
            class="h-full w-full object-cover"
          />
        </div>
      </div>
    </div>
  </NoiseBg>

  <Statistics />
  <Testimonials />

  <WhyChooseUs
    badgeText="Why Choose Us"
    title="A Roof You'll Love Coming Home To"
    description="Your roof should do more than keep water out. It should fit the look of your home, hold up to Colorado weather, and add lasting value without hidden fees or corner-cutting. Black Knight Roofing brings builder-level oversight, straightforward pricing, and residential roofing guidance that helps you feel good about the result long after the crew leaves."
    image="/placeholders/thumbnails/residential-2.png"
    buttonText="FREE Roof Estimate"
    imagePosition="left"
  />

  <div class="via-primary container h-px bg-linear-to-r from-transparent to-transparent lg:hidden"></div>

  <Process steps={processSteps} />
  <OtherServicesCarousel />
  <PopularRoofingMaterials
    categories={roofingMaterialsCategories}
    description="Colorado's climate is harder on roofs than most homeowners realize. High-altitude UV exposure, freeze-thaw cycles, hail season from April through September, and wind that shifts direction without warning — every material handles these differently. The right choice isn't always the cheapest one upfront, and it's not always the most expensive either. We'll give you a straight comparison based on your home, your neighborhood, and how long you want to own it."
    quote="“Most homeowners think price is the only difference between materials. It's not. The real difference is what you're dealing with ten years from now.”"
    quoteAuthor="Adam Knight"
    quoteRole="President"
    quoteImage={profileImg}
  />
  <RecentProjects />
  <ServiceAreas />
  <Faqs faqs={residentialFaqs} />
  <RecentArticales />

  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>
  <CTASection cta={residentialCTA} />
</Layout>
