---
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/Navbar.astro';
import Brands from '@/components/Brands.astro';
import CTASection from '@/components/cta/CTASection.astro';
import Footer from '@/components/Footer.astro';
import Testimonials from '@/components/Testimonials.astro';
import Faqs from '@/components/faqs/Faqs.astro';
import NoiseBg from '@/components/NoiseBg.astro';
import BadgeTitle from '@/components/BadgeTitle.astro';
import ServiceCard from '@/components/services/ServiceCard.astro';
import WhyChooseUs from '@/components/WhyChooseUs.astro';
import Button from '@/components/ui/Button.astro';
import EstimateButton from '@/components/EstimateButton.astro';
import { Icon } from 'astro-icon/components';
import { services, type Service } from '@/data/services';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import Hero from '@/components/hero/Hero.astro';
import RatingStars from '@/components/ui/RatingStars.astro';
import QuoteForm from '@/components/cta/QuoteForm.astro';
import { Image } from 'astro:assets';
import Process from '@/components/process/Process.astro';
import step1 from '@/assets/steps/step-1.png';
import step2 from '@/assets/steps/step-2.png';
import step3 from '@/assets/steps/step-3.png';
import step4 from '@/assets/steps/step-4.png';
import RecentProjects from '@/components/recent-projects/RecentProjects.astro';
import RecentArticales from '@/components/articales/RecentArticales.astro';
import ServiceAreas from '@/components/service-area/ServiceAreas.astro';
import StylesProfiles from '@/components/services/StylesProfiles.astro';
import sunflow from '@/assets/sunflow.avif';
import PopularRoofingMaterials from '@/components/services/PopularRoofingMaterials.astro';
import heroBg from '@/assets/tiles/hero-bg.png';
import heroGradient from '@/assets/tiles/hero-gradient.png';
import comparisonHero from '@/assets/tiles/comparison-hero.png';
import roiIllustration from '@/assets/tiles/roi-illustration.png';
import component1 from '@/assets/tiles/component-1.png';
import component2 from '@/assets/tiles/component-2.png';
import component3 from '@/assets/tiles/component-3.png';
import component4 from '@/assets/tiles/component-4.png';
import component5 from '@/assets/tiles/component-5.png';
import roofMini from '@/assets/comparison/roof-mini.png';
import lifespanIcon from '@/assets/comparison/lifespan-icon.svg';
import checkIcon from '@/assets/comparison/check-icon.svg';
import hailIcon from '@/assets/comparison/hail-icon.svg';
import tempIcon from '@/assets/comparison/temp-icon.svg';
import energyIcon from '@/assets/comparison/energy-icon.svg';
import aestheticIcon from '@/assets/comparison/aesthetic-icon.svg';
import illustrationTop from '@/assets/comparison/illustration-top.svg';
import bgEllipse from '@/assets/comparison/bg-ellipse.svg';
import shieldIcon1 from '@/assets/comparison/shield-icon-1.svg';
import shieldIcon2 from '@/assets/comparison/shield-icon-2.svg';
import comparisonBg from '@/assets/comparison/background.png';
import SocialProof from '@/components/ui/SocialProof.astro';
import Statistics from '@/components/ui/Statistics.astro';


const roofingMaterials = [
  {
    id: 'shingles',
    label: 'Architectural Shingles',
    description:
      'A reliable, budget-friendly choice with layered dimension, broad color options, and dependable everyday performance for Colorado homes.',
    image: '/placeholders/popular-materials/1.png',
  },
  {
    id: 'steel',
    label: 'Stone Coated Steel',
    description:
      'The ultimate protection against Colorado hail. Lightweight, non-combustible, and designed to last a lifetime with the look of traditional tile or wood shake.',
    image: '/placeholders/popular-materials/2.png',
  },
  {
    id: 'tile',
    label: 'Concrete Tile',
    description:
      'Superior thermal performance and exceptional durability. Concrete tile offers high fire resistance and a distinct aesthetic for premium Colorado residences.',
    image: '/placeholders/popular-materials/3.png',
  },
];

const processSteps = [
  {
    image: step1,
    step: 'Step 1',
    title: 'Contact Our Team',
    description: 'Get in touch with us by phone or fill out a form! Our customer service team is on standby.',
  },
  {
    image: step2,
    step: 'Step 2',
    title: 'Schedule Inspection',
    description: 'We will schedule a convenient time to inspect your roof and assess the project scope.',
  },
  {
    image: step3,
    step: 'Step 3',
    title: 'Review Your Proposal',
    description: 'Receive a detailed proposal outlining the work, timeline, and transparent pricing.',
  },
  {
    image: step4,
    step: 'Step 4',
    title: 'Project Completion',
    description: 'Our expert team completes the project to the highest standards with a final walkthrough.',
  },
];

export async function getStaticPaths() {
  return services.map(service => ({
    params: { serviceId: service.slug },
    props: { service },
  }));
}

interface Props {
  service: Service;
}

const { service } = Astro.props;

// Get other services for the "Other Services" section (exclude current)
const otherServices = services.filter(s => s.slug !== service.slug).slice(0, 3);
---

<Layout>
  <Navbar />

  <Hero
    title="Roofing Services Built for Colorado Homes and Colorado Weather"
    subtitle="Colorado's #1 Veteran-Owned Roofing Company"
  >
    <p class="text-sm">
      Need a repair, a storm-damage game plan, or a premium roof upgrade that changes the look of your home? Black
      Knight Roofing helps homeowners and property owners from Colorado Springs to Fort Collins with roof replacement,
      storm restoration, gutters, siding, windows, and premium roofing systems like stone-coated steel and concrete
      tile.
    </p>

    <div class="flex flex-col items-center gap-4 sm:flex-row sm:gap-x-6">
      <EstimateButton />

      <Button variant="link">
        <Icon name="map" />
        See Our Past Work
      </Button>
    </div>

    <Fragment slot="social-proof">
      <SocialProof />
    </Fragment>

    <QuoteForm slot="sidebar" />
  </Hero>

  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>

  <!-- Service Details -->
  <NoiseBg class="px-0 py-0">
    <div class="container py-8 lg:py-20">
      <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2">
        <!-- Left contents -->
        <div class="space-y-8 py-8">
          <div class="flex-1 space-y-4">
            <Breadcrumb items={[{ label: 'Services', href: '/services' }, { label: service.title }]} />

            <h2 class="text-medium max-w-[530px] text-[clamp(28px,4vw,48px)] leading-[clamp(40px,4vw,52px)]">
              Repairs vs. Replacement: Which Is Right For You?
            </h2>

            <p class="text-sm lg:text-base">
              When you're dealing with a roofing issue, it can feel overwhelming, especially when you do not know what
              to expect. We help you understand the difference between repairs and replacements, and when each one makes
              the most sense. In many cases, you might be surprised by what can be repaired, which can save you time and
              money. And when it is time for a new roofing system, we are here to guide you toward the right product and
              install it with care.
            </p>
          </div>

          <Button>
            <span> <strong> FREE </strong> Roof Estimate </span>
          </Button>
        </div>

        <!-- Right Contents -->

        <div class="">
          <Image src={service.image} alt={service.title} width={600} height={400} class="rounded-lg object-cover" />
        </div>
      </div>
    </div>
  </NoiseBg>

  <Statistics />
  <Testimonials />

  <WhyChooseUs
    badgeText="Expert Quality & Care"
    title={service.title}
    description={service.description}
    image={service.image}
    buttonText="FREE Roof Estimate"
    imagePosition="left"
  />

  <Process steps={processSteps} />

  <NoiseBg class="relative px-0 py-0">
    <div class="z-10 container space-y-4 py-10 lg:py-20">
      <div class="py-4 text-center">
        <BadgeTitle as="h2" title="Roofing Services In Colorado" />
      </div>

      <div class="grid grid-cols-[repeat(auto-fit,minmax(250px,1fr))] gap-4">
        {
          services
            .slice(0, 3)
            .map(s => (
              <ServiceCard
                image={s.image}
                title={s.title}
                description={s.description}
                icon={s.icon}
                tags={s.tags}
                href={`/services/${s.slug}`}
              />
            ))
        }
      </div>
    </div>

    <Image
      src={sunflow}
      alt="Background Noise"
      width={1520}
      height={900}
      loading="eager"
      sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw"
      class="pointer-events-none absolute bottom-0 rotate-180 opacity-10"
    />
  </NoiseBg>

  <PopularRoofingMaterials materials={roofingMaterials} />

  <!-- Tile Comparison Section -->
  <section class="relative overflow-hidden py-20">
    <!-- Background Layers -->
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-[#111]"></div>
      <Image src={heroBg} alt="" class="absolute inset-0 h-full w-full object-cover opacity-5" />
      <Image src={heroGradient} alt="" class="absolute inset-0 h-full w-full object-cover opacity-20" />
    </div>

    <div class="container space-y-12">
      <!-- Temperature Differences Hero -->
      <div class="relative min-h-[500px] w-full items-center justify-center pt-20">
        <div class="w-full max-w-[1440px]">
          <Image src={comparisonHero} alt="Temperature comparison" class="w-full object-cover" />
        </div>

        <div class="relative z-10 flex flex-col items-center justify-center text-center uppercase">
          <div
            class="bg-linear-to-b from-white via-[#d9d9d9] to-white/10 bg-clip-text text-[clamp(2rem,5vw,5rem)] font-bold tracking-tighter text-transparent"
          >
            <span class="block text-[0.6em] md:inline">Concrete Tile</span> vs <span
              class="block text-[0.6em] md:inline">Asphalt Shingle</span
            >
          </div>
          <div
            class="bg-linear-to-b from-white via-[#d9d9d9] to-[#1a1a1a] bg-clip-text text-[clamp(2.5rem,7vw,64px)] font-bold text-transparent"
            style="text-shadow: 0px 2px 16px rgba(0,0,0,0.5), 0px -4px 64px rgba(0,0,0,0.75), 0px -8px 80px black;"
          >
            Temperature Differences
          </div>
        </div>
      </div>

      <!-- Description Section -->
      <div class="space-y-6">
        <h2 class="text-center text-4xl leading-tight lg:text-5xl">
          Designed for Colorado Architecture. Built from the Right Material.
        </h2>
        <div class="mx-auto max-w-7xl border-l border-white/20 pl-8">
          <p class="text-neutral-light text-lg leading-relaxed">
            Colorado homes are exposed to extremes — high-altitude UV radiation, rapid temperature swings, freeze-thaw
            cycles, heavy hailstorms, and elevated wildfire risk — which means the roofing material must do far more
            than simply look good; it must endure. Concrete tile delivers structural integrity and architectural
            permanence in a way lightweight roofing systems cannot. Unlike traditional shingles that rely primarily on
            surface granules for protection, concrete tile is solid through its entire thickness, and its density and
            composition provide natural resistance to impact, heat, and fire, making it a practical and resilient choice
            for Colorado’s demanding climate.
          </p>
        </div>
      </div>

      <!-- ROI Section -->
      <div class="grid items-center gap-12 py-12 lg:grid-cols-2">
        <div class="space-y-8">
          <BadgeTitle badge="The ROI" title="Keeping Temperatures Cool and ROI High" />
          <p class="text-neutral-light">
            The energy-saving Westlake Royal™ Cool Roof System and Cool Roof Color options provide a comfortable living
            climate, savings on energy costs and can last longer than traditional roof construction.
          </p>
          <Button variant="primary" size="lg" class="text-sm">Learn More</Button>
        </div>
        <div class="relative overflow-hidden rounded-2xl">
          <Image src={roiIllustration} alt="ROI Illustration" class="w-full" />
        </div>
      </div>

      <!-- How it Works Section -->
      <div class="space-y-10 pt-20">
        <div class="flex flex-col items-center gap-y-4 text-center">
          <BadgeTitle badge="How it Works" class="flex flex-col items-center" />
          <h2 class="mx-auto max-w-4xl text-4xl lg:text-5xl">
            We Use 5 Components to Provide Energy Efficiency and Give Substantial Return on Your Investment
          </h2>
        </div>

        <div class="flex flex-wrap justify-center gap-6">
          {
            [
              { img: component1, label: 'Newpoint™ Concrete Roof Tile' },
              { img: component2, label: 'Westlake Royal TileSeal™ Underlayment' },
              { img: component3, label: 'Vented Eave Riser' },
              { img: component4, label: 'Elevated Batten System®' },
              { img: component5, label: 'Vented Ridge' },
            ].map(comp => (
              <div class="group w-full max-w-[380px] space-y-4 text-center">
                <div class="overflow-hidden rounded-lg">
                  <Image
                    src={comp.img}
                    alt={comp.label}
                    class="aspect-376/206 w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                </div>
                <p class="text-neutral-lighter text-sm font-medium">{comp.label}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Comparison table between concrete tile and asphalt shingle -->
  <section class="relative container overflow-hidden py-20">
    <Image
      src={illustrationTop}
      alt=""
      class="pointer-events-none absolute -top-[150px] left-1/2 z-0 w-full max-w-[800px] -translate-x-1/2 opacity-40"
    />

    <div class="from-primary to-primary/0 relative rounded-[48px] bg-linear-to-b p-[2px]">
      <NoiseBg class="relative overflow-hidden rounded-[48px] bg-[#171717] px-12 py-16">
        <div>
          <Image src={sunflow} alt="" class="pointer-events-none absolute inset-x-0 top-0 z-0 w-full opacity-20" />
          <Image src={comparisonBg} alt="" class="pointer-events-none absolute inset-x-0 top-0 z-0 w-full opacity-10" />
          <div class="absolute inset-0 top-0 left-0 h-full w-full bg-linear-to-b from-transparent from-70% to-black">
          </div>

          <!-- Heading & Icons -->
          <div class="relative z-10 mb-16 flex flex-col items-center gap-8 text-center">
            <div class="flex flex-col items-center gap-4">
              <div class="flex items-center gap-x-3">
                <div
                  class="relative size-5 rounded-[5px] bg-[#F7B715]/50 drop-shadow-2xl before:absolute before:top-1/2 before:left-1/2 before:size-2 before:-translate-1/2 before:rounded-full before:bg-[#F7D515] before:content-['']"
                >
                </div>
                <div class="text-sm font-medium tracking-wider text-white uppercase">Comparison</div>
              </div>

              <div class="relative mt-2 flex items-center justify-center gap-4 lg:gap-16">
                <Image
                  src={roofMini}
                  alt=""
                  class="hidden w-24 brightness-75 transition-all group-hover:brightness-100 lg:block"
                />
                <h2 class="font-heading text-4xl leading-tight text-white lg:text-6xl">
                  Stone-Coated Steel vs <br /> Asphalt Shingles
                </h2>
                <Image src={roofMini} alt="" class="hidden w-24 brightness-75 lg:block" />
                <!-- Floating Ellipse decoration -->
                <Image src={bgEllipse} alt="" class="pointer-events-none absolute -top-10 -right-20 w-48 opacity-40" />
              </div>
            </div>
          </div>

          <!-- Table -->
          <div class="relative z-10">
            <div>
              <table class="w-full border-separate border-spacing-0">
                <thead>
                  <tr>
                    <th class="border-b border-[#594216] px-6 py-6 text-left text-xl font-medium text-white">Feature</th
                    >
                    <th class="border-b border-[#594216] px-6 py-6 text-left text-xl font-medium text-white"
                      >Asphalt Shingles</th
                    >
                    <th class="relative p-0 text-left">
                      <div
                        class="from-primary absolute inset-0 -top-4 z-0 rounded-t-3xl bg-radial-[at_40%_20%] via-[#594216] to-[#594216] px-px pt-px"
                      >
                        <div class="h-full w-full rounded-t-3xl bg-[#111]"></div>
                      </div>

                      <div
                        class="text-primary relative z-10 border-b border-[#59421650] px-6 py-6 text-left text-xl font-medium"
                      >
                        Stone-Coated Steel
                      </div>
                    </th>
                  </tr>
                </thead>

                <tbody class="text-neutral-lighter">
                  {
                    [
                      { label: 'Lifespan', icon: 'battery', asphalt: '20–30 years', tile: '50-100 years' },
                      { label: 'Hail Rating', icon: 'hail', asphalt: 'Varies', tile: 'Class A' },
                      { label: 'Wind Warranty', icon: 'wind', asphalt: 'Typically lower', tile: '120 mph' },
                      { label: 'Attic Heat (Tested)', icon: 'heat-meter', asphalt: '139°', tile: '94°' },
                      {
                        label: 'Maintenance',
                        icon: 'setting',
                        asphalt: 'Moderate',
                        tile: 'Minimal',
                      },
                      {
                        label: 'Weight',
                        icon: 'wight-machine',
                        asphalt: 'Heavier layered system',
                        tile: '1.5 lbs/sq-ft',
                      },
                    ].map((row, idx, arr) => (
                      <tr class="group">
                        <td class="border-b border-[#594216] px-6 py-7 group-last:border-b-0">
                          <div class="flex items-center gap-4">
                            <Icon name={row.icon} size={24} class="text-primary" />
                            <span class="text-base font-medium">{row.label}</span>
                          </div>
                        </td>
                        <td class="border-b border-[#594216] px-6 py-7 text-left text-white/70 group-last:border-b-0">
                          {row.asphalt}
                        </td>
                        <td class="relative p-0 text-left">
                          <div
                            class:list={[
                              'absolute inset-0 z-0 border-x border-[#594216] bg-[#111]',
                              idx === arr.length - 1 && 'rounded-b-3xl border-b',
                            ]}
                          />
                          <div
                            class:list={[
                              'text-primary relative z-10 flex items-center gap-2 border-b border-[#59421650] px-6 py-7 text-left text-lg font-semibold',
                              idx === arr.length - 1 && 'border-none',
                            ]}
                          >
                            <Icon name="double-tick" size={16} />
                            <span>{row.tile}</span>
                          </div>
                        </td>
                      </tr>
                    ))
                  }
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </NoiseBg>
    </div>
  </section>

  <!-- style & profit -->
  <StylesProfiles />

  <RecentProjects />
  <ServiceAreas />
  <Faqs />
  <RecentArticales />
  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>
  <CTASection />
  <Footer />
</Layout>
