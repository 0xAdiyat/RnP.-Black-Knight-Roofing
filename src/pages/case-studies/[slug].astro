---
export const prerender = true;
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/Navbar.astro';
import Brands from '@/components/Brands.astro';
import CTASection from '@/components/cta/CTASection.astro';
import Footer from '@/components/Footer.astro';
import NoiseBg from '@/components/NoiseBg.astro';
import { Icon } from 'astro-icon/components';
import Button from '@/components/ui/Button.astro';
import { Image, getImage } from 'astro:assets';
import sunFlow from '@/assets/sunflow.avif';
import roofImage from '@/assets/roof.avif';
import Process from '@/components/process/Process.astro';
import step1 from '@/assets/steps/step-1.png';
import step2 from '@/assets/steps/step-2.png';
import step3 from '@/assets/steps/step-3.png';
import step4 from '@/assets/steps/step-4.png';
import ProjectSwiper from '@/components/case-study/ProjectSwiper.astro';
import Hero2 from '@/components/hero/Hero2.astro';
import EstimateButton from '@/components/EstimateButton.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import heroBg from '@/assets/bg/case-studies-detail-section__hero.avif';

const roofImgOp = await getImage({ src: roofImage });

export async function getStaticPaths() {
  const sharedImages = [
    '/bg/case-studies-section__hero.avif',
    '/bg/metal-roofing-section__hero.avif',
    '/bg/roof-replacement-section__hero.avif',
    '/bg/stone-coated-steel-roofing-section__hero.avif',
    '/bg/concrete-tile-roof-section__hero.avif',
    '/bg/siding-section__hero.avif',
    '/bg/hail-damage-repair-section__hero.avif',
  ];

  const caseStudies = [
    {
      slug: 'edco-metal-siding-charcoal-gray',
      title: 'EDCO Metal Siding — Charcoal Gray',
      subtitle: 'A homeowner wanted a modern, low-maintenance exterior with lasting curb appeal.',
      location: 'Denver, CO',
      services: 'Siding Replacement',
      materials: 'EDCO Metal Siding (Charcoal Gray)',
      videoThumbnail: '/placeholders/projects/project-1.jpg',
      summary: 'A homeowner wanted a modern, low-maintenance exterior with lasting curb appeal. We installed EDCO metal siding in Charcoal Gray for a clean, contemporary finish.',
      resultSummary: 'durable metal siding installed, curb appeal transformed.',
      customer: {
        title: 'A Denver Homeowner',
        content: 'wanted a premium siding solution that could withstand Colorado\'s harsh weather while delivering a modern aesthetic. They reached out to Black Knight Roofing for expert guidance and a reliable installation.',
      },
      problem: { content: 'The existing siding was aging and failing to protect the home from moisture and temperature extremes. The homeowner needed a durable, attractive replacement.' },
      solution: { content: 'We recommended EDCO metal siding in Charcoal Gray for its superior durability, low maintenance, and modern look. Our team completed the installation efficiently with clean, precise workmanship.' },
      result: { content: 'The home now features a stunning, weather-resistant exterior that will last decades. The homeowner is thrilled with the transformation and the reduced maintenance burden.' },
      images: sharedImages,
    },
    {
      slug: 'stone-coated-steel-weathered-wood',
      title: 'Stone Coated Steel — Weathered Wood',
      subtitle: 'A Colorado homeowner needed a roof that combines beauty with storm resistance.',
      location: 'Denver, CO',
      services: 'Roofing',
      materials: 'Stone Coated Steel (Weathered Wood)',
      videoThumbnail: '/placeholders/projects/project-1.jpg',
      summary: 'A Colorado homeowner needed a roof that combines beauty with storm resistance. We installed stone coated steel in Weathered Wood for the perfect balance of style and durability.',
      resultSummary: 'storm-resistant roof installed with a premium wood aesthetic.',
      customer: {
        title: 'A Front Range Homeowner',
        content: 'wanted a roof that looks high-end but holds up to Colorado\'s toughest weather. After repeated storm seasons and constant patchwork, they needed a long-term system—not another temporary fix.',
      },
      problem: { content: 'The existing asphalt shingles were repeatedly damaged by hail and high winds, requiring frequent repairs. The homeowner needed a long-term roofing solution.' },
      solution: { content: 'We installed stone coated steel roofing in the Weathered Wood finish, offering the aesthetic of natural wood with the strength of steel. This system is rated for 160 mph winds and Class 4 impact resistance.' },
      result: { content: 'The homeowner now has a roof that\'s both beautiful and virtually indestructible. No more storm anxiety—just lasting protection and stunning curb appeal.' },
      images: sharedImages,
    },
    {
      slug: 'concrete-tile-barcelona-sand',
      title: 'Concrete Tile — Barcelona Sand',
      subtitle: 'A homeowner sought a classic Mediterranean look with Colorado-tough performance.',
      location: 'Denver, CO',
      services: 'Roofing',
      materials: 'Concrete Tile (Barcelona Sand)',
      videoThumbnail: '/placeholders/projects/project-1.jpg',
      summary: 'A homeowner sought a classic Mediterranean look with Colorado-tough performance. We installed concrete tile in Barcelona Sand for timeless elegance and lasting protection.',
      resultSummary: 'elegant concrete tile roof installed with decades-long lifespan.',
      customer: {
        title: 'A Colorado Homeowner',
        content: 'dreamed of a Mediterranean-inspired home with a roof to match. They needed a solution that delivered the classic look they loved while standing up to Colorado\'s climate.',
      },
      problem: { content: 'The existing roof was outdated and no longer matched the homeowner\'s vision for their home. They needed a complete replacement with premium materials.' },
      solution: { content: 'We installed Barcelona Sand concrete tile roofing, providing the timeless Mediterranean aesthetic with superior durability. Concrete tile is fire-resistant, wind-resistant, and built to last 50+ years.' },
      result: { content: 'The home now boasts a stunning Mediterranean exterior that stands out in the neighborhood. The homeowner has a beautiful, low-maintenance roof built for the long haul.' },
      images: sharedImages,
    },
    {
      slug: 'asphalt-shingle-estate-gray',
      title: 'Asphalt Shingle — Estate Gray',
      subtitle: 'A homeowner needed a reliable, cost-effective roof replacement after storm damage.',
      location: 'Denver, CO',
      services: 'Roofing',
      materials: 'Asphalt Shingle (Estate Gray)',
      videoThumbnail: '/placeholders/projects/project-1.jpg',
      summary: 'A homeowner needed a reliable, cost-effective roof replacement after storm damage. We installed premium asphalt shingles in Estate Gray for a clean, classic finish.',
      resultSummary: 'new roof installed, insurance claim handled seamlessly.',
      customer: {
        title: 'A Denver Area Homeowner',
        content: 'experienced significant hail damage and needed a full roof replacement. They wanted quality materials at a fair price, with help navigating the insurance claim process.',
      },
      problem: { content: 'A severe hail storm caused widespread damage to the existing roof, leading to leaks and interior water damage. The homeowner needed a fast, reliable replacement.' },
      solution: { content: 'We handled the insurance claim from start to finish and installed premium Estate Gray asphalt shingles. The project was completed on schedule with zero disruption to the homeowner\'s routine.' },
      result: { content: 'The homeowner received a brand-new roof with full insurance coverage and zero out-of-pocket stress. The Estate Gray finish gives the home a clean, timeless look.' },
      images: sharedImages,
    },
    {
      slug: 'vinyl-siding-replacement-desert-tan',
      title: 'Vinyl Siding Replacement — Desert Tan',
      subtitle: 'A homeowner wanted to refresh their home\'s exterior with durable, low-maintenance vinyl.',
      location: 'Denver, CO',
      services: 'Siding Replacement',
      materials: 'Vinyl Siding (Desert Tan)',
      videoThumbnail: '/placeholders/projects/project-1.jpg',
      summary: 'A homeowner wanted to refresh their home\'s exterior with durable, low-maintenance vinyl siding in Desert Tan for a warm, inviting look.',
      resultSummary: 'fresh vinyl siding installed, home value boosted.',
      customer: {
        title: 'A Colorado Homeowner',
        content: 'wanted to modernize their home\'s exterior without breaking the bank. They needed a durable, attractive siding solution that would last for years with minimal upkeep.',
      },
      problem: { content: 'The existing siding was faded, cracked, and allowing moisture infiltration. The homeowner needed a complete replacement to protect their investment.' },
      solution: { content: 'We installed Desert Tan vinyl siding, offering excellent weather resistance, insulation, and a warm aesthetic. The installation was clean and completed ahead of schedule.' },
      result: { content: 'The home looks completely transformed with its new Desert Tan exterior. The homeowner is enjoying the fresh look and the energy savings from improved insulation.' },
      images: sharedImages,
    },
    {
      slug: 'tpo-commercial-roof',
      title: 'TPO Commercial Roof — Flat Roof Specialist',
      subtitle: 'A commercial property owner needed a durable, energy-efficient flat roof system.',
      location: 'Denver, CO',
      services: 'Commercial Roofing',
      materials: 'TPO Membrane',
      videoThumbnail: '/placeholders/projects/project-1.jpg',
      summary: 'A commercial property owner needed a durable, energy-efficient flat roof system. We installed a TPO membrane roof that delivers superior performance and energy savings.',
      resultSummary: 'commercial flat roof installed, energy costs reduced.',
      customer: {
        title: 'A Denver Commercial Property Owner',
        content: 'needed a reliable flat roofing system for their commercial building. They required minimal downtime during installation and a system with proven longevity.',
      },
      problem: { content: 'The existing flat roof was aging and developing leaks, risking damage to the building\'s interior and inventory. The owner needed a fast, professional replacement.' },
      solution: { content: 'We installed a high-quality TPO membrane roofing system, known for its durability, UV resistance, and energy efficiency. The project was completed with minimal disruption to daily business operations.' },
      result: { content: 'The commercial property now has a watertight, energy-efficient roof that will last 20+ years. The owner has seen reduced cooling costs and complete peace of mind.' },
      images: sharedImages,
    },
    {
      slug: 'seamless-gutters-6-inch-k-style',
      title: 'Seamless Gutters — 6-Inch K-Style',
      subtitle: 'A homeowner needed a reliable gutter system to protect their foundation and landscaping.',
      location: 'Denver, CO',
      services: 'Gutters',
      materials: '6-Inch K-Style Seamless Gutters',
      videoThumbnail: '/placeholders/projects/project-1.jpg',
      summary: 'A homeowner needed a reliable gutter system to protect their foundation and landscaping. We installed seamless 6-inch K-style gutters for maximum water management.',
      resultSummary: 'seamless gutters installed, water damage risk eliminated.',
      customer: {
        title: 'A Denver Homeowner',
        content: 'was dealing with water pooling around their foundation and erosion in their landscaping due to inadequate gutters. They needed a professional gutter system built to handle Colorado\'s heavy rain and snow melt.',
      },
      problem: { content: 'The existing gutters were sectional, prone to leaking at the seams, and undersized for the roof\'s drainage needs. Water was damaging the foundation and landscaping.' },
      solution: { content: 'We installed custom 6-inch K-style seamless gutters, fabricated on-site for a perfect fit with no seams to leak. The system efficiently channels water away from the home.' },
      result: { content: 'The homeowner now has a high-performance gutter system that protects their foundation and landscaping. No more water pooling or erosion concerns.' },
      images: sharedImages,
    },
    {
      slug: 'hail-damage-repair',
      title: 'Hail Damage Repair — Insurance Claim Expert',
      subtitle: 'A homeowner\'s roof suffered severe hail damage and needed expert repair and claims support.',
      location: 'Denver, CO',
      services: 'Roofing',
      materials: 'Impact-Resistant Shingles',
      videoThumbnail: '/placeholders/projects/project-1.jpg',
      summary: 'A homeowner\'s roof suffered severe hail damage and needed expert repair and insurance claims support. Black Knight Roofing handled everything from inspection to completion.',
      resultSummary: 'roof repaired, insurance claim maximized, homeowner relieved.',
      customer: {
        title: 'A Front Range Homeowner',
        content: 'experienced a devastating hail storm that left their roof with hundreds of impact marks and compromised their home\'s waterproofing. They were overwhelmed by the insurance process and needed an expert partner.',
      },
      problem: { content: 'A severe hail storm caused extensive damage across the entire roof surface. The homeowner was unsure how to document the damage and navigate the insurance claim process.' },
      solution: { content: 'Our team conducted a thorough inspection, documented all damage with photos and detailed reports, and worked directly with the insurance adjuster to maximize the claim. We then replaced the roof with Class 4 impact-resistant shingles.' },
      result: { content: 'The homeowner received full insurance coverage for the replacement and now has a superior, impact-resistant roof. The entire process—from claim to completion—was handled by Black Knight Roofing.' },
      images: sharedImages,
    },
  ];

  return caseStudies.map(caseStudy => ({
    params: { slug: caseStudy.slug },
    props: { caseStudy },
  }));
}

const { caseStudy } = Astro.props;

const processSteps = [
  {
    image: step1,
    step: 'Step 1',
    title: 'Contact Our Team',
    description: 'Get in touch with us by phone or fill out a form! Our customer service team is on standby.',
  },
  {
    image: step2,
    step: 'Step 2',
    title: 'Schedule Inspection',
    description: 'We will schedule a convenient time to inspect your roof and assess the project scope.',
  },
  {
    image: step3,
    step: 'Step 3',
    title: 'Review Your Proposal',
    description: 'Receive a detailed proposal outlining the work, timeline, and transparent pricing.',
  },
  {
    image: step4,
    step: 'Step 4',
    title: 'Project Completion',
    description: 'Our expert team completes the project to the highest standards with a final walkthrough.',
  },
];
---

<Layout title={`${caseStudy.title} | Case Study`}>
  <Navbar />

  <Hero2 backgroundImage={heroBg} title="Case Studies Denver" subtitle="Case Studies">
    <p>
      Insurance Claim Specialists: We navigate storm and hail damage claims for you, making insurance stress-free.
      Insurance Claim Specialists: We navigate storm and hail damage claims for you, making insurance stress-free.
      Insurance Claim Specialists: We navigate storm and hail damage claims for you, making insurance stress-free.
      Insurance Claim Specialists: We navigate storm and hail damage claims for you, making insurance stress-free.
    </p>

    <div class="flex items-center gap-x-4">
      <EstimateButton />
    </div>
  </Hero2>

  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>

  <section class="bg-[#111] py-20">
    <div class="container overflow-visible">
      <!-- Breadcrumbs -->

      <Breadcrumb
        items={[
          { label: 'Home', href: '/' },
          { label: 'Case Studies', href: '/case-studies' },
          { label: caseStudy.title, href: `/case-studies/${caseStudy.slug}` },
        ]}
        class="mb-4"
      />

      <div class="flex flex-col items-start justify-between gap-12 lg:flex-row">
        <!-- Main Content -->
        <div class="max-w-4xl flex-1 space-y-12">
          <!-- Video Section -->
          <div class="space-y-12 rounded-3xl">
            <div class="space-y-8">
              <!-- Thumbnail -->
              <div
                class="group border-primary/30 relative aspect-video cursor-pointer overflow-hidden rounded-2xl border"
              >
                <Image
                  src={caseStudy.videoThumbnail}
                  alt={caseStudy.title}
                  width={1200}
                  height={675}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
                <div
                  class="absolute inset-0 flex items-center justify-center bg-black/40 transition-opacity group-hover:bg-black/20"
                >
                  <div
                    class="bg-primary shadow-primary/40 flex size-16 transform items-center justify-center rounded-full shadow-2xl transition-transform group-hover:scale-110"
                  >
                    <Icon name="play" class="size-6 text-black" />
                  </div>
                </div>
              </div>

              <!-- Heading Area -->
              <div class="space-y-4 px-2 pb-4 text-center sm:text-left">
                <h4 class="font-heading pb-2 leading-tight text-white">
                  {caseStudy.title}
                </h4>

                <div>
                  <div class="relative py-2 pl-6">
                    <div class="bg-primary absolute inset-y-0 left-0 w-0.5 rounded-full"></div>
                    <p class="text-left text-base leading-relaxed text-[#ccc]">
                      {caseStudy.summary}
                    </p>
                  </div>

                  <div class="relative py-2 pl-6">
                    <div class="bg-primary absolute inset-y-0 left-0 w-0.5 rounded-full"></div>
                    <p class="text-left text-base text-[#ccc]">
                      <span class="font-bold text-white">Result:</span>
                      {caseStudy.resultSummary}
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Info Bar -->
          <div
            class="via-primary relative mx-auto w-full rounded-3xl bg-linear-to-r from-[#594216]/30 to-[#594216]/30 p-px sm:w-fit"
          >
            <div
              class="border-primary/20 relative grid max-w-[787px] grid-cols-1 divide-y divide-white/10 overflow-hidden rounded-3xl border bg-[#1a1a1a] p-8 shadow-2xl sm:grid-cols-3 sm:divide-x sm:divide-y-0"
            >
              <Image
                src={sunFlow}
                alt="sun-flow"
                width={1920}
                height={1080}
                class="absolute inset-0 h-full w-full object-cover opacity-20"
              />
              <!-- Location -->
              <div class="flex items-center gap-4 py-4 sm:py-0 sm:pr-8">
                <div class="py-4">
                  <div class="text-primary flex items-center gap-x-2 text-xl font-bold">
                    <Icon name="location-02" class="text-primary size-6" />
                    <span> Location </span>
                  </div>
                  <div class="text-[#ccc]">{caseStudy.location}</div>
                </div>
              </div>

              <!-- Services -->
              <div class="flex items-center gap-4 py-4 sm:px-8 sm:py-0">
                <div class="py-4">
                  <div class="text-primary flex items-center gap-x-2 text-xl font-bold">
                    <Icon name="cap" class="text-primary size-6" />
                    <span> Services </span>
                  </div>
                  <div class="text-[#ccc]">{caseStudy.services}</div>
                </div>
              </div>

              <!-- Materials -->
              <div class="flex items-center gap-4 py-4 sm:py-0 sm:pl-8">
                <div class="py-4">
                  <div class="text-primary flex items-center gap-x-2 text-xl font-bold">
                    <Icon name="materials" class="text-primary size-6" />
                    <span> Materials </span>
                  </div>
                  <div class="text-[#ccc]">{caseStudy.materials}</div>
                </div>
              </div>
            </div>
          </div>

          <!-- Detailed Sections -->
          <div class="space-y-20 pt-10">
            <!-- The Customer -->
            <section id="the-customer" class="scroll-mt-32 space-y-6">
              <h2 class="font-heading text-primary text-4xl font-normal">The Customer</h2>
              <p
                class="text-base leading-relaxed font-medium text-white/90 decoration-white/30 decoration-1 underline-offset-4"
              >
                <span class="underline decoration-white/50">{caseStudy.customer.title}</span>
                {caseStudy.customer.content}
              </p>
            </section>

            <!-- The Problem -->
            <section id="the-problem" class="scroll-mt-32 space-y-6">
              <h2 class="font-heading text-primary text-4xl font-normal">The Problem</h2>
              <div class="space-y-6 text-base leading-relaxed text-white/80">
                <p>{caseStudy.problem.content}</p>
                <p>To learn more about Vimeo's journey with Superside, we spoke with:</p>
                <ul class="space-y-3 pl-6">
                  <li class="flex items-start gap-3">
                    <div class="bg-primary mt-2.5 size-1.5 shrink-0 rounded-full"></div>
                    <span class="font-medium text-white underline decoration-white/30 underline-offset-4"
                      >Meagan Wood</span
                    >, Director of Integrated Production
                  </li>
                  <li class="flex items-start gap-3">
                    <div class="bg-primary mt-2.5 size-1.5 shrink-0 rounded-full"></div>
                    <span class="font-medium text-white underline decoration-white/30 underline-offset-4"
                      >Bia Castro</span
                    >, Director of Brand and Creative
                  </li>
                  <li class="flex items-start gap-3">
                    <div class="bg-primary mt-2.5 size-1.5 shrink-0 rounded-full"></div>
                    <span class="font-medium text-white underline decoration-white/30 underline-offset-4"
                      >Leif Huron</span
                    >, Lead Production Manager, Creative Operations
                  </li>
                </ul>
              </div>
            </section>

            <!-- The Solution -->
            <section id="the-solution" class="scroll-mt-32 space-y-6">
              <h2 class="font-heading text-primary text-4xl font-normal">The Solution</h2>
              <div class="space-y-4 text-base leading-relaxed text-white/80">
                <p>{caseStudy.solution.content}</p>
              </div>
            </section>

            <!-- The Result -->
            <section id="the-result" class="scroll-mt-32 space-y-6">
              <h2 class="font-heading text-primary text-4xl font-normal">The Result</h2>
              <div class="space-y-4 text-base leading-relaxed text-white/80">
                <p>{caseStudy.result.content}</p>
              </div>
            </section>
          </div>

          <!-- Bottom CTA -->
          <div class="from-primary rounded-2xl bg-radial-[at_30%_30%] via-[#594216]/50 to-[#594216]/50 p-px">
            <NoiseBg class="group relative rounded-2xl p-8 transition-all duration-300">
              <div
                class="from-primary/5 absolute inset-0 bg-radial-[at_center] via-transparent to-transparent opacity-0 transition-opacity group-hover:opacity-100"
              >
              </div>
              <div
                class="relative flex flex-col items-center justify-between gap-8 text-center md:flex-row md:text-left"
              >
                <div class="space-y-1">
                  <h3
                    class="font-heading to-primary bg-linear-to-r from-white via-white bg-clip-text text-4xl text-transparent"
                  >
                    Get Your FREE Roof Inspection Done!
                  </h3>
                  <p class="text-sm font-bold tracking-wider text-white/50 uppercase">
                    Need any roof repair help? Get in touch today!
                  </p>
                </div>
                <Button variant="primary" size="lg" class="shadow-primary/10 rounded-lg shadow-xl" data-estimate-trigger>
                  Get Started
                </Button>
              </div>
            </NoiseBg>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="w-full shrink-0 space-y-12 lg:sticky lg:top-32 lg:w-80">
          <!-- Table of Contents -->
          <div class="hidden space-y-6 lg:block">
            <div class="font-body text-xl font-bold text-white">Table of Contents</div>
            <nav class="flex flex-col gap-2 border-l border-white/20 pl-4">
              <a href="#the-customer" class="hover:text-primary py-1 text-[#ccc] transition-colors">01 — The Customer</a
              >
              <a href="#the-problem" class="hover:text-primary py-1 text-[#ccc] transition-colors">02 — The Problem</a>
              <a href="#the-solution" class="hover:text-primary py-1 text-[#ccc] transition-colors">03 — The Solution</a
              >
              <a href="#the-result" class="hover:text-primary py-1 text-[#ccc] transition-colors">04 — The Result</a>
            </nav>
          </div>

          <!-- Support Card -->
          <div class="via-primary rounded-2xl bg-linear-to-r from-white/0 to-white/0 p-px">
            <div
              class="group relative flex aspect-3/4 flex-col justify-end overflow-hidden rounded-2xl p-8"
              style={`
              background-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url(${roofImgOp.src});
              background-size: cover;
              background-position: bottom;
              background-repeat: no-repeat;
             `}
            >
              <div class="absolute inset-0 z-10 bg-linear-to-t from-black via-black/40 to-transparent"></div>
              <Image
                src={sunFlow}
                alt="Support"
                class="pointer-events-none absolute inset-0 h-full w-full object-cover opacity-30 transition-transform duration-700 group-hover:scale-105"
              />
              <div class="relative z-20 space-y-8">
                <div class="space-y-4">
                  <h3 class="font-heading text-primary text-4xl leading-tight">Need Help? Call Us Now</h3>
                  <p class="leading-relaxed text-[#ccc]">
                    Have questions or need a custom quote? Our team is here to help
                  </p>
                </div>

                <a href="tel:9708887230" class="flex items-center gap-4">
                  <div class="bg-primary flex size-12 shrink-0 items-center justify-center rounded-full">
                    <Icon name="phone" class="size-6 text-black" />
                  </div>
                  <div>
                    <div class="text-xs font-bold tracking-widest text-white/60 uppercase">Give us a call:</div>
                    <div class="text-primary font-heading mt-1 text-3xl leading-none">(970) 888-7230</div>
                  </div>
                </a>

                <div class="border-t border-white/20 pt-4 text-center">
                  <p class="text-sm text-white/60">Check Availability</p>
                  <p class="font-medium text-white">Secure your spot asap!</p>
                </div>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Image sliders -->
  <section class="mb-20">
    <ProjectSwiper images={caseStudy.images} />
  </section>

  <Process steps={processSteps} />

  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>
  <CTASection />
  <Footer />
</Layout>

<style>
  /* Custom scrollbar hiding */
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-none {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
