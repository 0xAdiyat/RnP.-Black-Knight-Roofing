---
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/Navbar.astro';
import Hero from '@/components/hero/Hero.astro';
import Brands from '@/components/Brands.astro';
import CTASection from '@/components/cta/CTASection.astro';
import { defaultCTA } from '@/data/cta';
import Footer from '@/components/Footer.astro';
import QuoteForm from '@/components/cta/QuoteForm.astro';
import Testimonials from '@/components/Testimonials.astro';
import ServiceAreas from '@/components/service-area/ServiceAreas.astro';
import NoiseBg from '@/components/NoiseBg.astro';
import { Icon } from 'astro-icon/components';
import Button from '@/components/ui/Button.astro';
import RatingStars from '@/components/ui/RatingStars.astro';
import sunFlow from '@/assets/sunflow.avif';
import { Image } from 'astro:assets';
import WorkCard from '@/components/recent-projects/WorkCard.astro';
import Pagination from '@/components/ui/pagination/Pagination.astro';
import Carousel from '@/components/ui/Carousel.astro';
import heroBg from '@/assets/bg/case-studies-section__hero.avif';
import caseStudiesHero from '@/assets/bg/case-studies-section__hero.avif';
import sidingHero from '@/assets/bg/siding-section__hero.avif';
import metalRoofingHero from '@/assets/bg/metal-roofing-section__hero.avif';
import concreteTileHero from '@/assets/bg/concrete-tile-roof-section__hero.avif';
import asphaltShingleHero from '@/assets/bg/roof-replacement-section__hero.avif';
import commercialRoofingHero from '@/assets/bg/commercial-roofing-section__hero.avif';
import guttersHero from '@/assets/bg/gutters-section__hero.avif';
import hailHero from '@/assets/bg/hail-damage-repair-section__hero.avif';

const works = [
  {
    image: caseStudiesHero,
    title: 'EDCO METAL SIDING',
    subtitle: 'CHARCOAL GRAY',
    category: 'Siding',
    slug: 'edco-metal-siding-charcoal-gray',
  },
  {
    image: metalRoofingHero,
    title: 'Stone Coated Steel',
    subtitle: 'Weathered Wood',
    category: 'Roofing',
    slug: 'stone-coated-steel-weathered-wood',
  },
  {
    image: concreteTileHero,
    title: 'Concrete Tile',
    subtitle: 'Barcelona Sand',
    category: 'Roofing',
    slug: 'concrete-tile-barcelona-sand',
  },
  {
    image: asphaltShingleHero,
    title: 'Asphalt Shingle',
    subtitle: 'Estate Gray',
    category: 'Roofing',
    slug: 'asphalt-shingle-estate-gray',
  },
  {
    image: sidingHero,
    title: 'Vinyl Siding Replacement',
    subtitle: 'DESERT TAN',
    category: 'Siding',
    slug: 'vinyl-siding-replacement-desert-tan',
  },
  {
    image: commercialRoofingHero,
    title: 'TPO Commercial Roof',
    subtitle: 'Flat Roof Specialist',
    category: 'Roofing',
    slug: 'tpo-commercial-roof',
  },
  {
    image: guttersHero,
    title: 'Seamless Gutters',
    subtitle: '6-Inch K-Style',
    category: 'Gutters',
    slug: 'seamless-gutters-6-inch-k-style',
  },
  {
    image: hailHero,
    title: 'Hail Damage Repair',
    subtitle: 'Insurance Claim Expert',
    category: 'Roofing',
    slug: 'hail-damage-repair',
  },
];

const currentPage = Number(Astro.url.searchParams.get('page') || 1);
const itemsPerPage = 4;
const totalPages = Math.ceil(works.length / itemsPerPage);
const displayedWorks = works.slice((currentPage - 1) * itemsPerPage, currentPage * itemsPerPage);
---

<Layout title="Denver Roofing Case Studies | Black Knight Roofing" noindex={true}>
  <Navbar />
  <Hero backgroundImage={heroBg} title="Roofing Case Studies" subtitle="Colorado's #1 Veteran-Owned Roofing Company">
    <p>
      Results speak louder than promises. Our case studies highlight real projects across residential and commercial
      properties in Wisconsin and Illinois, showcasing how we solve exterior remodeling challenges with expert
      craftsmanship, reliable materials, and lasting solutions. Explore our portfolio to see how we’ve helped property
      owners protect their investments, improve curb appeal, and gain peace of mind with exteriors built to last. Like
      what you see? Contact us to start a project of your own!
    </p>
  </Hero>

  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>

  <!-- Filters -->
  <div class="relative px-0 py-0">
    <Image
      src={sunFlow}
      alt=""
      width={1920}
      height={1080}
      class="absolute inset-0 h-full w-full object-cover opacity-20"
    />
    <div class="container py-12 lg:py-20">
      <div class="z-10 flex flex-col items-center space-y-8 lg:space-y-10">
        <div class="flex flex-col items-center gap-4 text-center">
          <div class="text-xs font-bold tracking-[0.2em] text-white/50 uppercase">Explore Our Results</div>
          <h2 class="font-heading text-4xl text-white md:text-5xl">Filter Gallery By:</h2>
        </div>

        <div class="flex flex-wrap items-end justify-center gap-3 sm:gap-4 md:gap-6 lg:gap-2">
          {
            [
              { name: 'All Work', icon: 'gallery-image' },
              { name: 'Stone Coated', icon: 'stone-roof' },
              { name: 'Asphalt', icon: 'roof-icon' },
              { name: 'Concrete Tile', icon: 'materials' },
              { isSeparator: true },
              { name: 'Siding', icon: 'materials' },
              { name: 'Gutters', icon: 'roof-air-flow' },
            ].map(cat =>
              cat.isSeparator ? (
                <div class="mx-4 hidden h-[90px] w-px bg-white/15 lg:block" />
              ) : (
                <button class="group flex flex-col items-center gap-3 transition-all hover:-translate-y-1">
                  <div class="group-hover:border-primary/50 flex h-[110px] w-[95px] items-center justify-center rounded-xl border border-white/5 bg-white/5 shadow-2xl transition-all duration-300 group-hover:bg-white/10 sm:h-[135px] sm:w-[116px]">
                    <Icon
                      name={cat.icon}
                      class="text-primary size-8 transition-transform duration-300 group-hover:scale-110 sm:size-10"
                    />
                  </div>
                  <span class="text-[10px] font-bold tracking-wider text-white/40 uppercase transition-colors duration-300 group-hover:text-white sm:text-xs">
                    {cat.name}
                  </span>
                </button>
              )
            )
          }
        </div>
      </div>
    </div>
  </div>

  <!-- Gallery -->
  <NoiseBg class="px-0 py-0">
    <div class="container py-10 lg:py-20">
      <div class="grid auto-cols-max auto-rows-max grid-cols-[repeat(auto-fit,minmax(250px,1fr))] gap-4 lg:gap-x-2">
        {
          displayedWorks.map(work => (
            <WorkCard image={work.image} title={work.title} subtitle={work.subtitle} category={work.category} href={`/case-studies/${work.slug}`} />
          ))
        }
      </div>

      <!-- Pagination -->
      <div class="mt-12 flex justify-center">
        <Pagination currentPage={currentPage} totalPages={totalPages} baseUrl="/case-studies" />
      </div>
    </div>
  </NoiseBg>

  <!-- Statistics -->
  <div class="container grid grid-cols-1 gap-4 py-16 sm:grid-cols-2 lg:grid-cols-4 lg:gap-x-2">
    <!-- Total Projects Completed -->
    <div class="from-primary rounded-[5px] bg-radial-[at_30%_30%] via-[#594216] to-[#594216] p-px">
      <NoiseBg class="flex h-full items-center justify-center gap-x-2 rounded-[5px] px-6 py-4">
        <div class="font-heading text-primary text-[2rem]">100+</div>
        <div>
          <div class="text-lg font-bold">Roofing Projects</div>
          <div class="text-[#AAAAAA]">in Colorado</div>
        </div>
      </NoiseBg>
    </div>

    <!-- Google Retings -->
    <div class="from-primary rounded-[5px] bg-radial-[at_30%_30%] via-[#594216] to-[#594216] p-px">
      <NoiseBg class="flex h-full items-center justify-center gap-x-2 rounded-[5px] px-6 py-4">
        <div class="text-primary text-[2rem] font-bold">5.0</div>
        <div class="space-y-1">
          <div class="text-lg font-bold">
            <RatingStars rating={5} size={16} fillColor="#F7B715" strokeColor="none" />
          </div>
          <div class="text-[#AAAAAA]">40+ Google Reviews</div>
        </div>
      </NoiseBg>
    </div>

    <!-- Workmanship Warranty -->
    <div class="from-primary rounded-[5px] bg-radial-[at_30%_30%] via-[#594216] to-[#594216] p-px">
      <NoiseBg class="flex h-full items-center justify-center gap-x-2 rounded-[5px] px-6 py-4">
        <div class="text-primary size-12 font-bold">
          <Icon name="shield-check" size={48} />
        </div>
        <div>
          <div class="font-heading text-[2rem] leading-11 font-normal">Licensed</div>
          <div class="text-[#AAAAAA]">Bonded & Insured</div>
        </div>
      </NoiseBg>
    </div>

    <div class="from-primary rounded-[5px] bg-radial-[at_30%_30%] via-[#594216] to-[#594216] p-px">
      <NoiseBg class="flex h-full items-center justify-center gap-x-2 rounded-[5px] px-6 py-4">
        <div class="text-primary size-12 font-bold">
          <Icon name="badge" size={48} />
        </div>
        <div>
          <div class="font-heading text-[2rem] leading-11 font-normal">Lifetime</div>
          <div class="text-[#AAAAAA]">Workmanship Warranty</div>
        </div>
      </NoiseBg>
    </div>
  </div>

  <Testimonials />
  <ServiceAreas />

  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>
  <CTASection cta={defaultCTA} />
  <Footer />
</Layout>
