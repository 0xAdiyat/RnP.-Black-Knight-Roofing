---
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/Navbar.astro';
import Hero from '@/components/hero/Hero.astro';
import Brands from '@/components/Brands.astro';
import CTASection from '@/components/cta/CTASection.astro';
import { defaultCTA } from '@/data/cta';
import Footer from '@/components/Footer.astro';
import QuoteForm from '@/components/cta/QuoteForm.astro';
import Testimonials from '@/components/Testimonials.astro';
import ServiceAreas from '@/components/service-area/ServiceAreas.astro';
import NoiseBg from '@/components/NoiseBg.astro';
import { Icon } from 'astro-icon/components';
import Button from '@/components/ui/Button.astro';
import RatingStars from '@/components/ui/RatingStars.astro';
import WorkCard from '@/components/recent-projects/WorkCard.astro';
import Pagination from '@/components/ui/pagination/Pagination.astro';
import Carousel from '@/components/ui/Carousel.astro';
import PastWorkFilter from '@/components/past-work/PastWorkFilter.astro';
import heroBg from '@/assets/bg/case-studies-section__hero.avif';
import caseStudiesHero from '@/assets/bg/case-studies-section__hero.avif';
import sidingHero from '@/assets/bg/siding-section__hero.avif';
import metalRoofingHero from '@/assets/bg/metal-roofing-section__hero.avif';
import concreteTileHero from '@/assets/bg/concrete-tile-roof-section__hero.avif';
import asphaltShingleHero from '@/assets/bg/roof-replacement-section__hero.avif';
import commercialRoofingHero from '@/assets/bg/commercial-roofing-section__hero.avif';
import guttersHero from '@/assets/bg/gutters-section__hero.avif';
import hailHero from '@/assets/bg/hail-damage-repair-section__hero.avif';

const works = [
  {
    image: caseStudiesHero,
    title: 'EDCO METAL SIDING',
    subtitle: 'CHARCOAL GRAY',
    category: 'Siding',
    slug: 'edco-metal-siding-charcoal-gray',
  },
  {
    image: metalRoofingHero,
    title: 'Stone Coated Steel',
    subtitle: 'Weathered Wood',
    category: 'Roofing',
    slug: 'stone-coated-steel-weathered-wood',
  },
  {
    image: concreteTileHero,
    title: 'Concrete Tile',
    subtitle: 'Barcelona Sand',
    category: 'Roofing',
    slug: 'concrete-tile-barcelona-sand',
  },
  {
    image: asphaltShingleHero,
    title: 'Asphalt Shingle',
    subtitle: 'Estate Gray',
    category: 'Roofing',
    slug: 'asphalt-shingle-estate-gray',
  },
  {
    image: sidingHero,
    title: 'Vinyl Siding Replacement',
    subtitle: 'DESERT TAN',
    category: 'Siding',
    slug: 'vinyl-siding-replacement-desert-tan',
  },
  {
    image: commercialRoofingHero,
    title: 'TPO Commercial Roof',
    subtitle: 'Flat Roof Specialist',
    category: 'Roofing',
    slug: 'tpo-commercial-roof',
  },
  {
    image: guttersHero,
    title: 'Seamless Gutters',
    subtitle: '6-Inch K-Style',
    category: 'Gutters',
    slug: 'seamless-gutters-6-inch-k-style',
  },
  {
    image: hailHero,
    title: 'Hail Damage Repair',
    subtitle: 'Insurance Claim Expert',
    category: 'Roofing',
    slug: 'hail-damage-repair',
  },
];

const requestedPage = Number(Astro.url.searchParams.get('page') || 1);
const itemsPerPage = 4;
const totalItems = works.length;
const totalPages = Math.max(1, Math.ceil(totalItems / itemsPerPage));
const currentPage = Math.min(Math.max(requestedPage, 1), totalPages);
const visibleSlugs = new Set(
  works.slice((currentPage - 1) * itemsPerPage, currentPage * itemsPerPage).map((work) => work.slug)
);
---

<Layout title="Denver Roofing Case Studies | Black Knight Roofing" noindex={true}>
  <Navbar />
  <Hero backgroundImage={heroBg} title="Roofing Case Studies" subtitle="Colorado's #1 Veteran-Owned Roofing Company">
    <p>
      Results speak louder than promises. Our case studies highlight real projects across residential and commercial
      properties in Wisconsin and Illinois, showcasing how we solve exterior remodeling challenges with expert
      craftsmanship, reliable materials, and lasting solutions. Explore our portfolio to see how we’ve helped property
      owners protect their investments, improve curb appeal, and gain peace of mind with exteriors built to last. Like
      what you see? Contact us to start a project of your own!
    </p>
  </Hero>

  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>

  <!-- Filters -->
  <PastWorkFilter currentPage="case-studies" />

  <!-- Gallery -->
  <NoiseBg class="px-0 py-0">
    <div class="container py-10 lg:py-20" data-case-studies-root>
      <div class="grid auto-cols-max auto-rows-max grid-cols-[repeat(auto-fit,minmax(250px,1fr))] gap-4 lg:gap-x-2">
        {
          works.map(work => (
            <div data-case-study-card data-card-id={work.slug} class:list={[visibleSlugs.has(work.slug) ? '' : 'hidden']}>
              <WorkCard image={work.image} title={work.title} subtitle={work.subtitle} category={work.category} href={`/case-studies/${work.slug}`} />
            </div>
          ))
        }
      </div>

      <Pagination
        currentPage={currentPage}
        totalPages={totalPages}
        totalItems={totalItems}
        itemsPerPage={itemsPerPage}
        itemLabel="Projects"
        variant="gallery"
        clientMode={true}
        baseUrl="/case-studies"
      />
    </div>
  </NoiseBg>

  <!-- Statistics -->
  <div class="container grid grid-cols-1 gap-4 py-16 sm:grid-cols-2 lg:grid-cols-4 lg:gap-x-2">
    <!-- Total Projects Completed -->
    <div class="from-primary rounded-[5px] bg-radial-[at_30%_30%] via-[#594216] to-[#594216] p-px">
      <NoiseBg class="flex h-full items-center justify-center gap-x-2 rounded-[5px] px-6 py-4">
        <div class="font-heading text-primary text-[2rem]">100+</div>
        <div>
          <div class="text-lg font-bold">Roofing Projects</div>
          <div class="text-[#AAAAAA]">in Colorado</div>
        </div>
      </NoiseBg>
    </div>

    <!-- Google Retings -->
    <div class="from-primary rounded-[5px] bg-radial-[at_30%_30%] via-[#594216] to-[#594216] p-px">
      <NoiseBg class="flex h-full items-center justify-center gap-x-2 rounded-[5px] px-6 py-4">
        <div class="text-primary text-[2rem] font-bold">5.0</div>
        <div class="space-y-1">
          <div class="text-lg font-bold">
            <RatingStars rating={5} size={16} fillColor="#F7B715" strokeColor="none" />
          </div>
          <div class="text-[#AAAAAA]">40+ Google Reviews</div>
        </div>
      </NoiseBg>
    </div>

    <!-- Workmanship Warranty -->
    <div class="from-primary rounded-[5px] bg-radial-[at_30%_30%] via-[#594216] to-[#594216] p-px">
      <NoiseBg class="flex h-full items-center justify-center gap-x-2 rounded-[5px] px-6 py-4">
        <div class="text-primary size-12 font-bold">
          <Icon name="shield-check" size={48} />
        </div>
        <div>
          <div class="font-heading text-[2rem] leading-11 font-normal">Licensed</div>
          <div class="text-[#AAAAAA]">Bonded & Insured</div>
        </div>
      </NoiseBg>
    </div>

    <div class="from-primary rounded-[5px] bg-radial-[at_30%_30%] via-[#594216] to-[#594216] p-px">
      <NoiseBg class="flex h-full items-center justify-center gap-x-2 rounded-[5px] px-6 py-4">
        <div class="text-primary size-12 font-bold">
          <Icon name="badge" size={48} />
        </div>
        <div>
          <div class="font-heading text-[2rem] leading-11 font-normal">Lifetime</div>
          <div class="text-[#AAAAAA]">Workmanship Warranty</div>
        </div>
      </NoiseBg>
    </div>
  </div>

  <Testimonials />
  <ServiceAreas />

  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>
  <CTASection cta={defaultCTA} />
  <Footer />

  <script define:vars={{ totalItems, itemsPerPage, initialPage: currentPage }}>
    const root = document.querySelector('[data-case-studies-root]');

    if (root) {
      const cards = Array.from(root.querySelectorAll('[data-case-study-card]'));
      const paginationRoot = root.querySelector('[data-pagination-root]');
      const pagesContainer = paginationRoot?.querySelector('[data-pagination-pages]');
      const prevButton = paginationRoot?.querySelector('[data-pagination-prev]');
      const nextButton = paginationRoot?.querySelector('[data-pagination-next]');
      const count = paginationRoot?.querySelector('[data-pagination-count]');
      const summary = paginationRoot?.querySelector('[data-pagination-summary]');

      const totalPages = Math.max(1, Math.ceil(totalItems / itemsPerPage));
      const state = { page: initialPage };
      const filterSection = document.querySelector('[data-past-work-filter]');

      const getPages = (currentPage, maxPages) => {
        const pages = [];
        const maxVisible = 7;

        if (maxPages <= maxVisible) {
          for (let i = 1; i <= maxPages; i += 1) pages.push(i);
          return pages;
        }

        if (currentPage <= 4) return [1, 2, 3, 4, 5, 'DOTS', maxPages];
        if (currentPage >= maxPages - 3) return [1, 'DOTS', maxPages - 4, maxPages - 3, maxPages - 2, maxPages - 1, maxPages];
        return [1, 'DOTS', currentPage - 1, currentPage, currentPage + 1, 'DOTS', maxPages];
      };

      const updateUrl = (mode = 'replace') => {
        const url = new URL(window.location.href);
        if (state.page <= 1) {
          url.searchParams.delete('page');
        } else {
          url.searchParams.set('page', String(state.page));
        }
        window.history[mode === 'push' ? 'pushState' : 'replaceState']({}, '', `${url.pathname}${url.search}`);
      };

      const getNavbarOffset = () => {
        const navbarWrapper = document.getElementById('navbar-wrapper');
        const mobileTopbar = document.getElementById('mobile-topbar');
        const rootStyles = getComputedStyle(document.documentElement);
        const syncedMobileTopbarHeight = Number.parseFloat(rootStyles.getPropertyValue('--mobile-topbar-h')) || 0;
        const measuredNavbarHeight = navbarWrapper?.getBoundingClientRect().height || mobileTopbar?.getBoundingClientRect().height || 0;
        const navbarHeight = Math.max(syncedMobileTopbarHeight, measuredNavbarHeight);
        const extraOffset = window.innerWidth < 768 ? 28 : 16;
        return navbarHeight + extraOffset;
      };

      const scrollToFilterTop = () => {
        if (!filterSection) return;

        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            const top = window.scrollY + filterSection.getBoundingClientRect().top - getNavbarOffset();
            window.scrollTo({
              top: Math.max(0, top),
              behavior: 'smooth',
            });
          });
        });
      };

      const animateCards = (visibleCards) => {
        visibleCards.forEach((card, index) => {
          card.animate(
            [
              { opacity: 0, transform: 'translateY(16px) scale(0.985)' },
              { opacity: 1, transform: 'translateY(0) scale(1)' },
            ],
            {
              duration: 340,
              delay: index * 40,
              easing: 'cubic-bezier(0.22, 1, 0.36, 1)',
              fill: 'both',
            }
          );
        });
      };

      const renderPagination = () => {
        if (!pagesContainer || !prevButton || !nextButton || !count || !summary) return;

        pagesContainer.innerHTML = '';
        prevButton.disabled = state.page <= 1;
        nextButton.disabled = state.page >= totalPages;
        prevButton.classList.toggle('pointer-events-none', state.page <= 1);
        prevButton.classList.toggle('opacity-30', state.page <= 1);
        nextButton.classList.toggle('pointer-events-none', state.page >= totalPages);
        nextButton.classList.toggle('opacity-30', state.page >= totalPages);

        getPages(state.page, totalPages).forEach((page) => {
          if (page === 'DOTS') {
            const dot = document.createElement('span');
            dot.className = 'inline-flex size-11 items-center justify-center text-white/50';
            dot.textContent = '...';
            pagesContainer.append(dot);
            return;
          }

          const pageButton = document.createElement('button');
          pageButton.type = 'button';
          pageButton.dataset.paginationPage = String(page);
          pageButton.textContent = String(page);
          pageButton.className =
            'inline-flex size-11 items-center justify-center rounded-full text-sm font-medium backdrop-blur-[16.5px] transition-all duration-300';

          if (state.page === page) {
            pageButton.classList.add('border-radial', 'bg-[#0d0d0d]', 'text-white');
          } else {
            pageButton.classList.add('bg-white/10', 'text-white/70', 'hover:bg-white/20', 'hover:text-white');
          }

          pageButton.addEventListener('click', () => {
            if (state.page === page) return;
            state.page = page;
            render({ pushHistory: true, scrollToFilter: true });
          });

          pagesContainer.append(pageButton);
        });

        const start = (state.page - 1) * itemsPerPage + 1;
        const end = Math.min(state.page * itemsPerPage, totalItems);
        count.textContent = `${totalItems} ${totalItems === 1 ? 'Project' : 'Projects'}`;
        summary.textContent = `Showing ${start}-${end} of ${totalItems}`;
      };

      const render = ({ pushHistory = false, scrollToFilter = false } = {}) => {
        state.page = Math.min(Math.max(state.page, 1), totalPages);
        const start = (state.page - 1) * itemsPerPage;
        const end = start + itemsPerPage;
        const visibleCards = [];

        cards.forEach((card, index) => {
          const isVisible = index >= start && index < end;
          card.classList.toggle('hidden', !isVisible);
          if (isVisible) visibleCards.push(card);
        });

        renderPagination();
        updateUrl(pushHistory ? 'push' : 'replace');
        if (scrollToFilter) {
          scrollToFilterTop();
        }
        requestAnimationFrame(() => animateCards(visibleCards));
      };

      prevButton?.addEventListener('click', () => {
        if (state.page <= 1) return;
        state.page -= 1;
        render({ pushHistory: true, scrollToFilter: true });
      });

      nextButton?.addEventListener('click', () => {
        if (state.page >= totalPages) return;
        state.page += 1;
        render({ pushHistory: true, scrollToFilter: true });
      });

      window.addEventListener('popstate', () => {
        const url = new URL(window.location.href);
        const page = Number(url.searchParams.get('page') || '1');
        state.page = Number.isFinite(page) && page > 0 ? page : 1;
        render({ scrollToFilter: true });
      });

      render();
    }
  </script>
</Layout>
