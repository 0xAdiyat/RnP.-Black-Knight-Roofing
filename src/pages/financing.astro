---
import Hero from '@/components/hero/Hero.astro';
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/Navbar.astro';
import Button from '@/components/ui/Button.astro';
import RatingStars from '@/components/ui/RatingStars.astro';
import QuoteForm from '@/components/cta/QuoteForm.astro';
import { Icon } from 'astro-icon/components';
import Brands from '@/components/Brands.astro';
import AboutFinancing from '@/components/AboutFinancing.astro';
import NoiseBg from '@/components/NoiseBg.astro';
import { Image } from 'astro:assets';
import checkIcon from '@/assets/financing-banner/check.svg';
import imgTop from '@/assets/financing-banner/img-top.png';
import imgBottom from '@/assets/financing-banner/img-bottom.png';
import wisetackLogo from '@/assets/financing-banner/wisetack-logo.png';
import Statistics from '@/components/ui/Statistics.astro';
import BadgeTitle from '@/components/BadgeTitle.astro';
import FinanceStepCard from '@/components/finance/FinanceStepCard.astro';
import step1 from '@/assets/steps/step-3.png';
import step2 from '@/assets/steps/step-5.png';
import step3 from '@/assets/steps/step-6.png';
import CreditCardImage from '@/assets/credit-card.avif';
import { cn } from '@/lib/utils';
import Footer from '@/components/Footer.astro';
import Faqs from '@/components/faqs/Faqs.astro';
import topFrmae from '@/assets/top-frame.avif';

const financeSteps = [
  {
    image: step1,
    step: 'Step 1',
    title: 'Contact Our Team',
    description: 'Get in touch with us by phone or fill out a form! Our customer service team is on standby.',
  },
  {
    image: step2,
    step: 'Step 2',
    title: 'Schedule Inspection',
    description: 'We will schedule a convenient time to inspect your roof and assess the project scope.',
  },
  {
    image: step3,
    step: 'Step 3',
    title: 'Review Your Proposal',
    description: 'Receive a detailed proposal outlining the work, timeline, and transparent pricing.',
  },
];
---

<Layout title="Roofing Financing | Top Veteran Owned Roofing Company | Black Knight Roofing">
  <Navbar />
  <Hero title="Flexible Roof Financing <br/> For All Your Needs" subtitle="Colorado's #1 Veteran-Owned Roofing Company">
    <p>
      Your roof shouldn't wait because the timing isn't perfect. We work with Service Finance Company and Wisetack to
      offer payment plans that fit real budgets — starting at $99/month, with no down payment required and no penalty if
      you pay it off early.
    </p>
  </Hero>

  <!-- Branding -->
  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>

  <AboutFinancing />

  <!-- Statistics -->
  <Statistics />

  <!-- Financing Banner Section -->
  <NoiseBg class="container mx-auto my-8 overflow-hidden rounded-[16px] px-6 py-8">
    <div class="mx-auto flex w-full max-w-7xl flex-col items-center justify-between gap-14 lg:flex-row">
      <!-- Left side: Overlapping images -->
      <div class="relative h-[400px] w-full max-w-[554px] shrink-0 sm:h-[480px] lg:h-[521px]">
        <Image
          src={imgTop}
          alt=""
          class="absolute top-0 right-0 h-[340px] w-[85%] rounded-2xl object-cover sm:h-[400px] lg:left-[77px] lg:h-[434px] lg:w-[477px]"
        />
        <div
          class="absolute bottom-0 left-0 h-[280px] w-[80%] overflow-hidden rounded-2xl shadow-[0px_40px_60px_-15px_rgba(0,0,0,0.5)] sm:h-[340px] lg:top-[133px] lg:h-[388px] lg:w-[426px]"
        >
          <Image src={imgBottom} alt="" class="absolute inset-0 h-full w-full object-cover" />
          <div class="absolute inset-0 rounded-2xl bg-linear-to-b from-transparent to-black opacity-80"></div>
          <Image
            src={wisetackLogo}
            alt="Wisetack"
            class="absolute bottom-[20px] left-[20px] z-10 h-[30px] w-[180px] object-contain lg:h-[43px] lg:w-[248px]"
          />
        </div>
      </div>

      <!-- Right side: Text Content -->
      <div class="flex flex-col items-start gap-[40px] lg:max-w-[656px]">
        <div class="flex flex-col gap-[24px]">
          <div class="flex flex-col gap-[16px]">
            <div class="flex h-[32px] items-center gap-[12px] rounded-full">
              <!-- Chip -->
              <div class="relative flex h-[21px] w-[21px] shrink-0 items-center justify-center">
                <div class="absolute inset-0 m-auto h-[12px] w-[12px]">
                  <div class="absolute -inset-[38%] animate-pulse rounded-[5px] bg-[#f7b715] opacity-50"></div>
                  <div class="absolute inset-[2px] rounded-[10px] bg-[#f7d515] shadow-[0_0_4px_rgba(247,213,21,0.5)]">
                  </div>
                </div>
              </div>
              <p class="text-base leading-[24px] font-medium text-white">Upgrade your home's curb appeal</p>
            </div>
            <h2 class="font-heading max-w-xl text-[48px] leading-[60px] text-white">
              With payments that fit your budget.
            </h2>
          </div>

          <p class="text-[16px] leading-[24px] font-normal text-[#ccc]">
            Wisetack is one of our financing partners for projects where speed and flexibility matter. Apply in under
            two minutes, see your options without a hard credit pull, and choose the terms that make sense for your
            situation.
          </p>

          <ul class="flex flex-col gap-[16px]">
            <li class="flex items-center gap-[12px]">
              <Icon name="circle-tick" class="text-primary size-8" />
              <span class="text-[20px] leading-[32px] font-semibold text-[#ccc]"
                >Pay nothing for the first 6 months</span
              >
            </li>
            <li class="flex items-center gap-[12px]">
              <Icon name="circle-tick" class="text-primary size-8" />
              <span class="text-[20px] leading-[32px] font-semibold text-[#ccc]">0% interest for 12 months</span>
            </li>
            <li class="flex items-center gap-[12px]">
              <Icon name="circle-tick" class="text-primary size-8" />
              <span class="text-[20px] leading-[32px] font-semibold text-[#ccc]">New door from $39/mo</span>
            </li>
          </ul>

          <p class="text-[16px] leading-[24px] font-normal text-[#ccc]">
            Quick application. No hidden fees. No prepayment penalty. Get approved and schedule your project in the same
            call.
          </p>
        </div>

        <Button
          variant="primary"
          class="flex h-[56px] items-center justify-center rounded-[4px] px-[32px] py-[16px] text-[16px] font-semibold text-[#111]"
        >
          Get Approved
        </Button>
      </div>
    </div>
  </NoiseBg>

  <!-- How It Work -->

  <NoiseBg class="px-0 py-10 lg:py-20">
    <div class="container mx-auto space-y-12 px-4">
      <BadgeTitle
        badge="How It Work"
        title="We've Made Getting Your Roof Financed Easier than Ever"
        class="flex flex-col items-center text-center"
      />

      <div class="relative">
        <div class="flex flex-col items-center justify-center">
          <div
            class="relative z-0 flex flex-col items-center justify-center space-y-8 self-stretch lg:flex-row lg:gap-[-160px] lg:space-y-0 lg:pr-20"
          >
            {
              financeSteps.map((f, i) => (
                <div
                  class={cn('w-full max-w-[320px] lg:w-[300px]')}
                  style={`
                z-index: ${3 - i};
          `}
                >
                  <FinanceStepCard image={f.image} step={f.step} title={f.title} description={f.description} />
                </div>
              ))
            }
          </div>
        </div>

        <div
          class="bg-primary z-10 mx-auto mt-12 flex w-full max-w-[942px] flex-col items-center gap-6 rounded-lg p-6 lg:-translate-y-20 lg:flex-row lg:items-center"
        >
          <div class="shrink-0">
            <Image
              src={CreditCardImage}
              width={426}
              height={230}
              alt="Credit Card Image"
              class="h-auto w-[180px] lg:h-[115px] lg:w-[213px]"
            />
          </div>

          <div class="text-inverted flex flex-1 flex-col items-center gap-6 text-center lg:flex-row lg:text-left">
            <div class="flex-1">
              <h4 class="text-xl font-bold lg:pb-2 lg:text-2xl">Explore 0%* APR Financing for your project</h4>
              <p class="text-sm opacity-80 lg:text-base">*0% interest for promotional period only</p>
            </div>

            <div class="flex flex-col items-center gap-y-4 lg:items-end">
              <Button
                class="text-inverted w-full bg-white px-6 py-4 text-sm leading-5 font-bold hover:bg-white hover:ring-1 hover:ring-black lg:w-auto"
              >
                See Options
              </Button>
              <div class="flex items-center gap-x-2 text-lg font-semibold lg:text-base">
                <Icon name="phone" class="size-6" />
                <span>(720) 805-9666 </span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </NoiseBg>

  <div class="relative">
    <Image
      src={topFrmae}
      width={topFrmae.width}
      height={topFrmae.height}
      alt="bottom shape"
      class="absolute inset-x-0 top-0 left-0 w-full"
    />

    <Faqs />
  </div>

  <Brands />
  <Footer />
</Layout>
