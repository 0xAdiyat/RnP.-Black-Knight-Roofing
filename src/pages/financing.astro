---
import Hero from '@/components/hero/Hero.astro';
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/Navbar.astro';
import Button from '@/components/ui/Button.astro';
import RatingStars from '@/components/ui/RatingStars.astro';
import QuoteForm from '@/components/cta/QuoteForm.astro';
import noise from '@/assets/noises.avif';
import { Icon } from 'astro-icon/components';
import Brands from '@/components/Brands.astro';
import AboutFinancing from '@/components/AboutFinancing.astro';
import NoiseBg from '@/components/NoiseBg.astro';
import { Image } from 'astro:assets';
import checkIcon from '@/assets/financing-banner/check.svg';
import imgTop from '@/assets/financing-banner/img-top.png';
import imgBottom from '@/assets/financing-banner/img-bottom.png';
import wisetackLogo from '@/assets/financing-banner/wisetack-logo.png';
import Statistics from '@/components/ui/Statistics.astro';
import BadgeTitle from '@/components/BadgeTitle.astro';
import FinanceStepCard from '@/components/finance/FinanceStepCard.astro';
import step1 from '@/assets/steps/step-3.png';
import step2 from '@/assets/steps/step-5.png';
import step3 from '@/assets/steps/step-6.png';
import CreditCardImage from '@/assets/credit-card.avif';
import { cn } from '@/lib/utils';
import Footer from '@/components/Footer.astro';
import Faqs from '@/components/faqs/Faqs.astro';
import topFrmae from '@/assets/top-frame.avif';
import roof from '@/assets/roof.avif';

const financeSteps = [
  {
    image: step1,
    step: 'STEP 01',
    title: '',
    description: 'Apply in minutes with our trusted financing partner.',
  },
  {
    image: step2,
    step: 'STEP 02',
    title: '',
    description: 'Get approved instantly with flexible payment options.',
  },
  {
    image: step3,
    step: 'STEP 03',
    title: '',
    description: 'Your roof gets done. You pay over time.',
  },
];

import heroImage from '@/assets/bg/faq-and-financing-section__hero.avif';
import EstimateButton from '@/components/EstimateButton.astro';
---

<Layout title="Roofing Financing | Top Veteran Owned Roofing Company | Black Knight Roofing">
  <Navbar />
  <div id="hero-section">
    <Hero
      backgroundImage={heroImage}
      title="Flexible Roof Financing <br/> For All Your Needs"
      subtitle="Colorado's #1 Veteran-Owned Roofing Company"
    >
      <p>
        Your roof shouldn't wait because the timing isn't perfect. We work with Service Finance Company and Wisetack to
        offer payment plans that fit real budgets — starting at $99/month, with no down payment required and no penalty
        if you pay it off early.
      </p>
    </Hero>
  </div>

  <!-- Branding -->
  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>

  <AboutFinancing />

  <!-- Statistics -->
  <Statistics />

  <!-- Financing Banner Section -->
  <NoiseBg class="container mx-auto my-8 overflow-hidden rounded-[16px] px-6 py-8">
    <div class="mx-auto flex w-full max-w-7xl flex-col items-center justify-between gap-14 lg:flex-row">
      <!-- Left side: Overlapping images -->
      <div class="relative h-[400px] w-full max-w-[554px] shrink-0 sm:h-[480px] lg:h-[521px]">
        <Image
          src={imgTop}
          alt=""
          class="absolute top-0 right-0 h-[340px] w-[85%] rounded-2xl object-cover sm:h-[400px] lg:left-[77px] lg:h-[434px] lg:w-[477px]"
        />
        <div
          class="absolute bottom-0 left-0 h-[280px] w-[80%] overflow-hidden rounded-2xl shadow-[0px_40px_60px_-15px_rgba(0,0,0,0.5)] sm:h-[340px] lg:top-[133px] lg:h-[388px] lg:w-[426px]"
        >
          <Image src={imgBottom} alt="" class="absolute inset-0 h-full w-full object-cover" />
          <div class="absolute inset-0 rounded-2xl bg-linear-to-b from-transparent to-black opacity-80"></div>
          <Image
            src={wisetackLogo}
            alt="Wisetack"
            class="absolute bottom-[20px] left-[20px] z-10 h-[30px] w-[180px] object-contain lg:h-[43px] lg:w-[248px]"
          />
        </div>
      </div>

      <!-- Right side: Text Content -->
      <div class="flex flex-col items-start gap-[40px] lg:max-w-[656px]">
        <div class="flex flex-col gap-[24px]">
          <div class="flex flex-col gap-[16px]">
            <div class="flex h-[32px] items-center gap-[12px] rounded-full">
              <!-- Chip -->
              <div class="relative flex h-[21px] w-[21px] shrink-0 items-center justify-center">
                <div class="absolute inset-0 m-auto h-[12px] w-[12px]">
                  <div class="absolute -inset-[38%] animate-pulse rounded-[5px] bg-[#f7b715] opacity-50"></div>
                  <div class="absolute inset-[2px] rounded-[10px] bg-[#f7d515] shadow-[0_0_4px_rgba(247,213,21,0.5)]">
                  </div>
                </div>
              </div>
              <p class="text-base leading-[24px] font-medium text-white">Upgrade your home's curb appeal</p>
            </div>
            <h2 class="font-heading max-w-xl text-3xl leading-tight text-white lg:text-[48px] lg:leading-[60px]">
              With payments that fit your budget.
            </h2>
          </div>

          <p class="text-[16px] leading-[24px] font-normal text-[#ccc]">
            Wisetack is one of our financing partners for projects where speed and flexibility matter. Apply in under
            two minutes, see your options without a hard credit pull, and choose the terms that make sense for your
            situation.
          </p>

          <ul class="flex flex-col gap-[16px]">
            <li class="flex items-center gap-[12px]">
              <Icon name="circle-tick" class="text-primary size-8" />
              <span class="text-lg leading-snug font-semibold text-[#ccc] lg:text-[20px] lg:leading-[32px]"
                >Pay nothing for the first 6 months</span
              >
            </li>
            <li class="flex items-center gap-[12px]">
              <Icon name="circle-tick" class="text-primary size-8" />
              <span class="text-lg leading-snug font-semibold text-[#ccc] lg:text-[20px] lg:leading-[32px]"
                >0% interest for 12 months</span
              >
            </li>
            <li class="flex items-center gap-[12px]">
              <Icon name="circle-tick" class="text-primary size-8" />
              <span class="text-lg leading-snug font-semibold text-[#ccc] lg:text-[20px] lg:leading-[32px]"
                >New door from $39/mo</span
              >
            </li>
          </ul>

          <p class="text-[16px] leading-[24px] font-normal text-[#ccc]">
            Quick application. No hidden fees. No prepayment penalty. Get approved and schedule your project in the same
            call.
          </p>
        </div>

        <Button
          variant="primary"
          class="flex h-[56px] items-center justify-center rounded-[4px] px-[32px] py-[16px] text-[16px] font-semibold text-[#111]"
          data-estimate-trigger
        >
          Get Approved
        </Button>
      </div>
    </div>
  </NoiseBg>

  <!-- How It Work -->

  <NoiseBg class="px-0 py-10 lg:py-20">
    <div class="container mx-auto space-y-12 px-4">
      <BadgeTitle
        badge="How It Work"
        title="We've Made Getting Your Roof Financed Easier than Ever"
        class="flex flex-col items-center text-center"
      />

      <div class="relative">
        <div class="flex flex-col items-center justify-center">
          <div
            class="group relative z-0 flex flex-col items-center justify-center space-y-8 self-stretch lg:flex-row lg:gap-[-160px] lg:space-y-0 lg:pr-20"
          >
            {
              financeSteps.map((f, i) => (
                <div
                  class={cn(
                    'relative w-full max-w-[320px] cursor-pointer transition-transform duration-200 ease-out hover:-translate-y-4 hover:scale-105 lg:w-[300px]',
                    i === 0
                      ? 'z-30 hover:z-50 lg:group-hover:-translate-x-20'
                      : i === 1
                        ? 'z-20 hover:z-50'
                        : 'z-10 hover:z-50 lg:group-hover:translate-x-20'
                  )}
                >
                  <FinanceStepCard image={f.image} step={f.step} title={f.title} description={f.description} />
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </NoiseBg>

  <div class="relative">
    <Image
      src={topFrmae}
      width={topFrmae.width}
      height={topFrmae.height}
      alt="bottom shape"
      class="absolute inset-x-0 top-0 left-0 w-full"
    />

    <Faqs />
  </div>

  <div
    id="sticky-financing-banner"
    class="pointer-events-none fixed bottom-[80px] z-50 mx-auto flex w-full translate-y-[20px] flex-col items-center opacity-0 transition-all duration-300 ease-out lg:sticky lg:bottom-4 lg:mb-10 lg:max-w-[942px] lg:px-4"
  >
    <!-- Close Button (Mobile only) -->
    <div class="pointer-events-auto relative z-10 mb-[-24px] flex w-full justify-end pr-6 lg:hidden">
      <button
        id="close-financing-banner"
        class="bg-primary flex size-[52px] items-center justify-center rounded-full border-[2.5px] border-[#111] text-[#111] shadow-lg transition-transform active:scale-95"
        aria-label="Dismiss"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="28"
          height="28"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg
        >
      </button>
    </div>

    <!-- Banner Inner -->
    <div
      class="bg-primary pointer-events-auto w-full origin-bottom shadow-[0_-10px_40px_rgba(0,0,0,0.15)] ring-1 ring-black/5 transition duration-200 ease-out lg:scale-[0.7] lg:rounded-lg lg:ring-white/10 lg:hover:scale-100 lg:hover:shadow-[0_40px_60px_rgba(0,0,0,0.4)]"
    >
      <!-- Mobile Layout -->
      <div class="flex flex-col gap-6 px-6 pt-6 pb-6 lg:hidden">
        <!-- Top row: image + text -->
        <div class="flex items-center gap-6">
          <div class="shrink-0">
            <Image
              src={CreditCardImage}
              width={216}
              height={116}
              alt="Credit Card"
              class="h-[58px] w-[108px] object-cover drop-shadow-sm"
              style="aspect-ratio: 54/29;"
            />
          </div>
          <div class="flex flex-1 flex-col gap-2 text-[#000]">
            <h4
              style="font-family: 'Instrument Serif', serif; font-size: 20px; font-weight: 400; line-height: 28px; color: #000;"
            >
              Explore 0%* APR Financing for your project
            </h4>
            <p
              style="font-family: Manrope, sans-serif; font-size: 12px; font-weight: 400; line-height: 16px; color: #444;"
            >
              *0% interest for promotional period only
            </p>
          </div>
        </div>

        <!-- Bottom row: button (left) + phone (centered) -->
        <div class="flex w-full items-center justify-between">
          <Button
            class="rounded-[4px] bg-white px-5 py-2.5 text-sm font-semibold text-[#111] shadow-[0_2px_4px_rgba(0,0,0,0.08)] transition-transform hover:bg-white active:scale-95"
            data-estimate-trigger
          >
            See Options
          </Button>
          <a
            href="tel:9708887230"
            class="flex flex-1 items-center justify-center gap-2 text-[18px] font-medium text-[#111] transition-opacity hover:opacity-80"
          >
            <Icon name="phone" class="size-5" />
            <span>(970) 888-7230</span>
          </a>
        </div>
      </div>

      <!-- Desktop Layout -->
      <div class="hidden w-full flex-col items-center gap-6 p-5 lg:flex lg:flex-row lg:items-center lg:p-6">
        <div class="shrink-0">
          <Image
            src={CreditCardImage}
            width={426}
            height={230}
            alt="Credit Card Image"
            class="h-auto w-[180px] lg:h-[115px] lg:w-[213px]"
          />
        </div>

        <div class="text-inverted flex flex-1 flex-col items-center gap-6 text-center lg:flex-row lg:text-left">
          <div class="flex-1">
            <h4 class="text-xl font-medium lg:pb-2 lg:text-2xl">Explore 0%* APR Financing for your project</h4>
            <p class="text-sm opacity-80 lg:text-base">*0% interest for promotional period only</p>
          </div>

          <div class="flex flex-col items-center gap-y-4 lg:items-end">
            <Button
              class="text-inverted w-full bg-white px-6 py-4 text-sm leading-5 font-bold transition-transform hover:scale-105 hover:bg-white hover:ring-2 hover:ring-black/20 lg:w-auto"
              data-estimate-trigger
            >
              See Options
            </Button>
            <a
              href="tel:9708887230"
              class="flex items-center gap-x-2 text-lg font-semibold transition-opacity hover:opacity-80 lg:text-base"
            >
              <Icon name="phone" class="size-6" />
              <span>(970) 888-7230 </span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div id="brands-section">
    <Brands />
  </div>

  <!-- CTA Section -->
  <section class="py-10 sm:py-20">
    <div class="container">
      <div
        class="border-gradient before:via-primary relative before:bg-linear-to-r before:from-transparent before:to-transparent"
      >
        <div class="relative overflow-hidden rounded-[24px]">
          <Image
            src={roof}
            width={roof.width}
            height={roof.height}
            alt="roof"
            class="absolute top-0 right-0 h-[140%] w-full object-cover object-right opacity-70 transition-opacity duration-700"
          />

          <Image
            src={noise}
            alt="noise"
            class="absolute top-0 right-0 h-[140%] w-full object-cover object-right opacity-10 transition-opacity duration-700"
          />

          <!-- Content -->
          <div
            class="relative z-10 flex flex-col items-center gap-6 bg-linear-[30deg] from-[rgba(242,199,68,0.7)] to-[rgba(13,13,13,0.3)] to-45% px-6 py-6 text-center"
          >
            <!-- Badge/Chip -->
            <BadgeTitle badge="Let's Get Started" title="Apply Online Today" class="flex flex-col items-center" />

            <!-- Heading & Text -->
            <p class="text-neutral-lighter mx-auto max-w-2xl pb-6 text-sm leading-relaxed">
              Most homeowners put off a roof they know needs replacing because the cost feels like too much to take on
              at once. Financing changes that. Fill out a short form, see your options, and get your project on the
              calendar — without emptying your savings account.
            </p>

            <!-- Button with Arrow Callout -->
            <div class="relative">
              <EstimateButton offerText="" actionText="Get Approved" />

              <!-- Arrow & Handwritten Note (Visible on desktop) -->
              <div class="absolute -top-4 left-[calc(100%+16px)] hidden -translate-y-1/2 lg:flex">
                <div class="flex items-center gap-4 whitespace-nowrap">
                  <!-- Arrow -->
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="90"
                    height="23"
                    viewBox="0 0 90 23"
                    fill="none"
                    class="h-8 w-auto opacity-60"
                  >
                    <path
                      d="M4.20312 7.70595C14.8698 11.296 41.8031 17.5068 64.2031 13.6295C67.9365 13.2705 77.9631 10.6139 88.2031 2.85938"
                      stroke="url(#paint0_linear_17029_56390)"
                      stroke-width="2"
                      stroke-linecap="round"></path>
                    <path
                      d="M20.4375 0.172852C20.8942 -0.137698 21.5166 -0.0191765 21.8271 0.4375C22.1377 0.89419 22.0192 1.51659 21.5625 1.82715C15.0658 6.24489 9.5142 7.77626 5.59277 8.00488C7.38685 9.14202 9.34084 10.5047 11.1934 12.0117C14.6103 14.7914 17.8599 18.2007 18.9541 21.7021C19.1186 22.2292 18.8249 22.7894 18.2979 22.9541C17.7708 23.1186 17.2106 22.8249 17.0459 22.2979C16.14 19.3994 13.3061 16.3086 9.93164 13.5635C6.59779 10.8514 2.9074 8.61271 0.541016 7.38867C0.0506437 7.13503 -0.141991 6.53147 0.111328 6.04102C0.285754 5.70379 0.625663 5.50741 0.980469 5.5C1.01809 5.49924 1.05586 5.50131 1.09375 5.50488C1.15292 5.51041 1.21209 5.52065 1.27051 5.53711C1.28039 5.5399 1.28996 5.54377 1.2998 5.54688C1.32266 5.55409 1.34561 5.56135 1.36816 5.57031C1.36912 5.57069 1.37014 5.57091 1.37109 5.57129C3.46043 6.40702 10.6073 6.8574 20.4375 0.172852Z"
                      fill="white"></path>
                    <defs>
                      <linearGradient
                        id="paint0_linear_17029_56390"
                        x1="98.6031"
                        y1="5.01341"
                        x2="62.5709"
                        y2="-26.4136"
                        gradientUnits="userSpaceOnUse"
                      >
                        <stop stop-color="#686868"></stop>
                        <stop offset="1" stop-color="white"></stop>
                      </linearGradient>
                    </defs>
                  </svg>

                  <div class="font-caveat flex translate-y-4 rotate-[-10deg] flex-col items-start">
                    <span
                      class="bg-linear-to-r from-white to-[#8C8C8C] bg-clip-text text-3xl leading-tight text-transparent italic"
                      >No Obligation</span
                    >
                    <span
                      class="bg-linear-to-r from-white/80 to-[#8C8C8C]/80 bg-clip-text text-[19px] leading-none text-transparent"
                      >It only takes 60 seconds</span
                    >
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <Footer />
</Layout>

<script>
  let cleanupFinancingBanner: (() => void) | null = null;

  function setupFinancingBanner() {
    const banner = document.getElementById('sticky-financing-banner');
    const closeBtn = document.getElementById('close-financing-banner');
    if (!banner || banner.dataset.bannerReady === 'true') return;

    banner.dataset.bannerReady = 'true';

    if (typeof cleanupFinancingBanner === 'function') {
      cleanupFinancingBanner();
    }

    let isDismissed = false;

    if (closeBtn) {
      closeBtn.addEventListener('click', () => {
        isDismissed = true;
        banner.classList.add('translate-y-full', 'opacity-0');
        banner.style.pointerEvents = 'none';
        setTimeout(() => banner.remove(), 300);
      });
    }

    const triggerSection = document.getElementById('hero-section');

    const getThreshold = () => {
      if (!triggerSection) return 300;
      // Show when the top of the "Industry-Best Warranties & Financing" section hits the top of viewport.
      return triggerSection.getBoundingClientRect().top + window.scrollY;
    };

    const handleScroll = () => {
      if (isDismissed) return;
      if (window.scrollY > getThreshold()) {
        banner.classList.remove('translate-y-[20px]', 'opacity-0');
        banner.classList.add('translate-y-0', 'opacity-100');
      } else {
        banner.classList.add('translate-y-[20px]', 'opacity-0');
        banner.classList.remove('translate-y-0', 'opacity-100');
      }
    };

    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll();

    cleanupFinancingBanner = () => {
      window.removeEventListener('scroll', handleScroll);
    };
  }

  setupFinancingBanner();
  document.addEventListener('astro:after-swap', setupFinancingBanner);
</script>
