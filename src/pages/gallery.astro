---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '@/components/hero/Hero.astro';
import Brands from '@/components/Brands.astro';
import CTASection from '@/components/cta/CTASection.astro';
import Footer from '@/components/Footer.astro';
import QuoteForm from '@/components/cta/QuoteForm.astro';
import Testimonials from '@/components/Testimonials.astro';
import ServiceAreas from '@/components/service-area/ServiceAreas.astro';
import NoiseBg from '@/components/NoiseBg.astro';
import { Icon } from 'astro-icon/components';
import Button from '@/components/ui/Button.astro';
import RatingStars from '@/components/ui/RatingStars.astro';
import EmptyGalleryFolder from '@/components/ui/EmptyGalleryFolder.astro';
import sunFlow from '@/assets/sunflow.avif';
import { Image } from 'astro:assets';
import WorkCard from '@/components/recent-projects/WorkCard.astro';
import Statistics from '@/components/ui/Statistics.astro';
import SocialProof from '@/components/ui/SocialProof.astro';
import heroImage from '@/assets/bg/services-and-gallery-section__hero.avif';
import serviceRoofingImg from '@/assets/services/service-roofing.png';
import serviceSidingImg from '@/assets/services/service-siding.png';
import serviceGutterImg from '@/assets/services/service-gutter.png';
import beforeAfterImg from '@/assets/comparison/roof-mini.png';
import residentialHero from '@/assets/bg/residential-roofing-section__hero.avif';
import caseStudiesHero from '@/assets/bg/case-studies-section__hero.avif';
import metalRoofingHero from '@/assets/bg/metal-roofing-section__hero.avif';
import stoneCoatedHero from '@/assets/bg/stone-coated-steel-roofing-section__hero.avif';
import concreteTileHero from '@/assets/bg/concrete-tile-roof-section__hero.avif';
import asphaltShingleHero from '@/assets/bg/roof-replacement-section__hero.avif'; // ridge line photo
import commercialRoofingHero from '@/assets/bg/commercial-roofing-section__hero.avif';
import sidingHero from '@/assets/bg/siding-section__hero.avif';
import guttersHero from '@/assets/bg/gutters-section__hero.avif';
import beforeAfterHero from '@/assets/bg/before-after-section__hero.avif';
import tile1 from '@/assets/tiles/component-1.png';
import tile2 from '@/assets/tiles/component-2.png';
import tile3 from '@/assets/tiles/component-3.png';
import tile4 from '@/assets/tiles/component-4.png';
import tile5 from '@/assets/tiles/component-5.png';

type GalleryCategory = 'Roofing' | 'Siding' | 'Gutters';
type GalleryFilter = 'featured' | 'roofing' | 'siding' | 'gutters';

const works = [
  {
    id: 'roofing-1',
    image: tile1,
    title: 'EDCO METAL SIDING',
    subtitle: 'CHARCOAL GRAY',
    category: 'Roofing' as GalleryCategory,
    date: '2026-03-24',
  },
  {
    id: 'roofing-2',
    image: tile2,
    title: 'Stone Coated Steel',
    subtitle: 'Weathered Wood',
    category: 'Roofing' as GalleryCategory,
    date: '2026-03-18',
  },
  {
    id: 'roofing-3',
    image: tile3,
    title: 'Concrete Tile',
    subtitle: 'Barcelona Sand',
    category: 'Roofing' as GalleryCategory,
    date: '2026-03-10',
  },
  {
    id: 'roofing-4',
    image: tile4,
    title: 'Asphalt Shingle',
    subtitle: 'Estate Gray',
    category: 'Roofing' as GalleryCategory,
    date: '2026-03-02',
  },
  {
    id: 'roofing-5',
    image: tile5,
    title: 'EDCO METAL SIDING',
    subtitle: 'CHARCOAL GRAY',
    category: 'Roofing' as GalleryCategory,
    date: '2026-02-24',
  },
  {
    id: 'roofing-6',
    image: metalRoofingHero,
    title: 'Stone Coated Steel',
    subtitle: 'Weathered Wood',
    category: 'Roofing' as GalleryCategory,
    date: '2026-02-16',
  },
  {
    id: 'roofing-7',
    image: stoneCoatedHero,
    title: 'Concrete Tile',
    subtitle: 'Barcelona Sand',
    category: 'Roofing' as GalleryCategory,
    date: '2026-02-08',
  },
  {
    id: 'roofing-8',
    image: concreteTileHero,
    title: 'Asphalt Shingle',
    subtitle: 'Estate Gray',
    category: 'Roofing' as GalleryCategory,
    date: '2026-02-01',
  },
  {
    id: 'roofing-9',
    image: asphaltShingleHero,
    title: 'Test Project 09',
    subtitle: 'Pagination Sample',
    category: 'Roofing' as GalleryCategory,
    date: '2026-01-24',
  },
  {
    id: 'roofing-10',
    image: commercialRoofingHero,
    title: 'Test Project 10',
    subtitle: 'Pagination Sample',
    category: 'Roofing' as GalleryCategory,
    date: '2026-01-16',
  },
  {
    id: 'roofing-11',
    image: tile1,
    title: 'Test Project 11',
    subtitle: 'Pagination Sample',
    category: 'Roofing' as GalleryCategory,
    date: '2026-01-08',
  },
  {
    id: 'roofing-12',
    image: tile2,
    title: 'Test Project 12',
    subtitle: 'Pagination Sample',
    category: 'Roofing' as GalleryCategory,
    date: '2026-01-01',
  },
];

const filterParam = (Astro.url.searchParams.get('filter') || 'featured').toLowerCase();
const allowedFilters: GalleryFilter[] = ['featured', 'roofing', 'siding', 'gutters'];
const activeFilter: GalleryFilter = allowedFilters.includes(filterParam as GalleryFilter)
  ? (filterParam as GalleryFilter)
  : 'featured';
const itemsPerPage = 12;

const sortedWorks = [...works].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
const filteredWorks =
  activeFilter === 'featured'
    ? sortedWorks
    : sortedWorks.filter((work) => work.category.toLowerCase() === activeFilter);

const requestedPage = Number(Astro.url.searchParams.get('page') || 1);
const totalPages = Math.max(1, Math.ceil(filteredWorks.length / itemsPerPage));
const currentPage = Math.min(Math.max(requestedPage, 1), totalPages);
const displayedWorks = filteredWorks.slice((currentPage - 1) * itemsPerPage, currentPage * itemsPerPage);
const visibleWorkIds = new Set(displayedWorks.map((work) => work.id));
const hasResults = filteredWorks.length > 0;

const getFilterHref = (filter: GalleryFilter) => {
  const url = new URL('/gallery', Astro.url.origin);
  if (filter !== 'featured') {
    url.searchParams.set('filter', filter);
  }
  return url.pathname + url.search;
};

const galleryFilters = [
  { label: 'Featured', image: residentialHero.src, type: 'filter', filter: 'featured' as GalleryFilter },
  { label: 'Roofing', image: asphaltShingleHero.src, type: 'filter', filter: 'roofing' as GalleryFilter },
  { label: 'Siding', image: sidingHero.src, type: 'filter', filter: 'siding' as GalleryFilter },
  { label: 'Gutters', image: guttersHero.src, type: 'filter', filter: 'gutters' as GalleryFilter },
  { label: 'Before-After', image: beforeAfterHero.src, type: 'link', href: '/before-and-after' },
  { label: 'Case Studies', image: caseStudiesHero.src, type: 'link', href: '/case-studies' },
];
---

<Layout title="Denver Roofing Portfolio | Black Knight Roofing">
  <Navbar />

  <!-- Hero section -->

  <Hero backgroundImage={heroImage} title="Black Knight Roofing Photo Gallery" subtitle="Colorado's #1 Veteran-Owned Roofing Company">
    <p>
      Black Knight Roofing contractors improve home value by providing modern and quality exterior solutions. See for
      yourself.
    </p>
  </Hero>

  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>

  <!-- Filters -->
  <div class="relative px-0 py-0" data-gallery-root>
    <Image
      src={sunFlow}
      alt="sun-flow"
      width={1920}
      height={1080}
      fetchpriority="high"
      loading="eager"
      format="avif"
      sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 25vw"
      class="absolute inset-0 h-full w-full object-cover opacity-20"
    />
    <div class="container py-20">
      <div class="z-10 flex flex-col items-center space-y-6">
        <div class="flex items-center justify-center gap-3">
          <div class="flex size-8 items-center justify-center rounded-full bg-[#B68A3D] text-black">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="4" y1="6" x2="20" y2="6"></line>
              <line x1="4" y1="12" x2="14" y2="12"></line>
              <line x1="4" y1="18" x2="8" y2="18"></line>
            </svg>
          </div>
          <div class="text-[20px] font-medium tracking-tight text-white/90">Filter GALLERY By:</div>
        </div>

        <div class="flex flex-wrap items-center justify-center gap-2 rounded-2xl border border-white/24 p-2">
          {
            galleryFilters.map((filter, index) => (
              <>
                {index === 4 && <div class="hidden h-[90px] w-px bg-white/15 md:block"></div>}
                <a
                  href={filter.type === 'filter' && filter.filter ? getFilterHref(filter.filter) : filter.href}
                  aria-current={filter.type === 'filter' && activeFilter === filter.filter ? 'page' : undefined}
                  data-gallery-filter={filter.type === 'filter' ? filter.filter : undefined}
                  class:list={[
                    'group relative block h-[135px] w-[116px] shrink-0 overflow-hidden rounded-xl text-center transition-transform duration-300 ease-out hover:-translate-y-1',
                    filter.type === 'filter' && activeFilter === filter.filter ? 'border-radial' : 'border-gradient',
                  ]}
                >
                  <img
                    src={filter.image}
                    alt={filter.label}
                    class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                  <div class="absolute inset-0 bg-linear-to-t from-black/90 via-black/30 to-transparent"></div>
                  <div class="absolute inset-x-0 bottom-0 p-[16px]">
                    <div class="text-[14px] leading-[20px] font-medium text-white">{filter.label}</div>
                  </div>
                </a>
              </>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <!-- Gallery -->
  <NoiseBg class="px-0">
    <div class="container py-20">
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4" data-gallery-grid>
        {
          sortedWorks.map((work) => (
            <div
              data-gallery-card
              data-work-id={work.id}
              data-category={work.category.toLowerCase()}
              class:list={[
                'transition duration-300 ease-out will-change-transform',
                visibleWorkIds.has(work.id) ? '' : 'hidden',
              ]}
            >
              <WorkCard image={work.image} title={work.title} subtitle={work.subtitle} category={work.category} />
            </div>
          ))
        }
      </div>

      <div
        data-gallery-empty
        class:list={[
          'mx-auto max-w-3xl px-8 py-14 text-center transition duration-300 ease-out',
          hasResults ? 'hidden' : '',
        ]}
      >
        <EmptyGalleryFolder />
        <h2 class="mt-4 text-3xl font-semibold text-white sm:text-4xl" data-gallery-empty-title>
          We&apos;re adding more {activeFilter} project examples.
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-base leading-8 text-white/70 sm:text-lg">
          In the meantime, explore our before-and-after transformations or review full project stories in our case
          studies.
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <Button variant="primary" href="/before-and-after">
            View Before &amp; After
          </Button>
          <Button variant="secondary" href="/case-studies">
            Read Case Studies
          </Button>
        </div>
      </div>

      <div
        data-gallery-pagination
        class:list={['mt-12 flex flex-col items-center justify-between gap-8 md:flex-row', hasResults ? '' : 'hidden']}
      >
        <div class="flex flex-col gap-1.5 text-center md:text-left">
          <div class="text-[11px] font-semibold uppercase tracking-[0.24em] text-white/45" data-gallery-count>
            {filteredWorks.length} {filteredWorks.length === 1 ? 'Project' : 'Projects'}
          </div>
          <div class="text-sm text-white/65" data-gallery-summary>
            {
              filteredWorks.length > 0
                ? `Showing ${(currentPage - 1) * itemsPerPage + 1}-${Math.min(currentPage * itemsPerPage, filteredWorks.length)} of ${filteredWorks.length}`
                : 'No projects yet'
            }
          </div>
        </div>

        <div class="flex items-center gap-2.5">
          <button
            type="button"
            data-gallery-prev
            aria-label="Previous page"
            class="inline-flex size-11 items-center justify-center rounded-full bg-white/10 text-white/70 backdrop-blur-[16.5px] transition-all duration-300 hover:bg-white/20 hover:text-white disabled:pointer-events-none disabled:opacity-30"
            disabled={currentPage <= 1}
          >
            <Icon name="chevron-left" class="size-5" />
          </button>

          <div class="flex items-center gap-2" data-gallery-pages>
            {
              Array.from({ length: totalPages }, (_, index) => {
                const pageNumber = index + 1;
                return (
                  <button
                    type="button"
                    data-gallery-page={pageNumber}
                    class:list={[
                      'inline-flex size-11 items-center justify-center rounded-full text-sm font-medium backdrop-blur-[16.5px] transition-all duration-300',
                      currentPage === pageNumber
                        ? 'border-radial bg-[#0d0d0d] text-white'
                        : 'bg-white/10 text-white/70 hover:bg-white/20 hover:text-white',
                    ]}
                  >
                    {pageNumber}
                  </button>
                );
              })
            }
          </div>

          <button
            type="button"
            data-gallery-next
            aria-label="Next page"
            class="inline-flex size-11 items-center justify-center rounded-full bg-white/10 text-white/70 backdrop-blur-[16.5px] transition-all duration-300 hover:bg-white/20 hover:text-white disabled:pointer-events-none disabled:opacity-30"
            disabled={currentPage >= totalPages}
          >
            <Icon name="chevron-right" class="size-5" />
          </button>
        </div>
      </div>
    </div>
  </NoiseBg>

  <Statistics />

  <Testimonials />
  <ServiceAreas />

  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>
  <CTASection />
  <Footer />

  <script
    define:vars={{
      sortedWorks,
      itemsPerPage,
      initialFilter: activeFilter,
      initialPage: currentPage,
    }}
  >
    const root = document.querySelector('[data-gallery-root]');

    if (root) {
      const cards = Array.from(document.querySelectorAll('[data-gallery-card]'));
      const filterTiles = Array.from(root.querySelectorAll('[data-gallery-filter]'));
      const emptyState = document.querySelector('[data-gallery-empty]');
      const emptyTitle = document.querySelector('[data-gallery-empty-title]');
      const paginationShell = document.querySelector('[data-gallery-pagination]');
      const pagesContainer = document.querySelector('[data-gallery-pages]');
      const prevButton = document.querySelector('[data-gallery-prev]');
      const nextButton = document.querySelector('[data-gallery-next]');
      const summary = document.querySelector('[data-gallery-summary]');
      const count = document.querySelector('[data-gallery-count]');

      const state = {
        filter: initialFilter,
        page: initialPage,
      };

      const works = sortedWorks.map((work) => ({
        ...work,
        category: work.category.toLowerCase(),
      }));

      const formatFilterLabel = (filter) =>
        filter === 'featured' ? 'featured' : filter.charAt(0).toUpperCase() + filter.slice(1);

      const getFilteredWorks = () =>
        state.filter === 'featured' ? works : works.filter((work) => work.category === state.filter);

      const getUrlForState = () => {
        const url = new URL(window.location.href);
        if (state.filter === 'featured') {
          url.searchParams.delete('filter');
        } else {
          url.searchParams.set('filter', state.filter);
        }

        if (state.page <= 1) {
          url.searchParams.delete('page');
        } else {
          url.searchParams.set('page', String(state.page));
        }

        return url;
      };

      const updateUrl = (mode = 'replace') => {
        const url = getUrlForState();
        window.history[mode === 'push' ? 'pushState' : 'replaceState']({}, '', `${url.pathname}${url.search}`);
      };

      const animateCards = (visibleCards) => {
        visibleCards.forEach((card, index) => {
          card.animate(
            [
              { opacity: 0, transform: 'translateY(18px) scale(0.985)' },
              { opacity: 1, transform: 'translateY(0) scale(1)' },
            ],
            {
              duration: 360,
              delay: index * 45,
              easing: 'cubic-bezier(0.22, 1, 0.36, 1)',
              fill: 'both',
            }
          );
        });
      };

      const updateFilterTiles = () => {
        filterTiles.forEach((tile) => {
          const isActive = tile.dataset.galleryFilter === state.filter;
          tile.setAttribute('aria-current', isActive ? 'page' : 'false');
          tile.classList.toggle('border-radial', isActive);
          tile.classList.toggle('border-gradient', !isActive);
          tile.classList.toggle('scale-[1.02]', isActive);
        });
      };

      const renderPagination = (totalPages) => {
        if (!pagesContainer || !prevButton || !nextButton || !summary || !count || !paginationShell) return;

        pagesContainer.innerHTML = '';

        prevButton.disabled = state.page <= 1;
        nextButton.disabled = state.page >= totalPages;

        for (let page = 1; page <= totalPages; page += 1) {
          const pageButton = document.createElement('button');
          pageButton.type = 'button';
          pageButton.dataset.galleryPage = String(page);
          pageButton.textContent = String(page);
          pageButton.className =
            'inline-flex size-11 items-center justify-center rounded-full text-sm font-medium backdrop-blur-[16.5px] transition-all duration-300';

          if (page === state.page) {
            pageButton.classList.add('border-radial', 'bg-[#0d0d0d]', 'text-white');
          } else {
            pageButton.classList.add('bg-white/10', 'text-white/70', 'hover:bg-white/20', 'hover:text-white');
          }

          pageButton.addEventListener('click', () => {
            if (state.page === page) return;
            state.page = page;
            render({ pushHistory: true });
          });

          pagesContainer.append(pageButton);
        }

        const filteredWorks = getFilteredWorks();
        const start = filteredWorks.length ? (state.page - 1) * itemsPerPage + 1 : 0;
        const end = Math.min(state.page * itemsPerPage, filteredWorks.length);

        count.textContent = `${filteredWorks.length} ${filteredWorks.length === 1 ? 'Project' : 'Projects'}`;
        summary.textContent =
          filteredWorks.length > 0 ? `Showing ${start}-${end} of ${filteredWorks.length}` : 'No projects yet';
        paginationShell.classList.toggle('hidden', filteredWorks.length === 0);
      };

      const render = ({ pushHistory = false } = {}) => {
        const filteredWorks = getFilteredWorks();
        const totalPages = Math.max(1, Math.ceil(filteredWorks.length / itemsPerPage));
        state.page = Math.min(Math.max(state.page, 1), totalPages);

        const startIndex = (state.page - 1) * itemsPerPage;
        const visibleIds = new Set(filteredWorks.slice(startIndex, startIndex + itemsPerPage).map((work) => work.id));
        const visibleCards = [];

        cards.forEach((card) => {
          const isVisible = visibleIds.has(card.dataset.workId);
          card.classList.toggle('hidden', !isVisible);
          if (isVisible) {
            visibleCards.push(card);
          }
        });

        if (emptyState && emptyTitle) {
          emptyState.classList.toggle('hidden', filteredWorks.length > 0);
          emptyTitle.textContent = `We're adding more ${formatFilterLabel(state.filter)} project examples.`;
        }

        updateFilterTiles();
        renderPagination(totalPages);
        updateUrl(pushHistory ? 'push' : 'replace');

        requestAnimationFrame(() => animateCards(visibleCards));
      };

      filterTiles.forEach((tile) => {
        tile.addEventListener('click', (event) => {
          event.preventDefault();
          const nextFilter = tile.dataset.galleryFilter;
          if (!nextFilter || nextFilter === state.filter) return;
          state.filter = nextFilter;
          state.page = 1;
          render({ pushHistory: true });
        });
      });

      prevButton?.addEventListener('click', () => {
        if (state.page <= 1) return;
        state.page -= 1;
        render({ pushHistory: true });
      });

      nextButton?.addEventListener('click', () => {
        const totalPages = Math.max(1, Math.ceil(getFilteredWorks().length / itemsPerPage));
        if (state.page >= totalPages) return;
        state.page += 1;
        render({ pushHistory: true });
      });

      window.addEventListener('popstate', () => {
        const url = new URL(window.location.href);
        const nextFilter = url.searchParams.get('filter');
        const nextPage = Number(url.searchParams.get('page') || '1');

        state.filter = ['featured', 'roofing', 'siding', 'gutters'].includes(nextFilter || '')
          ? nextFilter
          : 'featured';
        state.page = Number.isFinite(nextPage) && nextPage > 0 ? nextPage : 1;

        render();
      });

      render();
    }
  </script>
</Layout>
