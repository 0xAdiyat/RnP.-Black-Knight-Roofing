---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '@/components/hero/Hero.astro';
import Brands from '@/components/Brands.astro';
import CTASection from '@/components/cta/CTASection.astro';
import Footer from '@/components/Footer.astro';
import QuoteForm from '@/components/cta/QuoteForm.astro';

import { Icon } from 'astro-icon/components';
import Button from '@/components/ui/Button.astro';
import Faqs2 from '@/components/faqs/Faqs2.astro';
import SocialProof from '@/components/ui/SocialProof.astro';

import FaqHeroImage from '@/assets/bg/faq.avif';
---

<Layout title="Denver Roofing FAQs | Black Knight Roofing">
  <Navbar />

  <Hero
    title="Got Question? <br/> We've Got Answers."
    subtitle="Colorado's #1 Veteran-Owned Roofing Company"
    backgroundImage={FaqHeroImage}
  >
    <p>
      We've compiled answers to the questions Colorado homeowners ask us most — from storm damage and insurance claims
      to materials, financing, and what to expect from our process. Can't find what you're looking for? Call us directly
      at (970) 888-7230.
    </p>
  </Hero>

  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>

  <Faqs2 />

  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>
  <CTASection />
  <Footer />
</Layout>
