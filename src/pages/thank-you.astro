---
import Layout from '@/layouts/Layout.astro';
import Button from '@/components/ui/Button.astro';
import { Icon } from 'astro-icon/components';
---

<Layout
  title="Booking Confirmed | Black Knight Roofing"
  description="Your roofing consultation has been booked. Black Knight Roofing will be in touch shortly."
  noindex={true}
  showNavbar={false}
  showFooter={false}
>
  <main class="relative flex min-h-dvh flex-col items-center justify-center overflow-hidden bg-noise px-4 py-16 text-center md:py-24">

    <!-- Background glow -->
    <div class="pointer-events-none absolute top-1/2 left-1/2 -z-10 -translate-x-1/2 -translate-y-1/2 select-none opacity-20">
      <div class="h-[300px] w-[300px] animate-pulse rounded-full bg-primary blur-[100px] md:h-[600px] md:w-[600px] md:blur-[150px]"></div>
    </div>

    <!-- Background watermark text -->
    <div class="pointer-events-none absolute inset-0 -z-10 flex items-center justify-center select-none overflow-hidden">
      <span class="font-heading text-[6rem] leading-none tracking-tighter text-white/[0.03] transition-all duration-500 sm:text-[10rem] md:text-[15rem] lg:text-[18rem]">
        Done
      </span>
    </div>

    <div class="relative z-10 flex flex-col items-center justify-center gap-y-8 max-w-2xl">

      <!-- Icon -->
      <div class="flex size-20 items-center justify-center rounded-full border border-primary/40 bg-primary/10">
        <Icon name="circle-tick" class="size-10 text-primary" />
      </div>

      <!-- Text -->
      <div class="space-y-4">
        <h1 class="font-heading text-4xl leading-none text-white sm:text-5xl md:text-6xl">
          You're all set!
        </h1>
        <p class="text-base text-tx-body/80 leading-relaxed text-pretty md:text-lg">
          Thank you for your appointment request. We will contact you shortly to confirm your request.
          Please call our office at{' '}
          <a href="tel:+17208040571" class="text-white underline underline-offset-2 hover:text-primary transition-colors">
            (720) 804-0571
          </a>{' '}
          if you have any questions.
        </p>
      </div>

      <!-- Actions -->
      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row pt-2">
        <Button variant="primary" size="lg" href="/" class="w-full sm:w-auto min-w-[200px]">
          <span>Back to Home</span>
        </Button>

        <Button variant="link" href="tel:+17208040571" class="flex items-center gap-2 group text-white/70 hover:text-white transition-all">
          <Icon name="phone" class="size-5 transition-transform group-hover:scale-110" />
          <span class="text-lg">(720) 804-0571</span>
        </Button>
      </div>
    </div>

    <!-- Bottom accent line -->
    <div class="absolute bottom-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-primary/40 to-transparent"></div>
  </main>
</Layout>

<!-- Facebook Pixel Code -->
<script is:inline>
  !function(f,b,e,v,n,t,s)
  {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
  n.callMethod.apply(n,arguments):n.queue.push(arguments)};
  if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
  n.queue=[];t=b.createElement(e);t.async=!0;
  t.src=v;s=b.getElementsByTagName(e)[0];
  s.parentNode.insertBefore(t,s)}(window,document,'script',
  'https://connect.facebook.net/en_US/fbevents.js');
  fbq('init', '1141065794815083');
  fbq('track', 'PageView');
  fbq('track', 'Schedule');
</script>
<noscript>
  <img height="1" width="1" style="display:none"
    src="https://www.facebook.com/tr?id=1141065794815083&ev=PageView&noscript=1" />
</noscript>
<!-- End Facebook Pixel Code -->

<style>
  .bg-noise {
    --noise-radial: radial-gradient(50% 50% at 50% 50%, rgba(48, 48, 48, 0) 0%, rgba(48, 48, 48, 0.4) 100%);
    --noise-overlay: linear-gradient(to bottom, rgba(0, 0, 0, 0.93), rgba(0, 0, 0, 0.9));
    --noise-bg: #111;
    background: var(--noise-radial), var(--noise-overlay), url('/noises.avif') 0 0 / contain repeat var(--noise-bg);
  }
</style>
