---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Button from '@/components/ui/Button.astro';
import { Icon } from 'astro-icon/components';
---

<Layout title="404 - Page Not Found | Black Knight Roofing" description="The page you are looking for does not exist. Return to Black Knight Roofing home page for expert roofing services in Denver.">
  <Navbar />
  
  <main class="relative flex min-h-dvh flex-col items-center justify-center overflow-hidden bg-noise px-4 py-16 text-center md:py-24">
    <!-- Animated background glow -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 -z-10 opacity-20 select-none pointer-events-none">
       <div class="w-[300px] h-[300px] md:w-[600px] md:h-[600px] bg-primary blur-[100px] md:blur-[150px] rounded-full animate-pulse"></div>
    </div>
 
    <!-- Background 404 Text - Fixed for responsiveness -->
    <div class="absolute inset-0 flex items-center justify-center -z-10 select-none pointer-events-none overflow-hidden">
      <span class="font-heading text-[10rem] sm:text-[15rem] md:text-[20rem] lg:text-[25rem] leading-none text-white/[0.03] tracking-tighter transition-all duration-500">
        404
      </span>
    </div>
 
    <div class="container relative z-10 flex flex-col items-center justify-center max-w-4xl">
      <h1 class="font-heading text-5xl sm:text-6xl md:text-8xl lg:text-9xl text-white leading-none text-balance mb-4">
          404
      </h1>
      
      <!-- Content -->
      <div class="max-w-2xl space-y-6 md:space-y-8">
        <p class="text-base sm:text-lg md:text-xl text-tx-body/80 text-pretty leading-relaxed">
          It looks like this page has been weathered away or moved to a new location. Don't worry, our structural integrity remains intact.
        </p>
        
        <!-- Actions -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 md:gap-6 pt-2">
          <Button variant="primary" size="lg" href="/" class="w-full sm:w-auto min-w-[200px]">
            <span>Back to Home</span>
          </Button>
          
          <Button variant="link" href="/contact-us" class="flex items-center gap-2 group text-white/70 hover:text-white transition-all">
            <Icon name="phone" class="size-5 transition-transform group-hover:scale-110" />
            <span class="text-lg">Contact Support</span>
          </Button>
        </div>
      </div>
    </div>
    
    <!-- Bottom accent line -->
    <div class="absolute bottom-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-primary/40 to-transparent"></div>
  </main>

  <Footer />
</Layout>

<style>
  .bg-noise {
    --noise-radial: radial-gradient(50% 50% at 50% 50%, rgba(48, 48, 48, 0) 0%, rgba(48, 48, 48, 0.4) 100%);
    --noise-overlay: linear-gradient(to bottom, rgba(0, 0, 0, 0.93), rgba(0, 0, 0, 0.9));
    --noise-bg: #111;
    background: var(--noise-radial), var(--noise-overlay), url('/noises.avif') 50% / cover no-repeat var(--noise-bg);
  }

  @keyframes floating {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  .animate-floating {
    animation: floating 3s ease-in-out infinite;
  }
</style>
