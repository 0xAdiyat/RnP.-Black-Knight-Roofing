---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/hero/Hero.astro';
import Brands from '@/components/Brands.astro';
import CTASection from '@/components/cta/CTASection.astro';
import { defaultCTA } from '@/data/cta';
import QuoteForm from '@/components/cta/QuoteForm.astro';
import Testimonials from '@/components/Testimonials.astro';
import ServiceAreas from '@/components/service-area/ServiceAreas.astro';
import NoiseBg from '@/components/NoiseBg.astro';
import { Icon } from 'astro-icon/components';
import Button from '@/components/ui/Button.astro';
import RatingStars from '@/components/ui/RatingStars.astro';
import Pagination from '@/components/ui/pagination/Pagination.astro';
import ArticalCard from '@/components/articales/ArticalCard.astro';
import { blogListItems } from '@/data/blogs';
import BadgeTitle from '@/components/BadgeTitle.astro';
import heroImage from '@/assets/bg/blogs-and-blog-details-section__hero.avif';

const currentPage = Number(Astro.url.searchParams.get('page') || 1);
const itemsPerPage = 6;
const totalPages = Math.ceil(blogListItems.length / itemsPerPage);
const displayedBlogs = blogListItems.slice((currentPage - 1) * itemsPerPage, currentPage * itemsPerPage);
---

<Layout noindex={true}>
  <Hero
    backgroundImage={heroImage}
    title="Black Knight Roofing Blog Posts"
    subtitle="Colorado's #1 Veteran-Owned Roofing Company"
  >
    <p>
      Explore insights and tips on roofing with Black Knight Roofing. Stay updated on the latest trends, maintenance
      advice, and expert guidance to protect your home.
    </p>
  </Hero>

  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>

  <!-- Gallery/Blogs -->
  <div
    class="bg-linear-[135deg,rgba(255,255,255,0.10)_0%,rgba(255,255,255,0.05)_50%,rgba(255,255,255,0.00)_100%] px-0 py-0"
  >
    <div class="container py-10 lg:py-20">
      <div class="mb-12 space-y-8 rounded-3xl border border-white/5 bg-[#222] p-4 md:p-8 lg:p-12">
        <div class="flex flex-col items-center justify-between gap-8 md:flex-row">
          <BadgeTitle title="Blog Posts by The Roof Pros" badge="Blogs" />

          <div class="w-full max-w-md">
            <div
              class="group border-radial has-focus-within:border-primary has-focus-within:ring-primary/50 relative rounded-2xl has-focus-within:ring-1"
            >
              <Icon
                name="search"
                class="group-focus-within:text-primary absolute top-1/2 left-4 size-5 -translate-y-1/2 text-white/40 transition-colors"
              />
              <input
                type="text"
                placeholder="Search articles about roofing, gutters, etc..."
                class="w-full rounded-2xl border bg-[#111] py-4 pr-4 pl-12 text-white placeholder-white/40 outline-none"
              />
            </div>
          </div>
        </div>

        <div class="flex flex-wrap items-center gap-2 border-t border-white/5 pt-6">
          <span class="pr-2 text-xs font-bold tracking-widest text-white/40 uppercase">Trending:</span>
          {
            ['Storm Damage', 'Cost Estimates', 'Spring Maintenance'].map(tag => (
              <button class="hover:bg-primary rounded-full bg-white/5 px-4 py-1.5 text-sm text-white transition-all hover:text-black">
                {tag}
              </button>
            ))
          }
        </div>
      </div>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        {displayedBlogs.map(blog => <ArticalCard {...blog} />)}
      </div>

      <!-- Pagination -->
      <div class="mt-20 flex justify-center">
        <Pagination currentPage={currentPage} totalPages={totalPages} baseUrl="/blog" />
      </div>
    </div>
  </div>

  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>
    <Brands />
  </div>
  <CTASection cta={defaultCTA} />
</Layout>
