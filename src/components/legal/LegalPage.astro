---
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';

interface Props {
  title: string;
  description: string;
  eyebrow?: string;
  heading: string;
  intro?: string;
  updatedLabel?: string;
}

const {
  title,
  description,
  eyebrow = 'Legal Information',
  heading,
  intro,
  updatedLabel = 'Last updated: March 31, 2026',
} = Astro.props;

const legalLinks = [
  { href: '/privacy-policy', label: 'Privacy Policy' },
  { href: '/accessibility', label: 'Accessibility' },
  { href: '/company-info', label: 'Company Info' },
  { href: '/terms-of-use', label: 'Terms of Use' },
];

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<Layout title={title} description={description}>
  <Navbar />
  <section class="legal-shell px-0 pt-32 pb-14 sm:pt-28 lg:pt-32">
    <div class="container">
      <div class="px-1 sm:px-4 lg:px-0">
        <div class="mb-8 flex items-start justify-between gap-6 sm:mb-10 lg:mb-12 lg:gap-8">
          <div class="min-w-0 max-w-5xl">
            <div
              transition:name="legal-meta-mobile"
              class="text-[0.72rem] leading-5 font-semibold tracking-[0.02em] text-white/45 uppercase lg:hidden"
            >
              <div>{eyebrow}</div>
              <div class="mt-1 normal-case">{updatedLabel}</div>
            </div>
            <h1 transition:name="legal-heading" class="legal-display-word mt-4 max-w-4xl text-left sm:mt-5">
              {heading}
            </h1>
          </div>
          <div
            transition:name="legal-meta-desktop"
            class="hidden shrink-0 pt-4 text-right text-[0.78rem] leading-5 font-semibold tracking-[0.02em] text-white/45 uppercase lg:block"
          >
            <div>{eyebrow}</div>
            <div class="mt-1 normal-case">{updatedLabel}</div>
          </div>
        </div>

        <div class="mx-auto max-w-4xl">
          {intro && <p transition:name="legal-intro" class="legal-intro mt-3 lg:mt-0">{intro}</p>}

          <div class="sticky top-18 z-30 mt-6 border-y border-white/10 bg-[#171717]/88 py-3 backdrop-blur-md sm:top-20 sm:mt-8 sm:py-4">
            <nav
              transition:name="legal-nav"
              aria-label="Legal pages"
              class="legal-tabs-scroll -mx-1 flex gap-2 overflow-x-auto px-1 sm:mx-0 sm:flex-wrap sm:gap-2.5 sm:overflow-visible sm:px-0"
            >
              {
                legalLinks.map(link => {
                  const isActive = pathname === link.href;

                  return (
                    <a
                      transition:name={`legal-tab-${link.label.toLowerCase().replace(/\s+/g, '-')}`}
                      href={link.href}
                      aria-current={isActive ? 'page' : undefined}
                      class:list={[
                        'shrink-0 rounded-full px-3 py-1.5 text-sm whitespace-nowrap transition-colors',
                        isActive
                          ? 'bg-primary text-black'
                          : 'text-white/58 hover:bg-white/5 hover:text-white',
                      ]}
                    >
                      {link.label}
                    </a>
                  );
              })
            }
          </nav>
          </div>

          <article transition:name="legal-content" class="legal-prose mt-8 sm:mt-10">
            <slot />
          </article>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
