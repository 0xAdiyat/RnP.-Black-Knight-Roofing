---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { Icon } from 'astro-icon/components';

import NoiseBg from '@/components/NoiseBg.astro';
import ProcessCard from './ProcessCard.astro';
import RatingStars from '@/components/ui/RatingStars.astro';
import bbaLogo from '@/assets/bbb-logo.png';
import dogImage from '@/assets/dog-image.png';
import bottomShape from '@/assets/bottom-shape.png';
import shineImage from '@/assets/sunflow.webp';

interface ProcessStep {
  image: ImageMetadata;
  imageAlt?: string;
  step: string;
  title: string;
  description: string;
}

interface QuoteInfo {
  profileImage?: string;
  profileAlt?: string;
  quote: string;
  author: string;
}

interface Props {
  badge?: string;
  heading?: string;
  subheading?: string;
  subheadingDescription?: string;
  quote?: QuoteInfo;
  steps?: ProcessStep[];
  class?: string;
}

const {
  badge = 'Our Process',
  heading = 'A Clear 4-step Plan <br />From Kick-off to Project',
  subheading = 'And Here is How!',
  subheadingDescription = "You shouldn't have to worry about not getting a call back, wondering when your project will start, or who to contact. Know what to expect with our clear, straightforward process!",
  quote = {
    profileImage: '/placeholders/profile.png',
    profileAlt: 'profile',
    quote: "We'll help you every step of the way.",
    author: 'Adam Knight, President',
  },
  steps = [],
  class: className,
} = Astro.props;
---

<NoiseBg class:list={['relative space-y-12 overflow-hidden px-0 py-20', className]}>
  <!-- Top Section -->
  <div class="container flex flex-col gap-y-12 lg:flex-row lg:items-center">
    <div class="w-full space-y-4 lg:flex-1">
      <div class="flex items-center gap-x-3">
        <div
          class="relative size-5 rounded-[5px] bg-[#F7B715]/50 drop-shadow-2xl before:absolute before:top-1/2 before:left-1/2 before:size-2 before:-translate-1/2 before:rounded-full before:bg-[#F7D515] before:content-['']"
        >
        </div>
        <div class="text-sm font-bold tracking-wider uppercase opacity-80">{badge}</div>
      </div>

      <h2 class="text-3xl leading-tight font-bold md:text-5xl lg:text-5xl">
        <Fragment set:html={heading} />
      </h2>
    </div>

    {
      quote && (
        <div class="mx-auto w-[320px] lg:w-auto">
          <div class="via-primary rounded-2xl bg-linear-to-r from-[rgba(242,199,68,0)] to-[rgba(242,199,68,0)] p-px lg:ml-10">
            <NoiseBg class="relative flex min-h-[100px] items-center rounded-2xl py-6 pr-6 pl-12 lg:py-7 lg:pl-12">
              {/* Profile image */}
              <div class="via-primary absolute -left-6 flex w-fit items-center justify-center rounded-full bg-linear-to-r from-[rgba(242,199,68,0)] to-[rgba(242,199,68,0)] p-0.5 lg:-ml-20">
                <div class="from-primary to-tertiary relative h-[60px] w-[60px] overflow-hidden rounded-full bg-conic-150 lg:h-[73px] lg:w-[73px]">
                  <Image
                    src={quote.profileImage || '/placeholders/profile.png'}
                    alt={quote.profileAlt || 'profile'}
                    width={256}
                    height={256}
                    class="absolute h-full w-full object-cover"
                  />
                </div>
              </div>

              <div class="pl-4 lg:pl-0">
                <div class="text-sm leading-relaxed italic md:text-base">&ldquo;{quote.quote}&rdquo;</div>
                <div class="text-tx-brand mt-1 text-xs font-bold md:text-sm">{quote.author}</div>
              </div>
            </NoiseBg>
          </div>
        </div>
      )
    }
  </div>

  <!-- Slider container -->
  <div class="container">
    <div class="rounded-[32px] bg-linear-to-b from-white/15 to-white/5 p-px lg:rounded-[52px]">
      <NoiseBg class="rounded-[32px] p-6 sm:p-10 lg:rounded-[52px] lg:p-16">
        <div class="flex flex-col gap-12 lg:flex-row lg:items-center lg:justify-between lg:gap-8">
          <!-- Content -->
          <div class="flex-1">
            <div class="mb-12 flex max-w-[436px] items-center text-center lg:mb-[100px] lg:text-left">
              <div class="space-y-4">
                <h3 class="text-2xl font-bold md:text-3xl lg:text-4xl">{subheading}</h3>
                <div class="text-neutral-lighter text-sm leading-relaxed md:text-base">
                  {subheadingDescription}
                </div>
              </div>
            </div>

            <div class="relative mx-auto w-fit rounded-2xl lg:mx-0">
              <Image
                src={dogImage}
                alt=""
                width={128}
                height={128}
                class="absolute top-0 right-0 z-20 -mt-[60px] h-[70px] w-[80px] lg:right-10 lg:-mt-[85px] lg:h-[92px] lg:w-[102px]"
              />

              <div
                class="pointer-events-none absolute inset-0 rounded-2xl border border-transparent"
                style={`
              background: linear-gradient(to right, rgba(30, 30, 30, 1), rgba(58, 58, 58, 1), rgba(63, 63, 63, 1), rgba(131, 131, 131, 1)) border-box;
              -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
              -webkit-mask-composite: xor;
              mask-composite: exclude;
            `}
              >
              </div>
              <ul
                class="relative flex flex-wrap items-center justify-center gap-3 rounded-2xl bg-black/20 p-4 sm:flex-row"
              >
                <li class="flex items-center gap-x-2.5 p-2">
                  <Icon name="google-logo" class="size-6 text-[#F7B715] lg:size-8" />
                  <div>
                    <div>
                      <RatingStars rating={5} size={10} fillColor="white" strokeColor="transparent" />
                    </div>
                    <div class="text-xs lg:text-sm">5.0 Rating</div>
                  </div>
                </li>

                <li class="hidden h-8 w-px bg-white/10 sm:block"></li>

                <li class="flex items-center gap-x-2.5 p-2">
                  <Icon name="facebook-logo" class="size-6 text-[#F7B715] lg:size-8" />
                  <div>
                    <div>
                      <RatingStars rating={5} size={10} fillColor="white" strokeColor="transparent" />
                    </div>
                    <div class="text-xs lg:text-sm">5.0 Rating</div>
                  </div>
                </li>

                <li class="hidden h-8 w-px bg-white/10 sm:block"></li>

                <li class="flex items-center gap-x-2.5 p-2">
                  <div>
                    <Image
                      src={bbaLogo}
                      alt="Better Business Bureau Logo"
                      width={32}
                      height={32}
                      class="size-6 lg:size-8"
                    />
                  </div>
                  <div class="flex flex-col items-start">
                    <div>
                      <RatingStars rating={5} size={10} fillColor="white" strokeColor="transparent" />
                    </div>
                    <div class="text-xs lg:text-sm">5.0 Rating</div>
                  </div>
                </li>
              </ul>
            </div>
          </div>

          <!-- Process Cards Swiper -->
          <div class="flex w-full flex-col items-center gap-y-6 lg:w-auto">
            <process-cards-swiper class="swiper block w-full max-w-[320px] sm:max-w-[421px]">
              <div class="swiper-wrapper">
                {
                  steps.length > 0 ? (
                    steps.map(s => (
                      <div class="swiper-slide rounded-3xl!">
                        <ProcessCard
                          image={s.image}
                          imageAlt={s.imageAlt}
                          step={s.step}
                          title={s.title}
                          description={s.description}
                        />
                      </div>
                    ))
                  ) : (
                    <slot />
                  )
                }
              </div>
            </process-cards-swiper>

            <!-- Navigation -->
            <div class="flex items-center gap-x-2">
              <button
                class="process-swiper-prev flex h-10 w-10 items-center justify-center rounded-full bg-[#1A1A1A] text-white transition-colors duration-200 hover:bg-black"
                aria-label="Previous step"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="m15 18-6-6 6-6"></path>
                </svg>
              </button>
              <button
                class="process-swiper-next bg-primary hover:bg-primary/90 flex h-10 w-10 items-center justify-center rounded-full text-black transition-colors duration-200"
                aria-label="Next step"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="m9 18 6-6-6-6"></path>
                </svg>
              </button>
            </div>
          </div>
        </div>
      </NoiseBg>
    </div>
  </div>
  <Image src={bottomShape} alt="" width={1500} height={100} class="absolute bottom-0 z-10 w-full translate-y-12" />
  <Image
    src={shineImage}
    alt=""
    width={256}
    height={256}
    class="pointer-events-none absolute bottom-0 left-1/2 w-full -translate-x-1/2 rotate-z-180 opacity-20"
  />
</NoiseBg>

<script>
  import Swiper from 'swiper';
  import { Navigation, EffectCards } from 'swiper/modules';

  import 'swiper/css';
  import 'swiper/css/effect-cards';

  class ProcessCardsSwiper extends HTMLElement {
    constructor() {
      super();

      const container = this.closest('.container');
      const nextEl = container?.querySelector('.process-swiper-next') as HTMLElement;
      const prevEl = container?.querySelector('.process-swiper-prev') as HTMLElement;

      new Swiper(this, {
        modules: [Navigation, EffectCards],
        effect: 'cards',
        grabCursor: true,
        navigation: {
          nextEl,
          prevEl,
        },
      });
    }
  }

  customElements.define('process-cards-swiper', ProcessCardsSwiper);
</script>
