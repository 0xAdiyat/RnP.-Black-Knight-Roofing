---
import { Image } from 'astro:assets';
import NoiseBg from '@/components/NoiseBg.astro';
import BadgeTitle from '@/components/BadgeTitle.astro';
import Tabs from '@/components/ui/Tabs.astro';
import Carousel from '@/components/ui/Carousel.astro';
import CarouselSlide from '@/components/ui/CarouselSlide.astro';
import PopularRoofingCard from './PopularRoofingCard.astro';
import { Icon } from 'astro-icon/components';
import type { ImageMetadata } from 'astro';

interface MaterialItem {
  id?: string;
  title: string;
  description: string;
  image: any;
}

interface Category {
  id: string;
  label: string;
  items: MaterialItem[];
}

interface Props {
  badge?: string;
  title?: string;
  description?: string;
  quote?: string;
  quoteAuthor?: string;
  quoteRole?: string;
  quoteImage?: string;
  categories?: Category[];
  materials?: any[];
  source?: {
    label: string;
    href: string;
  };
}

const {
  badge = 'Popular Roofing Materials',
  title = 'Popular Roofing Materials Used in Colorado',
  description = 'The best residential roof is not just about price. It is about how the material looks on your home, how it handles Colorado weather, how much maintenance you want, and how long you want the system to last. We help you compare the tradeoffs clearly before you commit.',
  quote = '“We help homeowners choose the roofing system that fits their home, their budget, and how long they want it to last.”',
  quoteAuthor = 'Adam Knight',
  quoteRole = 'President',
  quoteImage = '/placeholders/profile.png',
  categories: categoriesProp,
  materials,
  source,
} = Astro.props;

// For backward compatibility: if materials is provided instead of categories
const categories =
  categoriesProp ||
  (materials
    ? [
        {
          id: 'materials',
          label: 'Materials',
          items: materials.map((m: any) => ({
            title: m.label,
            description: m.description,
            image: m.image,
          })),
        },
      ]
    : []);
---

<NoiseBg class="relative px-0 py-0">
  <div class="py-10 lg:py-20">
    <div class="container grid grid-cols-1 gap-12 pb-8 lg:grid-cols-2">
      <div class="space-y-4">
        <BadgeTitle badge={badge} title={title} class="flex flex-col items-start text-left" />
        <div class="space-y-6">
          <p class="text-neutral-lighter text-sm leading-relaxed font-normal lg:text-base">
            {description}
          </p>

          {
            source && (
              <p class="flex items-center gap-2 text-xs">
                <Icon name="circle-info" class="text-primary" />
                <span class="text-neutral-lighter">
                  Source:{' '}
                  <a href={source.href} class="hover:text-primary text-white underline">
                    {source.label}
                  </a>
                </span>
              </p>
            )
          }
        </div>
      </div>

      <div class="flex items-center justify-center lg:justify-end">
        <div
          class="border-gradient before:via-primary mt-8 ml-8 h-fit w-full max-w-[320px] rounded-2xl p-px before:bg-linear-to-r before:from-white/15 before:to-white/15 md:max-w-[400px] lg:mt-0 lg:ml-12"
        >
          <div class="relative flex items-center rounded-2xl py-6 pr-6 pl-0 lg:py-7">
            {/* Profile image */}
            <div
              class="via-primary z-10 -ml-8 flex w-fit items-center justify-center rounded-full bg-linear-to-r from-[rgba(242,199,68,0)] to-[rgba(242,199,68,0)] p-0.5"
            >
              <div
                class="from-primary to-tertiary relative h-[60px] w-[60px] overflow-hidden rounded-full bg-conic-150 lg:h-[73px] lg:w-[73px]"
              >
                {
                  quoteImage && (
                    <Image
                      src={quoteImage}
                      alt={quoteAuthor}
                      width={256}
                      height={256}
                      class="absolute h-full w-full object-cover"
                    />
                  )
                }
              </div>
            </div>

            <div class="pl-0">
              <div class="text-sm leading-relaxed italic">
                {quote}
              </div>
              <div class="text-tx-brand mt-1 text-sm font-bold">
                {quoteAuthor}, <span class="font-normal opacity-70"> {quoteRole} </span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Roofing Materials -->
    <Tabs tabs={categories.map((c: Category) => ({ label: c.label, id: c.id }))} listClass="no-scrollbar container">
      {
        categories.map((category: Category) => (
          <div data-tab-panel={category.id} class="hidden">
            <Carousel
              slidesPerView={1.2}
              spaceBetween={0}
              centeredSlides={true}
              autoplay={true}
              loop={true}
              loopedSlides={1}
              breakpoints={{
                1024: {
                  slidesPerView: 1.6,
                  spaceBetween: 0,
                  centeredSlides: false,
                  loopedSlides: 1,
                },
              }}
            >
              {category.items.map((item: MaterialItem) => (
                <CarouselSlide>
                  <PopularRoofingCard title={item.title} description={item.description} image={item.image} />
                </CarouselSlide>
              ))}
            </Carousel>
          </div>
        ))
      }
    </Tabs>
  </div>
</NoiseBg>
