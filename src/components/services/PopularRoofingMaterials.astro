---
import { Image } from 'astro:assets';
import NoiseBg from '@/components/NoiseBg.astro';
import BadgeTitle from '@/components/BadgeTitle.astro';
import Tabs from '@/components/ui/Tabs.astro';
import Carousel from '@/components/ui/Carousel.astro';
import CarouselSlide from '@/components/ui/CarouselSlide.astro';
import PopularRoofingCard from './PopularRoofingCard.astro';

interface Material {
  id: string;
  label: string;
  description: string;
  image: string;
}

interface Props {
  materials: Material[];
}

const { materials } = Astro.props;
---

<NoiseBg class="relative px-0 py-0">
  <div class="py-10 lg:py-20">
    <div class="container grid grid-cols-1 gap-12 pb-8 lg:grid-cols-2">
      <div class="space-y-4">
        <BadgeTitle
          badge="Popular Roofing Materials"
          title="Popular Roofing Materials Used in Colorado"
          class="flex flex-col items-start text-left"
        />
        <p class="text-neutral-lighter text-sm leading-relaxed font-normal lg:text-base">
          The best residential roof is not just about price. It is about how the material looks on your home, how it
          handles Colorado weather, how much maintenance you want, and how long you want the system to last. We help you
          compare the tradeoffs clearly before you commit.
        </p>
      </div>

      <div class="flex items-center justify-center lg:justify-end">
        <div
          class="via-primary mt-8 ml-8 h-fit w-full max-w-[320px] rounded-2xl bg-linear-to-r from-[rgba(242,199,68,0)] to-[rgba(242,199,68,0)] p-px md:max-w-[400px] lg:mt-0 lg:ml-12"
        >
          <NoiseBg class="relative flex items-center rounded-2xl py-6 pr-6 pl-0 lg:py-7">
            {/* Profile image */}
            <div
              class="via-primary z-10 -ml-8 flex w-fit items-center justify-center rounded-full bg-linear-to-r from-[rgba(242,199,68,0)] to-[rgba(242,199,68,0)] p-0.5"
            >
              <div
                class="from-primary to-tertiary relative h-[60px] w-[60px] overflow-hidden rounded-full bg-conic-150 lg:h-[73px] lg:w-[73px]"
              >
                <Image
                  src="/placeholders/profile.png"
                  alt="profile"
                  width={256}
                  height={256}
                  class="absolute h-full w-full object-cover"
                />
              </div>
            </div>

            <div class="pl-0">
              <div class="text-sm leading-relaxed italic md:text-base">
                “We help homeowners choose the roofing system that fits their home, their budget, and how long they want
                it to last.”
              </div>
              <div class="text-tx-brand mt-1 text-xs font-bold md:text-sm">
                Adam Knight, <small class="font-normal opacity-70"> President </small>
              </div>
            </div>
          </NoiseBg>
        </div>
      </div>
    </div>

    <!-- Roofing Materials -->
    <Tabs tabs={materials.map(m => ({ label: m.label, id: m.id }))} listClass="no-scrollbar container">
      {
        materials.map(material => (
          <div data-tab-panel={material.id} class="hidden">
            <Carousel
              slidesPerView={1.2}
              spaceBetween={0}
              centeredSlides={true}
              autoplay={true}
              loop={true}
              loopedSlides={1}
              breakpoints={{
                1024: {
                  slidesPerView: 1.6,
                  spaceBetween: 0,
                  centeredSlides: false,
                  loopedSlides: 1,
                },
              }}
            >
              <CarouselSlide>
                <PopularRoofingCard title={material.label} description={material.description} image={material.image} />
              </CarouselSlide>

              <CarouselSlide>
                <PopularRoofingCard title={material.label} description={material.description} image={material.image} />
              </CarouselSlide>

              <CarouselSlide>
                <PopularRoofingCard title={material.label} description={material.description} image={material.image} />
              </CarouselSlide>

              <CarouselSlide>
                <PopularRoofingCard title={material.label} description={material.description} image={material.image} />
              </CarouselSlide>
            </Carousel>
          </div>
        ))
      }
    </Tabs>
  </div>
</NoiseBg>
