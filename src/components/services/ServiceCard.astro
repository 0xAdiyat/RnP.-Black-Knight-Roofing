---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { cn } from '@/lib/utils';

interface Props {
  image: ImageMetadata | string;
  imageAlt?: string;
  title: string;
  description: string;
  icon?: string;
  tags?: string[];
  href?: string;
  class?: string;
}

const {
  image,
  imageAlt = '',
  title,
  description,
  icon = 'roof-icon',
  tags = [],
  href,
  class: className,
} = Astro.props;

const Tag = href ? 'a' : 'div';
---

<Tag href={href} class={cn('from-primary via-[#594216] to-[#594216] block w-full rounded-2xl bg-radial-[at_35%_35%] p-px transition-transform duration-300 hover:scale-[1.02]', className)}>
  <div class="relative rounded-2xl w-full h-full">
    {
      typeof image === 'string' ? (
        <img
          src={image}
          alt={imageAlt || title}
          class="h-full w-full rounded-2xl object-cover"
        />
      ) : (
        <Image
          src={image}
          alt={imageAlt || title}
          class="h-full w-full rounded-2xl object-cover"
        />
      )
    }
    <div
      class="from-inverted/0 to-inverted absolute inset-0 flex h-full w-full items-end rounded-2xl bg-linear-to-b from-50% px-4 py-8"
    >
      <div class="space-y-4">
        <div class="space-y-3">
          <div class="flex items-center gap-x-3 text-lg">
            <div class="rounded-full border w-8 h-8 bg-white flex items-center justify-center">
              <Icon name={icon} size={24} class="text-inverted" />
            </div>
            <span>{title}</span>
          </div>

          <div class="text-sm">
            {description}
          </div>
        </div>
        {
          tags.length > 0 && (
            <div class="flex items-center gap-x-3">
              <ul class="flex items-center gap-x-2 text-xs">
                {tags.map((tag) => (
                  <li class="bg-primary text-inverted rounded-full px-4 py-1">{tag}</li>
                ))}
              </ul>
            </div>
          )
        }
      </div>
    </div>
  </div>
</Tag>
