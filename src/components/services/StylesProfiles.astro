---
import { Image } from 'astro:assets';
import BadgeTitle from '@/components/BadgeTitle.astro';
import previewImg from '@/assets/styles-profiles/pine-crest-shake-preview.png';
import NoiseBg from '../NoiseBg.astro';

import type { ImageMetadata } from 'astro';

interface Color {
  name: string;
  code: string;
  color: string;
  thumbnail: any;
  isDefault?: boolean;
}

interface Profile {
  id: string;
  label: string;
  title: string;
  description: string;
  previewImage: any;
  colors: Color[];
}

interface Props {
  badge?: string;
  title?: string;
  description?: string;
  profiles?: Profile[];
}

const {
  badge = 'Options',
  title = 'Styles & Profiles',
  description = "Choose a profile that matches your home's architecture—then explore CRRC cool roof color options.",
  profiles: profilesProp,
} = Astro.props;

const defaultProfiles: Profile[] = [
  {
