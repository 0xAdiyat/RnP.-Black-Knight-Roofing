const profiles = profilesProp || defaultProfiles;
---

<NoiseBg class="px-0 py-0">
  <section class="container py-20 overflow-hidden" id="styles-profiles"> 
    <div class="flex flex-col items-center text-center mb-12">
      <div class="flex items-center gap-3 mb-6">
        <div class="relative flex items-center justify-center size-[21px]">
          <div class="relative size-3">
            <div class="absolute inset-0 rounded-full bg-[#f7b715] opacity-50 animate-ping"></div>
            <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 size-2 rounded-full bg-[#f7d515] shadow-[0_0_4px_rgba(247,213,21,0.5)]"></div>
          </div>
        </div>
        <span class="text-white text-base font-medium">{badge}</span>
      </div>

      <h2 class="text-white text-[48px] font-heading font-normal leading-[60px] mb-8">
        {title}
      </h2>

      <div class="flex flex-col items-center">
        <!-- Manually split description or just render paragraph with fixed width -->
        <p class="text-[#ccc] text-base font-normal leading-relaxed mb-6 max-w-2xl text-center">
          {description}
        </p>

        <!-- Source information -->
        <div class="flex items-center gap-3">
          <svg class="size-[24px] text-[#ccc]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 16v-4"></path>
            <path d="M12 8h.01"></path>
          </svg>
          <p class="text-[#ccc] text-xs font-medium m-0">
            Source: <a href="#" class="text-white underline underline-offset-2">Westlake Royal — Unified Steel™, Class 4 impact-rated panels.</a>
          </p>
        </div>
      </div>
    </div>

    <div class="styles-tabs-container flex flex-col items-center max-w-[1440px] mx-auto">
      <!-- Tabs Pill -->
      <div class="w-full lg:w-[1312px] border border-white/10 rounded-lg p-1 flex gap-1 mb-12 overflow-x-auto no-scrollbar shrink-0">
        {profiles.map((profile, idx) => (
          <button 
            class:list={[
              "style-tab-trigger flex-1 min-w-[200px] px-4 py-3 rounded-md text-center text-lg font-normal transition-all whitespace-nowrap",
              idx === 0 
                ? "active-tab border border-primary bg-gradient-to-r from-[#292929] to-[#171717] text-primary" 
                : "border border-transparent text-[#ccc] hover:bg-white/5" // Note: in FIGMA inactive is just transparent border logically in the flex box
            ]}
            data-id={profile.id}
          >
            {profile.label}
          </button>
        ))}
      </div>

      <!-- Panels -->
      <div class="w-full pb-10">
        {profiles.map((profile, idx) => (
          <div 
            class:list={["style-panel flex flex-col lg:flex-row gap-8 lg:gap-[48px] items-start w-full justify-center", idx !== 0 && "hidden"]} 
            data-panel={profile.id}
          >
            <!-- Left: Preview Image Container -->
            <div class="relative w-full lg:w-[758px] h-[500px] lg:h-[767px] shrink-0 rounded-[24px] overflow-hidden group/preview p-6 flex flex-col justify-between shadow-2xl">
              <!-- Background Image -->
              <div class="absolute inset-0 pointer-events-none rounded-[24px]">
                <Image 
                  src={profile.previewImage}
                  alt={profile.title} 
                  width={profile.previewImage.width}
                  height={profile.previewImage.height}
                  loading="eager"
                  class="absolute inset-0 size-full max-w-none object-cover transition-transform duration-1000 group-hover/preview:scale-105" 
                />
                <!-- Gradient Overlay -->
                <div class="absolute inset-0 bg-gradient-to-b from-transparent from-[61%] to-black/90 rounded-[24px]"></div>
                <!-- Dynamic Tint Overlays -->
                <div class="preview-tint-overlay absolute inset-0 mix-blend-overlay opacity-40 transition-colors duration-700 pointer-events-none" style={`background-color: ${profile.colors[0]?.color || 'transparent'};`}></div>
                <div class="preview-tint-multiply absolute inset-0 mix-blend-multiply opacity-[0.15] transition-colors duration-700 pointer-events-none" style={`background-color: ${profile.colors[0]?.color || 'transparent'};`}></div>
              </div>
              
              <!-- Top left preview chip -->
              <div class="relative z-10 bg-[#222] rounded-full h-8 flex items-center px-3 gap-3 w-fit shrink-0 border border-white/5">
                <div class="relative flex items-center justify-center size-[21px]">
                  <div class="relative size-3">
                    <div class="absolute inset-0 rounded-full bg-[#f7b715] opacity-50 animate-ping"></div>
                    <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 size-2 rounded-full bg-[#f7d515] shadow-[0_0_4px_rgba(247,213,21,0.5)]"></div>
                  </div>
                </div>
                <span class="text-white text-base font-medium tracking-wide uppercase">PREVIEW</span>
              </div>

              <!-- Bottom content -->
              <div class="relative z-10 flex flex-col gap-2 items-start shrink-0">
                <h3 class="text-white text-[48px] lg:text-[65px] font-medium leading-none m-0">{profile.title}</h3>
                
                <!-- Active color indicator -->
                <div class="bg-[#222] border border-white/10 rounded-full h-8 flex items-center px-3 gap-3 w-fit shrink-0 mb-2">
                  <div class="relative flex items-center justify-center size-[21px]">
                    <div class="relative size-3">
                      <div class="absolute inset-0 rounded-full bg-blue-100 opacity-50 animate-ping"></div>
                    </div>
                  </div>
                  <span class="text-white text-sm font-medium active-color-label">{profile.colors[0]?.name || 'Charcoal'}</span>
                </div>

                <p class="text-[#ccc] text-base font-normal leading-relaxed m-0 max-w-xl">
                  {profile.description}
                </p>
              </div>
            </div>

            <!-- Right: Color Options Grid -->
            <div class="flex-1 w-full lg:min-w-[519px] p-0 lg:p-6 rounded-[24px]">
              <div class="mb-6 flex items-center">
                <span class="text-primary text-base font-semibold whitespace-nowrap">Color Options</span>
              </div>

              <div class="grid grid-cols-2 lg:grid-cols-3 gap-6 auto-rows-max">
                {profile.colors.map(color => (
                  <div class="flex flex-col items-center lg:items-start lg:h-[218px] w-full lg:w-[154px] cursor-pointer group/swatch swatch-trigger" data-color-name={color.name} data-color-hex={color.color}>
                    <!-- Image Card -->
                    <div class="w-full aspect-square bg-[#3c3c3c] rounded-[16px] overflow-hidden relative shadow-md border border-transparent group-hover/swatch:border-white/20 transition-all duration-300 mb-4">
                      <Image 
                        src={color.thumbnail} 
                        width={225} 
                        height={225} 
                        alt={color.name} 
                        class="absolute inset-0 size-full max-w-none object-cover transition-opacity duration-300 group-hover/swatch:opacity-90" 
                      />
                      <div class="absolute inset-0 transition-opacity duration-500 opacity-20 group-hover/swatch:opacity-30" style={`background-color: ${color.color}; mix-blend-mode: overlay;`}></div>
                    </div>
                    
                    <!-- Text Info -->
                    <div class="flex flex-col items-center lg:items-start text-center lg:text-left gap-1 w-full">
                      <h4 class="text-white text-sm lg:text-[15px] font-medium leading-normal m-0 tracking-[0.2em] uppercase group-hover/swatch:text-white/80 transition-colors">{color.name}</h4>
                      <p class="text-[#aaa] text-xs lg:text-[14px] font-normal leading-tight m-0">{color.code}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section> 
</NoiseBg>

<script>
  function setupStyleTabs() {
    const container = document.querySelector('.styles-tabs-container');
    if (!container) return;

    const triggers = container.querySelectorAll('.style-tab-trigger');
    const panels = container.querySelectorAll('.style-panel');

    // Tab Switching
    triggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const id = trigger.getAttribute('data-id');
        
        triggers.forEach(t => {
            if (t === trigger) {
                t.classList.add('active-tab', 'border-primary', 'bg-gradient-to-r', 'from-[#292929]', 'to-[#171717]', 'text-primary');
                t.classList.remove('border-transparent', 'text-[#ccc]', 'hover:bg-white/5');
            } else {
                t.classList.remove('active-tab', 'border-primary', 'bg-gradient-to-r', 'from-[#292929]', 'to-[#171717]', 'text-primary');
                t.classList.add('border-transparent', 'text-[#ccc]', 'hover:bg-white/5');
            }
        });

        panels.forEach(p => {
            if (p.getAttribute('data-panel') === id) {
                p.classList.remove('hidden');
                p.classList.add('flex');
            } else {
                p.classList.add('hidden');
                p.classList.remove('flex');
            }
        });
      });
    });

    // Swatch Interaction
    const swatches = container.querySelectorAll('.swatch-trigger');
    swatches.forEach(swatch => {
       swatch.addEventListener('click', () => {
          const colorName = swatch.getAttribute('data-color-name');
          const colorHex = swatch.getAttribute('data-color-hex');
          const panel = swatch.closest('.style-panel');
          const colorLabel = panel?.querySelector('.active-color-label');
          const tintOverlay = panel?.querySelector('.preview-tint-overlay');
          const tintMultiply = panel?.querySelector('.preview-tint-multiply');

          if (colorLabel && colorName) {
             colorLabel.textContent = colorName;
             // Add a small animation to the label
             colorLabel.animate([
                { opacity: 0, transform: 'translateY(5px)' },
                { opacity: 1, transform: 'translateY(0)' }
             ], { duration: 300, easing: 'ease-out' });
          }

          if (tintOverlay && colorHex) {
              (tintOverlay as HTMLElement).style.backgroundColor = colorHex;
          }
          
          if (tintMultiply && colorHex) {
              (tintMultiply as HTMLElement).style.backgroundColor = colorHex;
          }
       });
    });
  }

  // Initialize
  setupStyleTabs();
  document.addEventListener('astro:after-swap', setupStyleTabs);
</script>

<style>
    .style-panel {
        animation: panelFadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    
    @keyframes panelFadeIn {
        from { opacity: 0; transform: translateY(30px); filter: blur(10px); }
        to { opacity: 1; transform: translateY(0); filter: blur(0); }
    }

    .swatch-trigger {
        transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }
</style>
