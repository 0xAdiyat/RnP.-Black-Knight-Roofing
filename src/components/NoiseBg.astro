---
import { getImage, Image } from 'astro:assets';
import noiseImage from '@/assets/noises.png';
import { cn } from '@/lib/utils';
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'section'> {}

const { class: className, ...props } = Astro.props;

const optimizedNoise = await getImage({ src: noiseImage, width: 1536, height: 1152, format: 'webp' });
---

<section
  class={cn('relative bg-[#141414] pt-[42px] pb-6 px-8 gap-x-4', className)}
  style={`
      background-image:
radial-gradient(50% 50% at 50% 50%, rgba(48,48,48,0) 0%, rgba(48,48,48,0.54) 100%), url('${optimizedNoise.src}');
      background-position: center, center;
      background-size: auto, 500px 500px;
      background-repeat: no-repeat, repeat;
      background-blend-mode: overlay;
    `}
  {...props}
>
  <slot />
</section>
