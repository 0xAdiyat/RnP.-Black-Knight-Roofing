---
import { allLinks } from '@/data/navigation';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import NoiseBg from './NoiseBg.astro';
import logo from '@/assets/logo.png';
import SunFlow from '@/assets/sunflow.avif';

interface Link {
  label: string;
  url: string;
  category: string;
}

const groupedLinks = allLinks.reduce((acc, link) => {
  const category = link.category || 'Other';
  if (!acc[category]) acc[category] = [];
  acc[category].push(link);
  return acc;
}, {} as Record<string, Link[]>);
---

<div
  id="site-links-modal"
  class="pointer-events-none fixed inset-0 z-[200] hidden opacity-0 transition-opacity duration-300 ease-out"
  role="dialog"
  aria-modal="true"
  aria-labelledby="modal-title"
>
  <button
    id="site-links-modal-backdrop"
    type="button"
    class="absolute inset-0 bg-black/80"
    aria-label="Close modal"
  ></button>

  <div class="relative z-10 flex min-h-full items-center justify-center px-3 py-4 sm:px-6 sm:py-8">
    <div
      id="site-links-modal-panel"
      class="border-radial site-links-modal-panel bg-noise relative flex w-full max-w-4xl translate-y-5 scale-[0.9] overflow-hidden rounded-2xl bg-[#161616]/95 text-white opacity-0 shadow-2xl transition-[transform,opacity] duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] will-change-transform sm:rounded-3xl [--noise-radial:radial-gradient(50%_50%_at_50%_50%,rgba(48,48,48,0.4)_0%,rgba(48,48,48,0.56)_100%)]"
    >
       <Image
        src={SunFlow}
        alt=""
        width={SunFlow.width}
        height={SunFlow.height}
        loading="eager"
        fetchpriority="high"
        class="absolute inset-0 top-0 left-0 opacity-20 pointer-events-none"
      />

      <!-- Close Button -->
      <button
        id="close-site-links-modal"
        type="button"
        class="border-radial text-primary absolute top-3 right-3 z-30 flex size-10 items-center justify-center rounded-full bg-[#1b1b1b]/95 transition-colors hover:bg-white/10 hover:text-white sm:top-4 sm:right-4 sm:bg-white/5"
        aria-label="Close modal"
      >
        <Icon name="close" class="size-5" />
      </button>

      <div class="relative flex flex-col w-full max-h-[85vh]">
        <!-- Search Header -->
        <div class="sticky top-0 z-20 w-full border-b border-white/10 bg-[#1a1a1a]/98 px-6 py-6 sm:px-8 pr-14 sm:pr-16 lg:bg-transparent">
          <div class="relative w-full">
            <Icon name="search" class="absolute top-1/2 left-4 size-5 -translate-y-1/2 text-white/30" />
            <input
              type="text"
              id="modal-search"
              placeholder="Search for a service or page..."
              class="w-full rounded-xl border border-white/10 bg-white/5 py-4 pr-4 pl-12 text-lg text-white placeholder:text-white/30 focus:border-primary/50 focus:ring-0 focus:outline-none transition-all"
              autocomplete="off"
            />
          </div>
        </div>

        <!-- Links Container -->
        <div class="grow overflow-y-auto px-6 py-6 sm:px-8 scrollbar-thin scrollbar-track-transparent scrollbar-thumb-white/20">
          <div id="modal-links-container" class="space-y-10 pb-8">
            {
              Object.entries(groupedLinks).map(([category, links]) => (
                <div class="category-section space-y-4" data-category={category.toLowerCase()}>
                  <div class="flex items-center gap-4">
                    <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-white/30 whitespace-nowrap">
                      {category}
                    </h3>
                    <div class="h-px w-full bg-white/5" />
                  </div>
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    {links.map((link) => (
                      <a
                        href={link.url}
                        class="group flex flex-col gap-1 rounded-xl border border-white/5 bg-white/2 p-4 transition-all hover:bg-[#232323] hover:border-primary/30"
                        data-link-label={link.label.toLowerCase()}
                        data-link-category={category.toLowerCase()}
                        tabindex="0"
                      >
                        <div class="flex items-center justify-between">
                          <span class="text-base font-semibold text-white group-hover:text-primary transition-colors">
                            {link.label}
                          </span>
                          <Icon name="send" class="size-3 text-white/20 group-hover:text-primary transition-colors" />
                        </div>
                        <span class="text-[10px] text-white/40 truncate font-mono">{link.url}</span>
                      </a>
                    ))}
                  </div>
                </div>
              ))
            }
          </div>
          <div id="no-results" class="hidden py-16 text-center">
            <Icon name="search" class="mx-auto size-16 text-white/10 mb-5" />
            <p class="text-lg text-white/50">No matching links found.</p>
            <button id="clear-search" class="text-primary mt-2 text-sm underline underline-offset-4">Clear search query</button>
          </div>
        </div>

        <!-- Key Hints -->
        <div class="border-t border-white/10 bg-[#1a1a1a]/95 p-5 px-6 sm:px-8 mt-auto lg:bg-transparent">
          <div class="flex flex-wrap items-center gap-x-8 gap-y-3 text-[10px] text-white/30 sm:text-xs">
            <div class="flex items-center gap-2 font-medium uppercase tracking-widest">
              <kbd class="rounded border border-white/10 bg-white/5 px-2 py-0.5 text-white/60 font-mono">ESC</kbd> 
              <span>Close</span>
            </div>
            <div class="flex items-center gap-2 font-medium uppercase tracking-widest">
               <kbd class="rounded border border-white/10 bg-white/5 px-2 py-0.5 text-white/60 font-mono">↑↓</kbd> 
               <span>Navigate</span>
            </div>
            <div class="flex items-center gap-2 font-medium uppercase tracking-widest sm:ml-auto">
               <span>Press</span>
               <div class="flex items-center gap-1">
                 <kbd class="rounded border border-white/10 bg-white/5 px-2 py-0.5 text-white/60 font-mono">⌘K</kbd> 
                 <span class="text-[8px]">or</span>
                 <kbd class="rounded border border-white/10 bg-white/5 px-2 py-0.5 text-white/60 font-mono">Ctrl+K</kbd>
               </div>
               <span>anytime</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function setupLinksModal() {
    const modal = document.getElementById('site-links-modal') as HTMLDivElement;
    const panel = document.getElementById('site-links-modal-panel') as HTMLDivElement;
    const backdrop = document.getElementById('site-links-modal-backdrop');
    const closeBtn = document.getElementById('close-site-links-modal');
    const searchInput = document.getElementById('modal-search') as HTMLInputElement;
    const noResults = document.getElementById('no-results');
    const clearBtn = document.getElementById('clear-search');
    const links = Array.from(document.querySelectorAll('#modal-links-container a')) as HTMLAnchorElement[];

    if (!modal || !panel || !backdrop || !closeBtn || modal.dataset.linksModalReady === 'true') return;
    
    modal.dataset.linksModalReady = 'true';

    const OPEN_DURATION_MS = 280;
    const CLOSE_DURATION_MS = 220;

    let isOpen = false;

    function openModal() {
      if (isOpen) return;
      isOpen = true;
      
      modal.style.transitionDuration = `${OPEN_DURATION_MS}ms`;
      panel.style.transitionDuration = `${OPEN_DURATION_MS}ms`;
      
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';

      requestAnimationFrame(() => {
        void panel.offsetHeight;
        requestAnimationFrame(() => {
          modal.classList.remove('pointer-events-none', 'opacity-0');
          panel.classList.remove('translate-y-5', 'scale-[0.9]', 'opacity-0');
          setTimeout(() => searchInput?.focus(), 150);
        });
      });
    }

    function closeModal() {
      if (!isOpen) return;
      isOpen = false;
      
      modal.style.transitionDuration = `${CLOSE_DURATION_MS}ms`;
      panel.style.transitionDuration = `${CLOSE_DURATION_MS}ms`;
      
      modal.classList.add('pointer-events-none', 'opacity-0');
      panel.classList.add('translate-y-5', 'scale-[0.9]', 'opacity-0');
      document.body.style.overflow = '';

      window.setTimeout(() => {
        if (!isOpen) {
          modal.classList.add('hidden');
          searchInput.value = '';
          handleSearch('');
        }
      }, CLOSE_DURATION_MS);
    }

    function handleSearch(query: string) {
      const q = query.toLowerCase();
      let hasVisibleAny = false;

      const sections = document.querySelectorAll('.category-section');
      sections.forEach(section => {
        const sectionLinks = section.querySelectorAll('a');
        let hasVisibleInSection = false;
        
        sectionLinks.forEach(link => {
          const label = (link as HTMLElement).dataset.linkLabel || '';
          const category = (link as HTMLElement).dataset.linkCategory || '';
          const isVisible = label.includes(q) || category.includes(q);
          
          (link as HTMLElement).style.display = isVisible ? 'flex' : 'none';
          if (isVisible) hasVisibleInSection = true;
        });

        (section as HTMLElement).style.display = hasVisibleInSection ? 'block' : 'none';
        if (hasVisibleInSection) hasVisibleAny = true;
      });

      if (noResults) {
        noResults.style.display = hasVisibleAny ? 'none' : 'block';
      }
    }

    // Hotkey listener
    window.addEventListener('keydown', (e) => {
      // Use Cmd+K or Ctrl+K to avoid Minimize conflict (Cmd+M) in macOS/Safari
      if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        if (isOpen) closeModal();
        else openModal();
      }

      if (e.key === 'Escape' && isOpen) {
        closeModal();
      }
    });

    closeBtn.addEventListener('click', closeModal);
    backdrop.addEventListener('click', closeModal);
    
    searchInput?.addEventListener('input', (e) => {
      handleSearch((e.target as HTMLInputElement).value);
    });

    clearBtn?.addEventListener('click', () => {
      searchInput.value = '';
      searchInput.focus();
      handleSearch('');
    });

    links.forEach(link => {
      link.addEventListener('click', () => closeModal());
    });
  }

  // Initialize
  setupLinksModal();
  document.addEventListener('astro:after-swap', setupLinksModal);
</script>

<style>
  .site-links-modal-panel {
    max-height: calc(100dvh - 2rem);
  }

  @media (min-width: 640px) {
    .site-links-modal-panel {
      max-height: 95vh;
    }
  }

  /* Prevent background scrolling when modal is open */
  html:has(#site-links-modal:not(.hidden)) {
    overflow: hidden;
  }
</style>
