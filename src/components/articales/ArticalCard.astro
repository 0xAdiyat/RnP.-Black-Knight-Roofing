---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { Icon } from 'astro-icon/components';
import NoiseBg from '../NoiseBg.astro';
import socialPreview from '@/assets/social-previews/social-preview.png';

interface Props {
  image?: ImageMetadata | string;
  imageAlt?: string;
  title: string;
  description?: string;
  date?: string;
  readTime?: string;
  href?: string;
  class?: string;
}

const {
  image = socialPreview,
  imageAlt = '',
  title,
  description = '',
  date = '',
  readTime = '',
  href = '#',
  class: className,
} = Astro.props;
---

<a
  href={href}
  class:list={[
    'group block overflow-hidden rounded-[16px] border border-white/30 bg-[#111111] transition-all hover:bg-white/5',
    className,
  ]}
>
  <NoiseBg class="px-0 py-0">
    <!-- Image -->
    <div class="relative h-[260px] overflow-hidden">
      {
        typeof image === 'string' ? (
          <img
            src={image}
            alt={imageAlt || title}
            class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
          />
        ) : (
          <Image
            src={image}
            alt={imageAlt || title}
            class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
          />
        )
      }
      <!-- Diamond accent -->
      <div class="absolute right-4 bottom-4 opacity-50">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M8 0L10 6L16 8L10 10L8 16L6 10L0 8L6 6L8 0Z" fill="white"></path>
        </svg>
      </div>
    </div>

    <!-- Content -->
    <div class="space-y-4 p-4">
      <!-- Meta -->
      <div class="flex items-center gap-x-6 text-[14.5px] text-[#ccc]">
        {
          date && (
            <div class="flex items-center gap-x-2">
              <Icon name="calender-2" class="size-[21px] shrink-0" />
              <span>{date}</span>
            </div>
          )
        }
        {
          readTime && (
            <div class="flex items-center gap-x-2">
              <Icon name="clock-2" class="size-[17px] shrink-0" />
              <span>{readTime}</span>
            </div>
          )
        }
      </div>

      <!-- Title & Description -->
      <div class="space-y-3">
        <h5 class="font-heading leading-[32px] font-normal text-white">{title}</h5>
        {description && <p class="line-clamp-3 text-sm leading-[24px] text-[#ccc]">{description}</p>}
      </div>

      <!-- Read More -->
      <div class="inline-block border-b border-white pb-0.5">
        <span class="text-base font-semibold text-white">Read More</span>
      </div>
    </div>
  </NoiseBg>
</a>
