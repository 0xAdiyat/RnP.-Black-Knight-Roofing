---
import EstimateForm from './EstimateForm.astro';
import { Icon } from 'astro-icon/components';
---

<div
  id="estimate-dialog"
  class="pointer-events-none fixed inset-0 z-[120] hidden opacity-0 transition-opacity duration-300"
  aria-hidden="true"
>
  <button
    id="estimate-dialog-backdrop"
    type="button"
    class="absolute inset-0 bg-black/80"
    aria-label="Close dialog"
  ></button>

  <div class="relative z-10 flex min-h-full items-center justify-center px-3 py-4 sm:px-6 sm:py-8">
    <div
      class="border-radial relative flex max-h-[94vh] w-full max-w-6xl overflow-hidden rounded-3xl bg-[#161616]/95 text-white shadow-2xl"
    >
      <!-- Close Button -->
      <button
        id="close-estimate-dialog"
        type="button"
        class="border-radial text-primary absolute top-4 right-4 z-20 flex size-10 items-center justify-center rounded-full bg-white/5 transition-colors hover:bg-white/10 hover:text-white"
        aria-label="Close dialog"
      >
        <Icon name="close" class="size-5" />
      </button>

      <!-- Content -->
      <div class="scrollbar-thin scrollbar-track-transparent scrollbar-thumb-white/20 grow overflow-y-auto">
        <EstimateForm />
      </div>
    </div>
  </div>
</div>

<script>
  // Global script for estimate dialog
  const setupEstimateDialog = () => {
    const dialog = document.getElementById('estimate-dialog') as HTMLDivElement;
    const backdrop = document.getElementById('estimate-dialog-backdrop');
    const closeBtn = document.getElementById('close-estimate-dialog');
    const triggers = document.querySelectorAll('[data-estimate-trigger]');

    if (!dialog || !backdrop || !closeBtn || dialog.dataset.estimateDialogReady === 'true') return;

    dialog.dataset.estimateDialogReady = 'true';

    const lockBodyScroll = () => {
      document.body.style.overflow = 'hidden';
    };

    const unlockBodyScroll = () => {
      document.body.style.overflow = '';
    };

    const handleOpen = (e: Event) => {
      e.preventDefault();
      e.stopPropagation();

      dialog.classList.remove('hidden');
      requestAnimationFrame(() => {
        dialog.classList.remove('pointer-events-none', 'opacity-0');
      });
      dialog.setAttribute('aria-hidden', 'false');
      lockBodyScroll();
    };

    const handleClose = () => {
      dialog.classList.add('pointer-events-none', 'opacity-0');
      dialog.setAttribute('aria-hidden', 'true');
      unlockBodyScroll();

      window.setTimeout(() => {
        if (dialog.getAttribute('aria-hidden') === 'true') {
          dialog.classList.add('hidden');
        }
      }, 300);
    };

    triggers.forEach(trigger => {
      trigger.addEventListener('click', handleOpen);
    });

    backdrop.addEventListener('click', handleClose);
    closeBtn.addEventListener('click', handleClose);

    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && dialog.getAttribute('aria-hidden') === 'false') {
        handleClose();
      }
    });
  };

  // Run on first load
  setupEstimateDialog();

  // Re-run for view transitions if enabled
  document.addEventListener('astro:after-swap', setupEstimateDialog);
</script>

<style>
  /* Prevent background scrolling when dialog is open */
  html:has(#estimate-dialog[aria-hidden='false']) {
    overflow: hidden;
  }
</style>
