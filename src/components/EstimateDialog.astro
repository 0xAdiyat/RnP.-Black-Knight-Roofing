---
import EstimateForm from './EstimateForm.astro';
import { Icon } from 'astro-icon/components';
import SunFlow from '@/assets/sunflow.avif';
import { Image } from 'astro:assets';
---

<dialog
  id="estimate-dialog"
  class="border-radial fixed inset-0 z-50 m-auto max-h-[90vh] w-[95vw] max-w-6xl overflow-hidden overflow-x-hidden overflow-y-auto rounded-3xl bg-[#161616]/95 p-0 text-white shadow-2xl backdrop-blur-xl backdrop:bg-black/60 backdrop:backdrop-blur-sm open:flex open:flex-col"
>
  <div class="relative z-10 flex h-full flex-col">
    <!-- Close Button -->
    <button
      id="close-estimate-dialog"
      class="border-radial text-primary absolute top-4 right-4 z-10 flex size-10 items-center justify-center rounded-full bg-white/5 transition-colors hover:bg-white/10 hover:text-white"
      aria-label="Close dialog"
    >
      <Icon name="close" class="size-5" />
    </button>

    <!-- Content -->
    <div class="scrollbar-thin scrollbar-track-transparent scrollbar-thumb-white/20 grow overflow-y-auto">
      <EstimateForm />
    </div>
  </div>
</dialog>

<script>
  // Global script for estimate dialog
  const setupEstimateDialog = () => {
    const dialog = document.getElementById('estimate-dialog') as HTMLDialogElement;
    const closeBtn = document.getElementById('close-estimate-dialog');

    if (!dialog || !closeBtn) return;

    // Open logic
    const handleOpen = (e: MouseEvent) => {
      const trigger = (e.target as HTMLElement).closest('[data-estimate-trigger]');
      if (trigger) {
        e.preventDefault();
        dialog.showModal();
        document.body.style.overflow = 'hidden';
      }
    };

    // Close logic
    const handleClose = () => {
      dialog.close();
      document.body.style.overflow = '';
    };

    // Outside click to close
    dialog.addEventListener('click', e => {
      const rect = dialog.getBoundingClientRect();
      const isInDialog =
        e.clientX >= rect.left && e.clientX <= rect.right && e.clientY >= rect.top && e.clientY <= rect.bottom;
      if (!isInDialog) {
        handleClose();
      }
    });

    closeBtn.addEventListener('click', handleClose);
    document.addEventListener('click', handleOpen);

    // ESC is native for dialog, but we want to reset body overflow
    dialog.addEventListener('close', () => {
      document.body.style.overflow = '';
    });
  };

  // Run on first load
  setupEstimateDialog();

  // Re-run for view transitions if enabled
  document.addEventListener('astro:after-swap', setupEstimateDialog);
</script>

<style>
  dialog[open] {
    animation: fadeInScale 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes fadeInScale {
    from {
      opacity: 0;
      transform: scale(0.95) translateY(10px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  dialog::backdrop {
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  dialog[open]::backdrop {
    opacity: 1;
  }

  /* Prevent background scrolling when dialog is open */
  html:has(dialog[open]) {
    overflow: hidden;
  }
</style>
