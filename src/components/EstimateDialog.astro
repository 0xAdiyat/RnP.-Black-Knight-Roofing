---
import EstimateForm from './EstimateForm.astro';
import { Icon } from 'astro-icon/components';
---

<div
  id="estimate-dialog"
  class="pointer-events-none fixed inset-0 z-[120] hidden opacity-0 transition-opacity duration-300 ease-out"
  aria-hidden="true"
>
  <button
    id="estimate-dialog-backdrop"
    type="button"
    class="absolute inset-0 bg-black/80"
    aria-label="Close dialog"
  ></button>

  <div class="relative z-10 flex min-h-full items-center justify-center px-3 py-4 sm:px-6 sm:py-8">
    <div
      id="estimate-dialog-panel"
      class="border-radial estimate-dialog-panel relative flex w-full max-w-6xl translate-y-5 scale-[0.9] overflow-hidden rounded-2xl bg-[#161616]/95 text-white opacity-0 shadow-2xl transition-[transform,opacity] duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] will-change-transform sm:rounded-3xl"
    >
      <!-- Close Button -->
      <button
        id="close-estimate-dialog"
        type="button"
        class="border-radial text-primary absolute top-3 right-3 z-30 flex size-10 items-center justify-center rounded-full bg-[#1b1b1b]/95 transition-colors hover:bg-white/10 hover:text-white sm:top-4 sm:right-4 sm:bg-white/5"
        aria-label="Close dialog"
      >
        <Icon name="close" class="size-5" />
      </button>

      <!-- Content -->
      <div class="scrollbar-thin scrollbar-track-transparent scrollbar-thumb-white/20 grow overflow-y-auto">
        <EstimateForm />
      </div>
    </div>
  </div>
</div>

<script>
  // Global script for estimate dialog
  const setupEstimateDialog = () => {
    const dialog = document.getElementById('estimate-dialog') as HTMLDivElement;
    const panel = document.getElementById('estimate-dialog-panel') as HTMLDivElement;
    const backdrop = document.getElementById('estimate-dialog-backdrop');
    const closeBtn = document.getElementById('close-estimate-dialog');
    const triggers = document.querySelectorAll('[data-estimate-trigger]');

    if (!dialog || !panel || !backdrop || !closeBtn || dialog.dataset.estimateDialogReady === 'true') return;

    dialog.dataset.estimateDialogReady = 'true';

    const OPEN_DURATION_MS = 280;
    const CLOSE_DURATION_MS = 220;

    const lockBodyScroll = () => {
      document.body.style.overflow = 'hidden';
    };

    const unlockBodyScroll = () => {
      document.body.style.overflow = '';
    };

    const handleOpen = (e: Event) => {
      e.preventDefault();
      e.stopPropagation();

      dialog.style.transitionDuration = `${OPEN_DURATION_MS}ms`;
      panel.style.transitionDuration = `${OPEN_DURATION_MS}ms`;
      dialog.classList.remove('hidden');
      dialog.setAttribute('aria-hidden', 'false');
      lockBodyScroll();

      requestAnimationFrame(() => {
        void panel.offsetHeight;

        requestAnimationFrame(() => {
          dialog.classList.remove('pointer-events-none', 'opacity-0');
          panel.classList.remove('translate-y-5', 'scale-[0.9]', 'opacity-0');
        });
      });
    };

    const handleClose = () => {
      dialog.style.transitionDuration = `${CLOSE_DURATION_MS}ms`;
      panel.style.transitionDuration = `${CLOSE_DURATION_MS}ms`;
      dialog.classList.add('pointer-events-none', 'opacity-0');
      panel.classList.add('translate-y-5', 'scale-[0.9]', 'opacity-0');
      dialog.setAttribute('aria-hidden', 'true');
      unlockBodyScroll();

      window.setTimeout(() => {
        if (dialog.getAttribute('aria-hidden') === 'true') {
          dialog.classList.add('hidden');
        }
      }, CLOSE_DURATION_MS);
    };

    triggers.forEach(trigger => {
      trigger.addEventListener('click', handleOpen);
    });

    backdrop.addEventListener('click', handleClose);
    closeBtn.addEventListener('click', handleClose);

    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && dialog.getAttribute('aria-hidden') === 'false') {
        handleClose();
      }
    });
  };

  // Run on first load
  setupEstimateDialog();

  // Re-run for view transitions if enabled
  document.addEventListener('astro:after-swap', setupEstimateDialog);
</script>

<style>
  .estimate-dialog-panel {
    max-height: calc(100dvh - 2rem);
  }

  @media (min-width: 640px) {
    .estimate-dialog-panel {
      max-height: 96vh;
    }
  }

  /* Prevent background scrolling when dialog is open */
  html:has(#estimate-dialog[aria-hidden='false']) {
    overflow: hidden;
  }
</style>
