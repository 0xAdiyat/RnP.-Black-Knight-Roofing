---
// src/components/HumanManifesto.astro
---

<div
  id="human-manifesto-overlay"
  class="fixed inset-0 z-[200] overflow-y-auto bg-[#111] font-mono transition-opacity duration-300"
>
  <div class="machine-manifesto-actions">
    <button
      id="machine-close-button"
      type="button"
      class="machine-manifesto-icon-button"
      aria-label="Exit machine mode"
      title="Exit machine mode"
    >
      <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 6 6 18"></path>
        <path d="m6 6 12 12"></path>
      </svg>
      <span class="sr-only">Exit machine mode</span>
    </button>
    <button
      id="machine-copy-button"
      type="button"
      class="machine-manifesto-icon-button"
      aria-label="Copy markdown for AEO"
      title="Copy markdown for AEO"
    >
      <svg data-copy-icon="copy" viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="9" y="9" width="10" height="10" rx="2"></rect>
        <path d="M15 9V7a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"></path>
      </svg>
      <svg data-copy-icon="success" viewBox="0 0 24 24" class="hidden h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M20 6 9 17l-5-5"></path>
      </svg>
      <span class="sr-only">Copy markdown for AEO</span>
    </button>
  </div>
  <div class="relative mx-auto flex min-h-screen w-full max-w-4xl flex-col border-x border-white/10 bg-[#111] px-4 pt-20 pb-28 sm:px-5 md:px-12 md:py-12">
    <div class="machine-manifesto-content prose prose-invert prose-mono max-w-none text-white/90">
      <h1 class="text-xl md:text-2xl font-normal leading-tight text-[#e9e9e9] mb-8">
        # Black Knight Roofing — Veteran-Owned Roofing Company Serving Colorado's Front Range
      </h1>

      <p class="mb-4">
        Colorado's premier full-construction roofing company. Veteran-owned and operated, specializing in insurance claims, storm damage restoration, and lifetime-warranted roof replacements from Colorado Springs to Fort Collins.
      </p>

      <div class="flex flex-col gap-2 mb-8">
        <a href="tel:720-805-9666" class="text-primary hover:underline">[GET FREE ROOF INSPECTION](tel:720-805-9666)</a>
        <a href="/contact" class="text-primary hover:underline">[REQUEST A QUOTE](https://www.blackknightroofing.com/contact)</a>
      </div>

      <hr class="border-white/10 my-8" />

      <h2 class="text-lg font-normal text-[#e9e9e9] mt-12 mb-4">## Trusted by Colorado homeowners</h2>
      <p class="mb-8">
        40+ Five-Star Google Reviews • BBB A+ Rating • 5.0 Facebook Rating • Licensed & Insured • Veteran-Owned • Lifetime Workmanship Warranty
      </p>

      <hr class="border-white/10 my-8" />

      <h2 class="text-lg font-normal text-[#e9e9e9] mt-12 mb-4">## [01] ABOUT / WHO WE ARE</h2>
      <p class="mb-4">
        Black Knight Roofing Company is led by Adam Knight, a US Army veteran who founded the company to raise the standard in an industry known for shortcuts and confusion. Based in Denver, Colorado, we serve homeowners throughout the Front Range from Colorado Springs to Fort Collins.
      </p>

      <h3 class="text-base font-normal text-[#e9e9e9] mt-8 mb-2">### Veteran-Owned Excellence</h3>
      <p class="mb-4">
        Founded by US Army veteran Adam Knight, we bring military values of accountability, discipline, and integrity to every roofing project. We do the job right the first time, every time.
      </p>

      <h3 class="text-base font-normal text-[#e9e9e9] mt-8 mb-2">### Licensed General Contractor</h3>
      <p class="mb-4">
        Adam Knight is a licensed general contractor and President of Black Knight Homes. We're not just roofers—we bring a full-construction, builder-level mindset to every project.
      </p>

      <h3 class="text-base font-normal text-[#e9e9e9] mt-8 mb-2">### Patent-Holder & Innovator</h3>
      <p class="mb-4">
        Adam holds a patent for an advanced Snow Retention System, proving our commitment to innovation and solving real problems for Colorado homeowners.
      </p>

      <hr class="border-white/10 my-8" />

      <h2 class="text-lg font-normal text-[#e9e9e9] mt-12 mb-4">## [02] SERVICES / WHAT WE DO</h2>
      <p class="mb-4">
        Complete roofing solutions for Colorado homes. From inspections to full replacements, storm damage restoration to insurance claims assistance—we handle it all with a lifetime workmanship warranty.
      </p>

      <h3 class="text-base font-normal text-[#e9e9e9] mt-8 mb-2">### Roofing Services</h3>
      <ul class="list-none space-y-4 mb-8">
        <li><strong>Roof Replacement</strong>: Complete tear-off and replacement with premium materials. Asphalt shingles, metal roofing, stone-coated steel, tile, and flat roofing systems (TPO/EPDM).</li>
        <li><strong>Roof Repair</strong>: Professional repairs for leaks, damaged shingles, flashing issues, and wind damage.</li>
        <li><strong>Roof Inspection</strong>: Free comprehensive roof inspections for homeowners. We assess condition, check for storm damage, and provide honest recommendations.</li>
        <li><strong>Storm Damage Restoration</strong>: Colorado hail and wind damage specialists. We document damage, work with insurance adjusters, and handle all paperwork.</li>
        <li><strong>Insurance Claims Assistance</strong>: We specialize in navigating insurance claims after storm damage. This is a core specialty—we fight to get you what you deserve.</li>
      </ul>

      <hr class="border-white/10 my-8" />

      <h2 class="text-lg font-normal text-[#e9e9e9] mt-12 mb-4">## [03] PROCESS / HOW WE WORK</h2>
      <p class="mb-4">Our straightforward 4-step process ensures you know exactly what to expect from first contact to final walkthrough.</p>

      <h3 class="text-base font-normal text-[#e9e9e9] mt-8 mb-2">### Step 1: Contact Our Team</h3>
      <p class="mb-4">Call (720) 805-9666 or fill out our online form. We'll schedule your free roof inspection at a time that works for you.</p>

      <h3 class="text-base font-normal text-[#e9e9e9] mt-8 mb-2">### Step 2: Free Roof Inspection</h3>
      <p class="mb-4">We assess your roof's condition, check for storm damage, and take detailed photos. Honest assessment with no pressure—we'll tell you exactly what you need.</p>

      <hr class="border-white/10 my-8" />

      <h2 class="text-lg font-normal text-[#e9e9e9] mt-12 mb-4">## [04] SERVICE AREA / WHERE WE WORK</h2>
      <p class="mb-4">Based in Denver, Colorado, we proudly serve the entire Colorado Front Range region.</p>
      <ul class="list-none space-y-2 mb-8">
        <li><strong>Metro Denver Area</strong>: Denver, Aurora, Lakewood, Arvada, Westminster, Thornton, Centennial, Englewood</li>
        <li><strong>Northern Front Range</strong>: Fort Collins, Loveland, Longmont, Boulder, Broomfield, Lafayette, Louisville</li>
        <li><strong>Southern Front Range</strong>: Colorado Springs, Castle Rock, Parker, Highlands Ranch, Littleton, Lone Tree</li>
      </ul>

      <hr class="border-white/10 my-8" />

      <h2 class="text-lg font-normal text-[#e9e9e9] mt-12 mb-4">## [09] ROOFING MATERIALS / WHAT WE RECOMMEND</h2>
      <div class="space-y-8">
        <div>
          <h3 class="text-base font-normal text-[#e9e9e9] mt-4 mb-2">### Asphalt Shingles (Most Popular)</h3>
          <p class="mb-1 text-sm opacity-70 font-bold">Cost: $8,000-$15,000 typical residential roof</p>
          <p class="mb-4">Best For: Budget-conscious homeowners, those planning to sell within 10-15 years.</p>
        </div>
        <div>
          <h3 class="text-base font-normal text-[#e9e9e9] mt-4 mb-2">### Metal Roofing (Premium Option)</h3>
          <p class="mb-1 text-sm opacity-70 font-bold">Cost: $15,000-$30,000+ typical residential roof</p>
          <p class="mb-4">Best For: Long-term homeowners, those wanting maximum durability, mountain homes.</p>
        </div>
      </div>

      <div class="h-40"></div>
    </div>

    <!-- Persistent Toggle Bottom Overlay (from Figma) -->
    <div class="fixed bottom-4 left-1/2 z-[300] w-[calc(100%-1.5rem)] max-w-max -translate-x-1/2 px-2 pointer-events-none sm:bottom-6 md:bottom-12 md:w-auto md:px-0">
       <div class="flex items-center rounded-full border border-white/15 bg-[#272524] p-[2px] shadow-2xl pointer-events-auto backdrop-blur-sm transition-transform duration-300 ease-out">
          <button id="human-toggle-to-close" class="rounded-full bg-transparent px-4 py-2 text-[11px] font-mono text-[#e9e9e9]/50 transition-all duration-300 ease-out sm:px-5 md:px-6 md:text-[12px]"> HUMAN </button>
          <button id="machine-toggle-active" class="rounded-full bg-[#111] px-4 py-2 text-[11px] font-mono text-[#e9e9e9] transition-all duration-300 ease-out sm:px-5 md:px-6 md:text-[12px]"> MACHINE </button>
       </div>
    </div>

    <!-- Gradient fade to match Figma top-[411px] -->
    <div class="pointer-events-none fixed bottom-0 left-0 h-[26vh] w-full bg-linear-to-t from-[#111] to-transparent z-[250] sm:h-[30vh] md:h-[40vh]"></div>
  </div>
</div>

<style>
  #human-manifesto-overlay {
    font-family: var(--font-mono);
    font-size: 14px;
    opacity: 0;
    pointer-events: none;
    visibility: hidden;
    transition: opacity 0.38s cubic-bezier(0.22, 1, 0.36, 1), visibility 0.38s ease;
  }
  .machine-manifesto-content {
    transform: translateY(18px) scale(0.985);
    transition: transform 0.42s cubic-bezier(0.22, 1, 0.36, 1);
    padding-bottom: 1rem;
  }
  .machine-manifesto-actions {
    position: fixed;
    top: max(1rem, env(safe-area-inset-top));
    right: max(1rem, env(safe-area-inset-right));
    z-index: 320;
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }
  .machine-manifesto-icon-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.25rem;
    color: rgba(233, 233, 233, 0.7);
    transition: color 0.2s ease;
  }
  #human-manifesto-overlay .prose {
    font-size: 0.875rem;
    line-height: 1.75;
    overflow-wrap: anywhere;
  }
  #human-manifesto-overlay :is(h1, h2, h3, p, a, li, button, strong, span) {
    font-family: inherit;
  }
  #human-manifesto-overlay h1 {
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }
  #human-manifesto-overlay h2 {
    font-size: 0.9rem;
    line-height: 1.6;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  #human-manifesto-overlay h3 {
    font-size: 0.84rem;
    line-height: 1.6;
    margin-top: 1.5rem;
    margin-bottom: 0.45rem;
  }
  #human-manifesto-overlay p,
  #human-manifesto-overlay li,
  #human-manifesto-overlay a {
    font-size: 0.875rem;
    line-height: 1.75;
  }
  #human-manifesto-overlay strong {
    font-size: inherit;
  }
  #machine-copy-button[data-copy-state='success'] {
    color: #f6d373;
  }
  #machine-copy-button[data-copy-state='error'] {
    color: #f3a6a6;
  }
  #machine-close-button:hover,
  #machine-copy-button:hover {
    color: #f3eee9;
  }
  #machine-copy-button[data-copy-state='success'] [data-copy-icon='copy'],
  #machine-copy-button[data-copy-state='error'] [data-copy-icon='success'] {
    display: none;
  }
  #machine-copy-button[data-copy-state='success'] [data-copy-icon='success'] {
    display: block;
  }
  :global(html.view-mode-human) #human-manifesto-overlay {
    opacity: 1;
    pointer-events: auto;
    visibility: visible;
  }
  :global(html.view-mode-human) .machine-manifesto-content {
    transform: translateY(0) scale(1);
  }
  @media (max-width: 767px) {
    #human-manifesto-overlay {
      font-size: 13px;
    }
    #human-manifesto-overlay .prose {
      font-size: 0.8125rem;
      line-height: 1.7;
    }
    #human-manifesto-overlay h1 {
      font-size: 0.95rem;
      line-height: 1.6;
      margin-bottom: 1.25rem;
      padding-right: 3.5rem;
    }
    #human-manifesto-overlay h2 {
      font-size: 0.84rem;
      margin-top: 1.5rem;
      margin-bottom: 0.625rem;
    }
    #human-manifesto-overlay h3 {
      font-size: 0.8rem;
      margin-top: 1.25rem;
    }
    #human-manifesto-overlay p,
    #human-manifesto-overlay li,
    #human-manifesto-overlay a {
      font-size: 0.8125rem;
      line-height: 1.7;
    }
    .machine-manifesto-actions svg {
      width: 1.375rem;
      height: 1.375rem;
    }
    .machine-manifesto-content hr {
      margin-top: 1.5rem;
      margin-bottom: 1.5rem;
    }
  }
  @media (max-width: 639px) {
    #human-manifesto-overlay > .relative {
      border-left: 0;
      border-right: 0;
    }
  }
</style>

<script>
  function setupHumanMode() {
    const humanToggle = document.getElementById('human-toggle-to-close');
    const closeButton = document.getElementById('machine-close-button') as HTMLButtonElement | null;
    const copyButton = document.getElementById('machine-copy-button') as HTMLButtonElement | null;
    const markdownRoot = document.querySelector('.machine-manifesto-content') as HTMLElement | null;

    function setMode(isMachine: boolean) {
      if (isMachine) {
        document.documentElement.classList.add('view-mode-human');
      } else {
        document.documentElement.classList.remove('view-mode-human');
      }
      window.dispatchEvent(new CustomEvent('view-mode-changed', { detail: { isHuman: !isMachine, isMachine } }));
    }

    function handleToggleEvent(event: Event) {
      const { detail } = event as CustomEvent<{ isHuman?: boolean; isMachine?: boolean; mode?: string }>;

      if (detail?.mode === 'machine') {
        setMode(true);
        return;
      }

      if (detail?.mode === 'human') {
        setMode(false);
        return;
      }

      if (typeof detail?.isMachine === 'boolean') {
        setMode(detail.isMachine);
        return;
      }

      if (typeof detail?.isHuman === 'boolean') {
        setMode(!detail.isHuman);
      }
    }

    function handleKeydown(event: KeyboardEvent) {
      if (event.key === 'Escape' && document.documentElement.classList.contains('view-mode-human')) {
        setMode(false);
      }
    }

    async function copyMarkdown() {
      if (!copyButton || !markdownRoot) {
        return;
      }

      const markdown = markdownRoot.innerText.replace(/\n{3,}/g, '\n\n').trim();
      if (!markdown) {
        copyButton.dataset.copyState = 'error';
        return;
      }

      try {
        await navigator.clipboard.writeText(markdown);
        copyButton.dataset.copyState = 'success';
      } catch {
        copyButton.dataset.copyState = 'error';
      }

      window.setTimeout(() => {
        if (copyButton) {
          copyButton.dataset.copyState = 'idle';
        }
      }, 1800);
    }

    window.addEventListener('toggle-view-mode', handleToggleEvent);
    window.addEventListener('toggle-human-mode', handleToggleEvent as EventListener);
    window.addEventListener('keydown', handleKeydown);

    humanToggle?.addEventListener('click', () => {
      setMode(false);
    });

    if (closeButton) {
      closeButton.onclick = () => {
        setMode(false);
      };
    }

    if (copyButton) {
      copyButton.onclick = () => {
        void copyMarkdown();
      };
    }
  }

  // Run on initial load
  setupHumanMode();
  // Run after View Transitions navigation
  document.addEventListener('astro:after-swap', setupHumanMode);
</script>
