---
import { getImage, Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import TestimonialCard from './TestimonialCard.astro';
import Carousel from './ui/Carousel.astro';
import CarouselSlide from './ui/CarouselSlide.astro';
import sunFlowImage from '@/assets/sunflow.avif';

import googleLogo from '@/assets/google-logo.avif';

import RatingStars from './ui/RatingStars.astro';
import Button from './ui/Button.astro';
import BadgeTitle from './BadgeTitle.astro';
import bgShapeImage from '@/assets/testimonial-section-shape.avif';

import { testimonials } from '@/data/testimonials';

const bgShape = await getImage({ src: bgShapeImage, width: 1536, height: 850, format: 'avif' });
---

<section data-testid="testimonials" id="testimonials" class="relative overflow-hidden">
  <!-- Background Image -->
  <div class="pointer-events-none absolute inset-0 -z-10 bg-[#151515]">
    <Image
      src={sunFlowImage}
      alt=""
      width={1536}
      height={1152}
      format="avif"
      loading="eager"
      fetchpriority="high"
      sizes="(max-width: 768px) 100vw, 1536px"
      class="h-full w-full object-cover object-top"
    />
    <!-- This div acts as your linear-gradient overlay to manage opacity/tint -->
    <div class="absolute inset-0 bg-[#151515]/85"></div>
  </div>
  <div
    class="z-10 py-20 lg:bg-size-[auto_100%] lg:bg-position-[top_right]"
    style={`
      background-image: url(${bgShape.src});
      background-repeat: no-repeat;
    `}
  >
    <div class="space-y-12">
      <!-- Top section -->
      <div class="container flex flex-col gap-y-10 pt-8 lg:flex-row lg:items-end">
        <div class="w-full max-w-[450px]">
          <BadgeTitle
            badge="Homeowner Reviews"
            title="Real Reviews from Colorado Homeowners"
            titleClass="text-3xl lg:text-4xl font-normal leading-tight"
          />
        </div>

        <div class="flex flex-col items-start gap-8 md:flex-row md:items-center lg:gap-x-16">
          <div class="flex flex-col items-start gap-y-4 sm:flex-row sm:items-center sm:gap-x-4">
            <Image
              fetchpriority="high"
              loading="eager"
              src={googleLogo}
              alt="Google Reviews logo"
              width={googleLogo.width}
              height={googleLogo.height}
              class="h-8 w-fit object-contain"
            />

            <div class="flex flex-wrap items-center gap-x-4 text-sm sm:text-base">
              <span class="font-medium"> Excellent </span>
              <RatingStars rating={5} size={18} fillColor="#F7B715" strokeColor="none" />
              <span class="font-bold"> 5.0 </span>
              <span class="hidden h-4 w-px bg-white/30 sm:block"></span>
              <span class="text-white/70"> 40+ reviews </span>
            </div>
          </div>

          <Button
            variant="primary"
            class="w-full max-w-[200px] sm:w-auto"
            href="https://maps.app.goo.gl/wnH4TMxKG99i1MUH8"
            target="_blank"
            rel="noopener noreferrer"
          >
            Write a Review
          </Button>
        </div>
      </div>

      <!-- Testimonial cards -->
      <div class="relative w-full overflow-hidden">
        <div class="relative">
          <!-- Responsive overlays -->
          <div
            class="pointer-events-none absolute inset-y-0 top-0 left-0 z-10 w-4 bg-linear-to-r from-[#151515] to-[#15151500] md:w-32 lg:w-[250px]"
          >
          </div>
          <div
            class="pointer-events-none absolute inset-y-0 top-0 right-0 z-10 w-4 bg-linear-to-l from-[#151515] to-[#15151500] md:w-32 lg:w-[250px]"
          >
          </div>
          <Carousel
            slidesPerView={1.3}
            centeredSlides={true}
            spaceBetween={12}
            loop={true}
            autoplay={true}
            breakpoints={{
              640: { slidesPerView: 1.5, spaceBetween: 20 },
              768: { slidesPerView: 2, spaceBetween: 24, centeredSlides: false },
              1024: { slidesPerView: 3, spaceBetween: 32, centeredSlides: false },
              1440: { slidesPerView: 3.5, spaceBetween: 40, centeredSlides: false },
            }}
            class="w-full pb-16"
          >
            {
              testimonials.map((testimonial) => (
                <CarouselSlide>
                  <TestimonialCard {...testimonial} />
                </CarouselSlide>
              ))
            }

            <div slot="navigation" class="mt-8 flex justify-center gap-x-2.5 lg:mt-12">
              <button
                type="button"
                aria-label="Previous testimonial"
                class="swiper-button-prev hover:bg-primary group static! mt-0! flex h-10! w-10! items-center justify-center rounded-full bg-[#1A1A1A] text-white transition-colors duration-200 after:content-none!"
              >
                <Icon name="chevron-left" class="size-4! text-white group-hover:text-black" />
              </button>
              <button
                type="button"
                aria-label="Next testimonial"
                class="swiper-button-next hover:bg-primary group static! mt-0! flex h-10! w-10! items-center justify-center rounded-full bg-[#1A1A1A] text-white transition-colors duration-200 after:content-none!"
              >
                <Icon name="chevron-right" class="size-4! text-white group-hover:text-black" />
              </button>
            </div>
          </Carousel>
        </div>
      </div>
    </div>
  </div>
</section>
