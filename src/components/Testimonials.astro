---
import { getImage, Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import TestimonialCard from './TestimonialCard.astro';
import Carousel from './ui/Carousel.astro';
import CarouselSlide from './ui/CarouselSlide.astro';
import sunFlowImage from '@/assets/sunflow.png';
import gridLines from '@/assets/grid-frame.png';
import googleLogo from '@/assets/google-logo.svg';
import RatingStars from './ui/RatingStars.astro';
import Button from './ui/Button.astro';
import BadgeTitle from './BadgeTitle.astro';

const sunFlowImageOp = await getImage({ src: sunFlowImage, width: 1536, height: 1152, format: 'webp' });
const gridLinesOp = await getImage({ src: gridLines, width: 1536, height: 1152, format: 'webp' });
---

<section data-testid="testimonials" id="testimonials" class="relative">
  <Image
    src={sunFlowImageOp.src}
    alt="Sunflow"
    width={sunFlowImageOp.options.width || 1536}
    height={sunFlowImageOp.options.height || 1152}
    class="pointer-events-none absolute -z-10 h-full w-full object-cover opacity-10 lg:hidden"
  />

  <div class="py-12 md:py-20">
    <svg
      viewBox="0 0 1536 850"
      class="absolute top-0 left-0 -z-10 hidden h-full w-full lg:block"
      preserveAspectRatio="none"
      fill="none"
    >
      <defs>
        <clipPath id="testimonialPathClip">
          <path
            d="M0 0 L100 0 L160 80 L980 80 Q1200 80 1200 100 L1300 450 L1300 780 Q1300 800 1280 800 L60 800 L0 850 Z"
          ></path>
        </clipPath>

        <mask id="testimonialGridMask">
          <rect width="100%" height="100%" fill="white"></rect>
          <path
            d="M0 0 L100 0 L160 80 L980 80 Q1200 80 1200 100 L1300 450 L1300 780 Q1300 800 1280 800 L60 800 L0 850 Z"
            fill="black"></path>
        </mask>

        <radialGradient
          id="paint0_radial_16435_10598"
          cx="0"
          cy="0"
          r="1"
          gradientUnits="userSpaceOnUse"
          gradientTransform="translate(720 422) scale(720 422)"
        >
          <stop stop-color="#303030" stop-opacity="0"></stop>
          <stop offset="1" stop-color="#303030"></stop>
        </radialGradient>
        <linearGradient id="paint1_linear_16435_10598" x1="0" y1="0" x2="0" y2="850" gradientUnits="userSpaceOnUse">
          <stop stop-color="#2a2a2a70"></stop>
          <stop offset="1" stop-color="#050505AA"></stop>
        </linearGradient>
      </defs>

      <rect width="100%" height="100%" mask="url(#testimonialGridMask)" fill="url(#paint0_radial_16435_10598)"></rect>

      <image
        width="100%"
        height="100%"
        preserveAspectRatio="xMidYMid slice"
        mask="url(#testimonialGridMask)"
        xlink:href={gridLinesOp.src}
      />

      <rect
        class="mix-blend-overlay"
        width="100%"
        height="100%"
        mask="url(#testimonialGridMask)"
        fill="url(#paint1_linear_16435_10598)"></rect>

      <image
        class="opacity-10 mix-blend-overlay"
        width="100%"
        height="100%"
        preserveAspectRatio="xMidYMid slice"
        clip-path="url(#testimonialPathClip)"
        xlink:href={sunFlowImageOp.src}
      />
    </svg>

    <div class="space-y-12">
      <!-- Top section -->
      <div class="container flex flex-col gap-y-10 lg:flex-row lg:items-end">
        <div class="w-full max-w-[450px]">
          <BadgeTitle
            badge="Homeowner Reviews"
            title="Real Reviews from Colorado Homeowners"
            titleClass="text-3xl lg:text-4xl font-bold leading-tight"
          />
        </div>

        <div class="flex flex-col items-start gap-8 md:flex-row md:items-center lg:gap-x-16">
          <div class="flex flex-col items-start gap-y-4 sm:flex-row sm:items-center sm:gap-x-8">
            <Image src={googleLogo} alt="google Logo" width={100} height={40} class="h-8 w-auto object-contain" />
            <div class="flex flex-wrap items-center gap-x-4 text-sm sm:text-base">
              <span class="font-medium"> Excellent </span>
              <RatingStars rating={5} size={18} fillColor="#F7B715" strokeColor="none" />
              <span class="font-bold"> 5.0 </span>
              <span class="hidden h-4 w-px bg-white/30 sm:block"></span>
              <span class="text-white/70"> 41 reviews </span>
            </div>
          </div>

          <Button variant="primary" class="w-full max-w-[200px] sm:w-auto"> Write a Review</Button>
        </div>
      </div>

      <!-- Testimonial cards -->
      <div class="relative w-full overflow-hidden">
        <div class="relative">
          <!-- Responsive overlays -->
          <div
            class="pointer-events-none absolute inset-y-0 top-0 left-0 z-10 w-4 bg-linear-to-r from-[#151515] to-[#15151500] md:w-32 lg:w-[250px]"
          >
          </div>
          <div
            class="pointer-events-none absolute inset-y-0 top-0 right-0 z-10 w-4 bg-linear-to-l from-[#151515] to-[#15151500] md:w-32 lg:w-[250px]"
          >
          </div>
          <Carousel
            slidesPerView={1.3}
            centeredSlides={true}
            spaceBetween={12}
            loop={true}
            autoplay={true}
            breakpoints={{
              640: { slidesPerView: 1.5, spaceBetween: 20 },
              768: { slidesPerView: 2, spaceBetween: 24, centeredSlides: false },
              1024: { slidesPerView: 3, spaceBetween: 32, centeredSlides: false },
              1440: { slidesPerView: 3.5, spaceBetween: 40, centeredSlides: false },
            }}
            class="w-full pb-16"
          >
            <CarouselSlide>
              <TestimonialCard />
            </CarouselSlide>
            <CarouselSlide>
              <TestimonialCard />
            </CarouselSlide>
            <CarouselSlide>
              <TestimonialCard />
            </CarouselSlide>
            <CarouselSlide>
              <TestimonialCard />
            </CarouselSlide>

            <div slot="navigation" class="mt-8 flex justify-center gap-x-2.5 lg:mt-12">
              <button
                class="swiper-button-prev hover:bg-primary group static! mt-0! flex h-10! w-10! items-center justify-center rounded-full bg-[#1A1A1A] text-white transition-colors duration-200 after:content-none!"
              >
                <Icon name="chevron-left" class="size-4! text-white group-hover:text-black" />
              </button>
              <button
                class="swiper-button-next hover:bg-primary group static! mt-0! flex h-10! w-10! items-center justify-center rounded-full bg-[#1A1A1A] text-white transition-colors duration-200 after:content-none!"
              >
                <Icon name="chevron-right" class="size-4! text-white group-hover:text-black" />
              </button>
            </div>
          </Carousel>
        </div>
      </div>
    </div>
  </div>
</section>
