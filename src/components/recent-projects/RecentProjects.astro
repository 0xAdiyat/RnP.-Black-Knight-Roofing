---
import { Image } from 'astro:assets';
import topShape from '@/assets/top-shape.png';
import NoiseBg from '../NoiseBg.astro';
import RecentProjectCard from './RecentProjectCard.astro';
---

<NoiseBg class="relative overflow-hidden px-0 py-20 pb-32">
  <Image src={topShape} alt="Top Shape" class="pointer-events-none absolute top-0 left-0 -mt-11 w-full opacity-50" />

  <div class="relative z-10 container flex flex-col items-center space-y-4 border-b border-white/10 pb-12 text-center">
    <div class="flex items-center gap-x-3">
      <div
        class="relative size-5 rounded-[5px] bg-[#F7B715]/50 drop-shadow-2xl before:absolute before:top-1/2 before:left-1/2 before:size-2 before:-translate-1/2 before:rounded-full before:bg-[#F7D515] before:content-['']"
      >
      </div>
      <div class="text-sm font-medium tracking-wide text-white/80 uppercase">Our Recent Work</div>
    </div>
    <h2 class="text-4xl font-normal lg:text-5xl">Our Handcrafted Roofs</h2>
  </div>

  <div class="container mt-16 px-4">
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      <RecentProjectCard
        image="/placeholders/projects/project-1.jpg"
        title="EDCO Metal Siding (Charcoal Gray)"
        category="Roofing"
      />
      <RecentProjectCard
        image="/placeholders/projects/project-2.jpg"
        title="Asphalt Shingle Replacement"
        category="Roofing"
      />
      <RecentProjectCard
        image="/placeholders/projects/project-3.jpg"
        title="Cedar Shake Restoration"
        category="Siding"
      />
      <RecentProjectCard
        image="/placeholders/projects/project-4.jpg"
        title="Standing Seam Metal Roof"
        category="Roofing"
      />
    </div>
  </div>
</NoiseBg>
