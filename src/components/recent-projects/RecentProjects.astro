---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import topShape from '@/assets/top-frame.avif';
import NoiseBg from '../NoiseBg.astro';
import RecentProjectCard from './RecentProjectCard.astro';
import BadgeTitle from '../BadgeTitle.astro';
import Carousel from '../ui/Carousel.astro';
import CarouselSlide from '../ui/CarouselSlide.astro';

const projects = [
  {
    image: '/placeholders/projects/project-1.jpg',
    title: 'EDCO Metal Siding (Charcoal Gray)',
    category: 'Roofing',
  },
  {
    image: '/placeholders/projects/project-2.jpg',
    title: 'Asphalt Shingle Replacement',
    category: 'Roofing',
  },
  {
    image: '/placeholders/projects/project-3.jpg',
    title: 'Cedar Shake Restoration',
    category: 'Siding',
  },
  {
    image: '/placeholders/projects/project-4.jpg',
    title: 'Standing Seam Metal Roof',
    category: 'Roofing',
  },
];
---

<NoiseBg class="relative overflow-hidden px-0 py-20 pb-32">
  <Image src={topShape} alt="Top Shape" class="pointer-events-none absolute top-0 left-0 -mt-11 w-full" />

  <BadgeTitle
    badge="Our Recent Work"
    title="120+ Families Protected <br/> Across Colorado"
    class="relative z-10 container flex flex-col items-center space-y-4 border-b border-white/10 pb-12 text-center text-balance"
  />

  <div class="container relative mt-16 overflow-visible! px-4">
    <div class="relative">
      <Carousel
        slidesPerView={1.2}
        spaceBetween={20}
        loop={true}
        autoplay={true}
        centeredSlides={true}
        breakpoints={{
          640: { slidesPerView: 2, spaceBetween: 24, centeredSlides: false },
          1024: { slidesPerView: 3, spaceBetween: 32, centeredSlides: false },
          1440: { slidesPerView: 4, spaceBetween: 40, centeredSlides: false },
        }}
        class="recent-projects-carousel w-full pb-16"
      >
        {
          projects.map(project => (
            <CarouselSlide>
              <RecentProjectCard image={project.image} title={project.title} category={project.category} />
            </CarouselSlide>
          ))
        }

        <div slot="navigation" class="mt-8 flex items-center justify-center gap-3 lg:mt-12">
          <button
            type="button"
            class="swiper-button-prev hover:bg-primary group static! mt-0! flex h-10! w-10! items-center justify-center rounded-full bg-[#1A1A1A] text-white transition-colors duration-200 after:content-none!"
            aria-label="Previous recent project"
          >
            <Icon name="chevron-left" class="size-4! text-white group-hover:text-black" />
          </button>
          <button
            type="button"
            class="swiper-button-next hover:bg-primary group static! mt-0! flex h-10! w-10! items-center justify-center rounded-full bg-[#1A1A1A] text-white transition-colors duration-200 after:content-none!"
            aria-label="Next recent project"
          >
            <Icon name="chevron-right" class="size-4! text-white group-hover:text-black" />
          </button>
        </div>
      </Carousel>
    </div>
  </div>

  <div
    class="pointer-events-none fixed inset-0 z-50 flex items-center justify-center bg-black/90 px-4 py-6 opacity-0 transition-opacity duration-300"
    data-project-lightbox
    aria-hidden="true"
    inert
  >
    <button
      type="button"
      class="absolute inset-0"
      data-project-lightbox-close
      aria-label="Close full screen project view"></button>

    <div class="relative z-10 flex h-full w-full max-w-6xl items-center justify-center">
      <button
        type="button"
        class="absolute top-4 right-0 z-20 flex size-11 items-center justify-center rounded-full border border-white/20 bg-[#1A1A1A]/90 text-white backdrop-blur-sm transition-colors hover:border-white/40"
        data-project-lightbox-close
        aria-label="Close full screen project view"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none">
          <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
        </svg>
      </button>

      <button
        type="button"
        class="hover:bg-primary hover:text-inverted absolute left-0 hidden h-10 w-10 items-center justify-center rounded-full bg-[#1A1A1A] text-white transition-colors duration-200 md:flex"
        data-project-lightbox-prev
        aria-label="Previous project"
      >
        <Icon name="chevron-left" size={16} />
      </button>

      <div
        class="mx-auto flex max-h-full w-full max-w-5xl flex-col overflow-hidden rounded-2xl bg-[#111111] shadow-2xl"
      >
        <div class="relative min-h-0 flex-1 bg-black">
          <img src="" alt="" class="h-[55vh] w-full object-contain md:h-[72vh]" data-project-lightbox-image />
        </div>
        <div class="flex items-center justify-between gap-4 border-t border-white/10 px-5 py-4 md:px-6">
          <div class="min-w-0">
            <h3 class="font-heading text-2xl leading-tight text-white md:text-3xl" data-project-lightbox-title></h3>
            <p
              class="mt-1 text-xs font-semibold tracking-widest text-white/70 uppercase"
              data-project-lightbox-category
            >
            </p>
          </div>
          <div class="flex items-center gap-3 md:hidden">
            <button
              type="button"
              class="hover:bg-primary hover:text-inverted flex h-10 w-10 items-center justify-center rounded-full bg-[#1A1A1A] text-white transition-colors duration-200"
              data-project-lightbox-prev
              aria-label="Previous project"
            >
              <Icon name="chevron-left" size={16} />
            </button>
            <button
              type="button"
              class="hover:bg-primary hover:text-inverted flex h-10 w-10 items-center justify-center rounded-full bg-[#1A1A1A] text-white transition-colors duration-200"
              data-project-lightbox-next
              aria-label="Next project"
            >
              <Icon name="chevron-right" size={16} />
            </button>
          </div>
        </div>
      </div>

      <button
        type="button"
        class="hover:bg-primary hover:text-inverted absolute right-0 hidden h-10 w-10 items-center justify-center rounded-full bg-[#1A1A1A] text-white transition-colors duration-200 md:flex"
        data-project-lightbox-next
        aria-label="Next project"
      >
        <Icon name="chevron-right" size={16} />
      </button>
    </div>
  </div>
</NoiseBg>

<script>
  function initRecentProjectsLightbox() {
    const lightbox = document.querySelector<HTMLElement>('[data-project-lightbox]');
    if (!lightbox || lightbox.dataset.initialized) return;
    lightbox.dataset.initialized = 'true';

    // Use event delegation on the carousel or container to handle both original and cloned slides
    const container = document.querySelector<HTMLElement>('.recent-projects-carousel');
    const image = lightbox.querySelector<HTMLImageElement>('[data-project-lightbox-image]');
    const title = lightbox.querySelector<HTMLElement>('[data-project-lightbox-title]');
    const category = lightbox.querySelector<HTMLElement>('[data-project-lightbox-category]');
    const closeButtons = lightbox.querySelectorAll<HTMLElement>('[data-project-lightbox-close]');
    const prevButtons = lightbox.querySelectorAll<HTMLElement>('[data-project-lightbox-prev]');
    const nextButtons = lightbox.querySelectorAll<HTMLElement>('[data-project-lightbox-next]');
    
    // We get the unique triggers (ignoring clones for reference)
    const originalTriggers = Array.from(document.querySelectorAll<HTMLElement>('.swiper-slide:not(.swiper-slide-duplicate) [data-project-trigger]'));
    let activeIndex = 0;

    const renderProject = (index: number) => {
      const trigger = originalTriggers[index];
      if (!trigger || !image || !title || !category) return;

      activeIndex = index;
      image.src = trigger.dataset.projectImage || '';
      image.alt = trigger.dataset.projectAlt || trigger.dataset.projectTitle || 'Project image';
      title.textContent = trigger.dataset.projectTitle || '';
      category.textContent = trigger.dataset.projectCategory || '';
    };

    const openLightbox = (index: number) => {
      renderProject(index);
      lightbox.classList.remove('pointer-events-none', 'opacity-0');
      lightbox.classList.add('opacity-100');
      lightbox.setAttribute('aria-hidden', 'false');
      lightbox.removeAttribute('inert');
      document.body.style.overflow = 'hidden';
    };

    const closeLightbox = () => {
      lightbox.classList.add('pointer-events-none', 'opacity-0');
      lightbox.classList.remove('opacity-100');
      lightbox.setAttribute('aria-hidden', 'true');
      lightbox.setAttribute('inert', '');
      document.body.style.overflow = '';
    };

    const showAdjacent = (direction: number) => {
      const nextIndex = (activeIndex + direction + originalTriggers.length) % originalTriggers.length;
      renderProject(nextIndex);
    };

    // Event delegation for clicks
    container?.addEventListener('click', (event) => {
      const trigger = (event.target as HTMLElement).closest<HTMLElement>('[data-project-trigger]');
      if (trigger) {
        // Find index of the project title in our original list
        const projectTitle = trigger.dataset.projectTitle;
        const index = originalTriggers.findIndex(t => t.dataset.projectTitle === projectTitle);
        if (index !== -1) openLightbox(index);
      }
    });

    closeButtons.forEach(button => {
      button.addEventListener('click', closeLightbox);
    });

    prevButtons.forEach(button => {
      button.addEventListener('click', () => showAdjacent(-1));
    });

    nextButtons.forEach(button => {
      button.addEventListener('click', () => showAdjacent(1));
    });

    document.addEventListener('keydown', event => {
      if (lightbox.getAttribute('aria-hidden') === 'true') return;

      if (event.key === 'Escape') closeLightbox();
      if (event.key === 'ArrowLeft') showAdjacent(-1);
      if (event.key === 'ArrowRight') showAdjacent(1);
    });
  }

  initRecentProjectsLightbox();
  document.addEventListener('astro:after-swap', initRecentProjectsLightbox);
</script>
