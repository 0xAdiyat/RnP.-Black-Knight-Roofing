---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Button from '../ui/Button.astro';

interface Props {
  image: ImageMetadata | string;
  imageAlt?: string;
  title: string;
  category?: string;
  href?: string;
  class?: string;
}

const {
  image,
  imageAlt = 'Project Image',
  title,
  category = 'Roofing',
  href,
  class: className,
} = Astro.props;
---

<div class:list={['relative h-[387px] w-[358px] overflow-hidden', className]}>
  {
    typeof image === 'string' ? (
      <Image src={image} alt={imageAlt} width={358} height={387} class="h-full w-full object-cover" />
    ) : (
      <Image src={image} alt={imageAlt} width={358} height={387} class="h-full w-full object-cover" />
    )
  }
  <div
    class="absolute inset-0 top-0 left-0 flex h-full items-end bg-linear-to-b from-black/0 from-75% to-black/90 to-100% p-5"
  >
    <div class="flex w-full items-center justify-between">
      <div class="flex flex-1 flex-col gap-y-2">
        <div class="max-w-[156px] font-bold">{title}</div>
        <div class="text-xs text-white/60">{category}</div>
      </div>
      <div>
        <Button class="rounded-full" {...(href ? { href } : {})}> + </Button>
      </div>
    </div>
  </div>
</div>
