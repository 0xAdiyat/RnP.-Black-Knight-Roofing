---
import { Image } from 'astro:assets';
import googleLogo from '@/assets/brands/google-logo.avif';
import mraLogo from '@/assets/brands/mra.avif';
import businessLogo from '@/assets/brands/business-rate.avif';
import bbaLogo from '@/assets/brands/bba.avif';
import tamkoLogo from '@/assets/brands/tamko-pro.avif';
import westlate from '@/assets/brands/westlake.avif';
import { cn } from '@/lib/utils';
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'section'> {}
const { class: className } = Astro.props;
const classes = cn('relative px-0 py-10 sm:p-16', className);
---

<section class={classes}>
  <div class="absolute inset-x-0 bottom-0 h-0.5 bg-linear-to-r from-transparent via-[#F2C744]/50 to-transparent"></div>

  <div class="container px-4">
    <div class="swiper brands-swiper overflow-hidden">
      <div class="swiper-wrapper items-center">
        <!-- Group 1 -->
        <div class="swiper-slide w-auto! px-8 lg:px-12">
          <Image
            src={googleLogo}
            alt="Google Reviews"
            loading="eager"
            width={100}
            height={100}
            class="h-10 w-auto object-contain opacity-70 grayscale transition-all hover:opacity-100 hover:grayscale-0 md:h-[50px] lg:h-[60px]"
          />
        </div>
        <div class="swiper-slide w-auto! px-8 lg:px-12">
          <Image
            src={mraLogo}
            alt="MRA Contractor Member"
            loading="eager"
            width={100}
            height={100}
            class="h-10 w-auto object-contain opacity-70 grayscale transition-all hover:opacity-100 hover:grayscale-0 md:h-[50px] lg:h-[60px]"
          />
        </div>
        <div class="swiper-slide w-auto! px-8 lg:px-12">
          <Image
            src={businessLogo}
            alt="Best of 2024 Business Rate"
            loading="eager"
            width={100}
            height={100}
            class="h-10 w-auto object-contain opacity-70 grayscale transition-all hover:opacity-100 hover:grayscale-0 md:h-[50px] lg:h-[60px]"
          />
        </div>
        <div class="swiper-slide w-auto! px-8 lg:px-12">
          <Image
            src={bbaLogo}
            alt="BBB Accredited Business A+ Rating"
            loading="eager"
            width={100}
            height={100}
            class="h-10 w-auto object-contain opacity-70 grayscale transition-all hover:opacity-100 hover:grayscale-0 md:h-[50px] lg:h-[60px]"
          />
        </div>
        <div class="swiper-slide w-auto! px-8 lg:px-12">
          <Image
            src={tamkoLogo}
            alt="Tamko Pro Certified Contractor"
            loading="eager"
            width={100}
            height={100}
            class="h-10 w-auto object-contain opacity-70 grayscale transition-all hover:opacity-100 hover:grayscale-0 md:h-[50px] lg:h-[60px]"
          />
        </div>
        <div class="swiper-slide w-auto! px-8 lg:px-12">
          <Image
            src={westlate}
            alt="Westlake Royal Window Solutions"
            loading="eager"
            width={100}
            height={100}
            class="h-10 w-auto object-contain opacity-70 grayscale transition-all hover:opacity-100 hover:grayscale-0 md:h-[50px] lg:h-[60px]"
          />
        </div>
        <!-- Group 2 (Duplicate for seamless loop) -->
        <div class="swiper-slide w-auto! px-8 lg:px-12">
          <Image
            src={googleLogo}
            alt="Google Reviews"
            loading="eager"
            width={100}
            height={100}
            class="h-10 w-auto object-contain opacity-70 grayscale transition-all hover:opacity-100 hover:grayscale-0 md:h-[50px] lg:h-[60px]"
          />
        </div>
        <div class="swiper-slide w-auto! px-8 lg:px-12">
          <Image
            src={mraLogo}
            alt="MRA Contractor Member"
            loading="eager"
            width={100}
            height={100}
            class="h-10 w-auto object-contain opacity-70 grayscale transition-all hover:opacity-100 hover:grayscale-0 md:h-[50px] lg:h-[60px]"
          />
        </div>
        <div class="swiper-slide w-auto! px-8 lg:px-12">
          <Image
            src={businessLogo}
            alt="Best of 2024 Business Rate"
            loading="eager"
            width={100}
            height={100}
            class="h-10 w-auto object-contain opacity-70 grayscale transition-all hover:opacity-100 hover:grayscale-0 md:h-[50px] lg:h-[60px]"
          />
        </div>
        <div class="swiper-slide w-auto! px-8 lg:px-12">
          <Image
            src={bbaLogo}
            alt="BBB Accredited Business A+ Rating"
            loading="eager"
            width={100}
            height={100}
            class="h-10 w-auto object-contain opacity-70 grayscale transition-all hover:opacity-100 hover:grayscale-0 md:h-[50px] lg:h-[60px]"
          />
        </div>
        <div class="swiper-slide w-auto! px-8 lg:px-12">
          <Image
            src={tamkoLogo}
            alt="Tamko Pro Certified Contractor"
            loading="eager"
            width={100}
            height={100}
            class="h-10 w-auto object-contain opacity-70 grayscale transition-all hover:opacity-100 hover:grayscale-0 md:h-[50px] lg:h-[60px]"
          />
        </div>
        <div class="swiper-slide w-auto! px-8 lg:px-12">
          <Image
            src={westlate}
            alt="Westlake Royal Window Solutions"
            loading="eager"
            width={100}
            height={100}
            class="h-10 w-auto object-contain opacity-70 grayscale transition-all hover:opacity-100 hover:grayscale-0 md:h-[50px] lg:h-[60px]"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import Swiper from 'swiper';
  import { Autoplay, FreeMode } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/autoplay';
  import 'swiper/css/free-mode';

  function initBrandsSwiper() {
    new Swiper('.brands-swiper', {
      modules: [Autoplay, FreeMode],
      loop: true,
      slidesPerView: 'auto',
      centeredSlides: false,
      spaceBetween: 0,
      speed: 3000,
      autoplay: {
        delay: 0,
        disableOnInteraction: false,
      },
      freeMode: {
        enabled: true,
        momentum: false,
      },
      allowTouchMove: true,
    });
  }

  // Initialize on load and after view transitions
  initBrandsSwiper();
  document.addEventListener('astro:after-swap', initBrandsSwiper);
</script>

<style>
  .brands-swiper .swiper-wrapper {
    transition-timing-function: linear !important;
  }
  .brands-swiper .swiper-slide {
    width: auto !important;
    display: flex;
    align-items: center;
    justify-content: center;
  }
</style>
