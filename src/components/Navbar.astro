            class="bg-primary rounded-[4px] px-[18px] py-3 font-bold transition-all hover:shadow-[0_0_20px_rgba(242,199,68,0.3)]"
          >
            <span class="text-sm font-bold text-[#1a1a1a]">
              Get <span class="text-base font-extrabold">FREE</span> Roof Estimate</span
            >
          </Button>
        </div>
      </div>

      <!-- Common Viewport for popovers -->
      <div
        id="popover-viewport"
        class="pointer-events-none absolute top-full left-0 z-50 mt-2 h-0 w-0 origin-[top_center] opacity-0 transition-all duration-300 ease-out"
      >
        <div
          id="viewport-content"
          class="animate-in fade-in zoom-in-95 relative h-full w-full overflow-hidden rounded-2xl bg-[#111] shadow-2xl ring-1 ring-white/15"
        >
          <!-- Active content will be cloned here -->
        </div>
      </div>
    </nav>
  </header>
  <MobileStickyNav />
  <MobileMenu />
</div>

<script>
  function setupNavbar() {
    const root = document.querySelector('.navbar-root');
    const viewport = document.querySelector('#popover-viewport') as HTMLElement;
    const viewportContent = document.querySelector('#viewport-content') as HTMLElement;
    const triggers = document.querySelectorAll('.popover-trigger');
    const popoverItems = document.querySelectorAll('.popover-item');

    let currentId: string | null = null;
    let leaveTimeout: any;

    function updateViewport(trigger: HTMLElement, id: string) {
      if (currentId === id) return;

      const content = document.querySelector(`[data-popover-content="${id}"]`) as HTMLElement;
      if (!content) return;

      // Determine movement direction
      const previousIndex = Array.from(triggers).findIndex(t => (t as HTMLElement).dataset.popoverId === currentId);
      const currentIndex = Array.from(triggers).findIndex(t => t === trigger);
      const direction = currentIndex > previousIndex ? 'right' : 'left';

      currentId = id;
      viewport.style.opacity = '1';
      viewport.style.pointerEvents = 'auto';

      // Clone content and apply sliding animation
      const innerContent = content.firstElementChild?.cloneNode(true) as HTMLElement;
      viewportContent.innerHTML = '';
      viewportContent.appendChild(innerContent);

      innerContent.classList.add('animate-in', 'fade-in', 'duration-500');
      innerContent.classList.add(direction === 'right' ? 'slide-in-from-left-4' : 'slide-in-from-right-4');

      // Position calculations
      const triggerRect = trigger.getBoundingClientRect();
      const navRect = root!.getBoundingClientRect();
      const contentRect = content.getBoundingClientRect();

      // Horizontal center relative to trigger
      const targetLeft = triggerRect.left + triggerRect.width / 2 - navRect.left;

      viewport.style.width = `${contentRect.width}px`;
      viewport.style.height = `${contentRect.height}px`;
      viewport.style.left = `${targetLeft}px`;
      viewport.style.transform = `translateX(-50%)`;

      // Keep viewport open while hovering trigger
    }

    function hideViewport() {
      viewport.style.opacity = '0';
      viewport.style.pointerEvents = 'none';
      viewport.style.height = '0';
      currentId = null;
    }

    triggers.forEach(trigger => {
      trigger.addEventListener('mouseenter', () => {
        clearTimeout(leaveTimeout);
        const id = (trigger as HTMLElement).dataset.popoverId;
        if (id) updateViewport(trigger as HTMLElement, id);
      });

      trigger.addEventListener('mouseleave', () => {
        leaveTimeout = setTimeout(hideViewport, 200);
      });
    });

    viewport.addEventListener('mouseenter', () => {
      clearTimeout(leaveTimeout);
    });

    viewport.addEventListener('mouseleave', () => {
      leaveTimeout = setTimeout(hideViewport, 200);
    });

    // Scroll handling
    const navbarWrapper = document.getElementById('navbar-wrapper');
    function handleScroll() {
      if (window.scrollY > 40) {
        navbarWrapper?.classList.add('is-scrolled');
      } else {
        navbarWrapper?.classList.remove('is-scrolled');
      }
    }

    window.addEventListener('scroll', handleScroll);
    handleScroll(); // Initial check
  }

  setupNavbar();
  document.addEventListener('astro:after-swap', setupNavbar);
</script>

<style>
  #navbar-wrapper {
    --logo-scale: 1;
  }

  #navbar-wrapper.is-scrolled {
    --logo-scale: 0.85;
  }

  #navbar-wrapper.is-scrolled .logo-container {
    margin-top: 0;
  }

  #navbar-logo {
    transform: scale(var(--logo-scale));
    transition:
      transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      margin-top 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #navbar-logo:hover {
    transform: scale(calc(var(--logo-scale) * 1.05));
  }

  #navbar-logo:active {
    transform: scale(calc(var(--logo-scale) * 0.95));
  }

  .logo-container {
    transition: margin-top 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
</style>
