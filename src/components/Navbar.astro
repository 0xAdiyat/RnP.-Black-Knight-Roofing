---
import { Image, getImage } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import noises from '@/assets/noises.avif';
import sunflow from '@/assets/sunflow.avif';
import heroImage from '@/assets/hero-logo.avif';
import Button from './ui/Button.astro';
import NavbarItemLink from './navbar/NavbarItemLink.astro';
import NavbarItemPopover from './navbar/NavbarItemPopover.astro';
import NavbarItemPopoverLink from './navbar/NavbarItemPopoverLink.astro';
import MobileStickyNav from './MobileStickyNav.astro';
import MobileMenu from './navbar/MobileMenu.astro';

const optimizedNoise = await getImage({ src: noises, width: 100, height: 100, format: 'avif' });
const optimizedSunflow = await getImage({ src: sunflow, width: 100, height: 100, format: 'avif' });
---

<div id="navbar-wrapper" class="sticky top-0 z-50 shadow-lg md:-top-10">
  <!-- Top navigation -->
  <section
    class="relative hidden h-10 items-center gap-x-4 px-4 md:flex"
    style={`
        background-image: url(${optimizedSunflow.src}), url(${optimizedNoise.src});
        background-size: cover, 200px 200px;
        background-repeat: no-repeat, repeat;
        background-position: center, center;
        background-color: var(--inverted); 
    `}
  >
    <div class="absolute inset-0 bg-black/50"></div>
    <div
      class="relative z-10 container flex h-full items-center justify-between text-sm leading-5 font-normal text-white"
    >
      <!-- Left content -->
      <div class="flex items-center gap-x-8">
        <div class="group hover:text-primary flex cursor-pointer items-center gap-x-1.5 transition-colors">
          <Icon name="location" class="text-primary h-4 w-4 transition-transform group-hover:scale-110" />
          <span> 865 Draw St, Lochbuie, CO 80603</span>
        </div>
        <div class="group hover:text-primary flex cursor-pointer items-center gap-x-1.5 transition-colors">
          <Icon name="mail" class="text-primary h-4 w-4 transition-transform group-hover:scale-110" />
          <span> Mail: support@blackknightroofing.com</span>
        </div>
      </div>

      <!-- Right Content -->
