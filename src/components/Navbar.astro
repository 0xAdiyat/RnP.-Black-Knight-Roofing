---
import { Image, getImage } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import noises from '@/assets/noises.png';
import sunflow from '@/assets/sunflow.png';
import heroImage from '@/assets/hero-logo.png';
import Button from './ui/Button.astro';

const optimizedNoise = await getImage({ src: noises, width: 100, height: 100, format: 'webp' });
const optimizedSunflow = await getImage({ src: sunflow, width: 100, height: 100, format: 'webp' });
---

<section>
  <!-- Top navigation -->
  <section
    class="relative flex h-10 items-center gap-x-4 px-4"
    style={`
        background-image: url(${optimizedSunflow.src}), url(${optimizedNoise.src});
        background-size: cover, 200px 200px;
        background-repeat: no-repeat, repeat;
        background-position: center, center;
        background-color: var(--inverted); 
    `}
  >
    <div class="absolute inset-0 bg-black/50">
      <div class="container flex h-full items-center justify-between text-sm leading-5 font-normal">
        <div class="flex items-center gap-x-5">
          <div class="flex items-center gap-x-1.5">
            <Icon name="location" />
            <span> 865 Draw St, Lochbuie, CO 80603</span>
          </div>
          <div class="flex items-center gap-x-1.5">
            <Icon name="mail" />
            <span> Mail: support@blackknightroofing.com</span>
          </div>
        </div>

        <div>
          <div class="flex items-center gap-x-1.5">
            <span>Need A Roof Inspection Help?</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Navbar -->
  <header class="z-50 flex h-16 items-center bg-[#111] text-white">
    <nav class="container flex items-center justify-between">
      <div class="flex items-center">
        <ul class="inline-flex items-center gap-x-6">
          <li>
            <a href="/" class="flex items-center gap-x-1.5">
              <Icon name="phone" />
              <span> (720) 805-9666</span>
            </a>
          </li>
          <li><a href="/about">About</a></li>
          <li><a href="/contact">Services</a></li>
          <li><a href="/financing"> Financing</a></li>
        </ul>
      </div>

      <div class="-translate-y-4">
        <Image src={heroImage} alt="Hero Logo" width={135} height={92} />
      </div>

      <ul class="inline-flex items-center gap-x-6">
        <li><a href="/">Past Work</a></li>
        <li><a href="/about">Service Areas</a></li>
        <li><a href="/contact">Contact</a></li>
        <li>
          <Button href="/financing">
            <span> Get <strong> FREE</strong> Roof Estimate</span>
          </Button>
        </li>
      </ul>
    </nav>
  </header>
</section>
