---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

import { Icon } from 'astro-icon/components';
import { cn } from '@/lib/utils';

import heroBgImage from '@/assets/hero-bg.jpg';
import gridFrame from '@/assets/grid-frame.png';

interface Props {
  backgroundImage?: ImageMetadata | string;
  title: string;
  subtitle?: string;
  subtitleIcon?: string;
  class?: string;
}

const { backgroundImage = heroBgImage, title, subtitle, subtitleIcon = 'badge-tick', class: className } = Astro.props;

const heroBgSrc =
  typeof backgroundImage === 'string'
    ? backgroundImage
    : (await getImage({ src: backgroundImage, width: 1536, height: 1152, format: 'webp' })).src;
const gridFrameOp = await getImage({ src: gridFrame });

const hasSidebar = Astro.slots.has('sidebar');
const hasSocialProof = Astro.slots.has('social-proof');
---

<section
  class={cn('grid-line relative max-h-[833px]', className)}
  style={`
      background-image:url(${heroBgSrc});
      background-size:cover;
      background-repeat: no-repeat;
      background-position: center;
  `}
>
  <div
    style={`
      background-image:
          url("${gridFrameOp.src}"),
          linear-gradient( 200deg, rgba(8, 42, 64, 0) 34.45%, #082A40 64.34%, #0D0D0D 97.01%);
      background-position: -178.686px -1.253px, center;
      background-size:  124.644% 151.637%, auto;
      background-repeat: no-repeat, no-repeat;
  `}
  >
    <div class="container space-y-6 py-20">
      <div class="flex items-stretch gap-x-8">
        <div class="relative h-full w-full max-w-[720px] text-white">
          <div class="space-y-8">
            <div class="space-y-6">
              <div class="space-y-4">
                {
                  subtitle && (
                    <div class="flex items-center gap-x-1.5">
                      <Icon name={subtitleIcon} />
                      <span>{subtitle}</span>
                    </div>
                  )
                }

                <div>
                  <h1 class="font-heading leading-16 font-normal" set:html={title} />
                </div>
              </div>

              <slot />
            </div>

            {
              hasSocialProof && (
                <div class="flex items-center divide-x py-2 text-sm">
                  <slot name="social-proof" />
                </div>
              )
            }
          </div>
        </div>

        {hasSidebar && <slot name="sidebar" />}
      </div>
    </div>
  </div>
</section>
