---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

import { Icon } from 'astro-icon/components';
import { cn } from '@/lib/utils';

import heroBgImage from '@/assets/hero-bg.avif';
import gridFrame from '@/assets/grid-frame.avif';
import { Image } from 'astro:assets';
import SocialProof from '../ui/SocialProof.astro';
import EstimateButton from '../EstimateButton.astro';
import Button from '../ui/Button.astro';
import QuoteForm from '../cta/QuoteForm.astro';

interface Props {
  backgroundImage?: ImageMetadata | string;
  title: string;
  subtitle?: string;
  subtitleIcon?: string;
  class?: string;
  hasQuoteForm?: boolean;
  hasSocialProof?: boolean;
  hasEstimateButton?: boolean;
}

const {
  backgroundImage = heroBgImage,
  title,
  subtitle,
  subtitleIcon = 'badge-tick',
  class: className,
  hasQuoteForm = true,
  hasSocialProof = true,
  hasEstimateButton = true,
} = Astro.props;

const heroBgSrc =
  typeof backgroundImage === 'string'
    ? backgroundImage
    : (await getImage({ src: backgroundImage, width: 1536, height: 1152, format: 'webp' })).src;
---

<section class={cn('relative lg:max-h-[833px]', className)}>
  <Image
    src={heroBgSrc}
    alt="hero-bg"
    width={1536}
    height={1152}
    format="avif"
    fetchpriority="high"
    loading="eager"
    sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 25vw"
    class="pointer-events-none absolute inset-0 -z-12 h-full w-full object-cover opacity-80"
  />

  <Image
    src={gridFrame}
    alt="grid-frame"
    width={gridFrame.width}
    height={gridFrame.height}
    format="avif"
    fetchpriority="high"
    loading="eager"
    sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 25vw"
    class="pointer-events-none absolute inset-0 h-full w-full object-cover opacity-50"
  />

  <div
    class="z-10 bg-[linear-gradient(234deg,rgba(0,0,0,0.0)_28.39%,rgba(0,0,0,0.20)_32.48%,rgba(0,0,0,0.40)_59.9%),linear-gradient(200deg,rgba(8,42,64,0)_14.45%,#082A40_50.34%,#0D0D0D_80.01%)] sm:bg-[linear-gradient(234deg,rgba(0,0,0,0.0)_28.39%,rgba(0,0,0,0.20)_72.48%,rgba(0,0,0,0.20)_89.9%),linear-gradient(200deg,rgba(8,42,64,0)_34.45%,#082A40_64.34%,#0D0D0D_97.01%)]"
  >
    <div class="container space-y-6 py-12 lg:py-20">
      <div class="flex flex-col items-stretch gap-y-10 lg:flex-row lg:items-center lg:gap-x-8">
        <div
          class="relative h-full w-full max-w-[720px] text-white lg:flex lg:min-h-full lg:flex-col lg:justify-center"
        >
          <div class="space-y-8">
            <div class="space-y-6">
              <div class="space-y-4">
                {
                  subtitle && (
                    <div class="flex items-center gap-x-1.5 text-sm sm:text-base">
                      <Icon name={subtitleIcon} />
                      <span>{subtitle}</span>
                    </div>
                  )
                }

                <div>
                  <h1
                    class="font-heading max-w-xl text-4xl leading-tight font-normal lg:text-[4rem] lg:leading-16"
                    set:html={title}
                  />
                </div>
              </div>

              <slot />

              {
                hasEstimateButton && (
                  <div class="flex flex-col items-center gap-4 sm:flex-row sm:gap-x-6">
                    <EstimateButton />

                    <Button variant="link">
                      <Icon name="map" />
                      See Our Past Work
                    </Button>
                  </div>
                )
              }
            </div>

            {
              hasSocialProof && (
                <div class="flex flex-col items-center gap-4 divide-white/20 text-sm sm:flex-row sm:divide-x lg:justify-start">
                  {Astro.slots.has('social-proof') ? <slot name="social-proof" /> : <SocialProof />}
                </div>
              )
            }
          </div>
        </div>

        {
          hasQuoteForm && (
            <div class="w-full lg:ml-auto lg:max-w-[34.375rem]">
              <QuoteForm slot="sidebar" />
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>
