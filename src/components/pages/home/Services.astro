---
import { Image, getImage } from 'astro:assets';
import dividerImage from '@/assets/divider-line.png';
import Button from '@/components/ui/Button.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import serviceRoofingImg from '@/assets/services/service-roofing.png';
import serviceSidingImg from '@/assets/services/service-siding.png';
import serviceGuttersImg from '@/assets/services/service-gutter.png';
import serviceRoofImg from '@/assets/services/service-roof.png';
import serviceRoofShade from '@/assets/services/service-roof-shade.png';
import NoiseBg from '@/components/NoiseBg.astro';
import popularBadge from '@/assets/popular-badge.png';

const dividerImageOp = await getImage({
  src: dividerImage,
  width: 1500,
  height: 80,
});
---

<NoiseBg class="relative bg-[#202020] py-20">
  <div class="">
    <div
      class="absolute inset-0 top-0 left-0 flex h-20 w-full items-center justify-center"
      style={`
          background-image: url(${dividerImageOp.src});
          background-repeat: no-repeat;
          background-position: center;
      `}
    >
    </div>

    <div class="container">
      <div class="grid grid-cols-2 items-center gap-x-4 py-8">
        <div class="space-y-4">
          <div class="flex items-center gap-x-3">
            <div
              class="relative size-5 rounded-[5px] bg-[#F7B715]/50 drop-shadow-2xl before:absolute before:top-1/2 before:left-1/2 before:size-2 before:-translate-1/2 before:rounded-full before:bg-[#F7D515] before:content-['']"
            >
            </div>
            <div>Our Services</div>
          </div>

          <h2>Complete Roofing <br /> Solutions for Colorado Homes</h2>
        </div>

        <div class="flex flex-col items-end gap-y-4 text-right">
          <Button variant="primary" size="md" href="/services">View All Services</Button>
          <div>
            From roof replacements and storm damage repairs to siding, gutters, and full exterior restoration — we
            handle it all. Every project backed by our lifetime workmanship warranty and veteran-owned commitment to
            quality.
          </div>
        </div>
      </div>

      <div class="flex flex-col items-center space-y-16 px-16">
        <div class="flex items-center gap-x-3">
          <ServiceCard
            title="Siding"
            description="We install durable, beautiful siding—vinyl and steel options available—to protect and refresh your home's exterior."
            image={serviceRoofingImg}
            imageAlt="Siding"
            buttons={[
              { label: 'Vinyl Siding', href: '/services/siding-installation' },
              { label: 'Steel Siding', href: '/services/siding-installation' },
            ]}
            class="[&_img[data-slot=thumbnail]]:scale-150"
          />

          <ServiceCard
            title="Roofing"
            description="We offer a complete line up of professional roofing services including inspections, replacements, and repairs."
            image={serviceSidingImg}
            imageAlt="Roofing"
            buttons={[
              { label: 'Shingle Roofing', href: '/services/residential-roofing' },
              { label: 'Metal Roofing', href: '/services/metal-roofing' },
            ]}
            class="w-[452px] [&_img[data-slot=thumbnail]]:scale-150"
            borderClass="bg-radial-[50%_50%_at_50%_50%] to-[rgba(89,66,22,1)] via-primary to-[rgba(89,66,22,1)] bg-conic-145 p-0.5"
          />

          <ServiceCard
            title="Gutters"
            description="Properly installed gutters protect your foundation and landscaping. We handle seamless systems and gutter guards."
            image={serviceGuttersImg}
            imageAlt="Gutters"
            buttons={[
              { label: 'Seamless Gutters', href: '/services/gutters-and-drainage' },
              { label: 'Gutter Guards', href: '/services/gutters-and-drainage' },
            ]}
            class="[&_img[data-slot=thumbnail]]:scale-150"
          />
        </div>

        <div
          class="via-primary w-fit rounded-3xl bg-conic-145 from-[rgba(89,66,22,0.5)] via-70% to-[rgba(89,66,22,0.5)] p-0.5"
        >
          <div class="flex items-center gap-x-3 rounded-3xl bg-[#171717] p-2.5">
            <div class="relative">
              <Image src={popularBadge} alt="Popular" class="absolute w-20" />
              <ServiceCard
                title="Concrete Tile Roofs"
                description="A premium roofing upgrade for homeowners who want standout curb appeal and serious durability. Concrete tile delivers exceptional longevity, wind resistance, and curb appeal — built to last 50+ years."
                image={serviceRoofImg}
                imageAlt="Gutters"
                buttons={[
                  { label: 'Concrete Tile Roofs', href: '/services/tile-roofing' },
                  { label: 'Free Estimate', href: '/contact-us' },
                ]}
                class="h-[480px]"
              />
            </div>

            <div class="relative">
              <Image src={popularBadge} alt="Popular" class="absolute w-20" />
              <ServiceCard
                title="Stone Coated Roofing"
                description="We offer stone-coated steel which gives you the strength of metal with the finished look of a premium roof."
                image={serviceRoofShade}
                imageAlt="Gutters"
                buttons={[
                  { label: 'Stone Coated Steel', href: '/services/metal-roofing' },
                  { label: 'Free Estimate', href: '/contact-us' },
                ]}
                class="h-[480px]"
                borderClass="h-full"
              />
            </div>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-3 pt-16 pb-16">
        <div
