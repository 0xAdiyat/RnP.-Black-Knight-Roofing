---
import { getImage, Image } from 'astro:assets';

import { Icon } from 'astro-icon/components';

import Button from '@/components/ui/Button.astro';
import InputGroup from '@/components/ui/input-group/InputGroup.astro';
import InputGroupInput from '@/components/ui/input-group/InputGroupInput.astro';
import InputGroupAddon from '@/components/ui/input-group/InputGroupAddon.astro';
import NoiseBg from '@/components/NoiseBg.astro';

import heroBgImage from '@/assets/hero-bg.jpg';
import heroShield from '@/assets/hero-shield.png';
import trustBadgeSSL from '@/assets/trust-badge-ssl.png';
import heroPerson from '@/assets/hero-person.png';
import gridFrame from '@/assets/grid-frame.png';
import stormBg from '@/assets/storm-bg.png';
import noiseBg from '@/assets/noises.png';

const optimizedHeroBg = await getImage({ src: heroBgImage, width: 1536, height: 1152, format: 'webp' });
const gridFrameOp = await getImage({ src: gridFrame });
const noiseBgOp = await getImage({ src: noiseBg });
---

<section
  class="grid-line relative max-h-[833px]"
  style={`
      background-image:linear-gradient(to right,var(--inverted),rgba(0,0,0,0.1)),url(${optimizedHeroBg.src});
      background-size:cover, cover;
      background-repeat: no-repeat, no-repeat;
      background-position: center, center;
  `}
>
  <!-- Hero Left Shape -->

  <svg
    xmlns="http://www.w3.org/2000/svg"
    xmlns:xlink="http://www.w3.org/1999/xlink"
    width="1209"
    height="837"
    viewBox="0 0 1209 837"
    fill="none"
  >
    <path
      d="M819.084 237.203L878 2H0V835H639.679C641.218 835 642.75 834.778 644.226 834.34L1194.6 671.197C1207.87 667.262 1210.22 649.468 1198.43 642.223L978.072 506.887C976.049 505.645 974.328 503.968 973.034 501.978L825.41 275.04C818.134 263.855 815.842 250.146 819.084 237.203Z"
      fill="url(#paint0_linear_16409_61238)"></path>
    <path
      d="M819.084 237.203L878 2H0V835H639.679C641.218 835 642.75 834.778 644.226 834.34L1194.6 671.197C1207.87 667.262 1210.22 649.468 1198.43 642.223L978.072 506.887C976.049 505.645 974.328 503.968 973.034 501.978L825.41 275.04C818.134 263.855 815.842 250.146 819.084 237.203Z"
      fill="url(#pattern0_16409_61238)"></path>
    <path
      d="M819.084 237.203L878 2H0V835H639.679C641.218 835 642.75 834.778 644.226 834.34L1194.6 671.197C1207.87 667.262 1210.22 649.468 1198.43 642.223L978.072 506.887C976.049 505.645 974.328 503.968 973.034 501.978L825.41 275.04C818.134 263.855 815.842 250.146 819.084 237.203Z"
      fill="url(#paint1_linear_16409_61238)"
      fill-opacity="0.2"></path>
    <path
      d="M819.084 237.203L878 2H0V835H639.679C641.218 835 642.75 834.778 644.226 834.34L1194.6 671.197C1207.87 667.262 1210.22 649.468 1198.43 642.223L978.072 506.887C976.049 505.645 974.328 503.968 973.034 501.978L825.41 275.04C818.134 263.855 815.842 250.146 819.084 237.203Z"
      stroke="url(#paint2_radial_16409_61238)"
      stroke-width="4"></path>
    <defs>
      <pattern id="pattern0_16409_61238" patternContentUnits="objectBoundingBox" width="1" height="1">
        <use xlink:href="#image0_16409_61238" transform="matrix(0.000244141 0 0 0.000360203 0 -0.00122202)"></use>
      </pattern>
      <linearGradient
        id="paint0_linear_16409_61238"
        x1="162"
        y1="-130"
        x2="481.5"
        y2="835"
        gradientUnits="userSpaceOnUse"
      >
        <stop offset="0.0327412" stop-color="#082A40" stop-opacity="0"></stop>
        <stop offset="0.494851" stop-color="#082A40"></stop>
        <stop offset="1" stop-color="#0D0D0D"></stop>
      </linearGradient>
      <linearGradient
        id="paint1_linear_16409_61238"
        x1="614.5"
        y1="1.99998"
        x2="305"
        y2="560.5"
        gradientUnits="userSpaceOnUse"
      >
        <stop stop-opacity="0"></stop>
        <stop offset="0.716859"></stop>
        <stop offset="1"></stop>
      </linearGradient>
      <radialGradient
        id="paint2_radial_16409_61238"
        cx="0"
        cy="0"
        r="1"
        gradientUnits="userSpaceOnUse"
        gradientTransform="translate(0.500089 -126) rotate(20.4228) scale(1358.38 1604.62)"
      >
        <stop stop-color="#8C7327" stop-opacity="0.24"></stop>
        <stop offset="0.490405" stop-color="#BE9C35" stop-opacity="0.05"></stop>
        <stop offset="1" stop-color="#F2C744"></stop>
      </radialGradient>
      <image
        id="image0_16409_61238"
        width="4096"
        height="2783"
        preserveAspectRatio="none"
        xlink:href={gridFrameOp.src}
      />
    </defs>
  </svg>

  <!-- End Hero Left Shape -->

  <!-- Weather widget -->
  <div class="absolute top-2/5 right-0 z-10 w-[132px] -translate-y-1/2 overflow-hidden rounded-l-[10px]">
    <div class="bg-tertiary flex w-full flex-col items-center p-2">
      <div class="flex flex-col items-center uppercase">
        <strong> COLORADO</strong>
        <span> WEATHER</span>
      </div>
      <div>
        <svg xmlns="http://www.w3.org/2000/svg" width="71" height="71" viewBox="0 0 71 71" fill="none">
          <path
            d="M28.7554 53.605C18.7444 53.605 10.6504 45.511 10.6504 35.5C10.6504 25.489 18.7444 17.395 28.7554 17.395C35.5714 17.395 41.4644 21.158 44.5174 26.696C45.2984 26.554 46.0084 26.483 46.7894 26.483C54.2444 26.483 60.3504 32.518 60.3504 40.044C60.3504 47.499 54.3154 53.605 46.7894 53.605C43.6654 53.605 32.3054 53.605 28.7554 53.605Z"
            fill="white"></path>
          <path
            d="M46.789 49.061C51.759 49.061 55.806 45.014 55.806 40.044C55.806 35.074 51.759 31.027 46.789 31.027C45.014 31.027 43.31 31.595 41.89 32.518C40.47 26.483 35.145 22.01 28.684 22.01C21.229 22.01 15.123 28.045 15.123 35.571C15.123 43.026 21.158 49.132 28.684 49.132C32.802 49.061 43.381 49.061 46.789 49.061Z"
            fill="#082A40"></path>
        </svg>
      </div>

      <h5 class="font-body leading-8 font-medium">45°F</h5>
      <div class="text-center text-[11px]">scattered clouds</div>
    </div>
    <div
      class="px-4 py-3"
      style={`
        background-image:url(${stormBg.src});
        background-repeat: no-repeat;
        background-position: center;
        background-size: cover;
      `}
    >
      <div class="space-y-4 py-1">
        <p class="text-center">
          Do you have <strong> storm damage?</strong>
        </p>
        <Button class="text-xs font-bold">Get an Inspection</Button>
      </div>
    </div>
  </div>
  <!-- End weather widget -->

  <div class="absolute inset-0 top-0 left-0">
    <div class="container space-y-6 py-20">
      <div class="flex items-stretch gap-x-8">
        <div class="relative h-full w-full max-w-[720px] text-white">
          <div class="space-y-8">
            <div class="space-y-6">
              <div class="space-y-4">
                <div class="flex items-center gap-x-1.5">
                  <Icon name="badge-tick" />
                  <span> Veteran-Owned. Licensed General Contractor. Denver, CO.</span>
                </div>

                <div>
                  <h1 class="font-heading leading-16 font-normal">
                    Colorado&apos;s “Most Trusted” Full-Construction Roofing Company
                  </h1>
                </div>
              </div>

              <ul class="space-y-3">
                <li class="flex items-center gap-x-2">
                  <Icon name="shield" size={36} />
                  <span class="flex-1">
                    Veteran Discipline, Builder Standards: Most roofers just replace shingles. As a licensed general
                    contractor and Army veteran, Adam inspects your whole home — and builds to last.
                  </span>
                </li>
                <li class="flex items-center gap-x-2">
                  <Icon name="helmet" size={36} />
                  <span class="flex-1">
                    Stone-Coated Steel Experts: We specialize in the materials most roofers won't touch — stone-coated
                    steel and concrete tile — because we know they're the best thing on your roof.
                  </span>
                </li>
                <li class="flex items-center gap-x-2">
                  <Icon name="star-leaf" size={36} />
                  <span class="flex-1">
                    Insurance Claim Specialists + Lifetime Guarantee: We handle insurance claim and provide lifetime
                    workmanship warranty plus manufacturer guarantees.
                  </span>
                </li>
              </ul>

              <div class="flex items-center gap-x-4">
                <Button variant="primary" size="lg">
                  <span class="text-xs"> 0% interest & <br /> 12 month no-pay</span>
                  <span class="h-6 w-0.5 bg-[rgba(133,89,1,0.4)]"></span>
                  <span> FREE Estimate</span>
                </Button>

                <Button variant="link">
                  <Icon name="map" />
                  See Our Past Work
                </Button>
              </div>
            </div>

            <div class="flex items-center divide-x py-2 text-sm">
              <div class="flex items-center gap-x-4 pr-4">
                <Icon name="google-logo" size={32} />
                <span>
                  40+ Five-Star <br />
                  Google Reviews
                </span>
              </div>

              <div class="flex items-center gap-x-4 px-4">
                <Icon name="facebook-logo" size={32} />
                <span>
                  40+ Five-Star <br />
                  Facebook Reviews
                </span>
              </div>

              <div class="flex items-center gap-x-4 pl-4">
                <Icon name="google-logo" size={32} />
                <span>
                  40+ Five-Star <br />
                  Google Reviews
                </span>
              </div>
            </div>
          </div>
        </div>

        <div class="relative flex min-h-full items-end">
          <Image src={heroPerson} alt="Hero Person" width={443} height={631} class="h-full object-cover" />
          <div class="absolute top-2/3 -left-20 flex h-[92px] w-[315px] items-center gap-x-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              xmlns:xlink="http://www.w3.org/1999/xlink"
              width="300"
              height="96"
              viewBox="0 0 300 96"
              fill="none"
              class="h-[96px] w-[300px]"
            >
              <foreignObject x="-14" y="-14" width="327.331" height="123.275">
                <div
                  style="backdrop-filter:blur(7px);clip-path:url(#bgblur_0_16409_61398_clip_path);height:100%;width:100%"
                >
                </div>
              </foreignObject><g data-figma-bg-blur-radius="14">
                <path
                  d="M278.126 0.974854C292.04 0.974854 301.793 14.7072 297.21 27.845L278.755 80.7454C275.923 88.862 268.267 94.3 259.671 94.3H21.2148C6.22081 94.3 -3.55368 78.5471 3.10449 65.1125L29.3232 12.2112C32.7343 5.32911 39.7516 0.974949 47.4326 0.974854H278.126Z"
                  fill="#0D0D0D"></path>
                <path
                  d="M278.126 0.974854C292.04 0.974854 301.793 14.7072 297.21 27.845L278.755 80.7454C275.923 88.862 268.267 94.3 259.671 94.3H21.2148C6.22081 94.3 -3.55368 78.5471 3.10449 65.1125L29.3232 12.2112C32.7343 5.32911 39.7516 0.974949 47.4326 0.974854H278.126Z"
                  fill="url(#pattern0_16409_61398)"
                  fill-opacity="0.32"></path>
                <path
                  d="M278.126 0.974854C292.04 0.974854 301.793 14.7072 297.21 27.845L278.755 80.7454C275.923 88.862 268.267 94.3 259.671 94.3H21.2148C6.22081 94.3 -3.55368 78.5471 3.10449 65.1125L29.3232 12.2112C32.7343 5.32911 39.7516 0.974949 47.4326 0.974854H278.126Z"
                  fill="url(#paint0_radial_16409_61398)"
                  fill-opacity="0.8"></path>
                <path
                  d="M278.126 0.974854C292.04 0.974854 301.793 14.7072 297.21 27.845L278.755 80.7454C275.923 88.862 268.267 94.3 259.671 94.3H21.2148C6.22081 94.3 -3.55368 78.5471 3.10449 65.1125L29.3232 12.2112C32.7343 5.32911 39.7516 0.974949 47.4326 0.974854H278.126Z"
                  stroke="url(#paint1_radial_16409_61398)"
                  stroke-width="1.95046"></path>
              </g>
              <defs>
                <clipPath id="bgblur_0_16409_61398_clip_path" transform="translate(14 14)"
                  ><path
                    d="M278.126 0.974854C292.04 0.974854 301.793 14.7072 297.21 27.845L278.755 80.7454C275.923 88.862 268.267 94.3 259.671 94.3H21.2148C6.22081 94.3 -3.55368 78.5471 3.10449 65.1125L29.3232 12.2112C32.7343 5.32911 39.7516 0.974949 47.4326 0.974854H278.126Z"
                  ></path>
                </clipPath><pattern
                  id="pattern0_16409_61398"
                  patternContentUnits="objectBoundingBox"
                  width="1"
                  height="1"
                >
                  <use xlink:href="#image0_16409_61398" transform="matrix(0.00138889 0 0 0.00478801 0 -1.2955)"></use>
                </pattern>
                <radialGradient
                  id="paint0_radial_16409_61398"
                  cx="0"
                  cy="0"
                  r="1"
                  gradientUnits="userSpaceOnUse"
                  gradientTransform="translate(159.333 47.6375) scale(171.527 45.687)"
                >
                  <stop stop-color="#303030" stop-opacity="0"></stop>
                  <stop offset="1" stop-color="#303030"></stop>
                </radialGradient>
                <radialGradient
                  id="paint1_radial_16409_61398"
                  cx="0"
                  cy="0"
                  r="1"
                  gradientTransform="matrix(189.673 28.3702 -8.48455 55.0198 115.538 19.2673)"
                  gradientUnits="userSpaceOnUse"
                >
                  <stop stop-color="#F2C744"></stop>
                  <stop offset="1" stop-color="#594216"></stop>
                </radialGradient>
                <image
                  id="image0_16409_61398"
                  width="720"
                  height="750"
                  preserveAspectRatio="none"
                  xlink:href={noiseBgOp.src}
                />
              </defs>
            </svg>

            <div class="absolute inset-0 top-0 left-0 flex items-center gap-x-4 px-3 py-2">
              <div class="relative">
                <svg xmlns="http://www.w3.org/2000/svg" width="102" height="78" viewBox="0 0 102 78" fill="none">
                  <path
                    d="M26.5881 9.17786L2.73197 53.27C-3.04549 63.9482 4.68656 76.9229 16.8275 76.9229H73.8289C81.2274 76.9229 87.6644 71.8584 89.4053 64.6676L100.08 20.5754C102.522 10.4896 94.881 0.777832 84.5038 0.777832H40.6836C34.7993 0.777832 29.3882 4.00248 26.5881 9.17786Z"
                    fill="white"
                    fill-opacity="0.1"
                    stroke="url(#paint0_radial_16409_61400)"
                    stroke-width="1.55556"></path>
                  <defs>
                    <radialGradient
                      id="paint0_radial_16409_61400"
                      cx="0"
                      cy="0"
                      r="1"
                      gradientTransform="matrix(-54.0556 44.7222 -35.933 -25.5367 104.657 0.540096)"
                      gradientUnits="userSpaceOnUse"
                    >
                      <stop stop-color="#F2C744"></stop>
                      <stop offset="1" stop-color="white" stop-opacity="0.2"></stop>
                    </radialGradient>
                  </defs>
                </svg>

                <div class="absolute top-1/2 left-1/2 -translate-1/2">
                  <Image src={trustBadgeSSL} alt="Trust Badge SSL" width={102} height={78} />
                </div>
              </div>
              <div class="flex flex-col gap-y-1.5">
                <div class="text-primary">Adam Knight</div>
                <p class="text-xs">President & Owner, Black Knight Roofing</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div
        class="from-primary/50 to-secondary/50 after:form-transparent after:via-primary relative -translate-y-20 rounded-[12px] bg-linear-to-b p-px after:absolute after:-inset-x-px after:bottom-0 after:z-10 after:h-0.5 after:bg-linear-to-r after:to-transparent after:opacity-50 after:content-['']"
      >
        <NoiseBg class="relative z-10 rounded-[12px]">
          <Image src={heroShield} alt="Hero Shield" width={100} height={100} class="mx-auto -mt-20" />
          <div class="[&_span]:text-primary backdrop-blue-[24px] flex w-full flex-col items-center gap-y-8">
            <h3>Get Your <span> FREE</span> Quote</h3>
            <form class="flex w-full items-center gap-x-2.5">
              <InputGroup class="h-[52px] border-white/15 px-4 py-4">
                <InputGroupInput id="inline-end-input" type="text" placeholder="Name" />
                <InputGroupAddon align="inline-end">
                  <Icon name="contact" />
                </InputGroupAddon>
              </InputGroup>

              <InputGroup class="h-[52px] border-white/15 px-4 py-4">
                <InputGroupInput id="inline-end-input" type="tel" placeholder="Phone" />
                <InputGroupAddon align="inline-end">
                  <Icon name="call" />
                </InputGroupAddon>
              </InputGroup>

              <InputGroup class="h-[52px] border-white/15 px-4 py-4">
                <InputGroupInput id="inline-end-input" type="email" placeholder="Email" />
                <InputGroupAddon align="inline-end">
                  <Icon name="mail2" />
                </InputGroupAddon>
              </InputGroup>

              <InputGroup class="h-[52px] border-white/15 px-4 py-4">
                <InputGroupInput id="inline-end-input" type="text" placeholder="How can we assist you?" />
                <InputGroupAddon align="inline-end">
                  <Icon name="chat" />
                </InputGroupAddon>
              </InputGroup>

              <Button class="h-[52px] px-8 py-4">Submit</Button>
            </form>
          </div>
        </NoiseBg>
      </div>
    </div>
  </div>
</section>
