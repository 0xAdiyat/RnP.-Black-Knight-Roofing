  }

  .funnel-field-wrapper-search :global(section) {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.09), rgba(255, 255, 255, 0.04)),
      linear-gradient(180deg, rgba(0, 0, 0, 0.08), rgba(0, 0, 0, 0.08)), var(--noise-bg, #111);
  }

  .funnel-field-wrapper {
    padding-inline: 1px;
  }

  :global(.pac-container) {
    margin-top: 0.35rem;
    border: 1px solid rgba(242, 199, 68, 0.28);
    border-radius: 0.9rem;
    background: #161616;
    box-shadow: 0 22px 60px rgba(0, 0, 0, 0.45);
    font-family: InterVariable, Inter, Arial, sans-serif;
  }

  :global(.pac-item) {
    border-top-color: rgba(255, 255, 255, 0.08);
    padding: 0.7rem 0.9rem;
    color: rgba(255, 255, 255, 0.88);
    background: transparent;
  }

  :global(.pac-item:hover),
  :global(.pac-item-selected) {
    background: rgba(242, 199, 68, 0.12);
  }

  :global(.pac-item-query) {
    color: #fff;
  }

  .funnel-quote-form-fields.is-booking-stage {
    width: min(1320px, calc(100vw - 2.5rem));
