  /* Embedded calendar frame no longer needed */
</style>

<script src="https://api.leadconnectorhq.com/js/form_embed.js" type="text/javascript"></script>

<script>
  // @ts-nocheck
  function loadGoogleMapsPlaces(apiKey) {
    if (!apiKey) return Promise.resolve(null);
    if (window.google?.maps?.places) return Promise.resolve(window.google);
    if (window.__googleMapsPlacesPromise) return window.__googleMapsPlacesPromise;

    window.__googleMapsPlacesPromise = new Promise((resolve, reject) => {
      const existingScript = document.querySelector('script[data-google-maps-places-loader]');
      if (existingScript) {
        existingScript.addEventListener('load', () => resolve(window.google));
        existingScript.addEventListener('error', () => reject(new Error('Google Maps failed to load.')));
        return;
      }

      const script = document.createElement('script');
      script.src = `https://maps.googleapis.com/maps/api/js?key=${encodeURIComponent(apiKey)}&libraries=places`;
      script.async = true;
      script.defer = true;
      script.dataset.googleMapsPlacesLoader = 'true';
      script.onload = () => resolve(window.google);
      script.onerror = () => reject(new Error('Google Maps failed to load.'));
      document.head.appendChild(script);
    });

    return window.__googleMapsPlacesPromise;
  }

  function initFunnelQuoteForms() {
    document.querySelectorAll('.funnel-quote-form-fields').forEach(form => {
      if (!(form instanceof HTMLFormElement)) return;
      if (form.dataset.initialized) return;
      form.dataset.initialized = 'true';

      const wrapper = form.closest('.funnel-quote-form');
      if (!(wrapper instanceof HTMLElement)) return;

      const TOTAL_STEPS = 5;
      let currentStep = 1;
      let activeStepObserver = null;
      let bookingVisible = false;
      let calendarInitialized = false;

      const steps = form.querySelectorAll('.funnel-step');
      const dots = wrapper.querySelectorAll('.funnel-step-dot');
      const lines = wrapper.querySelectorAll('.funnel-step-line');
      const btnBack = form.querySelector('.funnel-btn-back');
      const btnNext = form.querySelector('.funnel-btn-next');
      const globalError = wrapper.querySelector('.funnel-quote-error');
      const stepsShell = form.querySelector('.funnel-steps-shell');
      const bookingPanel = form.querySelector('.funnel-final-panel[data-panel="booking"]');
      const leadPanel = form.querySelector('.funnel-final-panel[data-panel="lead"]');
      const webhookWarning = form.querySelector('.funnel-webhook-warning');
      const bookingIframe = form.querySelector('[data-booking-iframe]');
      const addressLookupInput = form.elements.namedItem('addressLookup');
      const streetAddressInput = form.elements.namedItem('streetAddress');
      const cityInput = form.elements.namedItem('city');
      const postalCodeInput = form.elements.namedItem('postalCode');
      const googleMapsApiKey = form.dataset.googleMapsApiKey ?? '';
      const googleBiasLat = Number(form.dataset.googleBiasLat ?? '39.7392');
      const googleBiasLng = Number(form.dataset.googleBiasLng ?? '-104.9903');
      const googleBiasRadius = Number(form.dataset.googleBiasRadius ?? '160934');
      const wavebookWebhookUrl =
        'https://services.leadconnectorhq.com/hooks/QubIB9oYi7Q0mBKuLdWY/webhook-trigger/e4986955-4314-4bc1-b067-5ef75ed4ad11';
      const WAVEBOOK_TIMEOUT_MS = 8000;
      const WAVEBOOK_RETRY_DELAY_MS = 700;

      const isAddressComponentFilled = input => input instanceof HTMLInputElement && input.value.trim().length > 0;
      const hasManualAddressFallback = () =>
        isAddressComponentFilled(streetAddressInput) &&
        isAddressComponentFilled(cityInput) &&
        isAddressComponentFilled(postalCodeInput);

      const setAddressSelectionState = (selected, selectedLabel = '') => {
        if (!(addressLookupInput instanceof HTMLInputElement)) return;
        addressLookupInput.dataset.placeSelected = selected ? 'true' : 'false';
        addressLookupInput.dataset.selectedValue = selected ? selectedLabel : '';
      };

      const assignAttributionFields = () => {
        const params = new URLSearchParams(window.location.search);
        const mappings = {
          pagePath: window.location.pathname,
          utmSource: params.get('utm_source') ?? '',
          utmMedium: params.get('utm_medium') ?? '',
          utmCampaign: params.get('utm_campaign') ?? '',
          utmContent: params.get('utm_content') ?? '',
          utmTerm: params.get('utm_term') ?? '',
          fbclid: params.get('fbclid') ?? '',
          gclid: params.get('gclid') ?? '',
          msclkid: params.get('msclkid') ?? '',
          ttclid: params.get('ttclid') ?? '',
        };

        Object.entries(mappings).forEach(([name, value]) => {
          const input = form.elements.namedItem(name);
          if (input instanceof HTMLInputElement) {
            input.value = value;
          }
        });
      };

      const setShellHeight = (targetStep = currentStep) => {
        if (!(stepsShell instanceof HTMLElement)) return;
        const activeStep = form.querySelector(`.funnel-step[data-step="${targetStep}"]`);
        if (!(activeStep instanceof HTMLElement)) return;

        const nextHeight = Math.ceil(Math.max(activeStep.offsetHeight, activeStep.scrollHeight)) + 8;
        stepsShell.style.height = `${nextHeight}px`;
      };

      const observeActiveStep = step => {
        if (activeStepObserver) {
          activeStepObserver.disconnect();
        }

        const activeStep = form.querySelector(`.funnel-step[data-step="${step}"]`);
        if (!(activeStep instanceof HTMLElement) || typeof ResizeObserver === 'undefined') return;

        activeStepObserver = new ResizeObserver(() => {
          setShellHeight(step);
        });

        activeStepObserver.observe(activeStep);
      };

      const toggleMessageVisibility = (element, visible) => {
        if (!(element instanceof HTMLElement)) return;
        element.style.maxHeight = visible ? `${element.scrollHeight}px` : '0px';
        element.style.opacity = visible ? '1' : '0';
        element.setAttribute('aria-hidden', visible ? 'false' : 'true');
      };

      const setGlobalErrorVisibility = visible => {
        toggleMessageVisibility(globalError, visible);
      };

      const setFieldErrorVisibility = (fieldError, visible) => {
        toggleMessageVisibility(fieldError, visible);
      };

      const getFieldElements = input => {
        const fieldWrapper =
          input.closest('.funnel-field-wrapper') ||
          input.closest('.funnel-choice-card')?.querySelector('.funnel-choice-surface');

        // Most fields have the error message as the immediate sibling of the wrapper
        let fieldError = fieldWrapper?.nextElementSibling?.classList.contains('funnel-field-error')
          ? fieldWrapper.nextElementSibling
          : null;

        // Fallback: search the closest container (useful for radio groups/choice cards)
        if (!fieldError) {
          const container = input.closest('.funnel-choice-card')?.parentElement || input.closest('.funnel-step');
          fieldError = container?.querySelector('.funnel-field-error');
        }

        return { fieldError, fieldWrapper };
      };

      const getFieldValidationMessage = input => {
        const value = input.value.trim();

        // 1. Radio buttons (Step 1-3)
        if (input.type === 'radio') {
          const checked = form.querySelector(`input[name="${input.name}"]:checked`);
          return checked ? '' : 'Please select an option.';
        }

        // 2. Fetch label or placeholder for the field to create friendly messages
        const fieldGroup = input.closest('.funnel-choice-card') || input.parentElement?.parentElement;
        const labelText = fieldGroup?.querySelector('label')?.textContent.replace(/[*:]/g, '').trim();
        const fieldName = labelText || input.placeholder || 'This field';

        // 3. Handle empty state for required fields
        if (!value && input.hasAttribute('required')) {
          return `${fieldName} is required.`;
        }

        // 4. Specific validation for non-empty but invalid fields
        if (input.name === 'postalCode') {
          const digits = value.replace(/\D/g, '');
          return digits.length >= 5 ? '' : 'Please enter a valid postal code.';
        }

        if (input.name === 'addressLookup') {
          const placeSelected = input.dataset.placeSelected === 'true';
          return placeSelected || hasManualAddressFallback()
            ? ''
            : 'Please select an address from the list or complete the fields below.';
        }

        if (input.name === 'streetAddress' && value.length < 5) {
          return 'Please enter a full street address.';
        }

        if (input.name === 'city' && value.length < 2) {
          return 'Please enter a valid city name.';
        }

        if (input.name === 'phone') {
          const digits = value.replace(/\D/g, '');
          return digits.length >= 10 ? '' : 'Please enter a valid 10-digit phone number.';
        }

        if (input.type === 'email') {
          const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
          return emailRegex.test(value) ? '' : 'Please enter a valid email address.';
        }

        return '';
      };

      const updateFieldState = (input, showError = false) => {
        const { fieldError, fieldWrapper } = getFieldElements(input);
        const message = getFieldValidationMessage(input);
        const isValid = message === '';

        if (fieldError instanceof HTMLElement) {
          const content = fieldError.querySelector('span');
          if (content) content.textContent = message;
          setFieldErrorVisibility(fieldError, showError && !isValid);
        }

        if (input.type === 'radio') {
          const cards = form.querySelectorAll(`input[name="${input.name}"]`);
          cards.forEach(radio => {
            const surface = radio.closest('.funnel-choice-card')?.querySelector('.funnel-choice-surface');
            surface?.classList.toggle('ring-1', showError && !isValid);
            surface?.classList.toggle('ring-red-500', showError && !isValid);
          });
        } else if (fieldWrapper instanceof HTMLElement) {
          fieldWrapper.classList.toggle('ring-1', !isValid && showError);
          fieldWrapper.classList.toggle('ring-red-500', !isValid && showError);
        }

        return isValid;
      };

      const clearErrors = () => {
        setGlobalErrorVisibility(false);

        form.querySelectorAll('.funnel-field-error').forEach(el => {
          setFieldErrorVisibility(el, false);
        });

        form.querySelectorAll('.funnel-field-wrapper, .funnel-choice-surface').forEach(el => {
          el.classList.remove('ring-1', 'ring-red-500');
        });

        requestAnimationFrame(() => setShellHeight());
      };

      const updateAddressFieldsValidity = showError => {
        if (addressLookupInput instanceof HTMLInputElement) updateFieldState(addressLookupInput, showError);
        if (streetAddressInput instanceof HTMLInputElement) updateFieldState(streetAddressInput, showError);
        if (cityInput instanceof HTMLInputElement) updateFieldState(cityInput, showError);
        if (postalCodeInput instanceof HTMLInputElement) updateFieldState(postalCodeInput, showError);

        const addressStep = addressLookupInput?.closest('.funnel-step');
        const hasStepErrors = addressStep?.querySelector('.funnel-field-error[aria-hidden="false"]');
        setGlobalErrorVisibility(Boolean(hasStepErrors));
        requestAnimationFrame(() => setShellHeight());
      };

      const getAddressComponent = (components, types) => {
        if (!Array.isArray(components)) return '';
        const matched = components.find(component => types.every(type => component.types?.includes(type)));
        return matched?.long_name ?? '';
      };

      const populateAddressFromPlace = place => {
        const components = place?.address_components;
        if (!Array.isArray(components)) return false;

        const streetNumber = getAddressComponent(components, ['street_number']);
        const route = getAddressComponent(components, ['route']);
        const city =
          getAddressComponent(components, ['locality']) ||
          getAddressComponent(components, ['postal_town']) ||
          getAddressComponent(components, ['sublocality_level_1']) ||
          getAddressComponent(components, ['administrative_area_level_2']);
        const postalCode = getAddressComponent(components, ['postal_code']);
        const postalCodeSuffix = getAddressComponent(components, ['postal_code_suffix']);

        if (!(streetAddressInput instanceof HTMLInputElement)) return false;
        if (!(cityInput instanceof HTMLInputElement)) return false;
        if (!(postalCodeInput instanceof HTMLInputElement)) return false;
        if (!(addressLookupInput instanceof HTMLInputElement)) return false;

        streetAddressInput.value = [streetNumber, route].filter(Boolean).join(' ').trim();
        cityInput.value = city;
        postalCodeInput.value = postalCodeSuffix ? `${postalCode}-${postalCodeSuffix}` : postalCode;
        addressLookupInput.value = place.formatted_address || place.name || addressLookupInput.value;
        setAddressSelectionState(true, addressLookupInput.value.trim());
        updateAddressFieldsValidity(false);
        return true;
      };

      const initAddressAutocomplete = async () => {
        if (!(addressLookupInput instanceof HTMLInputElement)) return;
        if (!googleMapsApiKey) return;

        try {
          await loadGoogleMapsPlaces(googleMapsApiKey);
        } catch (error) {
          console.error(error);
          return;
        }

        if (!window.google?.maps?.places) return;
        if (addressLookupInput.dataset.autocompleteInitialized === 'true') return;

        const autocomplete = new window.google.maps.places.Autocomplete(addressLookupInput, {
          componentRestrictions: { country: ['us'] },
          fields: ['address_components', 'formatted_address', 'name'],
          types: ['address'],
        });

        autocomplete.setBounds(
          new window.google.maps.Circle({
            center: { lat: googleBiasLat, lng: googleBiasLng },
            radius: googleBiasRadius,
          }).getBounds()
        );
        autocomplete.setOptions({ strictBounds: false });

        addressLookupInput.dataset.autocompleteInitialized = 'true';
        setAddressSelectionState(false);

        autocomplete.addListener('place_changed', () => {
          const place = autocomplete.getPlace();
          const populated = populateAddressFromPlace(place);

          if (!populated) {
            setAddressSelectionState(false);
            updateAddressFieldsValidity(true);
          }
        });

        addressLookupInput.addEventListener('input', () => {
          if (!(addressLookupInput instanceof HTMLInputElement)) return;

          const selectedValue = addressLookupInput.dataset.selectedValue ?? '';
          if (!selectedValue || addressLookupInput.value.trim() !== selectedValue) {
            setAddressSelectionState(false);
          }
        });
      };

      const validateStep = step => {
        const currentPanel = form.querySelector(`.funnel-step[data-step="${step}"]`);
        if (!(currentPanel instanceof HTMLElement)) return true;

        clearErrors();
        let valid = true;
        const failingFields = [];

        const requiredInputs = Array.from(currentPanel.querySelectorAll('input[required]'));
        const radioNames = new Set(requiredInputs.filter(input => input.type === 'radio').map(input => input.name));

        radioNames.forEach(name => {
          const representative = currentPanel.querySelector(`input[name="${name}"]`);
          const groupValid = updateFieldState(representative, true);
          if (!groupValid) {
            valid = false;
            failingFields.push(name);
          }
        });

        currentPanel.querySelectorAll('input[required]:not([type="radio"]), select[required]').forEach(input => {
          const fieldValid = updateFieldState(input, true);
          if (!fieldValid) {
            valid = false;
            failingFields.push(input.name || input.id || 'unknown_field');
          }
        });

        if (!valid) {
          setGlobalErrorVisibility(true);
          // GTM: Track validation error
          pushDataLayer({
            event: 'funnel_validation_error',
            funnel_name: 'roof_quote_funnel',
            step_number: step,
            step_name: stepLabels[step] || `step_${step}`,
            failing_fields: failingFields.join(','),
            first_failing_field: failingFields[0] || 'unknown',
          });
        }

        requestAnimationFrame(() => setShellHeight(step));
        return valid;
      };

      const validateStepsThrough = finalStep => {
        for (let step = 1; step <= finalStep; step += 1) {
          const valid = validateStep(step);
          if (!valid) {
            showStep(step);
            return false;
          }
        }
        showStep(finalStep);
        return true;
      };

      const wait = delayMs =>
        new Promise(resolve => {
          window.setTimeout(resolve, delayMs);
        });

      const postWavebookPayload = async payload => {
        const controller = new AbortController();
        const timeoutId = window.setTimeout(() => controller.abort(), WAVEBOOK_TIMEOUT_MS);

        try {
          const response = await fetch(wavebookWebhookUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
            signal: controller.signal,
          });

          if (!response.ok) {
            throw new Error(`Webhook submission failed with status ${response.status}`);
          }
        } finally {
          window.clearTimeout(timeoutId);
        }
      };

      const getFormPayload = () => {
        const formData = new FormData(form);
        const values = {};

        formData.forEach((value, key) => {
          if (typeof value === 'string') {
            values[key] = value.trim();
          }
        });

        const [firstName = '', ...restNameParts] = (values.fullName || '').split(/\s+/).filter(Boolean);
        const lastName = restNameParts.join(' ');
        const queryParams = new URLSearchParams(window.location.search);

        return {
          ...values,
          firstName,
          lastName,
          submittedAt: new Date().toISOString(),
          timezone: Intl.DateTimeFormat().resolvedOptions().timeZone || '',
          referrer: document.referrer || '',
          userAgent: navigator.userAgent || '',
          currentUrl: window.location.href,
          queryString: window.location.search || '',
          funnelName: 'roof_quote_funnel',
          formName: 'roof_quote_step_5',
          funnelStep: 5,
          leadStatus: 'submitted_before_booking',
          submissionChannel: 'wavebook_webhook',
          fbclid: values.fbclid || queryParams.get('fbclid') || '',
          gclid: values.gclid || queryParams.get('gclid') || '',
          msclkid: values.msclkid || queryParams.get('msclkid') || '',
          ttclid: values.ttclid || queryParams.get('ttclid') || '',
        };
      };

      const splitNameForBooking = fullName => {
        const tokens = String(fullName || '')
          .trim()
          .split(/\s+/)
          .filter(Boolean);

        if (tokens.length === 0) {
          return { firstName: '', lastName: '' };
        }

        if (tokens.length === 1) {
          return { firstName: tokens[0], lastName: '' };
        }

        const firstNameTokenCount = Math.ceil(tokens.length / 2);
        return {
          firstName: tokens.slice(0, firstNameTokenCount).join(' '),
          lastName: tokens.slice(firstNameTokenCount).join(' '),
        };
      };

      const buildBookingPrefillParams = payload => {
        const { firstName, lastName } = splitNameForBooking(payload.fullName);

        const params = {
          full_name: payload.fullName || '',
          first_name: firstName,
          last_name: lastName,
          email: payload.email || '',
          phone: payload.phone || '',
        };

        const searchParams = new URLSearchParams();
        Object.entries(params).forEach(([key, value]) => {
          const normalized = String(value || '').trim();
          if (normalized) {
            searchParams.set(key, normalized);
          }
        });

        return searchParams;
      };

      const applyBookingPrefillToPageQuery = prefillParams => {
        if (!(prefillParams instanceof URLSearchParams)) return;

        const url = new URL(window.location.href);
        prefillParams.forEach((value, key) => {
          if (value) {
            url.searchParams.set(key, value);
          }
        });

        window.history.replaceState(window.history.state, '', `${url.pathname}${url.search}${url.hash}`);
      };

      const submitToWavebookWithRetry = async payload => {
        try {
          await postWavebookPayload(payload);
          return true;
        } catch (error) {
          // Only retry on network/abort errors, not on server errors (4xx/5xx already sent the webhook)
          const isNetworkError = error instanceof TypeError || (error instanceof DOMException && error.name === 'AbortError');
          if (!isNetworkError) {
            console.error('Wavebook webhook failed (no retry):', error);
            return false;
          }
          console.error('Wavebook webhook attempt 1 failed (network), retrying:', error);
        }

        await wait(WAVEBOOK_RETRY_DELAY_MS);

        try {
          await postWavebookPayload(payload);
          return true;
        } catch (error) {
          console.error('Wavebook webhook attempt 2 failed:', error);
          return false;
        }
      };

      const revealBookingPanel = async payload => {
        if (!(leadPanel instanceof HTMLElement) || !(bookingPanel instanceof HTMLElement)) return;

        leadPanel.classList.remove('is-active');
        leadPanel.classList.add('hidden');
        bookingPanel.classList.remove('hidden');
        bookingPanel.classList.add('is-active');
        bookingVisible = true;
        form.classList.add('is-booking-stage');

        // Meta Pixel: Lead – contact info captured, booking panel revealed
        if (typeof window.fbq === 'function') {
          window.fbq('track', 'Lead');
        }

        // GTM: Track booking calendar reveal
        pushDataLayer({
          event: 'funnel_booking_revealed',
          funnel_name: 'roof_quote_funnel',
          home_type: payload?.homeType || '',
          project_scope: payload?.projectScope || '',
          timeline: payload?.timeline || '',
          city: payload?.city || '',
        });

        if (btnNext instanceof HTMLElement) btnNext.classList.add('hidden');
        if (btnBack instanceof HTMLElement) btnBack.classList.add('hidden');

        if (!calendarInitialized) {
          const prefillParams = buildBookingPrefillParams(payload ?? {});
          applyBookingPrefillToPageQuery(prefillParams);

          const baseUrl = form.dataset.bookingBaseUrl || '';
          if (bookingIframe instanceof HTMLIFrameElement && baseUrl) {
            const src = new URL(baseUrl);
            prefillParams.forEach((value, key) => src.searchParams.set(key, value));
            bookingIframe.src = src.toString();
          }
          calendarInitialized = true;
        }

        if (btnNext) btnNext.style.display = 'none';
        if (btnBack) btnBack.style.display = 'none';

        requestAnimationFrame(() => setShellHeight(5));
      };

      const stepLabels = {
        1: 'home_type',
        2: 'timeline',
        3: 'project_scope',
        4: 'address',
        5: 'contact_info',
      };

      const pushDataLayer = (eventData) => {
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push(eventData);
      };

      const showStep = step => {
        steps.forEach(el => {
          const stepNumber = Number(el.dataset.step);
          const isActive = stepNumber === step;
          el.classList.toggle('is-active', isActive);
          el.setAttribute('aria-hidden', isActive ? 'false' : 'true');
          if (isActive) {
            el.removeAttribute('inert');
          } else {
            el.setAttribute('inert', '');
          }
        });

        dots.forEach(dot => {
          const stepNumber = Number(dot.dataset.step);
          const label = dot.querySelector('.funnel-step-label');
          const isCompleted = stepNumber < step;
          const isActive = stepNumber === step;

          if (isCompleted) {
            dot.dataset.state = 'complete';
            dot.className =
              'funnel-step-dot bg-primary flex size-10 shrink-0 items-center justify-center rounded-full text-sm font-bold text-black transition-all duration-300 ease-out';
            if (label) label.textContent = '✓';
          } else if (isActive) {
            dot.dataset.state = 'active';
            dot.className =
              'funnel-step-dot bg-primary flex size-10 shrink-0 items-center justify-center rounded-full text-sm font-bold text-black transition-all duration-300 ease-out';
            if (label) label.textContent = String(stepNumber);
          } else {
            dot.dataset.state = 'upcoming';
            dot.className =
              'funnel-step-dot flex size-10 shrink-0 items-center justify-center rounded-full border border-white/20 text-sm text-white/50 transition-all duration-300 ease-out';
            if (label) label.textContent = String(stepNumber);
          }
        });

        lines.forEach(line => {
          const afterStep = Number(line.dataset.afterStep);
          if (afterStep < step) {
            line.classList.remove('bg-white/20');
            line.classList.add('bg-primary/40');
          } else {
            line.classList.remove('bg-primary/40');
            line.classList.add('bg-white/20');
          }
        });

        if (btnBack instanceof HTMLElement) {
          btnBack.classList.toggle('hidden', step === 1 || bookingVisible);
        }

        if (btnNext instanceof HTMLElement) {
          btnNext.classList.toggle('hidden', step === 1);
          const label = btnNext.querySelector('.funnel-btn-next-label');
          if (label) {
            label.textContent = step === 5 ? 'Submit' : 'Next';
          }
        }

        currentStep = step;
        observeActiveStep(step);
        requestAnimationFrame(() => setShellHeight(step));

        // GTM: Track step view
        pushDataLayer({
          event: 'funnel_step_view',
          funnel_name: 'roof_quote_funnel',
          step_number: step,
          step_name: stepLabels[step] || `step_${step}`,
        });
      };

      let submitting = false;
      const handleFinalStepSubmit = async () => {
        if (submitting) return;
        if (!validateStepsThrough(5)) return;

        submitting = true;

        if (webhookWarning instanceof HTMLElement) {
          webhookWarning.classList.add('hidden');
        }

        if (btnNext instanceof HTMLButtonElement) {
          btnNext.disabled = true;
          const label = btnNext.querySelector('.funnel-btn-next-label');
          const spinner = btnNext.querySelector('.funnel-btn-next-spinner');
          if (label) label.textContent = 'Submitting...';
          if (spinner) spinner.classList.remove('hidden');
        }

        try {
          const payload = getFormPayload();

          // GTM: Track lead submission attempt
          pushDataLayer({
            event: 'funnel_lead_submitted',
            funnel_name: 'roof_quote_funnel',
            home_type: payload.homeType || '',
            project_scope: payload.projectScope || '',
            timeline: payload.timeline || '',
            city: payload.city || '',
            postal_code: payload.postalCode || '',
            utm_source: payload.utmSource || '',
            utm_medium: payload.utmMedium || '',
            utm_campaign: payload.utmCampaign || '',
            gclid: payload.gclid || '',
            fbclid: payload.fbclid || '',
          });

          const webhookSuccess = await submitToWavebookWithRetry(payload);

          // GTM: Track webhook result
          pushDataLayer({
            event: webhookSuccess ? 'funnel_lead_webhook_success' : 'funnel_lead_webhook_failure',
            funnel_name: 'roof_quote_funnel',
          });

          await revealBookingPanel(payload);

          if (!webhookSuccess && webhookWarning instanceof HTMLElement) {
            webhookWarning.classList.remove('hidden');
          }
        } catch (error) {
          console.error(error);
          submitting = false;
          if (btnNext instanceof HTMLButtonElement) {
            btnNext.disabled = false;
            const label = btnNext.querySelector('.funnel-btn-next-label');
            const spinner = btnNext.querySelector('.funnel-btn-next-spinner');
            if (label) label.textContent = 'Submit';
            if (spinner) spinner.classList.add('hidden');
          }
          alert('There was a problem opening the booking widget. Please try again.');
        }
      };

      btnNext?.addEventListener('click', () => {
        if (!validateStep(currentStep)) return;

        if (currentStep < TOTAL_STEPS) {
          showStep(currentStep + 1);
          return;
        }

        handleFinalStepSubmit();
      });

      btnBack?.addEventListener('click', () => {
        clearErrors();
        if (currentStep > 1) {
          // GTM: Track back navigation
          pushDataLayer({
            event: 'funnel_step_back',
            funnel_name: 'roof_quote_funnel',
            from_step_number: currentStep,
            from_step_name: stepLabels[currentStep] || `step_${currentStep}`,
            to_step_number: currentStep - 1,
            to_step_name: stepLabels[currentStep - 1] || `step_${currentStep - 1}`,
          });
          showStep(currentStep - 1);
        }
      });

      form.querySelectorAll('input[required], select[required]').forEach(input => {
        const validateCurrentField = () => {
          if (input.type === 'radio') {
            updateFieldState(input, false);
            return;
          }

          const hasVisibleError =
            form.querySelector('.funnel-quote-error')?.getAttribute('aria-hidden') === 'false' ||
            input.closest('.funnel-step')?.querySelector('.funnel-field-error[aria-hidden="false"]');

          updateFieldState(input, Boolean(hasVisibleError));

          const currentPanel = input.closest('.funnel-step');
          const hasStepErrors = currentPanel?.querySelector('.funnel-field-error[aria-hidden="false"]');
          setGlobalErrorVisibility(Boolean(hasStepErrors));
          requestAnimationFrame(() => setShellHeight());
        };

        const eventName = input.type === 'radio' ? 'change' : 'input';
        input.addEventListener(eventName, validateCurrentField);

        // Auto-forwarding for steps 1, 2, and 3
        if (input.type === 'radio') {
          input.addEventListener('change', () => {
            // GTM: Track option selection
            pushDataLayer({
              event: 'funnel_option_selected',
              funnel_name: 'roof_quote_funnel',
              step_number: currentStep,
              step_name: stepLabels[currentStep] || `step_${currentStep}`,
              option_category: input.name,
              option_value: input.value
            });

            const stepEl = input.closest('.funnel-step');
            const stepNumber = stepEl ? parseInt(stepEl.dataset.step) : 0;
            if (stepNumber >= 1 && stepNumber <= 3) {
              setTimeout(() => {
                if (currentStep === stepNumber) {
                  btnNext?.click();
                }
              }, 320);
            }
          });
        }
        input.addEventListener('blur', () => {
          if (input.type === 'radio') return;
          updateFieldState(input, true);
          const currentPanel = input.closest('.funnel-step');
          const hasStepErrors = currentPanel?.querySelector('.funnel-field-error[aria-hidden="false"]');
          setGlobalErrorVisibility(Boolean(hasStepErrors));
          requestAnimationFrame(() => setShellHeight());
        });
      });

      assignAttributionFields();
      void initAddressAutocomplete();
      window.addEventListener('resize', () => setShellHeight(currentStep));
      showStep(1);
      requestAnimationFrame(() => setShellHeight(1));
    });
  }

  initFunnelQuoteForms();
  document.addEventListener('astro:after-swap', initFunnelQuoteForms);
</script>
