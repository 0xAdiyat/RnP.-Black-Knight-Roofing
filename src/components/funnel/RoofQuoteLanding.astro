---
import { Image } from 'astro:assets';
import FunnelQuoteForm from '@/components/funnel/FunnelQuoteForm.astro';
import Brands from '@/components/Brands.astro';
import RatingStars from '@/components/ui/RatingStars.astro';

const visualThesis =
  'A dramatic full-bleed roof backdrop with a dark steel-blue gradient field, a centered crest logo, and a single conversion card.';
const contentPlan = 'Logo, funnel form, trust strip.';
const interactionThesis = 'Use the existing stepper motion and keep the rest of the page still.';
---

<section
  class="relative isolate overflow-hidden bg-[#0d0d0d]"
  data-visual-thesis={visualThesis}
  data-content-plan={contentPlan}
  data-interaction-thesis={interactionThesis}
>
  <div class="relative z-10 flex min-h-[calc(100svh-1px)] flex-col bg-[#111111]">
    <div
      class="w-full max-w-7xl mx-auto flex flex-1 flex-col items-center space-y-6 px-3 pt-6 pb-12 sm:space-y-8 sm:px-4 sm:pt-10 sm:pb-16"
    >
      <a href="/" class="block" aria-label="Black Knight Roofing home">
        <img
          src="/placeholders/logo.png"
          alt="Black Knight Roofing"
          class="z-10 w-[120px] sm:w-[160px]"
          loading="eager"
          fetchpriority="high"
        />
      </a>

      <div class="flex flex-col items-center justify-center space-y-2">
        <div class="flex justify-center">
          <RatingStars rating={5} size={22} fillColor="#F7B715" strokeColor="transparent" />
        </div>

        <h2 class="mx-auto max-w-2xl text-center text-[clamp(1.5rem,2rem,2rem)] leading-[1.1] font-normal text-white">
          Get a FREE Instant Roofing Estimate For Your Property
        </h2>
      </div>

      <div class="flex w-full items-center justify-center">
        <FunnelQuoteForm />
      </div>
    </div>

    <Brands class="bg-[#111111]/95" />
  </div>
</section>


