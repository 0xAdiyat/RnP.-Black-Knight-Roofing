---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import { actions } from 'astro:actions';
import NoiseBg from '@/components/NoiseBg.astro';
import Button from '@/components/ui/Button.astro';
import RatingStars from '@/components/ui/RatingStars.astro';
import bbbLogo from '@/assets/bbb-logo.png';

interface Props {
  headingLine1?: string;
  headingLine2?: string;
  services?: string[];
  rating?: number;
  class?: string;
}

const {
  headingLine1 = 'Do Your Roof With The Best Rated',
  headingLine2 = 'Roofer In Colorado',
  services = [
    'Roof Replacement',
    'Roof Repair',
    'New Roof Installation',
    'Roof Inspection',
    'Storm Damage',
    'Gutter Installation',
    'Siding',
    'Other',
  ],
  rating = 5,
  class: className,
} = Astro.props;

const result = Astro.getActionResult(actions.sendQuoteForm);
const success = result && !result.error;
---

<div class:list={['w-full max-w-[34.375rem] rounded-2xl bg-linear-to-t from-[#F2C744]/90 to-[#F2C744]/10 p-2', className]}>
  <NoiseBg class="space-y-6 rounded-2xl bg-[#222222] p-8">
    {success ? (
      <div class="flex flex-col items-center justify-center gap-y-6 py-8 text-center">
        <div class="bg-primary/20 border-primary/40 flex size-16 items-center justify-center rounded-full border">
          <Icon name="circle-tick" class="text-primary size-8" />
        </div>
        <h3 class="text-xl font-semibold text-white">Quote Request Sent!</h3>
        <p class="text-sm text-neutral-400">We'll reach out to you shortly with your free quote.</p>
      </div>
    ) : (
    <>
    <!-- Stars -->
    <div class="flex justify-center">
      <RatingStars rating={rating} size={20} fillColor="#F7B715" strokeColor="transparent" />
    </div>

    <!-- Heading -->
    <h4 class="text-center leading-snug font-normal">
      {headingLine1}
      <br />
      {headingLine2}
    </h4>

    <!-- Error message -->
    <div
      class="quote-form-error pointer-events-none max-h-0 overflow-hidden text-center text-sm font-semibold tracking-wide text-red-500 uppercase opacity-0 transition-all duration-300 ease-out"
      role="alert"
      aria-hidden="true"
    >
      <div class="pt-1">
        <span class="block">There was a problem with your submission.</span>
        <span class="block">Please review the fields below.</span>
      </div>
    </div>

    <!-- Step indicator -->
    <div class="flex items-center justify-center gap-x-2 px-8">
      <div
        class="quote-step-dot bg-primary flex size-10 shrink-0 items-center justify-center rounded-full text-sm font-bold text-black transition-all duration-300 ease-out"
        data-step="1"
        data-state="active"
      >
        <span class="quote-step-label">1</span>
      </div>
      <div
        class="quote-step-line h-px flex-1 bg-white/20 transition-colors duration-300 ease-out"
        data-after-step="1"></div>
      <div
        class="quote-step-dot flex size-10 shrink-0 items-center justify-center rounded-full border border-white/20 text-sm text-white/50 transition-all duration-300 ease-out"
        data-step="2"
        data-state="upcoming"
      >
        <span class="quote-step-label">2</span>
      </div>
      <div
        class="quote-step-line h-px flex-1 bg-white/20 transition-colors duration-300 ease-out"
        data-after-step="2"></div>
      <div
        class="quote-step-dot flex size-10 shrink-0 items-center justify-center rounded-full border border-white/20 text-sm text-white/50 transition-all duration-300 ease-out"
        data-step="3"
        data-state="upcoming"
      >
        <span class="quote-step-label">3</span>
      </div>
    </div>

    <!-- Form -->
    <form class="quote-form" novalidate method="POST" action={actions.sendQuoteForm}>
      <div class="quote-steps-shell relative overflow-hidden">
      <!-- Step 1: Zip Code -->
      <div class="quote-step is-active space-y-4" data-step="1" aria-hidden="false">
        <label class="block font-medium">Where is Your Project Located?</label>
        <div class="quote-field-wrapper from-primary rounded-lg bg-radial-[at_25%_25%] to-[#594216] p-px">
          <NoiseBg class="rounded-lg px-0 py-0">
            <input
              type="text"
              name="zipCode"
              placeholder="Zip Code"
              required
              maxlength="10"
              class="w-full rounded-lg bg-white/5 px-4 py-3 text-sm text-white placeholder:text-white/40 focus:outline-none"
            />
          </NoiseBg>
        </div>
        <p
          class="quote-field-error max-h-0 overflow-hidden text-xs font-semibold tracking-wide text-red-500 uppercase opacity-0 transition-all duration-300 ease-out"
          aria-hidden="true">
          <span class="block pt-2">The field is required.</span>
        </p>
      </div>

      <!-- Step 2: Service Selection -->
      <div class="quote-step space-y-4" data-step="2" aria-hidden="true" inert>
        <label class="block font-medium">What Service Do You Need?</label>
        <div class="quote-field-wrapper from-primary relative rounded-lg bg-radial-[at_25%_25%] to-[#594216] p-px">
          <NoiseBg class="rounded-lg px-0 py-0">
            <select
              name="service"
              required
              class="w-full appearance-none rounded-lg bg-white/5 px-4 py-3 pr-10 text-sm text-white/40 focus:outline-none"
            >
              <option value="" disabled selected>Select Your Service</option>
              {
                services.map(service => (
                  <option value={service} class="bg-[#252525] text-white">
                    {service}
                  </option>
                ))
              }
            </select>
            <!-- Chevron icon -->
            <svg
              class="pointer-events-none absolute top-1/2 right-4 size-5 -translate-y-1/2 text-white/50"
              viewBox="0 0 20 20"
              fill="currentColor"
            >
              <path
                fill-rule="evenodd"
                d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"
                clip-rule="evenodd"></path>
            </svg>
          </NoiseBg>
        </div>
        <p
          class="quote-field-error max-h-0 overflow-hidden text-xs font-semibold tracking-wide text-red-500 uppercase opacity-0 transition-all duration-300 ease-out"
          aria-hidden="true">
          <span class="block pt-2">Please select a service.</span>
        </p>
      </div>

      <!-- Step 3: Contact Details -->
      <div class="quote-step space-y-4" data-step="3" aria-hidden="true" inert>
        <label class="block font-medium">Tell Us More About You</label>

        <div class="space-y-4">
          <div>
            <div class="quote-field-wrapper from-primary rounded-lg bg-radial-[at_25%_25%] to-[#594216] p-px">
              <NoiseBg class="rounded-lg px-0 py-0">
                <input
                  type="text"
                  name="firstName"
                  placeholder="First Name"
                  required
                  class="w-full rounded-lg bg-white/5 px-4 py-3 text-sm text-white placeholder:text-white/40 focus:outline-none"
                />
              </NoiseBg>
            </div>
            <p
              class="quote-field-error max-h-0 overflow-hidden text-xs font-semibold tracking-wide text-red-500 uppercase opacity-0 transition-all duration-300 ease-out"
              aria-hidden="true">
              <span class="block pt-2">First name is required.</span>
            </p>
          </div>

          <div>
            <div class="quote-field-wrapper from-primary rounded-lg bg-radial-[at_25%_25%] to-[#594216] p-px">
              <NoiseBg class="rounded-lg px-0 py-0">
                <input
                  type="text"
                  name="lastName"
                  placeholder="Last Name"
                  required
                  class="w-full rounded-lg bg-white/5 px-4 py-3 text-sm text-white placeholder:text-white/40 focus:outline-none"
                />
              </NoiseBg>
            </div>
            <p
              class="quote-field-error max-h-0 overflow-hidden text-xs font-semibold tracking-wide text-red-500 uppercase opacity-0 transition-all duration-300 ease-out"
              aria-hidden="true">
              <span class="block pt-2">Last name is required.</span>
            </p>
          </div>

          <div>
            <div class="quote-field-wrapper from-primary rounded-lg bg-radial-[at_25%_25%] to-[#594216] p-px">
              <NoiseBg class="rounded-lg px-0 py-0">
                <input
                  type="tel"
                  name="phone"
                  placeholder="Phone Number"
                  required
                  class="w-full rounded-lg bg-white/5 px-4 py-3 text-sm text-white placeholder:text-white/40 focus:outline-none"
                />
              </NoiseBg>
            </div>
            <p
              class="quote-field-error max-h-0 overflow-hidden text-xs font-semibold tracking-wide text-red-500 uppercase opacity-0 transition-all duration-300 ease-out"
              aria-hidden="true">
              <span class="block pt-2">Phone number is required.</span>
            </p>
          </div>

          <div>
            <div class="quote-field-wrapper from-primary rounded-lg bg-radial-[at_25%_25%] to-[#594216] p-px">
              <NoiseBg class="rounded-lg px-0 py-0">
                <input
                  type="email"
                  name="email"
                  placeholder="Email Address"
                  required
                  class="w-full rounded-lg bg-white/5 px-4 py-3 text-sm text-white placeholder:text-white/40 focus:outline-none"
                />
              </NoiseBg>
            </div>
            <p
              class="quote-field-error max-h-0 overflow-hidden text-xs font-semibold tracking-wide text-red-500 uppercase opacity-0 transition-all duration-300 ease-out"
              aria-hidden="true">
              <span class="block pt-2">A valid email is required.</span>
            </p>
          </div>
        </div>
      </div>
      </div>

      <!-- Navigation buttons -->
      <div class="mt-6 flex items-center justify-center gap-x-3">
        <Button type="button" variant="outline" class="quote-btn-back hidden min-w-[120px] justify-center">
          Back
        </Button>
        <Button type="button" class="quote-btn-next min-w-[120px] justify-center">
          <span class="quote-btn-next-label">Next</span>
          <svg class="quote-btn-next-spinner hidden size-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
        </Button>
      </div>

      <p class="mt-4 text-center text-xs leading-5 text-white/60">
        By submitting this form, you agree that Black Knight Roofing may contact you about your request. See our
        <a href="/privacy-policy" class="text-primary font-semibold transition-colors hover:text-white">
          Privacy Policy
        </a>
        for details.
      </p>
    </form>
    </>
    )}

    <!-- Ratings row -->
    <div class="flex items-center justify-center gap-x-3 border-t border-white/10 pt-5 sm:gap-x-6">
      <div class="flex items-center gap-x-2">
        <Icon name="google-logo" class="size-4 text-white sm:size-5" />
        <div class="flex flex-col gap-y-[2px] text-[11px] leading-tight sm:text-xs">
          <RatingStars rating={5} size={8} fillColor="#fff" strokeColor="transparent" />
          <span class="font-semibold text-white">5.0 Rating</span>
        </div>
      </div>
      <div class="flex items-center gap-x-2">
        <Icon name="facebook-logo" class="size-4 text-white sm:size-5" />
        <div class="flex flex-col gap-y-[2px] text-[11px] leading-tight sm:text-xs">
          <RatingStars rating={5} size={8} fillColor="#fff" strokeColor="transparent" />
          <span class="font-semibold text-white">5.0 Rating</span>
        </div>
      </div>
      <div class="flex items-center gap-x-2">
        <Image src={bbbLogo} alt="BBB" width={16} height={16} class="size-4 sm:size-5" />
        <div class="flex flex-col gap-y-[2px] text-[11px] leading-tight sm:text-xs">
          <RatingStars rating={5} size={8} fillColor="#fff" strokeColor="transparent" />
          <span class="font-semibold text-white">A+ Rating</span>
        </div>
      </div>
    </div>
  </NoiseBg>
</div>

<style>
  .quote-steps-shell {
    transition: height 320ms ease;
  }

  .quote-step {
    position: absolute;
    inset: 0;
    width: 100%;
    opacity: 0;
    transform: translateY(14px);
    pointer-events: none;
    transition:
      opacity 280ms ease,
      transform 320ms ease;
  }

  .quote-step.is-active {
    position: relative;
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
</style>

<script>
  function initQuoteForms() {
    document.querySelectorAll<HTMLElement>('.quote-form').forEach(form => {
      // Prevent duplicate initialization
      if (form.dataset.initialized) return;
      form.dataset.initialized = 'true';

      const wrapper = form.closest('.rounded-2xl');
      if (!wrapper) return;

      const TOTAL_STEPS = 3;
      let currentStep = 1;

      // Elements
      const steps = form.querySelectorAll<HTMLElement>('.quote-step');
      const dots = wrapper.querySelectorAll<HTMLElement>('.quote-step-dot');
      const lines = wrapper.querySelectorAll<HTMLElement>('.quote-step-line');
      const btnBack = form.querySelector<HTMLButtonElement>('.quote-btn-back');
      const btnNext = form.querySelector<HTMLButtonElement>('.quote-btn-next');
      const globalError = wrapper.querySelector<HTMLElement>('.quote-form-error');
      const stepsShell = form.querySelector<HTMLElement>('.quote-steps-shell');
      let activeStepObserver: ResizeObserver | null = null;

      function setShellHeight(targetStep = currentStep) {
        if (!stepsShell) return;
        const activeStep = form.querySelector<HTMLElement>(`.quote-step[data-step="${targetStep}"]`);
        if (!activeStep) return;

        const nextHeight = Math.ceil(Math.max(activeStep.offsetHeight, activeStep.scrollHeight)) + 8;
        stepsShell.style.height = `${nextHeight}px`;
      }

      function observeActiveStep(step: number) {
        if (activeStepObserver) {
          activeStepObserver.disconnect();
        }

        const activeStep = form.querySelector<HTMLElement>(`.quote-step[data-step="${step}"]`);
        if (!activeStep || typeof ResizeObserver === 'undefined') return;

        activeStepObserver = new ResizeObserver(() => {
          setShellHeight(step);
        });

        activeStepObserver.observe(activeStep);
      }

      function toggleMessageVisibility(element: Element | null, visible: boolean) {
        if (!(element instanceof HTMLElement)) return;

        element.style.maxHeight = visible ? `${element.scrollHeight}px` : '0px';
        element.style.opacity = visible ? '1' : '0';
        element.setAttribute('aria-hidden', visible ? 'false' : 'true');
      }

      function setGlobalErrorVisibility(visible: boolean) {
        toggleMessageVisibility(globalError, visible);
      }

      function setFieldErrorVisibility(fieldError: Element | null, visible: boolean) {
        toggleMessageVisibility(fieldError, visible);
      }

      function getFieldElements(input: HTMLInputElement | HTMLSelectElement) {
        const fieldGroup =
          input.closest('.quote-step > div, .quote-step > .space-y-4 > div') || input.parentElement;
        const fieldError = fieldGroup?.querySelector('.quote-field-error');
        const fieldWrapper =
          fieldGroup?.querySelector('.quote-field-wrapper') || input.closest('.quote-field-wrapper');

        return { fieldGroup, fieldError, fieldWrapper };
      }

      function getFieldValidationMessage(input: HTMLInputElement | HTMLSelectElement) {
        const value = input.value.trim();

        if (input.tagName === 'SELECT') {
          return input.value ? '' : 'Please select a service.';
        }

        if (input.name === 'zipCode') {
          if (!value) return 'The field is required.';
          const digits = value.replace(/\D/g, '');
          return digits.length >= 5 ? '' : 'Please enter a valid ZIP code.';
        }

        if (input.name === 'phone') {
          if (!value) return 'Phone number is required.';
          const digits = value.replace(/\D/g, '');
          return digits.length >= 10 ? '' : 'Please enter a valid phone number.';
        }

        if (input.type === 'email') {
          if (!value) return 'A valid email is required.';
          const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
          return emailRegex.test(value) ? '' : 'Please enter a valid email address.';
        }

        if (!value) {
          switch (input.name) {
            case 'firstName':
              return 'First name is required.';
            case 'lastName':
              return 'Last name is required.';
            default:
              return 'The field is required.';
          }
        }

        return '';
      }

      function updateFieldState(input: HTMLInputElement | HTMLSelectElement, showError = false) {
        const { fieldError, fieldWrapper } = getFieldElements(input);
        const message = getFieldValidationMessage(input);
        const isValid = message === '';

        if (fieldError) {
          const content = fieldError.querySelector('span');
          if (content) content.textContent = message;
          setFieldErrorVisibility(fieldError, showError && !isValid);
        }

        if (fieldWrapper) {
          fieldWrapper.classList.toggle('ring-1', !isValid && showError);
          fieldWrapper.classList.toggle('ring-red-500', !isValid && showError);
        }

        if (input instanceof HTMLSelectElement) {
          input.classList.toggle('text-white/40', !input.value);
          input.classList.toggle('text-white', Boolean(input.value));
        }

        return isValid;
      }

      function showStep(step: number) {
        steps.forEach(el => {
          const s = Number(el.dataset.step);
          const isActive = s === step;
          el.classList.toggle('is-active', isActive);
          el.setAttribute('aria-hidden', isActive ? 'false' : 'true');
          if (isActive) {
            el.removeAttribute('inert');
          } else {
            el.setAttribute('inert', '');
          }
        });

        dots.forEach(dot => {
          const s = Number(dot.dataset.step);
          const label = dot.querySelector<HTMLElement>('.quote-step-label');
          const isCompleted = s < step;
          const isActive = s === step;

          if (isCompleted) {
            dot.dataset.state = 'complete';
            dot.className =
              'quote-step-dot bg-primary flex size-10 shrink-0 items-center justify-center rounded-full text-sm font-bold text-black transition-all duration-300 ease-out';
            if (label) label.textContent = '✓';
          } else if (isActive) {
            dot.dataset.state = 'active';
            dot.className =
              'quote-step-dot bg-primary flex size-10 shrink-0 items-center justify-center rounded-full text-sm font-bold text-black transition-all duration-300 ease-out';
            if (label) label.textContent = String(s);
          } else {
            dot.dataset.state = 'upcoming';
            dot.className =
              'quote-step-dot flex size-10 shrink-0 items-center justify-center rounded-full border border-white/20 text-sm text-white/50 transition-all duration-300 ease-out';
            if (label) label.textContent = String(s);
          }
        });

        lines.forEach(line => {
          const afterStep = Number(line.dataset.afterStep);
          if (afterStep < step) {
            line.classList.remove('bg-white/20');
            line.classList.add('bg-primary/40');
          } else {
            line.classList.remove('bg-primary/40');
            line.classList.add('bg-white/20');
          }
        });

        // Back button visibility
        if (btnBack) {
          btnBack.classList.toggle('hidden', step === 1);
        }

        // Next button text
        if (btnNext) {
          const lbl = btnNext.querySelector('.quote-btn-next-label');
          if (lbl) lbl.textContent = step === TOTAL_STEPS ? 'Submit' : 'Next';
        }

        currentStep = step;
        observeActiveStep(step);
        requestAnimationFrame(() => setShellHeight(step));
      }

      function clearErrors() {
        setGlobalErrorVisibility(false);

        form.querySelectorAll('.quote-field-error').forEach(el => {
          setFieldErrorVisibility(el, false);
        });

        form.querySelectorAll('.quote-field-wrapper').forEach(el => {
          el.classList.remove('ring-1', 'ring-red-500');
        });

        requestAnimationFrame(() => setShellHeight());
      }

      function validateStep(step: number): boolean {
        const currentPanel = form.querySelector<HTMLElement>(`.quote-step[data-step="${step}"]`);
        if (!currentPanel) return true;

        clearErrors();
        let valid = true;

        const inputs = currentPanel.querySelectorAll<HTMLInputElement | HTMLSelectElement>(
          'input[required], select[required]'
        );

        inputs.forEach(input => {
          const fieldValid = updateFieldState(input, true);
          if (!fieldValid) {
            valid = false;
          }
        });

        if (!valid) {
          setGlobalErrorVisibility(true);
        }

        requestAnimationFrame(() => setShellHeight(step));
        return valid;
      }

      // Next button
      btnNext?.addEventListener('click', () => {
        if (!validateStep(currentStep)) return;

        if (currentStep < TOTAL_STEPS) {
          showStep(currentStep + 1);
        } else {
          // Final submit
          handleSubmit();
        }
      });

      // Back button
      btnBack?.addEventListener('click', () => {
        clearErrors();
        if (currentStep > 1) {
          showStep(currentStep - 1);
        }
      });

      function handleSubmit() {
        if (!validateStep(currentStep)) return;
        // Show loading state
        if (btnNext) {
          btnNext.disabled = true;
          const lbl = btnNext.querySelector('.quote-btn-next-label');
          const spinner = btnNext.querySelector('.quote-btn-next-spinner');
          if (lbl) lbl.textContent = 'Sending…';
          if (spinner) spinner.classList.remove('hidden');
        }
        // Trigger the native form POST to the Astro Action endpoint
        (form as HTMLFormElement).requestSubmit();
      }

      form.querySelectorAll<HTMLInputElement | HTMLSelectElement>('input[required], select[required]').forEach(
        input => {
          const validateCurrentField = () => {
            const hasVisibleError =
              form.querySelector('.quote-form-error')?.getAttribute('aria-hidden') === 'false' ||
              input.closest('.quote-step')?.querySelector('.quote-field-error[aria-hidden="false"]');

            updateFieldState(input, Boolean(hasVisibleError));

            const currentPanel = input.closest<HTMLElement>('.quote-step');
            const hasStepErrors = currentPanel?.querySelector('.quote-field-error[aria-hidden="false"]');
            setGlobalErrorVisibility(Boolean(hasStepErrors));
            requestAnimationFrame(() => setShellHeight());
          };

          input.addEventListener('input', validateCurrentField);
          input.addEventListener('blur', () => {
            updateFieldState(input, true);
            const currentPanel = input.closest<HTMLElement>('.quote-step');
            const hasStepErrors = currentPanel?.querySelector('.quote-field-error[aria-hidden="false"]');
            setGlobalErrorVisibility(Boolean(hasStepErrors));
            requestAnimationFrame(() => setShellHeight());
          });

          if (input instanceof HTMLSelectElement) {
            input.addEventListener('change', () => {
              updateFieldState(input, true);
              const currentPanel = input.closest<HTMLElement>('.quote-step');
              const hasStepErrors = currentPanel?.querySelector('.quote-field-error[aria-hidden="false"]');
              setGlobalErrorVisibility(Boolean(hasStepErrors));
              requestAnimationFrame(() => setShellHeight());
            });
          }
        }
      );

      window.addEventListener('resize', () => setShellHeight(currentStep));

      showStep(1);
      requestAnimationFrame(() => setShellHeight(1));
    });
  }

  // Run on first load
  initQuoteForms();

  // Re-run if view transitions are used later
  document.addEventListener('astro:after-swap', initQuoteForms);
</script>
