---
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import dividerImage from '@/assets/divider-line.png';
import Button from '@/components/ui/Button.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import serviceRoofingImg from '@/assets/services/service-roofing.png';
import serviceSidingImg from '@/assets/services/service-siding.png';
import serviceGuttersImg from '@/assets/services/service-gutter.png';
import serviceRoofImg from '@/assets/services/service-roof.png';
import serviceRoofShade from '@/assets/services/service-roof-shade.png';
import NoiseBg from '@/components/NoiseBg.astro';
import sunflow from '@/assets/sunflow.avif';
import popularBadge from '@/assets/popular-badge.png';
import { marked } from 'marked';
import { Icon } from 'astro-icon/components';
import BadgeTitle from '../BadgeTitle.astro';

const dividerImageOp = await getImage({
  src: dividerImage,
  width: 1500,
  height: 80,
});

const rawHeadline = `Complete Roofing \ Solutions for Colorado Homes`;
const headline = await marked.parse(rawHeadline);

interface ServiceButton {
  label: string;
  href: string;
}

interface VisualService {
  title: string;
  description: string;
  image: ImageMetadata;
  imageAlt: string;
  buttons: (string | ServiceButton)[];
  class?: string;
  premium?: boolean;
}

const visualServices: VisualService[] = [
  {
    title: 'Siding',
    description:
      'We install durable vinyl and steel siding — authorized Westlake Royal products, built to handle Colorado’s hail and UV.',
    image: serviceRoofingImg,
    imageAlt: 'Siding',
    buttons: [
      { label: 'Vinyl Siding', href: '/services/siding-co' },
      { label: 'Steel Siding', href: '/services/siding-co' },
    ],
    class: 'md:[&_img[data-slot=thumbnail]]:scale-150',
  },
  {
    title: 'Roofing',
    description: 'We offer a complete line up of professional roofing services including inspections, replacements, and repairs.',
    image: serviceSidingImg,
    imageAlt: 'Roofing',
    buttons: [
      { label: 'Shingle Roofing', href: '/services/residential-roofing-co' },
      { label: 'Metal Roofing', href: '/services/metal-roofing-co' },
    ],
    class: 'lg:scale-110 md:[&_img[data-slot=thumbnail]]:scale-150',
  },
  {
    title: 'Gutters',
    description:
      'Properly installed gutters protect your foundation and landscaping — keeping water moving away from your home through every Colorado winter.',
    image: serviceGuttersImg,
    imageAlt: 'Gutters',
    buttons: [
      { label: 'Seamless Gutters', href: '/services/gutters-co' },
      { label: 'Gutter Guards', href: '/services/gutters-co' },
    ],
    class: 'md:[&_img[data-slot=thumbnail]]:scale-150',
  },
  {
    title: 'Stone Coated Roofing',
    description:
      'We install stone-coated steel panels that replicate the look of shake or tile — with a 50-year warranty, Class 4 hail protection warranted to 2½” diameter, and 120 mph wind resistance built for Colorado’s Front Range.',
    image: serviceRoofShade,
    imageAlt: 'Stone Coated Roofing',
    buttons: ['+ 50-Year Limited Warranty', '+ 120 MPH Wind Rated', '+ Class 4 Impact Rated'],
    class: 'border-gradient h-full w-full md:min-h-[480px]',
    premium: true,
  },
  {
    title: 'Concrete Tile Roofs',
    description:
      'We install Newpoint™ concrete tile roofs that bring architectural permanence to Colorado homes — with a fully transferable lifetime warranty, Class A fire rating, and 50–100 year performance potential.',
    image: serviceRoofImg,
    imageAlt: 'Concrete Tile Roofs',
    buttons: ['+ Limited Lifetime Warranty', '+ Class A Fire Rated', '+ Class 3 & 4 Hail Options'],
    class: 'border-gradient h-full md:min-h-[480px]',
    premium: true,
  },
];

const primaryServices = visualServices.filter(service => !service.premium);
const premiumServices = visualServices.filter(service => service.premium);
const mobileStackServices = [
  primaryServices.find(service => service.title === 'Roofing'),
  primaryServices.find(service => service.title === 'Siding'),
  primaryServices.find(service => service.title === 'Gutters'),
  ...premiumServices,
].filter(Boolean) as VisualService[];
---

<NoiseBg class="relative overflow-x-hidden px-0 py-20">
  <div class="">
    <div
      class="absolute inset-0 top-0 left-0 flex h-20 w-full items-center justify-center"
      style={`
          background-image: url(${dividerImageOp.src});
          background-repeat: no-repeat;
          background-position: center;
      `}
    >
    </div>

    <div class="z-10 container space-y-12 py-8 lg:py-12">
      <!-- Heading Content -->
      <div class="grid grid-cols-1 items-start gap-8 lg:grid-cols-2 lg:items-start lg:gap-x-12">
        <BadgeTitle badge="Our Services" title={headline} />

        <div class="flex flex-col items-start gap-y-4 lg:items-end lg:text-right">
          <Button variant="primary" size="md" class="w-fit sm:w-auto" href="/services">View All Services</Button>
          <div class="max-w-[500px] text-white/70">
            From roof replacements and storm damage repairs to siding, gutters, and full exterior restoration — we
            handle it all. Every project backed by our lifetime workmanship warranty and veteran-owned commitment to
            quality.
          </div>
        </div>
      </div>

      <!-- Services -->
      <div class="flex flex-col items-center space-y-8 px-4 md:space-y-12 lg:space-y-16 lg:px-16">
        <div class="services-stack-shell w-full md:hidden">
          <div class="flex w-full flex-col items-center gap-y-4">
            <services-cards-stack class="services-cards-stack swiper block w-full max-w-[292px]">
              <div class="swiper-wrapper">
                {
                  mobileStackServices.map(service => (
                    <div class="swiper-slide group/swiper-slide h-full rounded-3xl! bg-[#1A1A1A]">
                      <div class:list={['relative h-full rounded-3xl bg-[#1A1A1A]', service.premium && 'group/premium-card']}>
                        {
                          service.premium && (
                            <Image
                              src={popularBadge}
                              alt="Popular"
                              class="absolute top-3 left-3 z-10 w-14 transition-transform duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover/premium-card:scale-[1.06]"
                            />
                          )
                        }
                        <ServiceCard
                          title={service.title}
                          description={service.description}
                          image={service.image}
                          imageAlt={service.imageAlt}
                          buttons={service.buttons}
                          class={service.class}
                          compactMobile={true}
                        />
                      </div>
                    </div>
                  ))
                }
              </div>
            </services-cards-stack>

            <div class="flex items-center gap-x-2">
              <button
                type="button"
                class="services-stack-prev hover:bg-primary hover:text-inverted flex h-10 w-10 items-center justify-center rounded-full bg-[#1A1A1A] text-white transition-colors duration-200"
                aria-label="Previous service"
              >
                <Icon name="chevron-left" size={16} />
              </button>
              <button
                type="button"
                class="services-stack-next hover:bg-primary hover:text-inverted flex h-10 w-10 items-center justify-center rounded-full bg-[#1A1A1A] text-white transition-colors duration-200"
                aria-label="Next service"
              >
                <Icon name="chevron-right" size={16} />
              </button>
            </div>
          </div>
        </div>

        <div class="hidden md:grid md:grid-cols-2 md:gap-6 lg:grid-cols-3 lg:gap-8">
          {
            primaryServices.map(service => (
              <ServiceCard
                title={service.title}
                description={service.description}
                image={service.image}
                imageAlt={service.imageAlt}
                buttons={service.buttons}
                class={service.class}
              />
            ))
          }
        </div>

        <div class="hidden w-full max-w-[950px] rounded-3xl border-radial md:block">
          <div class="grid grid-cols-1 gap-6 rounded-3xl p-2 lg:grid-cols-2 lg:gap-x-3">
            {
              premiumServices.map(service => (
                <div class="group/premium-card relative h-full">
                  <Image
                    src={popularBadge}
                    alt="Popular"
                    class="absolute top-2 left-2 z-10 w-20 transition-transform duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover/premium-card:scale-[1.06] lg:w-24"
                  />
                  <ServiceCard
                    title={service.title}
                    description={service.description}
                    image={service.image}
                    imageAlt={service.imageAlt}
                    buttons={service.buttons}
                    class={service.class}
                  />
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 gap-6 pt-4 pb-16 md:pt-10 lg:grid-cols-2 lg:gap-3 lg:pt-16">
        <div class="border-radial group/service-panel flex h-full flex-col rounded-[10px] p-6 transition-colors duration-300 ease-out hover:bg-white/[0.02]">
          <div class="space-y-3">
            <div class="flex items-center gap-x-2.5">
              <Icon
                name="storm"
                class="text-primary size-10 transition-colors duration-300 ease-out group-hover/service-panel:text-[#f0bf33]"
              />
              <span class="text-xl transition-colors duration-300 ease-out group-hover/service-panel:text-primary">
                Storm Damage Repair
              </span>
            </div>
            <div class="pb-3 text-white/80 transition-colors duration-300 ease-out group-hover/service-panel:text-white/90">
              After a hail storm, most homeowners don't know what they're owed. We document the damage, coordinate with your adjuster, and handle the paperwork — so you get the roof you deserve.
            </div>
          </div>
          <Button
            variant="link"
            class="mt-auto self-start px-0 pt-6 underline underline-offset-4 transition-colors duration-300 ease-out group-hover/service-panel:text-primary"
            href="/services/storm-damage-repair-co"
          >
            <svg width="13" height="16" viewBox="0 0 13 16" fill="none">
              <path
                d="M12.361 8.27675L0.503906 14.866C0.367002 14.9434 0.249442 14.9523 0.151228 14.8928C0.0530134 14.8333 0.00390625 14.7262 0.00390625 14.5714V1.42853C0.00390625 1.27377 0.0530134 1.16663 0.151228 1.10711C0.249442 1.04758 0.367002 1.05651 0.503906 1.13389L12.361 7.72318C12.498 7.80056 12.5664 7.89282 12.5664 7.99996C12.5664 8.10711 12.498 8.19937 12.361 8.27675Z"
                fill="white"></path>
            </svg>

            Learn More
          </Button>
        </div>

        <div class="border-radial group/service-panel flex h-full flex-col rounded-[10px] p-6 transition-colors duration-300 ease-out hover:bg-white/[0.02]">
          <div class="space-y-3">
            <div class="flex items-center gap-x-2.5">
              <Icon
                name="calculate-doller"
                class="text-primary size-10 transition-colors duration-300 ease-out group-hover/service-panel:text-[#f0bf33]"
              />
              <span class="text-xl transition-colors duration-300 ease-out group-hover/service-panel:text-primary">
                Flexible Financing
              </span>
            </div>
            <div class="pb-3 text-white/80 transition-colors duration-300 ease-out group-hover/service-panel:text-white/90">
              Choose 0% promotional financing, fixed APR options, or long-term plans through Service Finance and Wisetack.
              Premium roof upgrades from as low as $99 per month.
            </div>
          </div>
          <Button
            variant="link"
            class="mt-auto self-start px-0 pt-6 underline underline-offset-4 transition-colors duration-300 ease-out group-hover/service-panel:text-primary"
            href="/financing"
          >
            <svg width="13" height="16" viewBox="0 0 13 16" fill="none">
              <path
                d="M12.361 8.27675L0.503906 14.866C0.367002 14.9434 0.249442 14.9523 0.151228 14.8928C0.0530134 14.8333 0.00390625 14.7262 0.00390625 14.5714V1.42853C0.00390625 1.27377 0.0530134 1.16663 0.151228 1.10711C0.249442 1.04758 0.367002 1.05651 0.503906 1.13389L12.361 7.72318C12.498 7.80056 12.5664 7.89282 12.5664 7.99996C12.5664 8.10711 12.498 8.19937 12.361 8.27675Z"
                fill="white"></path>
            </svg>

            Check Financing Options
          </Button>
        </div>
      </div>
    </div>
  </div>

  <Image
    src={sunflow}
    alt="Sunflow"
    class="pointer-events-none absolute bottom-0 left-0 w-full rotate-180 opacity-10"
  />

  <!-- Divider shape -->
  <div
    class="absolute right-0 bottom-0 left-0 flex h-20 w-full items-center justify-center"
    style={`
          background-image: url(${dividerImageOp.src});
          background-repeat: no-repeat;
          background-position: center;
      `}
  >
  </div>
</NoiseBg>

<script>
  import Swiper from 'swiper';
  import { Navigation, EffectCards } from 'swiper/modules';

  import 'swiper/css';
  import 'swiper/css/effect-cards';

  class ServicesCardsStack extends HTMLElement {
    private swiperInstance: Swiper | null = null;

    connectedCallback() {
      if (this.swiperInstance) return;

      const container = this.parentElement;
      const nextEl = container?.querySelector('.services-stack-next') as HTMLElement | null;
      const prevEl = container?.querySelector('.services-stack-prev') as HTMLElement | null;

      this.swiperInstance = new Swiper(this, {
        modules: [Navigation, EffectCards],
        effect: 'cards',
        grabCursor: true,
        initialSlide: 0,
        touchStartPreventDefault: false,
        touchMoveStopPropagation: false,
        touchReleaseOnEdges: true,
        threshold: 8,
        cardsEffect: {
          perSlideOffset: 10,
          perSlideRotate: 0,
          slideShadows: false,
        },
        navigation: {
          nextEl,
          prevEl,
        },
      });
    }

    disconnectedCallback() {
      this.swiperInstance?.destroy();
      this.swiperInstance = null;
    }
  }

  if (!customElements.get('services-cards-stack')) {
    customElements.define('services-cards-stack', ServicesCardsStack);
  }
</script>

<style>
  .services-stack-shell {
    overflow-x: clip;
  }

  .services-cards-stack {
    overflow: visible;
    touch-action: pan-y;
  }

  .services-cards-stack .swiper-wrapper {
    min-height: 430px;
  }
</style>
