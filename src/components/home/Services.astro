---
import { Image, getImage } from 'astro:assets';
import dividerImage from '@/assets/divider-line.png';
import Button from '@/components/ui/Button.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import serviceRoofingImg from '@/assets/services/service-roofing.png';
import serviceSidingImg from '@/assets/services/service-siding.png';
import serviceGuttersImg from '@/assets/services/service-gutter.png';
import serviceRoofImg from '@/assets/services/service-roof.png';
import serviceRoofShade from '@/assets/services/service-roof-shade.png';
import NoiseBg from '@/components/NoiseBg.astro';
import sunflow from '@/assets/sunflow.avif';
import popularBadge from '@/assets/popular-badge.png';
import { marked } from 'marked';
import { Icon } from 'astro-icon/components';
import BadgeTitle from '../BadgeTitle.astro';

const dividerImageOp = await getImage({
  src: dividerImage,
  width: 1500,
  height: 80,
});

const rawHeadline = `Complete Roofing \ Solutions for Colorado Homes`;
const headline = await marked.parse(rawHeadline);
---

<NoiseBg class="relative px-0 py-20">
  <div class="">
    <div
      class="absolute inset-0 top-0 left-0 flex h-20 w-full items-center justify-center"
      style={`
          background-image: url(${dividerImageOp.src});
          background-repeat: no-repeat;
          background-position: center;
      `}
    >
    </div>

    <div class="z-10 container space-y-12 py-8 lg:py-12">
      <!-- Heading Content -->
      <div class="grid grid-cols-1 items-start gap-8 lg:grid-cols-2 lg:items-start lg:gap-x-12">
        <BadgeTitle badge="Our Services" title={headline} />

        <div class="flex flex-col items-start gap-y-4 lg:items-end lg:text-right">
          <Button variant="primary" size="md" class="w-fit sm:w-auto" href="/services">View All Services</Button>
          <div class="max-w-[500px] text-white/70">
            From roof replacements and storm damage repairs to siding, gutters, and full exterior restoration — we
            handle it all. Every project backed by our lifetime workmanship warranty and veteran-owned commitment to
            quality.
          </div>
        </div>
      </div>

      <!-- Services -->
      <div class="flex flex-col items-center space-y-12 px-4 lg:space-y-16 lg:px-16">
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3 lg:gap-8">
          <ServiceCard
            title="Siding"
            description="We install durable vinyl and steel siding — authorized Westlake Royal products, built to handle Colorado’s hail and UV."
            image={serviceRoofingImg}
            imageAlt="Siding"
            buttons={[
              { label: 'Vinyl Siding', href: '/services/siding-installation' },
              { label: 'Steel Siding', href: '/services/siding-installation' },
            ]}
            class="[&_img[data-slot=thumbnail]]:scale-150"
          />

          <ServiceCard
            title="Roofing"
            description="We offer a complete line up of professional roofing services including inspections, replacements, and repairs."
            image={serviceSidingImg}
            imageAlt="Roofing"
            buttons={[
              { label: 'Shingle Roofing', href: '/services/residential-roofing' },
              { label: 'Metal Roofing', href: '/services/metal-roofing' },
            ]}
            class="lg:scale-110 [&_img[data-slot=thumbnail]]:scale-150"
          />

          <ServiceCard
            title="Gutters"
            description="Properly installed gutters protect your foundation and landscaping — keeping water moving away from your home through every Colorado winter."
            image={serviceGuttersImg}
            imageAlt="Gutters"
            buttons={[
              { label: 'Seamless Gutters', href: '/services/gutters-and-drainage' },
              { label: 'Gutter Guards', href: '/services/gutters-and-drainage' },
            ]}
            class="[&_img[data-slot=thumbnail]]:scale-150"
          />
        </div>

        <div class="border-radial w-full max-w-[950px] rounded-3xl">
          <div class="grid grid-cols-1 gap-6 rounded-3xl p-2 lg:grid-cols-2 lg:gap-x-3">
            <div class="relative h-full">
              <Image src={popularBadge} alt="Popular" class="absolute top-2 left-2 z-10 w-20 lg:w-24" />
              <ServiceCard
                title="Stone Coated Roofing"
                description="We install stone-coated steel panels that replicate the look of shake or tile — with a 50-year warranty, Class 4 hail protection warranted to 2½” diameter, and 120 mph wind resistance built for Colorado’s Front Range."
                image={serviceRoofShade}
                imageAlt="Stone Coated Roofing"
                buttons={[
                  '+ 50-Year Limited Warranty',
                  '+ 120 MPH Wind Rated',
                  '+ Class 4 Impact Rated',
                ]}
                class="border-gradient h-full min-h-[480px] w-full"
              />
            </div>

            <div class="relative h-full">
              <Image src={popularBadge} alt="Popular" class="absolute top-2 left-2 z-10 w-20 lg:w-24" />
              <ServiceCard
                title="Concrete Tile Roofs"
                description="We install Newpoint™ concrete tile roofs that bring architectural permanence to Colorado homes — with a fully transferable lifetime warranty, Class A fire rating, and 50–100 year performance potential."
                image={serviceRoofImg}
                imageAlt="Concrete Tile Roofs"
                buttons={[
                  '+ Limited Lifetime Warranty',
                  '+ Class A Fire Rated',
                  '+ Class 3 & 4 Hail Options',
                ]}
                class="border-gradient h-full min-h-[480px]"
              />
            </div>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 gap-6 pt-12 pb-16 lg:grid-cols-2 lg:gap-3 lg:pt-16">
        <div class="border-radial flex h-full flex-col rounded-[10px] p-6">
          <div class="space-y-3">
            <div class="flex items-center gap-x-2.5">
              <Icon name="storm" class="text-primary size-10" />
              <span class="text-xl"> Storm Damage Repair </span>
            </div>
            <div class="pb-3">
              After a hail storm, most homeowners don't know what they're owed. We document the damage, coordinate with your adjuster, and handle the paperwork — so you get the roof you deserve.
            </div>
          </div>
          <Button variant="link" class="mt-auto self-start px-0 pt-6 underline underline-offset-4" href="/services/storm-damage-repair">
            <svg width="13" height="16" viewBox="0 0 13 16" fill="none">
              <path
                d="M12.361 8.27675L0.503906 14.866C0.367002 14.9434 0.249442 14.9523 0.151228 14.8928C0.0530134 14.8333 0.00390625 14.7262 0.00390625 14.5714V1.42853C0.00390625 1.27377 0.0530134 1.16663 0.151228 1.10711C0.249442 1.04758 0.367002 1.05651 0.503906 1.13389L12.361 7.72318C12.498 7.80056 12.5664 7.89282 12.5664 7.99996C12.5664 8.10711 12.498 8.19937 12.361 8.27675Z"
                fill="white"></path>
            </svg>

            Learn More
          </Button>
        </div>

        <div class="border-radial flex h-full flex-col rounded-[10px] p-6">
          <div class="space-y-3">
            <div class="flex items-center gap-x-2.5">
              <Icon name="calculate-doller" class="text-primary size-10" />
              <span class="text-xl"> Flexible Financing </span>
            </div>
            <div class="pb-3">
              Choose 0% promotional financing, fixed APR options, or long-term plans through Service Finance and Wisetack.
              Premium roof upgrades from as low as $99 per month.
            </div>
          </div>
          <Button variant="link" class="mt-auto self-start px-0 pt-6 underline underline-offset-4" href="/services/storm-damage-repair">
            <svg width="13" height="16" viewBox="0 0 13 16" fill="none">
              <path
                d="M12.361 8.27675L0.503906 14.866C0.367002 14.9434 0.249442 14.9523 0.151228 14.8928C0.0530134 14.8333 0.00390625 14.7262 0.00390625 14.5714V1.42853C0.00390625 1.27377 0.0530134 1.16663 0.151228 1.10711C0.249442 1.04758 0.367002 1.05651 0.503906 1.13389L12.361 7.72318C12.498 7.80056 12.5664 7.89282 12.5664 7.99996C12.5664 8.10711 12.498 8.19937 12.361 8.27675Z"
                fill="white"></path>
            </svg>

            Check Financing Options
          </Button>
        </div>
      </div>
    </div>
  </div>

  <Image
    src={sunflow}
    alt="Sunflow"
    class="pointer-events-none absolute bottom-0 left-0 w-full rotate-180 opacity-10"
  />

  <!-- Divider shape -->
  <div
    class="absolute right-0 bottom-0 left-0 flex h-20 w-full items-center justify-center"
    style={`
          background-image: url(${dividerImageOp.src});
          background-repeat: no-repeat;
          background-position: center;
      `}
  >
  </div>
</NoiseBg>
