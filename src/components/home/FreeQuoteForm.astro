---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import Button from '@/components/ui/Button.astro';
import InputGroup from '@/components/ui/input-group/InputGroup.astro';
import InputGroupInput from '@/components/ui/input-group/InputGroupInput.astro';
import InputGroupAddon from '@/components/ui/input-group/InputGroupAddon.astro';
import NoiseBg from '@/components/NoiseBg.astro';
import heroShield from '@/assets/hero-shield.png';
---

<div
  class="from-primary/50 to-secondary/50 after:form-transparent after:via-primary relative container -mt-30 rounded-[12px] bg-linear-to-b p-px after:absolute after:-inset-x-px after:bottom-0 after:z-10 after:h-0.5 after:bg-linear-to-r after:to-transparent after:opacity-50 after:content-['']"
>
  <NoiseBg class="relative z-10 rounded-[12px] bg-[#212121]">
    <Image src={heroShield} alt="Hero Shield" width={100} height={100} class="mx-auto -mt-20" />
    <div class="[&_span]:text-primary backdrop-blue-[24px] flex w-full flex-col items-center gap-y-8 p-10">
      <h3>Get Your <span> FREE</span> Quote</h3>

      <form class="flex w-full items-center gap-x-2.5">
        <InputGroup class="h-[52px] border-white/15 px-4 py-4">
          <InputGroupInput id="name-input" type="text" placeholder="Name" />
          <InputGroupAddon align="inline-end">
            <Icon name="contact" />
          </InputGroupAddon>
        </InputGroup>

        <InputGroup class="h-[52px] border-white/15 px-4 py-4">
          <InputGroupInput id="phone-input" type="tel" placeholder="Phone" />
          <InputGroupAddon align="inline-end">
            <Icon name="call" />
          </InputGroupAddon>
        </InputGroup>

        <InputGroup class="h-[52px] border-white/15 px-4 py-4">
          <InputGroupInput id="email-input" type="email" placeholder="Email" />
          <InputGroupAddon align="inline-end">
            <Icon name="mail2" />
          </InputGroupAddon>
        </InputGroup>

        <InputGroup class="h-[52px] border-white/15 px-4 py-4">
          <InputGroupInput id="assist-input" type="text" placeholder="How can we assist you?" />
          <InputGroupAddon align="inline-end">
            <Icon name="chat" />
          </InputGroupAddon>
        </InputGroup>

        <Button class="h-[52px] px-8 py-4">Submit</Button>
      </form>
    </div>
  </NoiseBg>
</div>
