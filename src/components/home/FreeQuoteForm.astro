---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import Button from '@/components/ui/Button.astro';
import InputGroup from '@/components/ui/input-group/InputGroup.astro';
import InputGroupInput from '@/components/ui/input-group/InputGroupInput.astro';
import InputGroupAddon from '@/components/ui/input-group/InputGroupAddon.astro';
import NoiseBg from '@/components/NoiseBg.astro';
import heroShield from '@/assets/hero-shield.png';
---

<div class="container pt-8">
  <div class="border-radial relative -mt-10 rounded-[12px] p-px lg:-mt-30">
    <NoiseBg class="bg-testim testimonial-bg-noise relative z-10 rounded-[12px] px-0 backdrop-blur-md">
      <Image
        src={heroShield}
        alt="Hero Shield"
        width={100}
        height={100}
        class="mx-auto -mt-[70px] h-16 w-auto lg:-mt-20 lg:h-24"
        loading="eager"
      />
      <div class="[&_span]:text-primary flex w-full flex-col items-center gap-y-8 p-6 lg:p-10">
        <h3 class="text-2xl font-bold lg:text-3xl">Get Your <span> FREE</span> Quote</h3>

        <form class="flex w-full flex-col items-center gap-4 lg:flex-row lg:gap-x-2.5">
          <InputGroup class="h-[52px] w-full border-white/15 px-4 py-4">
            <InputGroupInput id="name-input" type="text" placeholder="Name" />
            <InputGroupAddon align="inline-end">
              <Icon name="contact" />
            </InputGroupAddon>
          </InputGroup>

          <InputGroup class="h-[52px] w-full border-white/15 px-4 py-4">
            <InputGroupInput id="phone-input" type="tel" placeholder="Phone" />
            <InputGroupAddon align="inline-end">
              <Icon name="call" />
            </InputGroupAddon>
          </InputGroup>

          <InputGroup class="h-[52px] w-full border-white/15 px-4 py-4">
            <InputGroupInput id="email-input" type="email" placeholder="Email" />
            <InputGroupAddon align="inline-end">
              <Icon name="mail2" />
            </InputGroupAddon>
          </InputGroup>

          <InputGroup class="h-[52px] w-full border-white/15 px-4 py-4">
            <InputGroupInput id="assist-input" type="text" placeholder="How can we assist you?" />
            <InputGroupAddon align="inline-end">
              <Icon name="chat" />
            </InputGroupAddon>
          </InputGroup>

          <Button class="h-[52px] w-full px-8 py-4 lg:w-auto">Submit</Button>
        </form>
      </div>
    </NoiseBg>
  </div>
</div>
