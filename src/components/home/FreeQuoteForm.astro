---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import Button from '@/components/ui/Button.astro';
import InputGroup from '@/components/ui/input-group/InputGroup.astro';
import InputGroupInput from '@/components/ui/input-group/InputGroupInput.astro';
import InputGroupAddon from '@/components/ui/input-group/InputGroupAddon.astro';
import NoiseBg from '@/components/NoiseBg.astro';
import heroShield from '@/assets/hero-shield.png';
const ghlSharedWebhookUrl = import.meta.env.GHL_SHARED_WEBHOOK_URL || '';
---

<div class="container pt-8">
  <div class="border-radial relative -mt-10 rounded-[12px] p-px lg:-mt-40">
    <div class="testimonial-bg-noise relative z-10 space-y-8 rounded-[12px] px-6 pt-10 pb-6 backdrop-blur-md lg:px-8">
      <Image
        src={heroShield}
        alt="Black Knight Roofing shield logo"
        width={100}
        height={100}
        class="absolute -top-10 left-1/2 mx-auto h-16 w-auto -translate-x-1/2 lg:h-24"
        loading="eager"
      />
      <div class="[&_h3_span]:text-primary flex w-full flex-col items-center gap-y-4">
        <h3>Get Your <span> FREE</span> Quote</h3>

        <!-- Client-side Success Message -->
        <div id="free-quote-success" class="hidden flex-col items-center justify-center gap-y-4 py-8 text-center">
          <div class="bg-primary/20 border-primary/40 flex size-16 items-center justify-center rounded-full border">
            <Icon name="circle-tick" class="text-primary size-8" />
          </div>
          <h3 class="text-xl font-semibold text-white">Request Sent!</h3>
          <p class="text-sm text-neutral-400">We'll be in touch with your free quote soon.</p>
        </div>

        <form
          id="hero-free-quote-form"
          class="hero-free-quote-form flex w-full flex-col items-start gap-4 lg:flex-row lg:items-start lg:gap-x-3"
          novalidate
          data-ghl-webhook-url={ghlSharedWebhookUrl}
        >
          <div class="hero-free-quote-field w-full">
            <InputGroup class="hero-free-quote-group h-[52px] w-full border-white/15 px-4 py-4">
              <InputGroupInput id="name-input" name="name" type="text" placeholder="Name" autocomplete="name" />
              <InputGroupAddon align="inline-end">
                <Icon name="contact" />
              </InputGroupAddon>
            </InputGroup>
            <p class="hero-free-quote-error mt-2 hidden text-xs font-medium text-[#FF8B8B]">Please enter your name.</p>
          </div>

          <div class="hero-free-quote-field w-full">
            <InputGroup class="hero-free-quote-group h-[52px] w-full border-white/15 px-4 py-4">
              <InputGroupInput
                id="phone-input"
                name="phone"
                type="tel"
                placeholder="Phone"
                autocomplete="tel"
                inputmode="tel"
              />
              <InputGroupAddon align="inline-end">
                <Icon name="call" />
              </InputGroupAddon>
            </InputGroup>
            <p class="hero-free-quote-error mt-2 hidden text-xs font-medium text-[#FF8B8B]">
              Please enter a valid phone number.
            </p>
          </div>

          <div class="hero-free-quote-field w-full">
            <InputGroup class="hero-free-quote-group h-[52px] w-full border-white/15 px-4 py-4">
              <InputGroupInput
                id="email-input"
                name="email"
                type="email"
                placeholder="Email"
                autocomplete="email"
                inputmode="email"
              />
              <InputGroupAddon align="inline-end">
                <Icon name="mail2" />
              </InputGroupAddon>
            </InputGroup>
            <p class="hero-free-quote-error mt-2 hidden text-xs font-medium text-[#FF8B8B]">
              Please enter a valid email address.
            </p>
          </div>

          <div class="hero-free-quote-field w-full">
            <InputGroup class="hero-free-quote-group h-[52px] w-full border-white/15 px-4 py-4">
              <InputGroupInput id="assist-input" name="assist" type="text" placeholder="How can we assist you?" />
              <InputGroupAddon align="inline-end">
                <Icon name="chat" />
              </InputGroupAddon>
            </InputGroup>
            <p class="hero-free-quote-error mt-2 hidden text-xs font-medium text-[#FF8B8B]">
              Please tell us how we can assist you.
            </p>
          </div>

          <div class="w-full lg:w-auto lg:self-start">
            <Button type="submit" class="h-[52px] w-full px-8 py-4 lg:w-auto" data-submit-btn>
              <span data-submit-label>Submit</span>
              <svg
                data-submit-spinner
                class="hidden size-4 animate-spin"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
              >
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
              </svg>
            </Button>
          </div>
        </form>

        <p class="max-w-5xl text-center text-xs leading-5 text-white/60">
          By submitting this form, you agree that Black Knight Roofing may contact you about your request. See our
          <a href="/privacy-policy" class="text-primary font-semibold transition-colors hover:text-white">
            Privacy Policy
          </a>
          for details.
        </p>
      </div>
    </div>
  </div>
</div>

<script lang="ts">
  const WEBHOOK_TIMEOUT_MS = 8000;
  const WEBHOOK_RETRY_DELAY_MS = 700;

  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  function digitsOnly(value) {
    return value.replace(/\D/g, '');
  }

  function getFieldMessage(name, value) {
    const trimmed = value.trim();

    if (name === 'name') {
      return trimmed.length >= 2 ? '' : 'Please enter your name.';
    }

    if (name === 'phone') {
      return digitsOnly(trimmed).length >= 10 ? '' : 'Please enter a valid phone number.';
    }

    if (name === 'email') {
      return EMAIL_RE.test(trimmed) ? '' : 'Please enter a valid email address.';
    }

    if (name === 'assist') {
      return trimmed.length >= 5 ? '' : 'Please tell us how we can assist you.';
    }

    return '';
  }

  function setFieldState(input, message, forceShowError = false) {
    const wrapper = input.closest('.hero-free-quote-field');
    const group = wrapper?.querySelector('[data-slot="input-group"]');
    const error = wrapper?.querySelector('.hero-free-quote-error');
    const hasValue = input.value.trim().length > 0;
    const isValid = hasValue && !message;

    input.setAttribute('aria-invalid', message ? 'true' : 'false');

    group?.classList.remove('border-[#2C8A4B]', 'border-[#C44E4E]');

    if (message && (hasValue || forceShowError)) {
      group?.classList.add('border-[#C44E4E]');
      error?.classList.remove('hidden');
      if (error) error.textContent = message;
    } else {
      error?.classList.add('hidden');
    }

    if (isValid) {
      group?.classList.add('border-[#2C8A4B]');
    }

    return isValid;
  }

  function validateField(input, forceShowError = false) {
    const message = getFieldMessage(input.name, input.value);
    return setFieldState(input, message, forceShowError);
  }

  const wait = delayMs =>
    new Promise(resolve => {
      window.setTimeout(resolve, delayMs);
    });

  const getAttributionData = () => {
    const params = new URLSearchParams(window.location.search);
    return {
      utmSource: params.get('utm_source') ?? '',
      utmMedium: params.get('utm_medium') ?? '',
      utmCampaign: params.get('utm_campaign') ?? '',
      utmContent: params.get('utm_content') ?? '',
      utmTerm: params.get('utm_term') ?? '',
      fbclid: params.get('fbclid') ?? '',
      gclid: params.get('gclid') ?? '',
      msclkid: params.get('msclkid') ?? '',
      ttclid: params.get('ttclid') ?? '',
    };
  };

  const postWebhookPayload = async (url, payload) => {
    const controller = new AbortController();
    const timeoutId = window.setTimeout(() => controller.abort(), WEBHOOK_TIMEOUT_MS);

    try {
      const response = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
        signal: controller.signal,
      });

      if (!response.ok) {
        throw new Error(`Webhook submission failed with status ${response.status}`);
      }
    } finally {
      window.clearTimeout(timeoutId);
    }
  };

  const submitWebhookWithRetry = async (url, payload) => {
    try {
      await postWebhookPayload(url, payload);
      return;
    } catch (error) {
      console.error('GHL webhook attempt 1 failed:', error);
    }

    await wait(WEBHOOK_RETRY_DELAY_MS);
    await postWebhookPayload(url, payload);
  };

  function initHeroFreeQuoteForms() {
    const forms = document.querySelectorAll<HTMLFormElement>('.hero-free-quote-form');

    forms.forEach(form => {
      if (form.dataset.initialized === 'true') return;
      form.dataset.initialized = 'true';
      form.setAttribute('action', 'javascript:void(0)');

      const inputs = Array.from(form.querySelectorAll('input'));

      inputs.forEach(input => {
        input.addEventListener('focus', () => {
          const group = input.closest('.hero-free-quote-group');
          group?.classList.add('border-white/30', 'ring-1', 'ring-white/10');
        });

        input.addEventListener('blur', () => validateField(input));
        input.addEventListener('blur', () => {
          const group = input.closest('.hero-free-quote-group');
          group?.classList.remove('border-white/30', 'ring-1', 'ring-white/10');
        });
        input.addEventListener('input', () => {
          if (input.getAttribute('aria-invalid') === 'true' || input.value.trim().length > 0) {
            validateField(input);
          }
        });
      });

      form.addEventListener('submit', async event => {
        event.preventDefault();
        event.stopPropagation();
        let firstInvalid = null;
        let formIsValid = true;

        inputs.forEach(input => {
          const valid = validateField(input, true);
          if (!valid) {
            formIsValid = false;
            if (!firstInvalid) firstInvalid = input;
          }
        });

        if (!formIsValid) {
          firstInvalid?.focus();
          return;
        }

        // Valid — show loading state
        const btn = form.querySelector<HTMLButtonElement>('[data-submit-btn]');
        const label = form.querySelector<HTMLElement>('[data-submit-label]');
        const spinner = form.querySelector<SVGElement>('[data-submit-spinner]');
        const successMsg = document.getElementById('free-quote-success');

        if (btn) btn.disabled = true;
        if (label) label.textContent = 'Sending…';
        if (spinner) spinner.classList.remove('hidden');

        try {
          const webhookUrl = form.dataset.ghlWebhookUrl ?? '';
          if (!webhookUrl) throw new Error('GHL_SHARED_WEBHOOK_URL is missing.');

          const formData = new FormData(form);
          const values = Object.fromEntries(
            Array.from(formData.entries()).map(([key, value]) => [key, typeof value === 'string' ? value.trim() : ''])
          );

          const payload = {
            ...values,
            formType: 'free_quote',
            formName: 'hero_free_quote_form',
            submissionChannel: 'ghl_shared_webhook',
            landingPage: window.location.pathname,
            pagePath: window.location.pathname,
            submittedAt: new Date().toISOString(),
            timezone: Intl.DateTimeFormat().resolvedOptions().timeZone || '',
            currentUrl: window.location.href,
            referrer: document.referrer || '',
            ...getAttributionData(),
          };

          await submitWebhookWithRetry(webhookUrl, payload);

          // Show success state
          form.classList.add('hidden');
          successMsg?.classList.remove('hidden');
          successMsg?.classList.add('flex');
        } catch (err) {
          console.error('Submission error:', err);
          if (btn) btn.disabled = false;
          if (label) label.textContent = 'Retry';
          if (spinner) spinner.classList.add('hidden');
          alert('There was a problem sending your request. Please try again.');
        }
      });
    });
  }

  initHeroFreeQuoteForms();
  document.addEventListener('astro:after-swap', initHeroFreeQuoteForms);
</script>
