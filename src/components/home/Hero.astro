---
import { getImage, Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import Button from '@/components/ui/Button.astro';
import EstimateButton from '@/components/EstimateButton.astro';
import WeatherWidget from './WeatherWidget.astro';
import heroBgImage from '@/assets/home-hero-fallback.avif';
import trustBadgeSSL from '@/assets/trust-badge-ssl.png';
import heroPerson from '@/assets/hero-person.avif';
import noiseBg from '@/assets/noises.avif';
import heroLeftShape from '@/assets/hero-left-shape.avif';
import FreeQuoteForm from './FreeQuoteForm.astro';
import SocialProof from '@/components/ui/SocialProof.astro';

const noiseBgOp = await getImage({ src: noiseBg, format: 'avif' });
---

<section class="relative h-fit overflow-hidden lg:max-h-[800px]">
  <!-- Background Video/Image Container -->
  <div class="absolute inset-0 -z-10 h-full w-full overflow-hidden bg-brand">
    <Image
      id="hero-fallback-image"
      alt=""
      src={heroBgImage}
      width={1536}
      height={1152}
      class="absolute inset-0 h-full w-full object-cover transition-opacity duration-1000"
      fetchpriority="high"
      loading="eager"
    />
    
    <!-- Dark Overlay to ensure text readability -->
    <div class="absolute inset-0 z-10 bg-black/40"></div>

    <div id="hero-video-wrapper" class="absolute inset-0 opacity-0 transition-opacity duration-1000">
      <div id="hero-youtube-player" class="absolute min-h-full min-w-full scale-150" style="top: 50%; left: 50%; transform: translate(-50%, -50%) scale(1.5);"></div>
    </div>
  </div>

  <script is:inline>
    // Load YouTube IFrame API
    if (!window.YT) {
      const tag = document.createElement('script');
      tag.src = "https://www.youtube.com/iframe_api";
      const firstScriptTag = document.getElementsByTagName('script')[0];
      firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);
    }

    let player;
    window.onYouTubeIframeAPIReady = function() {
      player = new YT.Player('hero-youtube-player', {
        videoId: 'hFSEUfyRzrw',
        playerVars: {
          'autoplay': 1,
          'mute': 1,
          'controls': 0,
          'loop': 1,
          'playlist': 'hFSEUfyRzrw',
          'rel': 0,
          'modestbranding': 1,
          'showinfo': 0,
          'iv_load_policy': 3,
          'enablejsapi': 1,
          'disablekb': 1
        },
        events: {
          'onReady': (event) => {
            event.target.mute();
            event.target.playVideo();
          },
          'onStateChange': (event) => {
            if (event.data === YT.PlayerState.PLAYING) {
              // Fade in the video wrapper and hide the fallback image once playing starts
              document.getElementById('hero-video-wrapper').classList.replace('opacity-0', 'opacity-100');
              document.getElementById('hero-fallback-image').classList.add('opacity-0');
            }
          }
        }
      });

      // Seamless loop: seek to 0 just before the video ends to avoid the black flash
      setInterval(() => {
        if (player && typeof player.getCurrentTime === 'function') {
          const duration = player.getDuration();
          const currentTime = player.getCurrentTime();
          if (duration > 0 && (duration - currentTime) < 0.3) {
            player.seekTo(0);
          }
        }
      }, 100);
    };
  </script>

  <!-- Mobile Overlay -->
  <div
    class="pointer-events-none absolute inset-0 top-0 left-0 block h-full w-full bg-[linear-gradient(200deg,rgba(8,42,64,0)_14.45%,#082A40_64.34%,#0D0D0D_97.01%),linear-gradient(to_bottom,rgba(0,0,0,0.8)_15%,rgba(0,0,0,0)_30%,rgba(0,0,0,0)_100%)] lg:hidden"
  >
  </div>

  <!-- Weather widget -->
  <div class="hidden lg:block">
    <WeatherWidget />
  </div>

  <!-- Main Hero Content -->
  <div class="bg-overlay relative">
    <div class="container space-y-6 py-12 lg:py-20">
      <div class="flex flex-col items-stretch gap-y-10 lg:flex-row lg:gap-x-8">
        <div class="relative h-full w-full max-w-[720px] text-white">
          <div class="space-y-8">
            <div class="space-y-8 lg:space-y-6">
              <!-- Hero section title -->
              <div class="space-y-4 text-center lg:text-left">
                <div
                  class="inline-flex items-center justify-center gap-x-1.5 text-[12px] font-semibold lg:flex lg:justify-start lg:text-[16px]"
                >
                  <Icon name="badge-tick" class="text-primary" />
                  <span>Veteran-Owned. Licensed General Contractor. Denver, CO.</span>
                </div>

                <div>
                  <h1 class="font-heading text-4xl leading-tight font-normal md:text-5xl lg:text-6xl lg:leading-16">
                    Colorado&apos;s "Most Trusted" Full-Construction Roofing Company
                  </h1>
                </div>
              </div>

              <!-- Hero section list -->
              <ul class="space-y-4 text-[14px] sm:text-[15px] lg:space-y-3">
                <li class="flex items-start gap-x-4 lg:items-center">
                  <Icon name="shield" size={24} class="shrink-0" />
                  <span class="text-normal flex-1">
                    <strong class="font-semibold text-white">Proud Veteran Owned:</strong>
                    Army veteran & licensed GC — we inspect your whole home, not just the roof.
                  </span>
                </li>

                <li class="flex items-start gap-x-4 lg:items-center">
                  <Icon name="helmet" size={24} class="shrink-0" />
                  <span class="text-normal flex-1">
                    <strong class="font-semibold text-white">Stone-Coated Steel Experts:</strong>
                    We install premium materials most roofers won't — stone-coated steel & concrete tile.
                  </span>
                </li>

                <li class="flex items-start gap-x-4 lg:items-center">
                  <Icon name="star-leaf" size={24} class="shrink-0" />
                  <span class="text-normal flex-1">
                    <strong class="font-semibold text-white">Insurance Claim Specialists + Lifetime Guarantee:</strong>
                    We handle your claim end-to-end, backed by lifetime workmanship & manufacturer warranties.
                  </span>
                </li>
              </ul>

              <!-- CTA Section -->
              <div class="flex flex-col items-center gap-y-4 md:flex-row md:gap-x-4 lg:gap-x-6">
                <EstimateButton href="/contact-us" class="w-fit" />

                <Button
                  variant="link"
                  href="/gallery"
                  class="px-0 pb-0 text-[16px] leading-[24px] font-normal text-white"
                >
                  <Icon name="map" />
                  <span class="border-b border-white">See Our Past Work</span>
                </Button>
              </div>
            </div>

            <SocialProof />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Free Quote Form -->
<FreeQuoteForm />
