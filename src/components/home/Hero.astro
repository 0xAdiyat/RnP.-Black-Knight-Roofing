---
import { getImage, Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import Button from '@/components/ui/Button.astro';
import WeatherWidget from './WeatherWidget.astro';

import heroBgImage from '@/assets/hero-bg.webp';
import trustBadgeSSL from '@/assets/trust-badge-ssl.png';
import heroPerson from '@/assets/hero-person.png';
import noiseBg from '@/assets/noises.avif';
import RatingStars from '@/components/ui/RatingStars.astro';
import bbbLogo from '@/assets/bbb-logo.png';
import heroLeftShape from '@/assets/hero-left-shape.avif';
import FreeQuoteForm from './FreeQuoteForm.astro';

const optimizedHeroBg = await getImage({ src: heroBgImage, width: 1536, height: 1152, format: 'webp' });
const noiseBgOp = await getImage({ src: noiseBg, format: 'avif' });
---

<section class="relative h-fit overflow-hidden lg:max-h-[800px]">
  <!-- Background Image -->
  <Image
    alt="background Image"
    src={optimizedHeroBg.src}
    width={1536}
    height={1152}
    class="absolute -z-10 h-full w-full object-cover"
    fetchpriority="high"
    loading="eager"
  />

  <!-- Hero Left Shape -->
  <Image
    src={heroLeftShape}
    alt="Hero Left Shape"
    width={1209}
    height={837}
    class="absolute top-0 -left-20 -z-10 hidden h-full w-[1309px] lg:block"
    fetchpriority="high"
    loading="eager"
  />

  <!-- Mobile Overlay -->
  <div
    class="absolute inset-0 top-0 left-0 -z-10 block h-full w-full bg-[linear-gradient(200deg,rgba(8,42,64,0)_34.45%,#082A40_64.34%,#0D0D0D_97.01%),linear-gradient(to_bottom,#0d0d0d_5%,rgba(0,0,0,0))] lg:hidden"
  >
  </div>

  <!-- Weather widget -->
  <div class="hidden lg:block">
    <WeatherWidget />
  </div>

  <!-- Main Hero Content -->
  <div class="">
    <div class="container space-y-6 py-12 lg:py-20">
      <div class="flex flex-col items-stretch gap-y-10 lg:flex-row lg:gap-x-8">
        <div class="relative h-full w-full max-w-[720px] text-white">
          <div class="space-y-8">
            <div class="space-y-6">
              <!-- Hero section title -->
              <div class="space-y-4">
                <div class="flex items-start gap-x-1.5 opacity-60 grayscale">
                  <Icon name="badge-tick" class="mt-1" />
                  <span class="text-sm md:text-base"> Veteran-Owned. Licensed General Contractor. Denver, CO.</span>
                </div>

                <div>
                  <h1 class="font-heading text-4xl leading-tight font-normal md:text-5xl lg:text-6xl lg:leading-16">
                    Colorado&apos;s "Most Trusted" Full-Construction Roofing Company
                  </h1>
                </div>
              </div>

              <!-- Hero section list -->
              <ul class="space-y-4 lg:space-y-3">
                <li class="flex items-start gap-x-3 text-[clamp(14px,1.5vw,16px)] lg:items-center lg:gap-x-2">
                  <Icon name="shield" class="size-6 shrink-0 lg:size-9" />
                  <span class="flex-1">
                    <span class="text-primary font-bold lg:font-normal lg:text-white"
                      >Veteran Discipline, Builder Standards:</span
                    > Most roofers just replace shingles. As a licensed general contractor and Army veteran, Adam inspects
                    your whole home — and builds to last.
                  </span>
                </li>

                <li class="flex items-start gap-x-3 lg:items-center lg:gap-x-2">
                  <Icon name="helmet" class="size-6 shrink-0 lg:size-9" />
                  <span class="flex-1">
                    <span class="text-primary font-bold lg:font-normal lg:text-white">Stone-Coated Steel Experts:</span> We
                    specialize in the materials most roofers won't touch — stone-coated steel and concrete tile — because
                    we know they're the best thing on your roof.
                  </span>
                </li>

                <li class="flex items-start gap-x-3 lg:items-center lg:gap-x-2">
                  <Icon name="star-leaf" class="size-6 shrink-0 lg:size-9" />
                  <span class="flex-1">
                    <span class="text-primary font-bold lg:font-normal lg:text-white"
                      >Insurance Claim Specialists + Lifetime Guarantee:</span
                    > We handle insurance claim and provide lifetime workmanship warranty plus manufacturer guarantees.
                  </span>
                </li>
              </ul>

              <!-- CTA Section -->
              <div class="flex flex-col items-center gap-y-4 md:flex-row md:gap-x-4 lg:gap-x-6">
                <Button variant="primary" size="lg" href="/contact-us" class="w-full md:w-auto">
                  <span class="text-left text-xs"> 0% interest & <br /> 12 month no-pay</span>
                  <span class="h-6 w-0.5 bg-[rgba(133,89,1,0.4)]"></span>
                  <span> FREE Estimate</span>
                </Button>

                <Button variant="link" href="/past-works" class="lg:text-lg">
                  <Icon name="map" />
                  See Our Past Work
                </Button>
              </div>
            </div>

            <!-- Social Proof -->
            <div
              class="flex items-center justify-center gap-4 divide-white/20 py-2 text-sm sm:divide-x md:justify-start lg:gap-x-0"
            >
              <div class="flex items-center gap-x-4 pr-4">
                <Icon name="google-logo" class="size-5 md:size-8" />
                <div class="flex flex-col gap-y-1">
                  <RatingStars
                    rating={5}
                    fillColor="white"
                    strokeColor="transparent"
                    class="[&_svg]:size-2 md:[&_svg]:size-3"
                  />
                  <span class="text-xs md:text-sm"> 5.0 Rating </span>
                </div>
              </div>

              <div class="flex items-center gap-x-4 px-0 sm:px-4">
                <Icon name="facebook-logo" class="size-5 md:size-8" />
                <div class="flex flex-col gap-y-1">
                  <RatingStars
                    rating={5}
                    fillColor="white"
                    strokeColor="transparent"
                    class="[&_svg]:size-2 md:[&_svg]:size-3"
                  />
                  <span class="text-xs md:text-sm"> 5.0 Rating </span>
                </div>
              </div>

              <div class="flex items-center gap-x-4 pl-0 sm:pl-4">
                <Image src={bbbLogo} alt="BBB Logo" width={64} height={64} class="size-5 md:size-8" />
                <div class="flex flex-col gap-y-1">
                  <RatingStars
                    rating={5}
                    class="[&_svg]:size-2 md:[&_svg]:size-3"
                    fillColor="white"
                    strokeColor="transparent"
                  />
                  <span class="text-xs md:text-sm"> A+ Rating </span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Profile  -->
        <div class="relative hidden min-h-full items-end lg:flex lg:flex-1">
          <Image src={heroPerson} alt="Hero Person" width={443} height={631} class="h-full object-cover" />
          <div class="absolute top-2/3 -left-20 flex h-[92px] w-[315px] items-center gap-x-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              xmlns:xlink="http://www.w3.org/1999/xlink"
              width="300"
              height="96"
              viewBox="0 0 300 96"
              fill="none"
              class="h-[96px] w-[300px]"
            >
              <foreignObject x="-14" y="-14" width="327.331" height="123.275">
                <div
                  style="backdrop-filter:blur(7px);clip-path:url(#bgblur_0_16409_61398_clip_path);height:100%;width:100%"
                >
                </div>
              </foreignObject><g data-figma-bg-blur-radius="14">
                <path
                  d="M278.126 0.974854C292.04 0.974854 301.793 14.7072 297.21 27.845L278.755 80.7454C275.923 88.862 268.267 94.3 259.671 94.3H21.2148C6.22081 94.3 -3.55368 78.5471 3.10449 65.1125L29.3232 12.2112C32.7343 5.32911 39.7516 0.974949 47.4326 0.974854H278.126Z"
                  fill="#0D0D0D"></path>
                <path
                  d="M278.126 0.974854C292.04 0.974854 301.793 14.7072 297.21 27.845L278.755 80.7454C275.923 88.862 268.267 94.3 259.671 94.3H21.2148C6.22081 94.3 -3.55368 78.5471 3.10449 65.1125L29.3232 12.2112C32.7343 5.32911 39.7516 0.974949 47.4326 0.974854H278.126Z"
                  fill="url(#pattern0_16409_61398)"
                  fill-opacity="0.32"></path>
                <path
                  d="M278.126 0.974854C292.04 0.974854 301.793 14.7072 297.21 27.845L278.755 80.7454C275.923 88.862 268.267 94.3 259.671 94.3H21.2148C6.22081 94.3 -3.55368 78.5471 3.10449 65.1125L29.3232 12.2112C32.7343 5.32911 39.7516 0.974949 47.4326 0.974854H278.126Z"
                  fill="url(#paint0_radial_16409_61398)"
                  fill-opacity="0.8"></path>
                <path
                  d="M278.126 0.974854C292.04 0.974854 301.793 14.7072 297.21 27.845L278.755 80.7454C275.923 88.862 268.267 94.3 259.671 94.3H21.2148C6.22081 94.3 -3.55368 78.5471 3.10449 65.1125L29.3232 12.2112C32.7343 5.32911 39.7516 0.974949 47.4326 0.974854H278.126Z"
                  stroke="url(#paint1_radial_16409_61398)"
                  stroke-width="1.95046"></path>
              </g>
              <defs>
                <clipPath id="bgblur_0_16409_61398_clip_path" transform="translate(14 14)"
                  ><path
                    d="M278.126 0.974854C292.04 0.974854 301.793 14.7072 297.21 27.845L278.755 80.7454C275.923 88.862 268.267 94.3 259.671 94.3H21.2148C6.22081 94.3 -3.55368 78.5471 3.10449 65.1125L29.3232 12.2112C32.7343 5.32911 39.7516 0.974949 47.4326 0.974854H278.126Z"
                  ></path>
                </clipPath><pattern
                  id="pattern0_16409_61398"
                  patternContentUnits="objectBoundingBox"
                  width="1"
                  height="1"
                >
                  <use xlink:href="#image0_16409_61398" transform="matrix(0.00138889 0 0 0.00478801 0 -1.2955)"></use>
                </pattern>
                <radialGradient
                  id="paint0_radial_16409_61398"
                  cx="0"
                  cy="0"
                  r="1"
                  gradientUnits="userSpaceOnUse"
                  gradientTransform="translate(159.333 47.6375) scale(171.527 45.687)"
                >
                  <stop stop-color="#303030" stop-opacity="0"></stop>
                  <stop offset="1" stop-color="#303030"></stop>
                </radialGradient>
                <radialGradient
                  id="paint1_radial_16409_61398"
                  cx="0"
                  cy="0"
                  r="1"
                  gradientTransform="matrix(189.673 28.3702 -8.48455 55.0198 115.538 19.2673)"
                  gradientUnits="userSpaceOnUse"
                >
                  <stop stop-color="#F2C744"></stop>
                  <stop offset="1" stop-color="#594216"></stop>
                </radialGradient>
                <image
                  id="image0_16409_61398"
                  width="720"
                  height="750"
                  preserveAspectRatio="none"
                  xlink:href={noiseBgOp.src}
                />
              </defs>
            </svg>

            <div class="absolute inset-0 top-0 left-0 flex items-center gap-x-4 px-3 py-2">
              <div class="relative">
                <svg xmlns="http://www.w3.org/2000/svg" width="102" height="78" viewBox="0 0 102 78" fill="none">
                  <path
                    d="M26.5881 9.17786L2.73197 53.27C-3.04549 63.9482 4.68656 76.9229 16.8275 76.9229H73.8289C81.2274 76.9229 87.6644 71.8584 89.4053 64.6676L100.08 20.5754C102.522 10.4896 94.881 0.777832 84.5038 0.777832H40.6836C34.7993 0.777832 29.3882 4.00248 26.5881 9.17786Z"
                    fill="white"
                    fill-opacity="0.1"
                    stroke="url(#paint0_radial_16409_61400)"
                    stroke-width="1.55556"></path>
                  <defs>
                    <radialGradient
                      id="paint0_radial_16409_61400"
                      cx="0"
                      cy="0"
                      r="1"
                      gradientTransform="matrix(-54.0556 44.7222 -35.933 -25.5367 104.657 0.540096)"
                      gradientUnits="userSpaceOnUse"
                    >
                      <stop stop-color="#F2C744"></stop>
                      <stop offset="1" stop-color="white" stop-opacity="0.2"></stop>
                    </radialGradient>
                  </defs>
                </svg>

                <div class="absolute top-1/2 left-1/2 -translate-1/2">
                  <Image src={trustBadgeSSL} alt="Trust Badge SSL" width={102} height={78} />
                </div>
              </div>
              <div class="flex flex-col gap-y-1.5 font-medium">
                <div class="text-primary text-sm lg:text-base">Adam Knight</div>
                <p class="text-[10px] lg:text-xs">President & Owner, Black Knight Roofing</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Free Quote Form -->
<FreeQuoteForm />
