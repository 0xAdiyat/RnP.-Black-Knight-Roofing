---
import { Image, getImage } from 'astro:assets';

import { Icon } from 'astro-icon/components';

import NoiseBg from '@/components/NoiseBg.astro';
import IntroBadge from '@/components/IntroBadge.astro';
import Button from '@/components/ui/Button.astro';

import PersonImage from '@/assets/hero-person.avif';
import RatingStars from '@/components/ui/RatingStars.astro';
import dotImage from '@/assets/dog-image.avif';
import familyImage from '@/assets/family-image.avif';
import GoogleIcon from '@/assets/google-icon-logo.avif';

import TopFrameImage from '@/assets/top-frame.avif';
---

<NoiseBg class="relative px-0">
  <!-- Top Frame Image -->
  <Image
    src={TopFrameImage}
    alt="Top Frame"
    width={1440}
    height={202}
    class="h-auto w-full"
    loading="eager"
    fetchpriority="high"
    format="avif"
  />

  <div class="container pb-12 lg:pb-20">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:gap-x-8">
      <div class="relative flex flex-col items-center space-y-8 lg:items-start lg:space-y-12">
        <!-- Person Image container -->
        <div class="relative w-full max-w-[531px] sm:h-[543px] lg:px-16">
          <div class="h-full w-full">
            <div class="absolute inset-0 z-10 bg-linear-to-b from-black/0 from-60% to-black/75"></div>
            <Image
              src={PersonImage}
              width={543}
              height={531}
              alt="Adam Knight"
              class="h-full w-full rounded-2xl object-cover lg:rounded-lg"
            />
          </div>
          <IntroBadge class="absolute bottom-4 left-4 z-10 lg:bottom-0 lg:left-0" />
        </div>

        <div class="relative w-full max-w-fit rounded-2xl">
          <div
            class="pointer-events-none absolute inset-0 rounded-2xl border border-transparent"
            style={`
              background: linear-gradient(to right, rgba(30, 30, 30, 1), rgba(58, 58, 58, 1), rgba(63, 63, 63, 1), rgba(131, 131, 131, 1)) border-box;
              -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
              -webkit-mask-composite: xor;
              mask-composite: exclude;
            `}
          >
          </div>
          <ul
            class="relative flex flex-wrap items-center justify-center gap-3 rounded-2xl p-4 sm:flex-nowrap lg:justify-start"
          >
            <li class="flex items-center gap-x-2.5 p-2">
              <Icon name="google-logo" class="size-6 text-[#F7B715] sm:size-8" />
              <div>
                <div>
                  <RatingStars rating={5} size={12} fillColor="white" strokeColor="transparent" />
                </div>
                <div class="text-xs sm:text-sm">5.0 Rating</div>
              </div>
            </li>

            <li class="flex items-center gap-x-2.5 p-2">
              <Icon name="facebook-logo" class="size-6 text-[#F7B715] sm:size-8" />
              <div>
                <div>
                  <RatingStars rating={5} size={12} fillColor="white" strokeColor="transparent" />
                </div>
                <div class="text-xs sm:text-sm">5.0 Rating</div>
              </div>
            </li>

            <li class="flex items-center gap-x-2.5 p-2">
              <div>
                <Image
                  src="/bba.avif"
                  loading="eager"
                  format="avif"
                  alt="BBB Logo"
                  width={32}
                  height={32}
                  class="size-6 sm:size-8"
                />
              </div>
              <div>
                <div>
                  <RatingStars rating={5} size={12} fillColor="white" strokeColor="transparent" />
                </div>
                <div class="text-xs sm:text-sm">5.0 Rating</div>
              </div>
            </li>
          </ul>
        </div>
      </div>

      <div class="flex flex-col justify-center py-4 lg:py-8">
        <div class="w-full space-y-6 lg:space-y-4">
          <div class="flex items-center gap-x-3">
            <div
              class="relative size-5 rounded-[5px] bg-[#F7B715]/50 drop-shadow-2xl before:absolute before:top-1/2 before:left-1/2 before:size-2 before:-translate-1/2 before:rounded-full before:bg-[#F7D515] before:content-['']"
            >
            </div>
            <div class="text-sm font-medium tracking-wide text-white/80 uppercase">About Black Knight Roofing</div>
          </div>
          <h2 class="text-3xl font-bold lg:text-4xl">
            Meet Adam Knight — US Army Veteran and Colorado's Stone-Coated Steel Roofing Expert
          </h2>

          <div class="prose prose-invert max-w-none text-white/70">
            <p>
              Black Knight Roofing was built to give homeowners something better than the typical roofing contractor.
              Founded by US Army veteran Adam Knight, the company was created to raise the standard in an industry known
              for shortcuts and confusion. As part of Black Knight Construction Group, we bring a whole-home,
              builder-level mindset to every project — not just a roof replacement.
            </p>

            <p>
              Adam is also a licensed General Contractor and President of Black Knight Homes, so every roof gets the
              attention of someone who understands full-home construction. We specialize in asphalt shingle, metal,
              stone-coated steel, and flat roofing systems, and we're highly experienced in storm and hail damage claims
              — helping Colorado homeowners navigate insurance correctly and confidently.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Meet the Team Section -->
  <div class="container pb-12 lg:pb-20">
    <div class="grid grid-cols-1 gap-12 rounded-2xl border border-white/10 p-6 lg:grid-cols-2 lg:p-12">
      <div class="flex flex-col space-y-10 lg:space-y-12">
        <div class="space-y-6">
          <div class="flex items-center gap-x-3">
            <div
              class="relative size-5 rounded-[5px] bg-[#F7B715]/50 drop-shadow-2xl before:absolute before:top-1/2 before:left-1/2 before:size-2 before:-translate-1/2 before:rounded-full before:bg-[#F7D515] before:content-['']"
            >
            </div>
            <div class="text-sm font-medium tracking-wide text-white/80 uppercase">Meet the Team</div>
          </div>

          <div class="prose prose-invert max-w-none text-white/70">
            <p>
              Our crew treats every job with the care and attention your home deserves. From the first inspection to the
              final cleanup, we're respectful, professional, and focused on getting it done right.
            </p>
            <p>
              Led by veteran values of accountability and discipline, our team shows up on time, communicates clearly,
              and delivers work we're proud to put our name on.
            </p>
          </div>
        </div>

        <Button
          variant="outline"
          class="from-primary h-fit w-fit border-none bg-linear-to-r to-[#E5E5E51A] p-px"
          href="/about-us"
        >
          <div
            class="bg-bg-default hover:text-inverted hover:bg-primary flex h-12 w-full items-center gap-x-1.5 rounded px-8 sm:w-auto"
          >
            <span> Learn More About Us </span>
            <span> <Icon name="arow-open-link" class="size-3" /> </span>
          </div>
        </Button>

        <div class="relative mt-8 flex flex-col items-center lg:items-start">
          <Image src={dotImage} alt="Roofus pattern" width={246} height={229} class="z-10 w-48 lg:w-60" />
          <div
            class="font-caveat top-[235px] -mt-3.5 w-full border-t-2 border-[#F7B715] text-center text-[28px] lg:text-start lg:text-[32px]"
          >
            Meet Roofus and the Team
          </div>
        </div>
      </div>

      <!-- Right grid -->
      <div class="relative min-h-[400px] rounded-xl lg:min-h-full">
        <div class="absolute inset-x-0 bottom-0 z-10 h-1/2 bg-linear-to-t from-black via-black/50 to-transparent"></div>
        <Image
          src="/placeholders/team-pic.avif"
          alt="team pic"
          width={800}
          height={800}
          format="avif"
          loading="eager"
          class="absolute inset-0 h-full w-full rounded-xl object-cover"
        />

        <!-- Review Wedget Card 1 -->
        <div
          class="animate-floating border-radial absolute top-8 -left-4 z-20 w-[90%] max-w-[320px] rounded-2xl p-px sm:left-[-20px] sm:w-full lg:max-w-[372px]"
        >
          <div class="flex items-center gap-x-3 rounded-2xl bg-[#222]/95 p-3 backdrop-blur-sm sm:p-4">
            <div class="size-12 shrink-0 rounded-full bg-white/10 sm:size-[74px]"></div>
            <div class="flex-1 space-y-1 sm:space-y-2">
              <div class="text-primary flex items-center gap-x-2 text-xs sm:text-sm">
                <span class="font-normal"> Mary Cay </span>
                <div class="flex items-center gap-x-1">
                  <Image alt="G" width={16} height={16} src={GoogleIcon} class="size-3 sm:size-4" />
                  <RatingStars rating={5} size={10} fillColor="#F7B715" strokeColor="transparent" />
                </div>
              </div>
              <div class="line-clamp-2 text-xs text-white/80 sm:text-sm">
                I was impressed with Black Knight Roofing. The crew did a great job and ...
              </div>
            </div>
          </div>
        </div>

        <!-- Review Wedget Card 2 -->
        <div
          class="animate-floating border-radial absolute -right-4 bottom-8 z-20 w-[90%] max-w-[320px] rounded-2xl p-px sm:right-[-20px] sm:w-full lg:max-w-[372px]"
          style="animation-delay: -2s;"
        >
          <div class="flex items-center gap-x-3 rounded-2xl bg-[#222]/95 p-3 backdrop-blur-sm sm:p-4">
            <div class="size-12 shrink-0 rounded-full bg-white/10 sm:size-[74px]"></div>
            <div class="flex-1 space-y-1 sm:space-y-2">
              <div class="text-primary flex items-center gap-x-2 text-xs sm:text-sm">
                <span class="font-normal"> Mark T. </span>
                <div class="flex items-center gap-x-1">
                  <Image alt="G" width={16} height={16} src={GoogleIcon} class="size-3 sm:size-4" />
                  <RatingStars rating={5} size={10} fillColor="#F7B715" strokeColor="transparent" />
                </div>
              </div>
              <div class="line-clamp-2 text-xs text-white/80 sm:text-sm">
                Adam and his team were professional from start to finish. Highly recommend!
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Our Promises section -->
  <div class="container pt-12 pb-20">
    <div
      class="border-gradient rounded-2xl [--mask-border-bg:linear-gradient(to_right,transparent_30%,var(--color-primary)_100%)]"
    >
      <div class="absolute inset-0 z-10 hidden bg-linear-to-r from-[#111]/90 to-[#111]/10 to-50% lg:block lg:w-8/10">
      </div>

      <NoiseBg
        class="relative flex w-full flex-col items-stretch rounded-2xl px-0 py-0 [--noise-overlay:linear-gradient(to_right,rgba(0,0,0,1)_20%,rgba(0,0,0,.85)_80%)] [--noise-radial:radial-gradient(50%_50%_at_50%_50%,rgba(48,48,48,0.3)_0%,rgba(48,48,48,0.54)_50%)] lg:flex-row"
      >
        <div class="relative z-0 w-full shrink-0 border-b border-white/10 lg:w-1/2 lg:border-b-0 lg:border-l">
          <Image
            src={familyImage}
            alt="Adam Knight with family"
            width={1200}
            height={800}
            class="h-full w-full object-cover"
          />
        </div>

        <div
          class="from-primary w-full rounded-2xl bg-radial-[at_40%_20%] via-[#594216] to-[#594216] p-px pt-0.5 lg:bg-none lg:p-0 lg:pt-0"
        >
          <div
            class="bg-bg-default relative z-20 flex h-full flex-col justify-center gap-6 rounded-2xl p-8 sm:p-12 lg:bg-transparent lg:pr-12 lg:pl-16"
          >
            <div class="space-y-4">
              <div class="flex items-center gap-x-3">
                <div
                  class="relative size-5 rounded-[5px] bg-[#F7B715]/50 drop-shadow-2xl before:absolute before:top-1/2 before:left-1/2 before:size-2 before:-translate-1/2 before:rounded-full before:bg-[#F7D515] before:content-['']"
                >
                </div>
                <div class="text-sm font-medium tracking-wide text-white/80">Our Promise</div>
              </div>

              <h3 class="font-bold">Partner With a Company That Believes In The Golden Rule</h3>
            </div>

            <div class="space-y-4 text-white/70">
              <p>
                Most homeowners have been burned before — a contractor who didn't show, an estimate that changed after
                the job started, a repair that didn't hold. We built this company on the opposite of that. Every project
                gets our full attention, our honest assessment, and our name on the warranty.
              </p>
              <p>
                We're A+ accredited by the Better Business Bureau, rated Best of 2026, and Tamko Pro Certified — which
                means we've passed background checks, product training, and manufacturer testing to unlock enhanced
                warranties most roofers simply can't offer you. That's accountability.
              </p>
            </div>

            <Button class="mt-4 w-fit px-8 text-sm font-bold" href="/contact-us">Schedule a FREE Roof Inspection</Button
            >
          </div>
        </div>
      </NoiseBg>
    </div>
  </div>
</NoiseBg>
