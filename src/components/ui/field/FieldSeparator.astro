---
import { cn } from '@/lib/utils';
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'div'>;
const { class: className, ...props } = Astro.props;

const hasChildren = Astro.slots.has('default');
---

<div
  data-slot="field-separator"
  data-content={hasChildren ? 'true' : undefined}
  class={cn('-my-2 h-5 text-sm group-data-[variant=outline]/field-group:-mb-2 relative', className)}
  {...props}
>
  <div class="border-border absolute inset-0 top-1/2 border-t" role="separator"></div>
  {
    hasChildren && (
      <span
        class="text-muted-foreground bg-background relative mx-auto block w-fit px-2"
        data-slot="field-separator-content"
      >
        <slot />
      </span>
    )
  }
</div>
