---
import NoiseBg from '@/components/NoiseBg.astro';
import { Icon } from 'astro-icon/components';
import RatingStars from '@/components/ui/RatingStars.astro';

interface Props {
  className?: string;
}

const { className = '' } = Astro.props;
---

<div class={`container grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 py-16 ${className}`}>
  <!-- Total Projects Completed -->
  <div class="border-radial rounded-[5px]">
    <div class="testimonial-bg-noise flex h-full items-center justify-center gap-x-2 rounded-[5px] px-6 py-4">
      <div class="font-heading text-primary text-[2rem]">100+</div>
      <div>
        <div class="text-lg font-bold">Roofing Projects</div>
        <div class="text-[#AAAAAA]">in Colorado</div>
      </div>
    </div>
  </div>

  <!-- Google Retings -->
  <div class="border-radial rounded-[5px]">
    <div class="testimonial-bg-noise flex h-full items-center justify-center gap-x-2 rounded-[5px] px-6 py-4">
      <div class="text-primary text-[2rem] font-bold">5.0</div>
      <div class="space-y-1">
        <div class="text-lg leading-none font-bold">
          <RatingStars rating={5} size={16} fillColor="#F7B715" strokeColor="none" />
        </div>
        <div class="text-[#AAAAAA]">40+ Google Reviews</div>
      </div>
    </div>
  </div>

  <!-- Workmanship Warranty -->
  <div class="border-radial rounded-[5px]">
    <div class="testimonial-bg-noise flex h-full items-center justify-center gap-x-2 rounded-[5px] px-6 py-4">
      <div class="text-primary size-12 font-bold">
        <Icon name="shield-check" size={48} />
      </div>
      <div>
        <div class="font-heading text-[2rem] leading-11 font-normal">Licensed</div>
        <div class="text-[#AAAAAA]">Bonded & Insured</div>
      </div>
    </div>
  </div>

  <!-- Lifetime Warranty -->
  <div class="border-radial rounded-[5px]">
    <div class="testimonial-bg-noise flex h-full items-center justify-center gap-x-2 rounded-[5px] px-6 py-4">
      <div class="text-primary size-12 font-bold">
        <Icon name="badge" size={48} />
      </div>
      <div>
        <div class="font-heading text-[2rem] leading-11 font-normal">Lifetime</div>
        <div class="text-[#AAAAAA]">Workmanship Warranty</div>
      </div>
    </div>
  </div>
</div>
