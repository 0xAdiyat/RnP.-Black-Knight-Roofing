---
---

<div
  class="folder-trigger group relative mx-auto mb-10 h-52 w-80 cursor-pointer outline-none"
  tabindex="0"
  role="button"
  aria-label="Toggle gallery folder"
>
  <div
    class="relative mx-auto flex h-full w-[87.5%] justify-center overflow-visible rounded-xl"
    style="background: var(--color-secondary); border: 1px solid var(--color-secondary);"
  >
    <!-- Page 1 -->
    <div class="folder-page folder-page-1 absolute top-2 z-10 h-fit w-32 rounded-xl shadow-lg">
      <div class="h-full w-full rounded-xl border border-neutral-200 bg-gradient-to-b from-white to-[#F5F5F7] p-4">
        <div class="flex flex-col gap-2">
          <div class="h-1.5 w-full rounded-full bg-black/10"></div>
          {Array.from({ length: 8 }).map((_) => (
            <div class="flex gap-2">
              <div class="h-1.5 flex-1 rounded-full bg-black/10"></div>
              <div class="h-1.5 flex-1 rounded-full bg-black/10"></div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Page 2 -->
    <div class="folder-page folder-page-2 absolute top-2 z-20 h-fit w-32 rounded-xl shadow-lg">
      <div class="h-full w-full rounded-xl border border-neutral-200 bg-gradient-to-b from-white to-[#F5F5F7] p-4">
        <div class="flex flex-col gap-2">
          <div class="h-1.5 w-full rounded-full bg-black/10"></div>
          {Array.from({ length: 8 }).map((_) => (
            <div class="flex gap-2">
              <div class="h-1.5 flex-1 rounded-full bg-black/10"></div>
              <div class="h-1.5 flex-1 rounded-full bg-black/10"></div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Page 3 -->
    <div class="folder-page folder-page-3 absolute top-2 z-10 h-fit w-32 rounded-xl shadow-lg">
      <div class="h-full w-full rounded-xl border border-neutral-200 bg-gradient-to-b from-white to-[#F5F5F7] p-4">
        <div class="flex flex-col gap-2">
          <div class="h-1.5 w-full rounded-full bg-black/10"></div>
          {Array.from({ length: 8 }).map((_) => (
            <div class="flex gap-2">
              <div class="h-1.5 flex-1 rounded-full bg-black/10"></div>
              <div class="h-1.5 flex-1 rounded-full bg-black/10"></div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Folder Front Cover -->
  <div class="folder-cover absolute inset-x-0 -bottom-px z-30 flex h-44 origin-bottom items-center justify-center overflow-visible rounded-3xl">
    <div class="relative h-full w-full">
      <svg
        class="h-full w-full overflow-visible"
        viewBox="0 0 235 121"
        fill="none"
        preserveAspectRatio="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M104.615 0.350494L33.1297 0.838776C32.7542 0.841362 32.3825 0.881463 32.032 0.918854C31.6754 0.956907 31.3392 0.992086 31.0057 0.992096H31.0047C30.6871 0.99235 30.3673 0.962051 30.0272 0.929596C29.6927 0.897686 29.3384 0.863802 28.9803 0.866119L13.2693 0.967682H13.2527L13.2352 0.969635C13.1239 0.981406 13.0121 0.986674 12.9002 0.986237H9.91388C8.33299 0.958599 6.76052 1.22345 5.27423 1.76651H5.27325C4.33579 2.11246 3.48761 2.66213 2.7879 3.37393L2.49689 3.68839L2.492 3.69424C1.62667 4.73882 1.00023 5.96217 0.656067 7.27725C0.653324 7.28773 0.654065 7.29886 0.652161 7.30948C0.3098 8.62705 0.257231 10.0048 0.499817 11.3446L12.2147 114.399L12.2156 114.411L12.2176 114.423C12.6046 116.568 13.7287 118.508 15.3934 119.902C17.058 121.297 19.1572 122.056 21.3231 122.049V122.05H215.379C217.76 122.02 220.064 121.192 221.926 119.698V119.697C223.657 118.384 224.857 116.485 225.305 114.35L225.307 114.339L235.914 53.3798L235.968 53.1093L235.97 53.0985L235.971 53.0888C236.134 51.8978 236.044 50.685 235.705 49.5321C235.307 48.1669 234.63 46.9005 233.717 45.8144L233.383 45.4296C232.58 44.5553 231.614 43.8449 230.539 43.3398C229.311 42.7628 227.971 42.4685 226.616 42.4774H146.746C144.063 42.4705 141.423 41.8004 139.056 40.5263C136.691 39.2522 134.671 37.4127 133.175 35.1689L113.548 5.05948L113.544 5.05362L113.539 5.04776C112.545 3.65165 111.238 2.51062 109.722 1.72061C108.266 0.886502 106.627 0.422235 104.952 0.365143V0.364166L104.633 0.350494H104.615Z"
          fill="var(--color-primary)"
          stroke="var(--color-secondary)"
          stroke-width="1.5"
        />
      </svg>

      <div class="pointer-events-none absolute inset-0 flex flex-col items-center justify-center pt-8 opacity-75">
        <div class="mb-2.5 flex gap-11">
          <div class="size-2.5 rounded-full bg-black/20"></div>
          <div class="size-2.5 rounded-full bg-black/20"></div>
        </div>
        <div class="h-1 w-9 rounded-full bg-black/20"></div>
      </div>
    </div>
  </div>
</div>

<style>
  /* Base folder pages setup */
  .folder-page {
    /* Fast close (less bounce) */
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .folder-page-1 {
    transform: translate(-38px, 2px) rotate(-3deg);
  }
  .folder-page-2 {
    transform: translate(0, 0) rotate(0deg);
  }
  .folder-page-3 {
    transform: translate(42px, 1px) rotate(3.5deg);
  }

  /* Open state with slower, springy bounce */
  .is-open .folder-page, .group:hover .folder-page {
    transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  
  .is-open .folder-page-1, .group:hover .folder-page-1  {
    transform: translate(-70px, -75px) rotate(-8deg);
  }
  
  .is-open .folder-page-2, .group:hover .folder-page-2 {
    transform: translate(2px, -95px) rotate(1deg);
  }
  
  .is-open .folder-page-3, .group:hover .folder-page-3 {
    transform: translate(75px, -80px) rotate(9deg);
  }

  /* Folder cover */
  .folder-cover {
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    transform: rotateX(0deg);
  }

  .is-open .folder-cover, .group:hover .folder-cover {
    transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    transform: rotateX(-35deg);
  }
</style>

<script>
  function initGalleryFolder() {
    const triggers = document.querySelectorAll('.folder-trigger');
    triggers.forEach((trigger) => {
      // Avoid attaching multiple listeners if re-evaluated.
      if (trigger.hasAttribute('data-initialized')) return;
      trigger.setAttribute('data-initialized', 'true');

      trigger.addEventListener('click', () => {
        trigger.classList.toggle('is-open');
      });
      trigger.addEventListener('keydown', (e) => {
        const keyboardEvent = e as KeyboardEvent;
        if (keyboardEvent.key === 'Enter' || keyboardEvent.key === ' ') {
          e.preventDefault();
          trigger.classList.toggle('is-open');
        }
      });
    });
  }

  // Run on initial load and after Astro view transitions
  initGalleryFolder();
  document.addEventListener('astro:page-load', initGalleryFolder);
</script>
