---
import { buttonVariants, type ButtonVariants } from '@/components/ui/button.variants';
import { cn } from '@/lib/utils';

interface Props extends ButtonVariants {
  class?: string;
  href?: string;
  disabled?: boolean;
  type?: 'button' | 'submit' | 'reset';
}

const { variant, size, class: className, href, disabled, type, ...rest } = Astro.props;
const classes = cn(
  buttonVariants({ variant, size }),
  cn('hover:cursor-pointer transition-[background-color,color,border-color,box-shadow,opacity] duration-200 ease-out', className)
);
const Comp = href ? 'a' : 'button';
---

<Comp class={classes} href={href} disabled={disabled} type={href ? undefined : type} {...rest}>
  <slot />
</Comp>
