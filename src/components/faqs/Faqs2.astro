---
import { Icon } from 'astro-icon/components';
import NoiseBg from '../NoiseBg.astro';
import Button from '../ui/Button.astro';
import FaqItem from './FaqItem.astro';
import { faqCategories } from '@/data/faqs';

const allTabLabel = 'All';
const tabs = [allTabLabel, ...faqCategories.map((category) => category.label)];
const defaultTab = tabs[0];
---

<NoiseBg class="px-0 py-0">
  <div class="container py-12 lg:py-20">
    <div class="flex flex-1 flex-col items-center space-y-4 text-center">
      <div class="flex items-center gap-x-3 text-sm md:text-base">
        <div
          class="relative size-4 rounded-[5px] bg-[#F7B715]/50 drop-shadow-2xl before:absolute before:top-1/2 before:left-1/2 before:size-1.5 before:-translate-1/2 before:rounded-full before:bg-[#F7D515] before:content-[''] md:size-5 md:before:size-2"
        >
        </div>
        <div>FAQs</div>
      </div>
      <h2 class="max-w-[530px] text-3xl md:text-5xl">Frequently Asked Questions</h2>
      
    </div>

    <div class="mx-auto flex max-w-[920px] flex-col space-y-8">
      <!-- Search -->
      <div class="border-radial mt-12 rounded-full">
        <div class="testimonial-bg-noise relative flex items-center rounded-full px-0 py-0 backdrop-blur-md">
          <Icon name="search" size={24} class="absolute top-1/2 left-8 -translate-y-1/2 text-white" />
          <input
            id="faq-search-input"
            placeholder="Search for answers..."
            class="h-[56px] w-full rounded-full bg-transparent px-20 py-4 focus:outline-none"
          />
        </div>
      </div>

      <!-- Categories -->
      <div class="relative lg:hidden">
        <div class="border-radial rounded-full">
          <button
            id="faq-dropdown-trigger"
            class="flex h-12 w-full items-center justify-between px-6 text-sm font-semibold"
          >
            <span id="faq-active-label">{tabs[0]}</span>
            <Icon name="chevron-down" size={20} class="transition-transform duration-300" id="faq-chevron" />
          </button>
        </div>
        <div
          id="faq-dropdown-menu"
          class="absolute top-full right-0 left-0 z-50 mt-2 hidden rounded-2xl border border-white/10 bg-[#0F0F0F]/95 p-1 shadow-2xl backdrop-blur-xl"
        >
          {
            tabs.map(t => (
              <button
                class="faq-mobile-tab flex h-11 w-full items-center rounded-xl px-5 text-sm font-semibold transition-colors hover:bg-white/5"
                data-category={t}
              >
                {t}
              </button>
            ))
          }
        </div>
      </div>

      <div class="border-radial hidden rounded-full lg:block">
        <div
          class="no-scrollbar flex items-center gap-2 overflow-x-auto rounded-full p-2 lg:justify-center lg:gap-x-2.5"
        >
          {
            tabs.map((t, index) => (
              <button
                class:list={[
                  'faq-desktop-tab border-radial flex-1 shrink-0 rounded-full whitespace-nowrap',
                  { 'bg-white/10': index === 0 },
                ]}
                data-category={t}
              >
                <div class="flex h-12 items-center justify-center rounded-full px-4 py-4 text-xs font-semibold lg:px-6">
                  {t}
                </div>
              </button>
            ))
          }
        </div>
      </div>

      <div id="faq-items" class="space-y-4">
        {
          faqCategories.map((category) =>
            category.items.map((faq, index) => (
              <div
                class:list={[{ hidden: defaultTab !== allTabLabel }]}
                data-faq-entry
                data-category={category.label}
                data-search={`${faq.question} ${faq.answer.join(' ')}`.toLowerCase()}
              >
                <FaqItem
                  question={faq.question}
                  answer={faq.answer}
                  open={category.label === faqCategories[0]?.label && index === 0}
                />
              </div>
            ))
          )
        }
        <div id="faq-empty-state" class="hidden rounded-2xl border border-white/10 bg-white/5 px-6 py-8 text-center text-white/60">
          No answers match this search in the selected category.
        </div>
      </div>
    </div>
  </div>
</NoiseBg>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script>
  function initFaqTabs() {
    const dropdownTrigger = document.getElementById('faq-dropdown-trigger');
    const dropdownMenu = document.getElementById('faq-dropdown-menu');
    const chevron = document.getElementById('faq-chevron');
    const activeLabel = document.getElementById('faq-active-label');
    const mobileTabs = document.querySelectorAll('.faq-mobile-tab');
    const desktopTabs = document.querySelectorAll('.faq-desktop-tab');
    const searchInput = document.getElementById('faq-search-input') as HTMLInputElement | null;
    const faqEntries = document.querySelectorAll('[data-faq-entry]');
    const emptyState = document.getElementById('faq-empty-state');
    let activeCategory = activeLabel?.textContent?.trim() || 'All';

    function closeDropdown() {
      dropdownMenu?.classList.add('hidden');
      chevron?.classList.remove('rotate-180');
    }

    function setActiveDesktopTab(category: string) {
      desktopTabs.forEach(tab => {
        tab.classList.toggle('bg-white/10', (tab as HTMLElement).dataset.category === category);
      });
    }

    function resetVisibleAccordions() {
      let firstVisibleFound = false;

      faqEntries.forEach(entry => {
        if ((entry as HTMLElement).classList.contains('hidden')) return;

        const faqItem = entry.querySelector('faq-item');
        const button = entry.querySelector('button');
        const shouldOpen = !firstVisibleFound;

        if (faqItem) {
          faqItem.setAttribute('data-open', shouldOpen.toString());
        }

        if (button) {
          button.setAttribute('aria-expanded', shouldOpen.toString());
        }

        if (!firstVisibleFound) {
          firstVisibleFound = true;
        }
      });
    }

    function applyFilters() {
      const searchValue = searchInput?.value.trim().toLowerCase() || '';
      let visibleCount = 0;

      faqEntries.forEach(entry => {
        const element = entry as HTMLElement;
        const matchesCategory = activeCategory === 'All' || element.dataset.category === activeCategory;
        const searchText = element.dataset.search || '';
        const matchesSearch = !searchValue || searchText.includes(searchValue);
        const shouldShow = matchesCategory && matchesSearch;

        element.classList.toggle('hidden', !shouldShow);
        if (shouldShow) visibleCount += 1;
      });

      emptyState?.classList.toggle('hidden', visibleCount !== 0);
      resetVisibleAccordions();
    }

    function setActiveCategory(category: string) {
      activeCategory = category;
      if (activeLabel) activeLabel.innerText = category;
      setActiveDesktopTab(category);
      applyFilters();
      closeDropdown();
    }

    dropdownTrigger?.addEventListener('click', () => {
      dropdownMenu?.classList.toggle('hidden');
      chevron?.classList.toggle('rotate-180');
    });

    mobileTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const category = (tab as HTMLElement).dataset.category;
        if (category) setActiveCategory(category);
      });
    });

    desktopTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const category = (tab as HTMLElement).dataset.category;
        if (category) setActiveCategory(category);
      });
    });

    searchInput?.addEventListener('input', applyFilters);

    document.addEventListener('click', e => {
      if (!dropdownTrigger?.contains(e.target as Node) && !dropdownMenu?.contains(e.target as Node)) {
        closeDropdown();
      }
    });

    setActiveDesktopTab(activeCategory);
    applyFilters();
  }

  // Run on page load
  initFaqTabs();
  // Handle Astro transitions
  document.addEventListener('astro:after-swap', initFaqTabs);
</script>
