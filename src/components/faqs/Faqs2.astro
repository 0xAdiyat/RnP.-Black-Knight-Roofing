---
import { Icon } from 'astro-icon/components';
import NoiseBg from '../NoiseBg.astro';
import Button from '../ui/Button.astro';
import FaqItem from './FaqItem.astro';

const faqs = [
  {
    question: "Will my homeowner's insurance cover a new roof?",
    answer:
      "It depends on the cause of damage. Most policies cover storm, hail, and wind damage. We're insurance claim specialists—we inspect your roof, document the damage, and work directly with your adjuster to give you the best chance of full claim approval.",
  },
  {
    question: 'How long does a roof replacement take?',
    answer:
      'Most residential roof replacements are completed in 1-3 days, depending on the size of your roof and weather conditions. We always aim to minimize disruption to your daily routine.',
  },
  {
    question: 'Do you offer financing?',
    answer:
      'Yes! We offer flexible financing options to make your roofing project affordable. Ask us about our payment plans and we will find the right solution for your budget.',
  },
  {
    question: 'What roofing materials do you install?',
    answer:
      'We install a wide range of materials including asphalt shingles, metal roofing, cedar shakes, and flat roofing systems. Our team can help you choose the best material for your home and budget.',
  },
  {
    question: 'What areas do you serve?',
    answer:
      'We proudly serve homeowners from Colorado Springs to Fort Collins and everywhere in between, including Denver, Aurora, Lakewood, and surrounding communities.',
  },
  {
    question: 'What warranty do you offer?',
    answer:
      "We stand behind our work with a comprehensive warranty on both materials and labor. Specific warranty terms vary by product, so we'll walk you through the details before your project begins.",
  },
  {
    question: 'Do you offer any discounts?',
    answer:
      'Yes, we offer seasonal promotions and discounts for military, first responders, and seniors. Contact us to learn about current offers available in your area.',
  },
];

const tabs = [
  'About Shams Roofing',
  'Roofing Services',
  'Insurance & Claims',
  'Financing',
  'Before & After',
  'Case Studies',
];
---

<NoiseBg class="px-0 py-0">
  <div class="container py-12 lg:py-20">
    <div class="flex flex-1 flex-col items-center space-y-4 text-center">
      <div class="flex items-center gap-x-3 text-sm md:text-base">
        <div
          class="relative size-4 rounded-[5px] bg-[#F7B715]/50 drop-shadow-2xl before:absolute before:top-1/2 before:left-1/2 before:size-1.5 before:-translate-1/2 before:rounded-full before:bg-[#F7D515] before:content-[''] md:size-5 md:before:size-2"
        >
        </div>
        <div>Our Promise</div>
      </div>
      <h2 class="max-w-[530px] text-3xl md:text-5xl">Frequently Asked Questions</h2>
      <div class="pt-4">
        <Button variant="primary" size="lg" class="w-fit text-sm leading-5">
          <span class="text-center text-[10px] leading-3 font-bold text-[#855901]">
            $99/month roofs <br /> No repayment penalty</span
          >
          <span class="h-6 w-0.5 bg-[rgba(133,89,1,0.4)]"></span>
          <span> <strong> FREE </strong> Estimate</span>
        </Button>
      </div>
    </div>

    <div class="mx-auto flex max-w-[920px] flex-col space-y-8">
      <!-- Search -->
      <div class="border-radial mt-12 rounded-full">
        <div class="testimonial-bg-noise relative flex items-center rounded-full px-0 py-0 backdrop-blur-md">
          <Icon name="search" size={24} class="absolute top-1/2 left-8 -translate-y-1/2 text-white" />
          <input
            placeholder="Search for answers..."
            class="h-[56px] w-full rounded-full bg-transparent px-20 py-4 focus:outline-none"
          />
        </div>
      </div>

      <!-- Categories -->
      <div class="relative lg:hidden">
        <div class="border-radial rounded-full">
          <button
            id="faq-dropdown-trigger"
            class="flex h-12 w-full items-center justify-between px-6 text-sm font-semibold"
          >
            <span id="faq-active-label">{tabs[0]}</span>
            <Icon name="chevron-down" size={20} class="transition-transform duration-300" id="faq-chevron" />
          </button>
        </div>
        <div
          id="faq-dropdown-menu"
          class="absolute top-full right-0 left-0 z-50 mt-2 hidden rounded-2xl border border-white/10 bg-[#0F0F0F]/95 p-1 shadow-2xl backdrop-blur-xl"
        >
          {
            tabs.map(t => (
              <button class="faq-mobile-tab flex h-11 w-full items-center rounded-xl px-5 text-sm font-semibold transition-colors hover:bg-white/5">
                {t}
              </button>
            ))
          }
        </div>
      </div>

      <div class="border-radial hidden rounded-full lg:block">
        <div
          class="no-scrollbar flex items-center gap-2 overflow-x-auto rounded-full p-2 lg:justify-center lg:gap-x-2.5"
        >
          {
            tabs.map((t, index) => (
              <button
                class:list={[
                  'faq-desktop-tab border-radial flex-1 shrink-0 rounded-full whitespace-nowrap',
                  { 'bg-white/10': index === 0 },
                ]}
              >
                <div class="flex h-12 items-center justify-center rounded-full px-4 py-4 text-xs font-semibold lg:px-6">
                  {t}
                </div>
              </button>
            ))
          }
        </div>
      </div>

      <div>
        {faqs.map((faq, index) => <FaqItem question={faq.question} answer={faq.answer} open={index === 0} />)}
      </div>
    </div>
  </div>
</NoiseBg>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script>
  function initFaqTabs() {
    const dropdownTrigger = document.getElementById('faq-dropdown-trigger');
    const dropdownMenu = document.getElementById('faq-dropdown-menu');
    const chevron = document.getElementById('faq-chevron');
    const activeLabel = document.getElementById('faq-active-label');
    const mobileTabs = document.querySelectorAll('.faq-mobile-tab');
    const desktopTabs = document.querySelectorAll('.faq-desktop-tab');

    // Toggle dropdown
    dropdownTrigger?.addEventListener('click', () => {
      dropdownMenu?.classList.toggle('hidden');
      chevron?.classList.toggle('rotate-180');
    });

    // Handle Mobile Tab Selection
    mobileTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const text = (tab as HTMLElement).innerText;
        if (activeLabel) activeLabel.innerText = text;

        // Update Desktop active state visually
        desktopTabs.forEach(dt => {
          if ((dt as HTMLElement).innerText === text) {
            dt.classList.add('bg-white/10');
          } else {
            dt.classList.remove('bg-white/10');
          }
        });

        dropdownMenu?.classList.add('hidden');
        chevron?.classList.remove('rotate-180');
      });
    });

    // Handle Desktop Tab Selection
    desktopTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const text = (tab as HTMLElement).innerText;

        desktopTabs.forEach(dt => dt.classList.remove('bg-white/10'));
        tab.classList.add('bg-white/10');

        if (activeLabel) activeLabel.innerText = text;
      });
    });

    // Close dropdown on outside click
    document.addEventListener('click', e => {
      if (!dropdownTrigger?.contains(e.target as Node) && !dropdownMenu?.contains(e.target as Node)) {
        dropdownMenu?.classList.add('hidden');
        chevron?.classList.remove('rotate-180');
      }
    });
  }

  // Run on page load
  initFaqTabs();
  // Handle Astro transitions
  document.addEventListener('astro:after-swap', initFaqTabs);
</script>
