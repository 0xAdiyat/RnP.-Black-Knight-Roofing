---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';

interface Props {
  image: string;
  date: string;
  readTime: string;
  title: string;
  description: string;
}

const { image, date, readTime, title, description } = Astro.props;
---

<div class="group flex flex-col items-start overflow-hidden rounded-2xl border border-white/5 bg-[#1a1a1a] shadow-2xl transition-all duration-300 hover:border-primary/50">
  <div class="relative aspect-video w-full overflow-hidden">
    <Image 
      src={image} 
      alt={title} 
      width={1200} 
      height={675}
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
    />
  </div>
  
  <div class="flex w-full flex-col gap-4 p-6">
    <div class="flex items-center gap-6">
      <div class="flex items-center gap-2 text-sm text-[#ccc]">
        <Icon name="calendar" class="size-4 text-primary" />
        <span>{date}</span>
      </div>
      <div class="flex items-center gap-2 text-sm text-[#ccc]">
        <Icon name="clock" class="size-4 text-primary" />
        <span>{readTime}</span>
      </div>
    </div>
    
    <div class="space-y-4">
      <h3 class="font-heading text-2xl font-normal leading-tight text-white line-clamp-2">
        {title}
      </h3>
      <p class="text-base leading-relaxed text-[#ccc] line-clamp-3">
        {description}
      </p>
      
      <div class="pt-2">
          <a href="#" class="inline-block border-b border-primary text-base font-semibold text-primary transition-colors hover:text-white hover:border-white">
            Read More
          </a>
      </div>
    </div>
  </div>
</div>
