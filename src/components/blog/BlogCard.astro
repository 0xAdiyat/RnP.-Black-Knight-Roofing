---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';

interface Props {
  image: string;
  date: string;
  readTime: string;
  title: string;
  description: string;
}

const { image, date, readTime, title, description } = Astro.props;
---

<a
  href="#"
  class="group hover:border-primary/50 flex flex-col items-start overflow-hidden rounded-2xl border border-white/5 bg-radial-[50%_50%_at_50%_50%,rgba(48,48,48,0)_0%,rgba(48,48,48,0.54)_100%] transition-all duration-300"
>
  <div class="relative aspect-video w-full overflow-hidden">
    <Image
      src={image}
      alt={title}
      width={1200}
      height={675}
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
    />
  </div>

  <div class="flex w-full flex-col gap-4 p-6">
    <div class="flex items-center gap-6">
      <div class="flex items-center gap-2 text-sm text-[#ccc]">
        <Icon name="calendar" class="text-primary size-4" />
        <span>{date}</span>
      </div>
      <div class="flex items-center gap-2 text-sm text-[#ccc]">
        <Icon name="clock" class="text-primary size-4" />
        <span>{readTime}</span>
      </div>
    </div>

    <div class="space-y-4">
      <h3 class="font-heading line-clamp-2 text-2xl leading-tight font-normal text-white">
        {title}
      </h3>
      <p class="line-clamp-3 text-base leading-relaxed text-[#ccc]">
        {description}
      </p>

      <div class="pt-2">
        <span
          class="inline-block border-b border-white text-base font-semibold text-white transition-colors hover:border-white hover:text-white"
        >
          Read More
        </span>
      </div>
    </div>
  </div>
</a>
