---
import '@/styles/global.css';
import { ClientRouter } from 'astro:transitions';
import '@fontsource-variable/manrope';
import '@fontsource/instrument-serif';
import '@fontsource-variable/jetbrains-mono';
import '@fontsource-variable/caveat';
import HumanManifesto from '@/components/HumanManifesto.astro';
import EstimateDialog from '@/components/EstimateDialog.astro';
import SiteLinksModal from '@/components/SiteLinksModal.astro';
import SpeedInsights from '@vercel/speed-insights/astro';

import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  showNavbar?: boolean;
  showFooter?: boolean;
}

const {
  title = 'Top Veteran Owned Roofing Company | Black Knight Roofing',
  description = 'Veteran-owned roofing company serving Denver & all of Colorado. Stone-coated steel specialists. 40+ five-star reviews. Free inspections. Call (720) 804-0571.',
  image = '/social-preview.png',
  noindex = false,
  showNavbar = true,
  showFooter = true,
} = Astro.props;

const siteUrl = Astro.site || Astro.url.origin || 'https://www.blackknightroofing.com/';
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const socialImageURL = new URL(image, siteUrl);
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-KZV9XLDS');</script>
    <!-- End Google Tag Manager -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-MTF8VLF3HJ"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }

      gtag('js', new Date());
      gtag('config', 'G-MTF8VLF3HJ');
    </script>
    <ClientRouter />
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-KZV9XLDS"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    {showNavbar && <Navbar />}
    <slot />
    {showFooter && <Footer />}
    <HumanManifesto transition:persist />
    <EstimateDialog transition:persist />
    <SiteLinksModal transition:persist />
    <SpeedInsights />
    <script is:inline>
      (() => {
        const pastWorkPaths = new Set(['/gallery', '/before-and-after', '/case-studies']);
        let lastPathname = window.location.pathname;
        let skipAutoScrollOnce = false;

        const getNavbarOffset = () => {
          const navbarWrapper = document.getElementById('navbar-wrapper');
          const mobileTopbar = document.getElementById('mobile-topbar');
          const rootStyles = getComputedStyle(document.documentElement);
          const syncedMobileTopbarHeight = Number.parseFloat(rootStyles.getPropertyValue('--mobile-topbar-h')) || 0;
          const measuredNavbarHeight = navbarWrapper?.getBoundingClientRect().height || mobileTopbar?.getBoundingClientRect().height || 0;
          const navbarHeight = Math.max(syncedMobileTopbarHeight, measuredNavbarHeight);
          const extraOffset = window.innerWidth < 768 ? 28 : 16;

          return navbarHeight + extraOffset;
        };

        const scrollToPastWorkFilter = () => {
          const target = document.querySelector('[data-past-work-filter]');
          if (!target) return;

          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              const top = window.scrollY + target.getBoundingClientRect().top - getNavbarOffset();
              window.scrollTo({
                top: Math.max(0, top),
                behavior: 'smooth',
              });
            });
          });
        };

        const shouldAutoScroll = (pathname, { initial = false } = {}) => {
          if (!pastWorkPaths.has(pathname)) return false;
          if (window.location.hash) return false;

          if (skipAutoScrollOnce) {
            skipAutoScrollOnce = false;
            return false;
          }

          if (initial) {
            const navigationEntry = performance.getEntriesByType('navigation')[0];
            if (navigationEntry && navigationEntry.type === 'back_forward') return false;
            return true;
          }

          return pathname !== lastPathname;
        };

        const handlePastWorkEntry = ({ initial = false } = {}) => {
          const pathname = window.location.pathname;
          const shouldScroll = shouldAutoScroll(pathname, { initial });
          lastPathname = pathname;

          if (shouldScroll) {
            scrollToPastWorkFilter();
          }
        };

        window.addEventListener('popstate', () => {
          skipAutoScrollOnce = true;
          lastPathname = window.location.pathname;
        });

        document.addEventListener('astro:page-load', () => {
          handlePastWorkEntry();
        });

        if (document.readyState === 'loading') {
          document.addEventListener(
            'DOMContentLoaded',
            () => {
              handlePastWorkEntry({ initial: true });
            },
            { once: true }
          );
        } else {
          handlePastWorkEntry({ initial: true });
        }
      })();
    </script>
  </body>
</html>

<style is:global>
  html {
    scrollbar-gutter: stable;
  }
  @supports not (scrollbar-gutter: stable) {
    html {
      overflow-y: scroll;
    }
  }
</style>
