{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/_actions(?:/(.*?))?/?$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/about-us/?$",
			"dest": "_render"
		},
		{
			"src": "^/accessibility/?$",
			"dest": "_render"
		},
		{
			"src": "^/before-and-after/?$",
			"dest": "_render"
		},
		{
			"src": "^/blogs/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/blogs/?$",
			"dest": "_render"
		},
		{
			"src": "^/case-studies/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/case-studies/?$",
			"dest": "_render"
		},
		{
			"src": "^/company-info/?$",
			"dest": "_render"
		},
		{
			"src": "^/contact-us/?$",
			"dest": "_render"
		},
		{
			"src": "^/faqs/?$",
			"dest": "_render"
		},
		{
			"src": "^/financing/?$",
			"dest": "_render"
		},
		{
			"src": "^/gallery/?$",
			"dest": "_render"
		},
		{
			"src": "^/privacy-policy/?$",
			"dest": "_render"
		},
		{
			"src": "^/service-areas/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/service-areas/?$",
			"dest": "_render"
		},
		{
			"src": "^/services/commercial-roofing-co/?$",
			"dest": "_render"
		},
		{
			"src": "^/services/gutters-co/?$",
			"dest": "_render"
		},
		{
			"src": "^/services/hail-damage-repair-co/?$",
			"dest": "_render"
		},
		{
			"src": "^/services/metal-roofing-co/?$",
			"dest": "_render"
		},
		{
			"src": "^/services/residential-roofing-co/?$",
			"dest": "_render"
		},
		{
			"src": "^/services/roof-replacement-services-co/?$",
			"dest": "_render"
		},
		{
			"src": "^/services/siding-co/?$",
			"dest": "_render"
		},
		{
			"src": "^/services/stone-coated-steel-roofing-co/?$",
			"dest": "_render"
		},
		{
			"src": "^/services/storm-damage-repair-co/?$",
			"dest": "_render"
		},
		{
			"src": "^/services/wind-damage-repair-co/?$",
			"dest": "_render"
		},
		{
			"src": "^/services/window-replacement-services-co/?$",
			"dest": "_render"
		},
		{
			"src": "^/services/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/services/?$",
			"dest": "_render"
		},
		{
			"src": "^/terms-of-use/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}